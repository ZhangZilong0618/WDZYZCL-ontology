        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000091"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000825"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">magnetic ceramic</rdfs:label> <rdfs:label xml:lang="zh">磁性陶瓷</rdfs:label>
        <skos:altLabel xml:lang="en">ferrites</skos:altLabel> <skos:altLabel xml:lang="zh">铁氧体</skos:altLabel>
        <skos:definition xml:lang="en">electroceramic that exhibits magnetic properties, typically based on iron oxides combined with other metal oxides</skos:definition> <skos:definition xml:lang="zh">表现出磁性的电陶瓷，通常基于铁氧化物与其他金属氧化物的组合</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050088 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050088">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0050081"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000091"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000111"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050081"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000091"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000111"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">superconducting ceramic</rdfs:label> <rdfs:label xml:lang="zh">超导陶瓷</rdfs:label>
        <skos:definition xml:lang="en">electroceramic that exhibits zero electrical resistance below a critical temperature</skos:definition> <skos:definition xml:lang="zh">在临界温度以下表现出零电阻的电陶瓷</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050089 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050089">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050055"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050088"/>
        <rdfs:label xml:lang="en">yttrium barium copper oxide ceramic</rdfs:label> <rdfs:label xml:lang="zh">钇钡铜氧陶瓷</rdfs:label>
        <skos:definition xml:lang="en">oxide is a superconducting oxide ceramic that is composed of yttrium, barium, copper, and oxygen, notable for its high critical temperature</skos:definition> <skos:definition xml:lang="zh">氧化物是一种由钇、钡、铜和氧组成的超导氧化物陶瓷，以其高临界温度著称</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050090 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050090">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050055"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050088"/>
        <rdfs:label xml:lang="en">bismuth strontium calcium copper oxide ceramic</rdfs:label> <rdfs:label xml:lang="zh">铋锶钙铜氧陶瓷</rdfs:label>
        <skos:definition xml:lang="en">oxide ceramic that is superconducting and composed of bismuth, strontium, calcium, copper, and oxygen, featuring a layered crystal structure</skos:definition> <skos:definition xml:lang="zh">由铋、锶、钙、铜和氧组成的超导氧化物陶瓷，具有层状晶体结构</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050091 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050091">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000546"/>
