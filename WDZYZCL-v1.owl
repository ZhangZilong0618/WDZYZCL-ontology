    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050083 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050083">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050055"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050082"/>
        <rdfs:label xml:lang="en">barium titanate ceramic</rdfs:label> <rdfs:label xml:lang="zh">钛酸钡陶瓷</rdfs:label>
        <skos:definition xml:lang="en">oxide ceramic that is dielectric and composed of barium, titanium, and oxygen, noted for its ferroelectric properties</skos:definition> <skos:definition xml:lang="zh">由钡、钛和氧组成的介电氧化物陶瓷，以其铁电性能著称</skos:definition>
        <PMD_0050117>BaTiO₃</PMD_0050117>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050084 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050084">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050055"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050082"/>
        <rdfs:label xml:lang="en">lead zirconate titanate ceramic</rdfs:label> <rdfs:label xml:lang="zh">锆钛酸铅陶瓷</rdfs:label>
        <skos:definition xml:lang="en">oxide ceramic that is dielectric and composed of lead, zirconium, and titanium, renowned for its piezoelectric behavior</skos:definition> <skos:definition xml:lang="zh">由铅、锆和钛组成的介电氧化物陶瓷，以其压电性能闻名</skos:definition>
        <PMD_0050117>PZT</PMD_0050117>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050085 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050085">
        <owl:equivalentClass>
