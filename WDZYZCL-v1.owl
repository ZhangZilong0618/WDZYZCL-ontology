                        </owl:intersectionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">solid solution</rdfs:label> <rdfs:label xml:lang="zh">固溶体</rdfs:label>
        <skos:definition xml:lang="en">a solution with solid aggregate state</skos:definition> <skos:definition xml:lang="zh">具有固态聚集状态的溶液</skos:definition>
    </owl:Class>
    


