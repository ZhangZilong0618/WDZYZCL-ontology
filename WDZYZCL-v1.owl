     -->

    


    <!-- http://www.w3.org/2000/01/rdf-schema#Literal -->

    <rdfs:Datatype rdf:about="http://www.w3.org/2000/01/rdf-schema#Literal"/>
    


    <!-- http://www.w3.org/2001/XMLSchema#date -->

    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#date"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://purl.obolibrary.org/obo/BFO_0000050 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000050">
        <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <obo:IAO_0000112 xml:lang="en">my brain is part of my body (continuant parthood, two material entities)</obo:IAO_0000112> <obo:IAO_0000112 xml:lang="zh">我的大脑是我身体的一部分（连续体部分关系，两个物质实体）</obo:IAO_0000112>
        <obo:IAO_0000112 xml:lang="en">my stomach cavity is part of my stomach (continuant parthood, immaterial entity is part of material entity)</obo:IAO_0000112> <obo:IAO_0000112 xml:lang="zh">我的胃腔是我的胃的一部分（连续体部分关系，非物质实体是物质实体的一部分）</obo:IAO_0000112>
        <obo:IAO_0000112 xml:lang="en">this day is part of this year (occurrent parthood)</obo:IAO_0000112> <obo:IAO_0000112 xml:lang="zh">这一天是这一年的一部分（发生体部分关系）</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">a core relation that holds between a part and its whole</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">一个核心关系，表示部分与整体之间的关系</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Everything is part of itself. Any part of any part of a thing is itself part of that thing. Two distinct things cannot be part of each other.</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">任何事物都是其自身的一部分。任何事物任何部分的部分仍然是该事物的一部分。两个不同的事物不能互为部分。</obo:IAO_0000116>
        <obo:IAO_0000116 xml:lang="en">Occurrents are not subject to change and so parthood between occurrents holds for all the times that the part exists. Many continuants are subject to change, so parthood between continuants will only hold at certain times, but this is difficult to specify in OWL. See http://purl.obolibrary.org/obo/ro/docs/temporal-semantics/</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">发生体不发生变化，因此发生体之间的部分关系在部分存在的所有时间都成立。许多连续体会发生变化，因此连续体之间的部分关系仅在特定时间成立，但这在OWL中难以指定。参见 http://purl.obolibrary.org/obo/ro/docs/temporal-semantics/</obo:IAO_0000116>
        <obo:IAO_0000116 xml:lang="en">Parthood requires the part and the whole to have compatible classes: only an occurrent can be part of an occurrent; only a process can be part of a process; only a continuant can be part of a continuant; only an independent continuant can be part of an independent continuant; only an immaterial entity can be part of an immaterial entity; only a specifically dependent continuant can be part of a specifically dependent continuant; only a generically dependent continuant can be part of a generically dependent continuant. (This list is not exhaustive.)

A continuant cannot be part of an occurrent: use 'participates in'. An occurrent cannot be part of a continuant: use 'has participant'. A material entity cannot be part of an immaterial entity: use 'has location'. A specifically dependent continuant cannot be part of an independent continuant: use 'inheres in'. An independent continuant cannot be part of a specifically dependent continuant: use 'bearer of'.</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">部分关系要求部分和整体具有兼容的类别：只有发生体可以是发生体的部分；只有过程可以是过程的部分；只有连续体可以是连续体的部分；只有独立连续体可以是独立连续体的部分；只有非物质实体可以是非物质实体的部分；只有特定依赖连续体可以是特定依赖连续体的部分；只有一般依赖连续体可以是一般依赖连续体的部分。（此列表并非详尽无遗。）

连续体不能是发生体的部分：使用'participates in'。发生体不能是连续体的部分：使用'has participant'。物质实体不能是非物质实体的部分：使用'has location'。特定依赖连续体不能是独立连续体的部分：使用'inheres in'。独立连续体不能是特定依赖连续体的部分：使用'bearer of'。</obo:IAO_0000116>
        <rdfs:label xml:lang="en">part of</rdfs:label> <rdfs:label xml:lang="zh">部分</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000051 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000051">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <obo:IAO_0000112 xml:lang="en">my body has part my brain (continuant parthood, two material entities)</obo:IAO_0000112> <obo:IAO_0000112 xml:lang="zh">我的身体有部分我的大脑（连续体部分关系，两个物质实体）</obo:IAO_0000112>
        <obo:IAO_0000112 xml:lang="en">my stomach has part my stomach cavity (continuant parthood, material entity has part immaterial entity)</obo:IAO_0000112> <obo:IAO_0000112 xml:lang="zh">我的胃有部分我的胃腔（持续体部分关系，物质实体有部分非实体实体）</obo:IAO_0000112>
        <obo:IAO_0000112 xml:lang="en">this year has part this day (occurrent parthood)</obo:IAO_0000112> <obo:IAO_0000112 xml:lang="zh">今年有部分今天（发生体部分关系）</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">a core relation that holds between a whole and its part</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">一个核心关系，存在于整体与其部分之间</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Everything has itself as a part. Any part of any part of a thing is itself part of that thing. Two distinct things cannot have each other as a part.</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">每个事物都以自身为部分。任何事物的任何部分本身也是该事物的一部分。两个不同的事物不能互为部分。</obo:IAO_0000116>
        <obo:IAO_0000116 xml:lang="en">Occurrents are not subject to change and so parthood between occurrents holds for all the times that the part exists. Many continuants are subject to change, so parthood between continuants will only hold at certain times, but this is difficult to specify in OWL. See http://purl.obolibrary.org/obo/ro/docs/temporal-semantics/</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">发生体不发生变化，因此发生体之间的部分关系在部分存在的所有时间都成立。许多连续体会发生变化，因此连续体之间的部分关系仅在特定时间成立，但这在OWL中难以指定。参见 http://purl.obolibrary.org/obo/ro/docs/temporal-semantics/</obo:IAO_0000116>
        <obo:IAO_0000116 xml:lang="en">Parthood requires the part and the whole to have compatible classes: only an occurrent have an occurrent as part; only a process can have a process as part; only a continuant can have a continuant as part; only an independent continuant can have an independent continuant as part; only a specifically dependent continuant can have a specifically dependent continuant as part; only a generically dependent continuant can have a generically dependent continuant as part. (This list is not exhaustive.)

A continuant cannot have an occurrent as part: use 'participates in'. An occurrent cannot have a continuant as part: use 'has participant'. An immaterial entity cannot have a material entity as part: use 'location of'. An independent continuant cannot have a specifically dependent continuant as part: use 'bearer of'. A specifically dependent continuant cannot have an independent continuant as part: use 'inheres in'.</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">部分关系要求部分与整体具有兼容的类别：只有发生体才能以发生体为部分；只有过程才能以过程为部分；只有持续体才能以持续体为部分；只有独立持续体才能以独立持续体为部分；只有特定依赖持续体才能以特定依赖持续体为部分；只有一般依赖持续体才能以一般依赖持续体为部分。（此列表并非详尽无遗。）

持续体不能以发生体为部分：请使用 'participates in'。发生体不能以持续体为部分：请使用 'has participant'。非实体实体不能以物质实体为部分：请使用 'location of'。独立持续体不能以特定依赖持续体为部分：请使用 'bearer of'。特定依赖持续体不能以独立持续体为部分：请使用 'inheres in'。</obo:IAO_0000116>
        <rdfs:label xml:lang="en">has part</rdfs:label> <rdfs:label xml:lang="zh">具有部分</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000054 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000054">
        <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000055"/>
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/BFO_0000017"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:label xml:lang="en">has realization</rdfs:label> <rdfs:label xml:lang="zh">具有实现</rdfs:label>
        <rdfs:label xml:lang="en">realized in</rdfs:label> <rdfs:label xml:lang="zh">实现于</rdfs:label>
        <skos:definition xml:lang="en">b has realization c =Def c realizes b</skos:definition> <skos:definition xml:lang="zh">b具有实现c 定义为 c实现b</skos:definition>
        <skos:example xml:lang="en">As for realizes</skos:example> <skos:example xml:lang="zh">关于实现</skos:example>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000055 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000055">
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/BFO_0000017"/>
        <obo:IAO_0000115 xml:lang="en">Paraphrase of elucidation: a relation between a process and a realizable entity, where there is some material entity that is bearer of the realizable entity and participates in the process, and the realizable entity comes to be realized in the course of the process</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">释义：一种过程与可兑现实体之间的关系，其中存在某个物质实体，它是可兑现实体的承载者并参与该过程，且该可兑现实体在该过程过程中得以兑现。</obo:IAO_0000115>
        <rdfs:label xml:lang="en">realizes</rdfs:label> <rdfs:label xml:lang="zh">实现</rdfs:label>
        <skos:definition xml:lang="en">(Elucidation) realizes is a relation between a process b and realizable entity c such that c inheres in some d &amp; for all t, if b has participant d then c exists &amp; the type instantiated by b is correlated with the type instantiated by c</skos:definition> <skos:definition xml:lang="zh">（说明）实现是过程b与可兑现实体c之间的关系，使得c内在于某个d，且对于所有t，如果b具有参与者d，则c存在，且b所实例化的类型与c所实例化的类型相关。</skos:definition>
        <skos:example xml:lang="en">A balding process realizes a disposition to go bald; a studying process realizes a student role; a process of pumping blood realizes the pumping function of a heart</skos:example> <skos:example xml:lang="zh">一个脱发过程实现了一种脱发倾向；一个学习过程实现了学生角色；一个泵血过程实现了心脏的泵血功能。</skos:example>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000062 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000062">
        <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000063"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/BFO_0000003"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/BFO_0000003"/>
        <obo:IAO_0000115 xml:lang="en">x is preceded by y if and only if the time point at which y ends is before or equivalent to the time point at which x starts. Formally: x preceded by y iff ω(y) &lt;= α(x), where α is a function that maps a process to a start point, and ω is a function that maps a process to an end point.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">x被y先于当且仅当y结束的时间点早于或等于x开始的时间点。形式上：x被y先于当且仅当ω(y) &lt;= α(x)，其中α是将过程映射到起始点的函数，ω是将过程映射到结束点的函数。</obo:IAO_0000115>
        <rdfs:label xml:lang="en">preceded by</rdfs:label> <rdfs:label xml:lang="zh">被先于</rdfs:label>
        <skos:definition xml:lang="en">b preceded by c =Def b precedes c</skos:definition> <skos:definition xml:lang="zh">b被c先于 定义为 b先于c</skos:definition>
        <skos:example xml:lang="en">The temporal region occupied by the second half of the match is preceded by the temporal region occupied by the first half of the match</skos:example> <skos:example xml:lang="zh">比赛下半场所占据的时间区域被上半场所占据的时间区域所先于。</skos:example>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000063 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000063">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/BFO_0000003"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/BFO_0000003"/>
        <obo:IAO_0000115 xml:lang="en">x precedes y if and only if the time point at which x ends is before or equivalent to the time point at which y starts. Formally: x precedes y iff ω(x) &lt;= α(y), where α is a function that maps a process to a start point, and ω is a function that maps a process to an end point.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">x先于y当且仅当x结束的时间点早于或等于y开始的时间点。形式上：x先于y当且仅当ω(x) &lt;= α(y)，其中α是将过程映射到起始点的函数，ω是将过程映射到结束点的函数。</obo:IAO_0000115>
        <rdfs:label xml:lang="en">precedes</rdfs:label> <rdfs:label xml:lang="zh">先于</rdfs:label>
        <skos:definition xml:lang="en">(Elucidation) precedes is a relation between occurrents o, o' such that if t is the temporal extent of o &amp; t' is the temporal extent of o' then either the last instant of o is before the first instant of o' or the last instant of o is the first instant of o' &amp; neither o nor o' are temporal instants</skos:definition> <skos:definition xml:lang="zh">（说明）先于是发生体o与o'之间的关系，使得如果t是o的时间范围，t'是o'的时间范围，那么要么o的最后时刻在o'的第一个时刻之前，要么o的最后时刻是o'的第一个时刻，并且o和o'都不是时间瞬刻。</skos:definition>
        <skos:example xml:lang="en">The temporal region occupied by Mary's birth precedes the temporal region occupied by Mary's death.</skos:example> <skos:example xml:lang="zh">玛丽出生所占据的时间区域先于玛丽死亡所占据的时间区域。</skos:example>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000066 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000066">
        <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000183"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000015"/>
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000035"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000029"/>
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000040"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:label xml:lang="en">occurs in</rdfs:label> <rdfs:label xml:lang="zh">发生于</rdfs:label>
        <skos:definition xml:lang="en">b occurs in c =Def b is a process or a process boundary &amp; c is a material entity or site &amp; there exists a spatiotemporal region r &amp; b occupies spatiotemporal region r &amp; for all time t, if b exists at t then c exists at t &amp; there exist spatial regions s and s' where b spatially projects onto s at t &amp; c occupies spatial region s' at t &amp; s is a continuant part of s' at t</skos:definition> <skos:definition xml:lang="zh">b发生于c 定义为 b是一个过程或过程边界，c是一个物质实体或场所，存在一个时空区域r，b占据时空区域r，且对于所有时间t，如果b在t存在则c在t存在，且存在空间区域s和s'，b在t空间投影到s上，c在t占据空间区域s'，且s在t是s'的持续体部分。</skos:definition>
        <skos:example xml:lang="en">A process of digestion occurs in the interior of an organism; a process of loading artillery rounds into a tank cannon occurs in the interior of the tank</skos:example> <skos:example xml:lang="zh">消化过程发生于生物体内部；将炮弹装入坦克炮筒的过程发生于坦克内部。</skos:example>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000108 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000108">
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/BFO_0000001"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/BFO_0000008"/>
        <rdfs:label xml:lang="en">exists at</rdfs:label> <rdfs:label xml:lang="zh">存在于</rdfs:label>
        <skos:definition xml:lang="en">(Elucidation) exists at is a relation between a particular and some temporal region at which the particular exists</skos:definition> <skos:definition xml:lang="zh">(释义) 存在于是特定个体与时间区域之间的关系，该特定个体存在于该时间区域</skos:definition>
        <skos:example xml:lang="en">First World War exists at 1914-1916; Mexico exists at January 1, 2000</skos:example> <skos:example xml:lang="zh">第一次世界大战存在于1914-1916；墨西哥存在于2000年1月1日</skos:example>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000117 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000117">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
        <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000132"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/BFO_0000003"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/BFO_0000003"/>
        <rdfs:label xml:lang="en">has occurrent part</rdfs:label> <rdfs:label xml:lang="zh">有发生部分</rdfs:label>
        <skos:definition xml:lang="en">b has occurrent part c =Def c occurrent part of b</skos:definition> <skos:definition xml:lang="zh">b 有发生部分 c =Def c 是 b 的发生部分</skos:definition>
        <skos:example xml:lang="en">Mary's life has occurrent part Mary's 5th birthday</skos:example> <skos:example xml:lang="zh">玛丽的生命有发生部分玛丽的5岁生日</skos:example>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000118 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000118">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000117"/>
        <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000138"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/BFO_0000003"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/BFO_0000003"/>
        <rdfs:label xml:lang="en">has proper occurrent part</rdfs:label> <rdfs:label xml:lang="zh">有真发生部分</rdfs:label>
        <skos:definition xml:lang="en">b has proper occurrent part c =Def b has occurrent part c &amp; b and c are not identical</skos:definition> <skos:definition xml:lang="zh">b 有真发生部分 c =Def b 有发生部分 c 且 b 和 c 不相同</skos:definition>
        <skos:example xml:lang="en">As for has occurrent part.</skos:example> <skos:example xml:lang="zh">关于有发生部分。</skos:example>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000121 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000121">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000117"/>
        <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000139"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/BFO_0000003"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/BFO_0000003"/>
        <rdfs:label xml:lang="en">has temporal part</rdfs:label> <rdfs:label xml:lang="zh">有时间部分</rdfs:label>
        <skos:definition xml:lang="en">b has temporal part c =Def c temporal part of b</skos:definition> <skos:definition xml:lang="zh">b 有时间部分 c =Def c 是 b 的时间部分</skos:definition>
        <skos:example xml:lang="en">Your life has temporal part the first year of your life</skos:example> <skos:example xml:lang="zh">你的生命有时间部分你生命的第一年</skos:example>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000132 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000132">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/BFO_0000003"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/BFO_0000003"/>
        <rdfs:label xml:lang="en">occurrent part of</rdfs:label> <rdfs:label xml:lang="zh">是...的发生部分</rdfs:label>
        <skos:definition xml:lang="en">(Elucidation) occurrent part of is a relation between occurrents b and c when b is part of c</skos:definition> <skos:definition xml:lang="zh">(释义) 是...的发生部分是发生体 b 和 c 之间的关系，当 b 是 c 的部分时</skos:definition>
        <skos:example xml:lang="en">Mary's 5th birthday is an occurrent part of Mary's life; the first set of the tennis match is an occurrent part of the tennis match</skos:example> <skos:example xml:lang="zh">玛丽的5岁生日是玛丽生命的一个发生部分；网球比赛的第一盘是网球比赛的一个发生部分</skos:example>
    </owl:ObjectProperty>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/BFO_0000132"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subPropertyOf"/>
        <owl:annotatedTarget rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
        <rdfs:comment>"occurrent part of" is not a BFO2020 temporalized relation. It just restricts the domain and range to "occurrent". That's why is should be OK to make it sub property of RO "part of"</rdfs:comment>
    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000136 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000136">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000139"/>
        <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000181"/>
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/BFO_0000003"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/BFO_0000003"/>
        <rdfs:label xml:lang="en">proper temporal part of</rdfs:label> <rdfs:label xml:lang="zh">是...的真时间部分</rdfs:label>
        <skos:definition xml:lang="en">b proper temporal part of c =Def b temporal part of c &amp; not (b = c)</skos:definition> <skos:definition xml:lang="zh">b 是 c 的真时间部分 =Def b 是 c 的时间部分 且 b 不等于 c</skos:definition>
        <skos:example xml:lang="en">As for temporal part of.</skos:example> <skos:example xml:lang="zh">关于时间部分。</skos:example>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000138 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000138">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000132"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/BFO_0000003"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/BFO_0000003"/>
        <rdfs:label xml:lang="en">proper occurrent part of</rdfs:label> <rdfs:label xml:lang="zh">是...的真发生部分</rdfs:label>
        <skos:definition xml:lang="en">b proper occurrent part of c =Def b occurrent part of c &amp; b and c are not identical</skos:definition> <skos:definition xml:lang="zh">b 是 c 的真发生部分 =Def b 是 c 的发生部分 且 b 和 c 不相同</skos:definition>
        <skos:example xml:lang="en">As for occurrent part of.</skos:example> <skos:example xml:lang="zh">关于发生部分。</skos:example>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000139 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000139">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000132"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/BFO_0000003"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/BFO_0000003"/>
        <rdfs:label xml:lang="en">temporal part of</rdfs:label> <rdfs:label xml:lang="zh">是...的时间部分</rdfs:label>
        <skos:definition xml:lang="en">b temporal part of c =Def b occurrent part of c &amp; (b and c are temporal regions) or (b and c are spatiotemporal regions &amp; b temporally projects onto an occurrent part of the temporal region that c temporally projects onto) or (b and c are processes or process boundaries &amp; b occupies a temporal region that is an occurrent part of the temporal region that c occupies)</skos:definition> <skos:definition xml:lang="zh">b 是 c 的时间部分 =Def b 是 c 的发生部分 且 (b 和 c 是时间区域) 或 (b 和 c 是时空区域 且 b 时间投影到 c 时间投影到的时间区域的一个发生部分上) 或 (b 和 c 是过程或过程边界 且 b 占据一个时间区域，该区域是 c 占据的时间区域的一个发生部分)</skos:definition>
        <skos:example xml:lang="en">Your heart beating from 4pm to 5pm today is a temporal part of the process of your heart beating; the 4th year of your life is a temporal part of your life, as is the process boundary which separates the 3rd and 4th years of your life; the first quarter of a game of football is a temporal part of the whole game</skos:example> <skos:example xml:lang="zh">你今天从下午4点到5点的心跳是你心跳过程的一个时间部分；你生命的第4年是你生命的一个时间部分，同样，分隔你生命第3年和第4年的过程边界也是如此；一场足球比赛的第一节是整场比赛的一个时间部分</skos:example>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000153 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000153">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/BFO_0000011"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/BFO_0000008"/>
        <rdfs:label xml:lang="en">temporally projects onto</rdfs:label> <rdfs:label xml:lang="zh">时间投影到</rdfs:label>
        <skos:definition xml:lang="en">(Elucidation) temporally projects onto is a relation between a spatiotemporal region s and some temporal region which is the temporal extent of s</skos:definition> <skos:definition xml:lang="zh">(说明) 时间上投影到 是时空区域s与某个时间区域之间的关系，该时间区域是s的时间范围</skos:definition>
        <skos:example xml:lang="en">The world line of a particle temporally projects onto the temporal region extending from the beginning to the end of the existence of the particle</skos:example> <skos:example xml:lang="zh">粒子的世界线时间上投影到从粒子存在开始到结束的时间区域</skos:example>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000181 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000181">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000121"/>
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/BFO_0000003"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/BFO_0000003"/>
        <rdfs:label xml:lang="en">has proper temporal part</rdfs:label> <rdfs:label xml:lang="zh">具有恰当的时间部分</rdfs:label>
        <skos:definition xml:lang="en">b has proper temporal part c =Def c proper temporal part of b</skos:definition> <skos:definition xml:lang="zh">b具有恰当的时间部分c =Def c是b的恰当时间部分</skos:definition>
        <skos:example xml:lang="en">As for has temporal part.</skos:example> <skos:example xml:lang="zh">至于具有时间部分。</skos:example>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000183 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000183">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000029"/>
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000040"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000015"/>
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000035"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:label xml:lang="en">environs</rdfs:label> <rdfs:label xml:lang="zh">包围</rdfs:label>
        <skos:definition xml:lang="en">b environs c =Def c occurs in b</skos:definition> <skos:definition xml:lang="zh">b包围c =Def c发生在b中</skos:definition>
        <skos:example xml:lang="en">Mouth environs process of mastication; city environs traffic</skos:example> <skos:example xml:lang="zh">口腔包围咀嚼过程；城市包围交通</skos:example>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000184 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000184">
        <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000185"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/BFO_0000182"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/BFO_0000040"/>
        <rdfs:label xml:lang="en">history of</rdfs:label> <rdfs:label xml:lang="zh">的历史</rdfs:label>
        <skos:definition xml:lang="en">(Elucidation) history of is a relation between history b and material entity c such that b is the unique history of c</skos:definition> <skos:definition xml:lang="zh">(说明) 的历史 是历史b与物质实体c之间的关系，使得b是c的唯一历史</skos:definition>
        <skos:example xml:lang="en">This life is the history of this organism</skos:example> <skos:example xml:lang="zh">这个生命是这个有机体的历史</skos:example>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000185 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000185">
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/BFO_0000040"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/BFO_0000182"/>
        <rdfs:label xml:lang="en">has history</rdfs:label> <rdfs:label xml:lang="zh">具有历史</rdfs:label>
        <skos:definition xml:lang="en">b has history c =Def c history of b</skos:definition> <skos:definition xml:lang="zh">b具有历史c =Def c是b的历史</skos:definition>
        <skos:example xml:lang="en">This organism has history this life</skos:example> <skos:example xml:lang="zh">这个有机体具有历史这个生命</skos:example>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000199 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000199">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000015"/>
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000035"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/BFO_0000008"/>
        <rdfs:label xml:lang="en">occupies temporal region</rdfs:label> <rdfs:label xml:lang="zh">占据时间区域</rdfs:label>
        <skos:definition xml:lang="en">p occupies temporal region t =Def p is a process or process boundary &amp; the spatiotemporal region occupied by p temporally projects onto t</skos:definition> <skos:definition xml:lang="zh">p占据时间区域t =Def p是一个过程或过程边界 &amp; p所占据的时空区域时间上投影到t</skos:definition>
        <skos:example xml:lang="en">The Second World War occupies the temporal region September 1, 1939 - September 2, 1945</skos:example> <skos:example xml:lang="zh">第二次世界大战占据的时间区域是1939年9月1日至1945年9月2日</skos:example>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000200 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000200">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000015"/>
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000035"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/BFO_0000011"/>
        <rdfs:label xml:lang="en">occupies spatiotemporal region</rdfs:label> <rdfs:label xml:lang="zh">占据时空区域</rdfs:label>
        <skos:definition xml:lang="en">(Elucidation) occupies spatiotemporal region is a relation between a process or process boundary p and the spatiotemporal region s which is its spatiotemporal extent</skos:definition> <skos:definition xml:lang="zh">(说明) 占据时空区域 是过程或过程边界p与其时空范围s之间的关系</skos:definition>
        <skos:example xml:lang="en">A particle emitted by a nuclear reactor occupies the spatiotemporal region which is its trajectory</skos:example> <skos:example xml:lang="zh">由核反应堆发射的粒子占据其轨迹的时空区域</skos:example>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000221 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000221">
        <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000222"/>
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/BFO_0000203"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/BFO_0000008"/>
        <rdfs:label xml:lang="en">first instant of</rdfs:label> <rdfs:label xml:lang="zh">的最初瞬间</rdfs:label>
        <skos:definition xml:lang="en">t first instant of t' =Def t is a temporal instant &amp; t' is a temporal region t' &amp; t precedes all temporal parts of t' other than t</skos:definition> <skos:definition xml:lang="zh">t是t'的最初瞬间 =Def t是一个时间瞬时 &amp; t'是一个时间区域 &amp; t先于t'的所有其他时间部分</skos:definition>
        <skos:example xml:lang="en">An hour starting at midnight yesterday has first instant midnight yesterday</skos:example> <skos:example xml:lang="zh">从昨天午夜开始的一个小时的最初瞬间是昨天午夜</skos:example>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000222 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000222">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/BFO_0000008"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/BFO_0000203"/>
        <rdfs:label xml:lang="en">has first instant</rdfs:label> <rdfs:label xml:lang="zh">具有最初瞬间</rdfs:label>
        <skos:definition xml:lang="en">t has first instant t' =Def t' first instant of t</skos:definition> <skos:definition xml:lang="zh">t具有最初瞬间t' =Def t'是t的最初瞬间</skos:definition>
        <skos:example xml:lang="en">The first hour of a year has first instant midnight on December 31</skos:example> <skos:example xml:lang="zh">一年的第一个小时在12月31日有第一个瞬间午夜</skos:example>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000223 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000223">
        <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000224"/>
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/BFO_0000203"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/BFO_0000008"/>
        <rdfs:label xml:lang="en">last instant of</rdfs:label> <rdfs:label xml:lang="zh">的最后瞬间</rdfs:label>
        <skos:definition xml:lang="en">t last instant of t' =Def t is a temporal instant &amp; t' is a temporal region &amp; all temporal parts of t' other than t precede t</skos:definition> <skos:definition xml:lang="zh">t是t'的最后瞬间，定义为：t是一个时间瞬间，t'是一个时间区域，且t'中除t以外的所有时间部分都在t之前</skos:definition>
        <skos:example xml:lang="en">Last midnight is the last instant of yesterday</skos:example> <skos:example xml:lang="zh">最后一个午夜是昨天的最后瞬间</skos:example>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000224 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000224">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/BFO_0000008"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/BFO_0000203"/>
        <rdfs:label xml:lang="en">has last instant</rdfs:label> <rdfs:label xml:lang="zh">有最后瞬间</rdfs:label>
        <skos:definition xml:lang="en">t has last instant t' =Def t' last instant of t</skos:definition> <skos:definition xml:lang="zh">t有最后瞬间t'，定义为：t'是t的最后瞬间</skos:definition>
        <skos:example xml:lang="en">The last hour of a year has last instant midnight December 31</skos:example> <skos:example xml:lang="zh">一年的最后一个小时有最后一个瞬间，即12月31日的午夜</skos:example>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/COB_0000081 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/COB_0000081">
        <rdfs:label xml:lang="en">intended to realize</rdfs:label> <rdfs:label xml:lang="zh">旨在实现</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/IAO_0000039 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/IAO_0000039">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/IAO_0000003"/>
        <rdfs:label xml:lang="en">has measurement unit label</rdfs:label> <rdfs:label xml:lang="zh">有测量单位标签</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/IAO_0000136 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/IAO_0000136">
        <owl:inverseOf rdf:resource="https://w3id.org/pmd/co/PMD_0000004"/>
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/IAO_0000030"/>
        <obo:IAO_0000112 xml:lang="en">This document is about information artifacts and their representations</obo:IAO_0000112> <obo:IAO_0000112 xml:lang="zh">本文档是关于信息制品及其表示的</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">A (currently) primitive relation that relates an information artifact to an entity.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">一个（目前）原始的关系，将信息制品与实体关联起来。</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">7/6/2009 Alan Ruttenberg. Following discussion with Jonathan Rees, and introduction of "mentions" relation. Weaken the is_about relationship to be primitive. 

We will try to build it back up by elaborating the various subproperties that are more precisely defined.

Some currently missing phenomena that should be considered "about" are predications - "The only person who knows the answer is sitting beside me" , Allegory, Satire, and other literary forms that can be topical without explicitly mentioning the topic.</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">2009年7月6日 Alan Ruttenberg。在与Jonathan Rees讨论并引入“提及”关系后，将is_about关系弱化为原始关系。

我们将通过详细阐述更精确定义的各种子属性来尝试重新构建它。

一些目前缺失的应被视为“关于”的现象包括：谓述——“唯一知道答案的人正坐在我旁边”，寓言、讽刺以及其他可以不明确提及主题但具有主题性的文学形式。</obo:IAO_0000116>
        <obo:IAO_0000119 xml:lang="en">Smith, Ceusters, Ruttenberg, 2000 years of philosophy</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">Smith, Ceusters, Ruttenberg, 2000年的哲学</obo:IAO_0000119>
        <rdfs:label xml:lang="en">is about</rdfs:label> <rdfs:label xml:lang="zh">是关于</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/IAO_0000219 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/IAO_0000219">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
        <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000235"/>
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/IAO_0000030"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/BFO_0000001"/>
        <obo:IAO_0000112 xml:lang="en">A person's name denotes the person. A variable name in a computer program denotes some piece of memory. Lexically equivalent strings can denote different things, for instance "Alan" can denote different people. In each case of use, there is a case of the denotation relation obtaining, between "Alan" and the person that is being named.</obo:IAO_0000112> <obo:IAO_0000112 xml:lang="zh">一个人的名字表示这个人。计算机程序中的变量名表示某段内存。词法上等价的字符串可以表示不同的事物，例如"Alan"可以表示不同的人。在每个使用案例中，都存在一个指称关系，介于"Alan"和被命名的人之间。</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">A primitive, instance-level, relation obtaining between an information content entity and some portion of reality. Denotation is what happens when someone creates an information content entity E in order to specifically refer to something. The only relation between E and the thing is that E can be used to 'pick out' the thing. This relation connects those two together. Freedictionary.com sense 3: To signify directly; refer to specifically</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">一个原始的、实例层面的关系，存在于信息内容实体与现实的某一部分之间。指称发生在某人创建信息内容实体E以专门指代某事物时。E与该事物之间的唯一关系是E可用于‘挑出’该事物。这个关系将两者连接起来。Freedictionary.com释义3：直接表示；专门指代</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">2009-11-10 Alan Ruttenberg. Old definition said the following to emphasize the generic nature of this relation. We no longer have 'specifically denotes', which would have been primitive, so make this relation primitive.
g denotes r =def 
r is a portion of reality
there is some c that is a concretization of g 
every c that is a concretization of g specifically denotes r</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">2009年11月10日 Alan Ruttenberg。旧定义如下所述，以强调该关系的通用性质。我们不再有‘专门指称’（原本是原始关系），因此将此关系设为原始关系。
g表示r定义为：
r是现实的一部分
存在某个c是g的具体化
每个c是g的具体化都专门指称r</obo:IAO_0000116>
        <obo:IAO_0000119 xml:lang="en">Conversations with Barry Smith, Werner Ceusters, Bjoern Peters, Michel Dumontier, Melanie Courtot, James Malone, Bill Hogan</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">与Barry Smith, Werner Ceusters, Bjoern Peters, Michel Dumontier, Melanie Courtot, James Malone, Bill Hogan的对话</obo:IAO_0000119>
        <rdfs:comment xml:lang="en"/>
        <rdfs:label xml:lang="en">denotes</rdfs:label> <rdfs:label xml:lang="zh">表示</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/IAO_0000221 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/IAO_0000221">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
        <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000417"/>
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/IAO_0000109"/>
        <obo:IAO_0000115 xml:lang="en">m is a quality measurement of q at t. When q is a quality, there is a measurement process p that has specified output m, a measurement datum, that is about q</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">m是在t时刻对q的质量测量。当q是一种质量时，存在一个测量过程p，其有指定输出m，即一个关于q的测量数据。</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">8/6/2009 Alan Ruttenberg: The strategy is to be rather specific with this relationship. There are other kinds of measurements that are not of qualities, such as those that measure time. We will add these as separate properties for the moment and see about generalizing later</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">2009年8月6日 Alan Ruttenberg：策略是让这个关系相当具体。还有其他类型的测量不是针对质量的，例如测量时间的那些。我们暂时将这些作为单独的属性添加，稍后再考虑泛化。</obo:IAO_0000116>
        <obo:IAO_0000116 xml:lang="en">From the second IAO workshop [Alan Ruttenberg 8/6/2009: not completely current, though bringing in comparison is probably important]

This one is the one we are struggling with at the moment. The issue is what a measurement measures. On the one hand saying that it measures the quality would include it "measuring" the bearer = referring to the bearer in the measurement. However this makes comparisons of two different things not possible. On the other hand not having it inhere in the bearer, on the face of it, breaks the audit trail.

Werner suggests a solution based on "Magnitudes" a proposal for which we are awaiting details.
--
From the second IAO workshop, various comments, [commented on by Alan Ruttenberg 8/6/2009]

unit of measure is a quality, e.g. the length of a ruler.

[We decided to hedge on what units of measure are, instead talking about measurement unit labels, which are the information content entities that are about whatever measurement units are. For IAO we need that information entity in any case. See the term measurement unit label]

[Some struggling with the various subflavors of is_about. We subsequently removed the relation represents, and describes until and only when we have a better theory]

a represents b means either a denotes b or a describes

describe:
a describes b means a is about b and a allows an inference of at least one quality of b

We have had a long discussion about denotes versus describes.</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">来自第二次IAO研讨会 [Alan Ruttenberg 2009年8月6日：并非完全当前，但引入比较可能很重要]

这个是我们目前正在努力解决的。问题在于测量测量的是什么。一方面，说它测量质量会包括它“测量”承载者=在测量中指向承载者。但这使得无法比较两个不同的事物。另一方面，不让它固有于承载者，从表面上看，破坏了审计追踪。

Werner建议基于“大小”的解决方案，我们正在等待其细节。
--
来自第二次IAO研讨会，各种评论，[由Alan Ruttenberg于2009年8月6日评论]

测量单位是一种质量，例如尺子的长度。

[我们决定对测量单位是什么含糊其辞，转而谈论测量单位标签，这些是信息内容实体，它们关于任何测量单位。对于IAO，我们无论如何都需要那个信息实体。参见术语测量单位标签]

[一些关于is_about的各种子类型的努力。我们随后移除了关系代表和描述，直到我们有了更好的理论]

a代表b意味着要么a表示b要么a描述b

描述：
a描述b意味着a是关于b的，并且a允许推断出b的至少一个质量

我们进行了一场关于表示与描述的长时间讨论。</obo:IAO_0000116>
        <obo:IAO_0000116 xml:lang="en">From the second IAO workshop: An attempt at tieing the quality to the measurement datum more carefully.

a is a magnitude means a is a determinate quality particular inhering in some bearer b existing at a time t that can be represented/denoted by an information content entity e that has parts denoting a unit of measure, a number, and b. The unit of measure is an instance of the determinable quality.</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">来自第二次IAO研讨会：更仔细地将质量与测量数据关联的尝试。

a是一种大小，意味着a是一种确定的特定质量，固有于某个存在于时间t的承载者b中，该质量可以由信息内容实体e表示/指称，e有表示测量单位、数字和b的部分。测量单位是可确定质量的一个实例。</obo:IAO_0000116>
        <obo:IAO_0000116 xml:lang="en">From the second meeting on IAO:

An attempt at defining assay using Barry's "reliability" wording

assay:
process and has_input some material entity
and has_output some information content entity 
and which is such that instances of this process type reliably generate 
outputs that describes the input.</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">来自关于IAO的第二次会议：

使用Barry的“可靠性”措辞定义分析的尝试

分析：
过程，有输入某种物质实体
并有输出某种信息内容实体
并且该过程类型的实例可靠地生成
描述输入的输出。</obo:IAO_0000116>
        <obo:IAO_0000116 xml:lang="en">This one is the one we are struggling with at the moment. The issue is what a measurement measures. On the one hand saying that it measures the quality would include it "measuring" the bearer = referring to the bearer in the measurement. However this makes comparisons of two different things not possible. On the other hand not having it inhere in the bearer, on the face of it, breaks the audit trail.

Werner suggests a solution based on "Magnitudes" a proposal for which we are awaiting details.</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">这个是我们目前正在努力解决的。问题在于测量测量的是什么。一方面，说它测量质量会包括它“测量”承载者=在测量中指向承载者。但这使得无法比较两个不同的事物。另一方面，不让它固有于承载者，从表面上看，破坏了审计追踪。

Werner建议基于“大小”的解决方案，我们正在等待其细节。</obo:IAO_0000116>
        <rdfs:label xml:lang="en">is quality measurement of</rdfs:label> <rdfs:label xml:lang="zh">是质量测量</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/IAO_0000235 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/IAO_0000235">
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/BFO_0000001"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/IAO_0000030"/>
        <obo:IAO_0000115 xml:lang="en">inverse of the relation 'denotes'</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">关系'表示'的逆</obo:IAO_0000115>
        <obo:IAO_0000233 rdf:resource="https://github.com/information-artifact-ontology/IAO/issues/206"/>
        <rdfs:label xml:lang="en">denoted by</rdfs:label> <rdfs:label xml:lang="zh">由...表示</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/IAO_0000417 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/IAO_0000417">
        <obo:IAO_0000115 xml:lang="en">inverse of the relation of is quality measurement of</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">关系'是质量测量'的逆</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">2009/10/19 Alan Ruttenberg. Named 'junk' relation useful in restrictions, but not a real instance relationship</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">2009/10/19 Alan Ruttenberg. 命名为'junk'的关系在限制中有用，但不是真正的实例关系</obo:IAO_0000116>
        <rdfs:label xml:lang="en">is quality measured as</rdfs:label> <rdfs:label xml:lang="zh">质量被测量为</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/IAO_0000418 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/IAO_0000418">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
        <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000419"/>
        <obo:IAO_0000115 xml:lang="en">A relation between a data item and a quality of a material entity where the material entity is the specified output of a material transformation which achieves an objective specification that indicates the intended value of the specified quality.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">数据项与物质实体质量之间的关系，其中物质实体是物质转化的指定输出，该转化实现了一个目标规范，指示指定质量的预期值。</obo:IAO_0000115>
        <rdfs:label xml:lang="en">is quality specification of</rdfs:label> <rdfs:label xml:lang="zh">是质量规范</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/IAO_0000419 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/IAO_0000419">
        <obo:IAO_0000115 xml:lang="en">inverse of the relation of is quality specification of</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">关系'是质量规范'的逆</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">2009/10/19 Alan Ruttenberg. Named 'junk' relation useful in restrictions, but not a real instance relationship</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">2009/10/19 Alan Ruttenberg. 命名为'junk'的关系在限制中有用，但不是真正的实例关系</obo:IAO_0000116>
        <rdfs:label xml:lang="en">quality is specified as</rdfs:label> <rdfs:label xml:lang="zh">质量被指定为</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/OBI_0000293 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/OBI_0000293">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/RO_0000057"/>
        <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/OBI_0000295"/>
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/COB_0000035"/>
        <obo:IAO_0000112 xml:lang="en">see is_input_of example_of_usage</obo:IAO_0000112> <obo:IAO_0000112 xml:lang="zh">参见is_input_of的使用示例</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">The inverse property of is specified input of</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">属性'是指定输入'的逆</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">8/17/09: specified inputs of one process are not necessarily specified inputs of a larger process that it is part of. This is in contrast to how 'has participant' works.</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">8/17/09: 一个过程的指定输入不一定是它所参与的更大过程的指定输入。这与'has participant'的工作方式相反。</obo:IAO_0000116>
        <rdfs:label xml:lang="en">has specified input</rdfs:label> <rdfs:label xml:lang="zh">有指定输入</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/OBI_0000295 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/OBI_0000295">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/RO_0000056"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/COB_0000035"/>
        <obo:IAO_0000112 xml:lang="en">some Autologous EBV(Epstein-Barr virus)-transformed B-LCL (B lymphocyte cell line) is_input_for instance of Chromum Release Assay described at https://wiki.cbil.upenn.edu/obiwiki/index.php/Chromium_Release_assay</obo:IAO_0000112> <obo:IAO_0000112 xml:lang="zh">一些自体EBV（Epstein-Barr病毒）转化的B-LCL（B淋巴细胞细胞系）是Chromum Release Assay实例的is_input_for，描述于https://wiki.cbil.upenn.edu/obiwiki/index.php/Chromium_Release_assay</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">A relation between a completely executed planned process and a continuant participating in that process that is not created during the process. The presence of the continuant during the process is explicitly specified in the plan specification which the process realizes the concretization of.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">完全执行的计划过程与参与该过程且不在过程中创建的连续体之间的关系。连续体在过程中的存在由过程实现其具体化的计划规范明确指定。</obo:IAO_0000115>
        <rdfs:label xml:lang="en">is specified input of</rdfs:label> <rdfs:label xml:lang="zh">是指定输入</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/OBI_0000299 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/OBI_0000299">
        <owl:equivalentProperty>
            <rdf:Description>
                <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/OBI_0000312"/>
            </rdf:Description>
        </owl:equivalentProperty>
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/RO_0000057"/>
        <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/OBI_0000312"/>
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/COB_0000035"/>
        <obo:IAO_0000115 xml:lang="en">The inverse property of is specified output of</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">属性'是指定输出'的逆</obo:IAO_0000115>
        <rdfs:label xml:lang="en">has specified output</rdfs:label> <rdfs:label xml:lang="zh">有指定输出</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/OBI_0000304 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/OBI_0000304">
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/BFO_0000040"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/OBI_0000835"/>
        <obo:IAO_0000112 xml:lang="en">http://www.affymetrix.com/products/arrays/specific/hgu133.affx is_manufactered_by http://www.affymetrix.com/ (if we decide to use these URIs for the actual entities)</obo:IAO_0000112> <obo:IAO_0000112 xml:lang="zh">http://www.affymetrix.com/products/arrays/specific/hgu133.affx is_manufactered_by http://www.affymetrix.com/ （如果我们决定为实际实体使用这些URI）</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">c is_manufactured_by o means that there was a process p in which c was built in which a person, or set of people or machines did the work(bore the "Manufacturer Role", and those people/and or machines were members or of directed by the organization to do this.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">c is_manufactured_by o 意味着存在一个过程p，在此过程中c被构建，其中一个人或一组人或机器做了工作（承担了'制造商角色'），并且这些人/或机器是该组织的成员或受其指导来完成此事。</obo:IAO_0000115>
        <rdfs:label xml:lang="en">is_manufactured_by</rdfs:label> <rdfs:label xml:lang="zh">由...制造</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/OBI_0000312 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/OBI_0000312">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/RO_0000056"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/COB_0000035"/>
        <obo:IAO_0000115 xml:lang="en">A relation between a completely executed planned process and a continuant participating in that process. The presence of the continuant at the end of the process is explicitly specified in the objective specification which the process realizes the concretization of.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">完全执行的计划过程与参与该过程的连续体之间的关系。连续体在过程结束时的存在由过程实现其具体化的目标规范明确指定。</obo:IAO_0000115>
        <rdfs:label xml:lang="en">is specified output of</rdfs:label> <rdfs:label xml:lang="zh">是指定输出</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/OBI_0000417 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/OBI_0000417">
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/COB_0000035"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/IAO_0000005"/>
        <obo:IAO_0000112 xml:lang="en">A cell sorting process achieves the objective specification 'material separation objective'</obo:IAO_0000112> <obo:IAO_0000112 xml:lang="zh">细胞分选过程实现了目标规范'材料分离目标'</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">This relation obtains between a planned process and a objective specification when the criteria specified in the objective specification are met at the end of the planned process.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">该关系存在于计划过程和目标规范之间，当计划过程结束时满足目标规范中指定的标准。</obo:IAO_0000115>
        <obo:IAO_0000119 xml:lang="en">PPPB branch derived</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">PPPB分支派生</obo:IAO_0000119>
        <obo:IAO_0000232>modified according to email thread from 1/23/09 in accordince with DT and PPPB branch</obo:IAO_0000232>
        <rdfs:label xml:lang="en">achieves_planned_objective</rdfs:label> <rdfs:label xml:lang="zh">实现计划目标</rdfs:label>
        <PMD_0000064>https://github.com/search?q=repo%3Amaterialdigital%2Fcore-ontology+path%3A%2F%5Epatterns%5C%2F%2F+OBI_0000417&amp;type=code</PMD_0000064>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/OBI_0001927 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/OBI_0001927">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
        <owl:inverseOf rdf:resource="https://w3id.org/pmd/co/PMD_0000077"/>
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/OBI_0001933"/>
        <obo:IAO_0000115 xml:lang="en">A relation between a value specification and an entity which the specification is about.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">值规范与规范所描述的实体之间的关系。</obo:IAO_0000115>
        <rdfs:label xml:lang="en">specifies value of</rdfs:label> <rdfs:label xml:lang="zh">指定值</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/OBI_0001938 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/OBI_0001938">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/IAO_0000030"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/OBI_0001933"/>
        <obo:IAO_0000115 xml:lang="en">A relation between an information content entity and a value specification that specifies its value.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">信息内容实体与指定其值的值规范之间的关系。</obo:IAO_0000115>
        <obo:IAO_0000119>OBI</obo:IAO_0000119>
        <rdfs:label xml:lang="en">has value specification</rdfs:label> <rdfs:label xml:lang="zh">具有值规范</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/RO_0000052 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/RO_0000052">
        <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/RO_0000053"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <obo:IAO_0000112 xml:lang="en">this fragility is a characteristic of this vase</obo:IAO_0000112> <obo:IAO_0000112 xml:lang="zh">这种易碎性是这只花瓶的特性</obo:IAO_0000112>
        <obo:IAO_0000112 xml:lang="en">this red color is a characteristic of this apple</obo:IAO_0000112> <obo:IAO_0000112 xml:lang="zh">这种红色是这个苹果的特性</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">a relation between a specifically dependent continuant (the characteristic) and any other entity (the bearer), in which the characteristic depends on the bearer for its existence.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">特定依赖持续体（特性）与任何其他实体（承载者）之间的关系，其中特性依赖于承载者而存在。</obo:IAO_0000115>
        <rdfs:comment>Note that this relation was previously called "inheres in", but was changed to be called "characteristic of" because BFO2 uses "inheres in" in a more restricted fashion. This relation differs from BFO2:inheres_in in two respects: (1) it does not impose a range constraint, and thus it allows qualities of processes, as well as of information entities, whereas BFO2 restricts inheres_in to only apply to independent continuants (2) it is declared functional, i.e. something can only be a characteristic of one thing.</rdfs:comment>
        <rdfs:label xml:lang="en">characteristic of</rdfs:label> <rdfs:label xml:lang="zh">特性</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/RO_0000053 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/RO_0000053">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/BFO_0000020"/>
        <obo:IAO_0000112 xml:lang="en">this apple is bearer of this red color</obo:IAO_0000112> <obo:IAO_0000112 xml:lang="zh">这个苹果是这种红色的承载者</obo:IAO_0000112>
        <obo:IAO_0000112 xml:lang="en">this vase is bearer of this fragility</obo:IAO_0000112> <obo:IAO_0000112 xml:lang="zh">这只花瓶是这种易碎性的承载者</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">Inverse of characteristic_of</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">characteristic_of的逆关系</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">A bearer can have many dependents, and its dependents can exist for different periods of time, but none of its dependents can exist when the bearer does not exist.</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">一个承载者可以有多个依赖者，并且其依赖者可以在不同的时间段存在，但任何依赖者都不能在承载者不存在时存在。</obo:IAO_0000116>
        <rdfs:label xml:lang="en">has characteristic</rdfs:label> <rdfs:label xml:lang="zh">具有特性</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/RO_0000056 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/RO_0000056">
        <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/RO_0000057"/>
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/BFO_0000002"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/BFO_0000003"/>
        <obo:IAO_0000112 xml:lang="en">this blood clot participates in this blood coagulation</obo:IAO_0000112> <obo:IAO_0000112 xml:lang="zh">这个血块参与血液凝固过程</obo:IAO_0000112>
        <obo:IAO_0000112 xml:lang="en">this input material (or this output material) participates in this process</obo:IAO_0000112> <obo:IAO_0000112 xml:lang="zh">这个输入材料（或这个输出材料）参与这个过程</obo:IAO_0000112>
        <obo:IAO_0000112 xml:lang="en">this investigator participates in this investigation</obo:IAO_0000112> <obo:IAO_0000112 xml:lang="zh">这个研究者参与这个调查</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">a relation between a continuant and a process, in which the continuant is somehow involved in the process</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">连续体与过程之间的关系，其中连续体以某种方式参与过程</obo:IAO_0000115>
        <rdfs:label xml:lang="en">participates in</rdfs:label> <rdfs:label xml:lang="zh">参与</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/RO_0000057 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/RO_0000057">
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/BFO_0000003"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/BFO_0000002"/>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000051"/>
            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/RO_0000057"/>
        </owl:propertyChainAxiom>
        <obo:IAO_0000112 xml:lang="en">this blood coagulation has participant this blood clot</obo:IAO_0000112> <obo:IAO_0000112 xml:lang="zh">血液凝固过程有参与者这个血块</obo:IAO_0000112>
        <obo:IAO_0000112 xml:lang="en">this investigation has participant this investigator</obo:IAO_0000112> <obo:IAO_0000112 xml:lang="zh">这个调查有参与者这个研究者</obo:IAO_0000112>
        <obo:IAO_0000112 xml:lang="en">this process has participant this input material (or this output material)</obo:IAO_0000112> <obo:IAO_0000112 xml:lang="zh">这个过程有参与者这个输入材料（或这个输出材料）</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">a relation between a process and a continuant, in which the continuant is somehow involved in the process</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">过程与持续体之间的关系，其中持续体以某种方式参与该过程</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Has_participant is a primitive instance-level relation between a process, a continuant, and a time at which the continuant participates in some way in the process. The relation obtains, for example, when this particular process of oxygen exchange across this particular alveolar membrane has_participant this particular sample of hemoglobin at this particular time.</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">Has_participant是一个原始的实例级关系，涉及一个过程、一个持续体以及该持续体以某种方式参与该过程的时间。例如，当这个特定的肺泡膜氧气交换过程在特定时间有_participant这个特定的血红蛋白样本时，该关系成立。</obo:IAO_0000116>
        <rdfs:label xml:lang="en">has participant</rdfs:label> <rdfs:label xml:lang="zh">有参与者</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/RO_0000058 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/RO_0000058">
        <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/RO_0000059"/>
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/BFO_0000031"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000015"/>
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000020"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <obo:IAO_0000112 xml:lang="en">A journal article is an information artifact that inheres in some number of printed journals. For each copy of the printed journal there is some quality that carries the journal article, such as a pattern of ink. The journal article (a generically dependent continuant) is concretized as the quality (a specifically dependent continuant), and both depend on that copy of the printed journal (an independent continuant).</obo:IAO_0000112> <obo:IAO_0000112 xml:lang="zh">期刊文章是一种信息人工制品，存在于一定数量的印刷期刊中。对于每份印刷期刊的副本，都有某种承载该期刊文章的质量，例如墨迹图案。期刊文章（一种普遍依赖的持续体）被具体化为质量（一种特殊依赖的持续体），两者都依赖于该印刷期刊的副本（一种独立持续体）。</obo:IAO_0000112>
        <obo:IAO_0000112 xml:lang="en">An investigator reads a protocol and forms a plan to carry out an assay. The plan is a realizable entity (a specifically dependent continuant) that concretizes the protocol (a generically dependent continuant), and both depend on the investigator (an independent continuant). The plan is then realized by the assay (a process).</obo:IAO_0000112> <obo:IAO_0000112 xml:lang="zh">研究者阅读方案并形成执行测定的计划。该计划是一个可实现实体（一种特殊依赖的持续体），它具体化了方案（一种普遍依赖的持续体），两者都依赖于研究者（一种独立持续体）。然后，该计划通过测定（一个过程）得以实现。</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">A relationship between a generically dependent continuant and a specifically dependent continuant or process, in which the generically dependent continuant depends on some independent continuant or process in virtue of the fact that the specifically dependent continuant or process also depends on that same independent continuant. A generically dependent continuant may be concretized as multiple specifically dependent continuants or processes.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">普遍依赖的持续体与特殊依赖的持续体或过程之间的关系，其中普遍依赖的持续体依赖于某个独立持续体或过程，因为该特殊依赖的持续体或过程也依赖于同一个独立持续体。一个普遍依赖的持续体可以具体化为多个特殊依赖的持续体或过程。</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="en">A relationship between a generically dependent continuant and a specifically dependent continuant, in which the generically dependent continuant depends on some independent continuant in virtue of the fact that the specifically dependent continuant also depends on that same independent continuant. A generically dependent continuant may be concretized as multiple specifically dependent continuants.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">普遍依赖的持续体与特殊依赖的持续体之间的关系，其中普遍依赖的持续体依赖于某个独立持续体，因为该特殊依赖的持续体也依赖于同一个独立持续体。一个普遍依赖的持续体可以具体化为多个特殊依赖的持续体。</obo:IAO_0000115>
        <rdfs:label xml:lang="en">is concretized as</rdfs:label> <rdfs:label xml:lang="zh">被具体化为</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/RO_0000059 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/RO_0000059">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000015"/>
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000020"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/BFO_0000031"/>
        <obo:IAO_0000112 xml:lang="en">A journal article is an information artifact that inheres in some number of printed journals. For each copy of the printed journal there is some quality that carries the journal article, such as a pattern of ink. The quality (a specifically dependent continuant) concretizes the journal article (a generically dependent continuant), and both depend on that copy of the printed journal (an independent continuant).</obo:IAO_0000112> <obo:IAO_0000112 xml:lang="zh">一份期刊文章是一种信息人工制品，存在于一定数量的印刷期刊中。对于每份印刷期刊的副本，都有某种承载该期刊文章的质量，例如墨迹图案。质量（一种特殊依赖的持续体）具体化了期刊文章（一种普遍依赖的持续体），两者都依赖于该印刷期刊的副本（一种独立持续体）。</obo:IAO_0000112>
        <obo:IAO_0000112 xml:lang="en">An investigator reads a protocol and forms a plan to carry out an assay. The plan is a realizable entity (a specifically dependent continuant) that concretizes the protocol (a generically dependent continuant), and both depend on the investigator (an independent continuant). The plan is then realized by the assay (a process).</obo:IAO_0000112> <obo:IAO_0000112 xml:lang="zh">研究者阅读方案并形成执行测定的计划。该计划是一个可实现实体（一种特殊依赖的持续体），它具体化了方案（一种普遍依赖的持续体），两者都依赖于研究者（一种独立持续体）。然后，该计划通过测定（一个过程）得以实现。</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">A relationship between a specifically dependent continuant and a generically dependent continuant, in which the generically dependent continuant depends on some independent continuant in virtue of the fact that the specifically dependent continuant also depends on that same independent continuant. Multiple specifically dependent continuants can concretize the same generically dependent continuant.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">特殊依赖的持续体与普遍依赖的持续体之间的关系，其中普遍依赖的持续体依赖于某个独立持续体，因为该特殊依赖的持续体也依赖于同一个独立持续体。多个特殊依赖的持续体可以具体化同一个普遍依赖的持续体。</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="en">A relationship between a specifically dependent continuant or process and a generically dependent continuant, in which the generically dependent continuant depends on some independent continuant in virtue of the fact that the specifically dependent continuant or process also depends on that same independent continuant. Multiple specifically dependent continuants or processes can concretize the same generically dependent continuant.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">特殊依赖的持续体或过程与普遍依赖的持续体之间的关系，其中普遍依赖的持续体依赖于某个独立持续体，因为该特殊依赖的持续体或过程也依赖于同一个独立持续体。多个特殊依赖的持续体或过程可以具体化同一个普遍依赖的持续体。</obo:IAO_0000115>
        <rdfs:label xml:lang="en">concretizes</rdfs:label> <rdfs:label xml:lang="zh">具体化</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/RO_0000079 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/RO_0000079">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/RO_0000052"/>
        <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/RO_0000085"/>
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/BFO_0000034"/>
        <obo:IAO_0000112 xml:lang="en">this catalysis function is a function of this enzyme</obo:IAO_0000112> <obo:IAO_0000112 xml:lang="zh">这个催化功能是这种酶的一种功能</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">a relation between a function and an independent continuant (the bearer), in which the function specifically depends on the bearer for its existence</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">功能与独立持续体（载体）之间的关系，其中功能的存在特定地依赖于该载体</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">A function inheres in its bearer at all times for which the function exists, however the function need not be realized at all the times that the function exists.</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">功能在其存在的所有时间内都存在于其载体中，但该功能不必在其存在的所有时间都得以实现。</obo:IAO_0000116>
        <rdfs:comment>This relation is modeled after the BFO relation of the same name which was in BFO2, but is used in a more restricted sense - specifically, we model this relation as functional (inherited from characteristic-of). Note that this relation is now removed from BFO2020.</rdfs:comment>
        <rdfs:label xml:lang="en">function of</rdfs:label> <rdfs:label xml:lang="zh">的功能</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/RO_0000080 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/RO_0000080">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/RO_0000052"/>
        <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/RO_0000086"/>
        <rdfs:domain>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000019"/>
                    <owl:Class>
                        <owl:complementOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000145"/>
                    </owl:Class>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:domain>
        <obo:IAO_0000112 xml:lang="en">this red color is a quality of this apple</obo:IAO_0000112> <obo:IAO_0000112 xml:lang="zh">这种红色是这种苹果的一种特性</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">a relation between a quality and an independent continuant (the bearer), in which the quality specifically depends on the bearer for its existence</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">特性与独立持续体（载体）之间的关系，其中特性的存在特定地依赖于该载体</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">A quality inheres in its bearer at all times for which the quality exists.</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">特性在其存在的所有时间内都存在于其载体中。</obo:IAO_0000116>
        <rdfs:comment>This relation is modeled after the BFO relation of the same name which was in BFO2, but is used in a more restricted sense - specifically, we model this relation as functional (inherited from characteristic-of). Note that this relation is now removed from BFO2020.</rdfs:comment>
        <rdfs:label xml:lang="en">quality of</rdfs:label> <rdfs:label xml:lang="zh">的特性</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/RO_0000081 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/RO_0000081">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/RO_0000052"/>
        <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/RO_0000087"/>
        <obo:IAO_0000112 xml:lang="en">this investigator role is a role of this person</obo:IAO_0000112> <obo:IAO_0000112 xml:lang="zh">这个研究者角色是这个人的一种角色</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">a relation between a role and an independent continuant (the bearer), in which the role specifically depends on the bearer for its existence</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">角色与独立持续体（载体）之间的关系，其中角色的存在特定地依赖于该载体</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">A role inheres in its bearer at all times for which the role exists, however the role need not be realized at all the times that the role exists.</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">角色在其存在的所有时间内都存在于其载体中，但该角色不必在其存在的所有时间都得以实现。</obo:IAO_0000116>
        <rdfs:comment>This relation is modeled after the BFO relation of the same name which was in BFO2, but is used in a more restricted sense - specifically, we model this relation as functional (inherited from characteristic-of). Note that this relation is now removed from BFO2020.</rdfs:comment>
        <rdfs:label xml:lang="en">role of</rdfs:label> <rdfs:label xml:lang="zh">的角色</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/RO_0000085 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/RO_0000085">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/RO_0000053"/>
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/BFO_0000004"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/BFO_0000034"/>
        <obo:IAO_0000112 xml:lang="en">this enzyme has function this catalysis function (more colloquially: this enzyme has this catalysis function)</obo:IAO_0000112> <obo:IAO_0000112 xml:lang="zh">这种酶具有功能这个催化功能（更通俗地说：这种酶有这个催化功能）</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">a relation between an independent continuant (the bearer) and a function, in which the function specifically depends on the bearer for its existence</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">独立延续物（承载者）与功能之间的关系，其中功能专门依赖于承载者而存在</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">A bearer can have many functions, and its functions can exist for different periods of time, but none of its functions can exist when the bearer does not exist. A function need not be realized at all the times that the function exists.</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">承载者可以具有多种功能，其功能可以存在于不同时间段，但承载者不存在时，其任何功能都不能存在。功能不一定在功能存在的所有时间都实现。</obo:IAO_0000116>
        <rdfs:label xml:lang="en">has function</rdfs:label> <rdfs:label xml:lang="zh">具有功能</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/RO_0000086 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/RO_0000086">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/RO_0000053"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <obo:IAO_0000112 xml:lang="en">this apple has quality this red color</obo:IAO_0000112> <obo:IAO_0000112 xml:lang="zh">这个苹果具有特性这种红色</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">a relation between an independent continuant (the bearer) and a quality, in which the quality specifically depends on the bearer for its existence</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">独立延续物（承载者）与特性之间的关系，其中特性专门依赖于承载者而存在</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">A bearer can have many qualities, and its qualities can exist for different periods of time, but none of its qualities can exist when the bearer does not exist.</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">承载者可以具有多种特性，其特性可以存在于不同时间段，但承载者不存在时，其任何特性都不能存在。</obo:IAO_0000116>
        <rdfs:label xml:lang="en">has quality</rdfs:label> <rdfs:label xml:lang="zh">具有特性</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/RO_0000087 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/RO_0000087">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/RO_0000053"/>
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/BFO_0000004"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/BFO_0000023"/>
        <obo:IAO_0000112 xml:lang="en">this person has role this investigator role (more colloquially: this person has this role of investigator)</obo:IAO_0000112> <obo:IAO_0000112 xml:lang="zh">这个人具有角色这个研究者角色（更口语化：这个人具有研究者的角色）</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">a relation between an independent continuant (the bearer) and a role, in which the role specifically depends on the bearer for its existence</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">独立延续物（承载者）与角色之间的关系，其中角色专门依赖于承载者而存在</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">A bearer can have many roles, and its roles can exist for different periods of time, but none of its roles can exist when the bearer does not exist. A role need not be realized at all the times that the role exists.</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">承载者可以具有多种角色，其角色可以存在于不同时间段，但承载者不存在时，其任何角色都不能存在。角色不一定在角色存在的所有时间都实现。</obo:IAO_0000116>
        <rdfs:label xml:lang="en">has role</rdfs:label> <rdfs:label xml:lang="zh">具有角色</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/RO_0000091 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/RO_0000091">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/RO_0000053"/>
        <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/RO_0000092"/>
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/BFO_0000004"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/BFO_0000016"/>
        <obo:IAO_0000115 xml:lang="en">a relation between an independent continuant (the bearer) and a disposition, in which the disposition specifically depends on the bearer for its existence</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">独立延续物（承载者）与属性之间的关系，其中属性专门依赖于承载者而存在</obo:IAO_0000115>
        <rdfs:label xml:lang="en">has disposition</rdfs:label> <rdfs:label xml:lang="zh">具有属性</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/RO_0000092 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/RO_0000092">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/RO_0000052"/>
        <obo:IAO_0000115 xml:lang="en">inverse of has disposition</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">具有属性的逆关系</obo:IAO_0000115>
        <rdfs:comment>This relation is modeled after the BFO relation of the same name which was in BFO2, but is used in a more restricted sense - specifically, we model this relation as functional (inherited from characteristic-of). Note that this relation is now removed from BFO2020.</rdfs:comment>
        <rdfs:label xml:lang="en">disposition of</rdfs:label> <rdfs:label xml:lang="zh">……的属性</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/RO_0001000 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/RO_0001000">
        <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/RO_0001001"/>
        <obo:IAO_0000112 xml:lang="en">this cell derives from this parent cell (cell division)</obo:IAO_0000112> <obo:IAO_0000112 xml:lang="zh">这个细胞来源于这个母细胞（细胞分裂）</obo:IAO_0000112>
        <obo:IAO_0000112 xml:lang="en">this nucleus derives from this parent nucleus (nuclear division)</obo:IAO_0000112> <obo:IAO_0000112 xml:lang="zh">这个细胞核来源于这个母细胞核（核分裂）</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">a relation between two distinct material entities, the new entity and the old entity, in which the new entity begins to exist when the old entity ceases to exist, and the new entity inherits the significant portion of the matter of the old entity</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">两个不同物质实体（新实体和旧实体）之间的关系，新实体在旧实体停止存在时开始存在，且新实体继承旧实体的大部分物质</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">This is a very general relation. More specific relations are preferred when applicable, such as 'directly develops from'.</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">这是一个非常一般的关系。在适用的情况下更推荐使用更具体的关系，例如'直接来源于'。</obo:IAO_0000116>
        <rdfs:label xml:lang="en">derives from</rdfs:label> <rdfs:label xml:lang="zh">来源于</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/RO_0001001 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/RO_0001001">
        <obo:IAO_0000112 xml:lang="en">this parent cell derives into this cell (cell division)</obo:IAO_0000112> <obo:IAO_0000112 xml:lang="zh">这个母细胞衍生出这个细胞（细胞分裂）</obo:IAO_0000112>
        <obo:IAO_0000112 xml:lang="en">this parent nucleus derives into this nucleus (nuclear division)</obo:IAO_0000112> <obo:IAO_0000112 xml:lang="zh">这个母细胞核衍生出这个细胞核（核分裂）</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">a relation between two distinct material entities, the old entity and the new entity, in which the new entity begins to exist when the old entity ceases to exist, and the new entity inherits the significant portion of the matter of the old entity</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">两个不同物质实体（旧实体和新实体）之间的关系，新实体在旧实体停止存在时开始存在，且新实体继承旧实体的大部分物质</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">This is a very general relation. More specific relations are preferred when applicable, such as 'directly develops into'. To avoid making statements about a future that may not come to pass, it is often better to use the backward-looking 'derives from' rather than the forward-looking 'derives into'.</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">这是一个非常一般的关系。在适用的情况下更推荐使用更具体的关系，例如'直接发展为'。为了避免对可能不会发生的未来做出声明，通常最好使用回顾性的'来源于'而不是前瞻性的'衍生出'。</obo:IAO_0000116>
        <rdfs:label xml:lang="en">derives into</rdfs:label> <rdfs:label xml:lang="zh">衍生出</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/RO_0001015 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/RO_0001015">
        <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/RO_0001025"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <obo:IAO_0000112 xml:lang="en">my head is the location of my brain</obo:IAO_0000112> <obo:IAO_0000112 xml:lang="zh">我的头是我大脑的位置</obo:IAO_0000112>
        <obo:IAO_0000112 xml:lang="en">this cage is the location of this rat</obo:IAO_0000112> <obo:IAO_0000112 xml:lang="zh">这个笼子是这只老鼠的位置</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">a relation between two independent continuants, the location and the target, in which the target is entirely within the location</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">一种关系，存在于两个独立持续体之间，即位置和目标，其中目标完全位于位置之内</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Most location relations will only hold at certain times, but this is difficult to specify in OWL. See http://purl.obolibrary.org/obo/ro/docs/temporal-semantics/</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">大多数位置关系只在特定时间成立，但这一点在OWL中难以指定。请参见 http://purl.obolibrary.org/obo/ro/docs/temporal-semantics/</obo:IAO_0000116>
        <rdfs:label xml:lang="en">location of</rdfs:label> <rdfs:label xml:lang="zh">位于</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/RO_0001025 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/RO_0001025">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/BFO_0000004"/>
        <rdfs:domain>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000004"/>
                    <owl:Class>
                        <owl:complementOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000006"/>
                    </owl:Class>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/BFO_0000004"/>
        <rdfs:range>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000004"/>
                    <owl:Class>
                        <owl:complementOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000006"/>
                    </owl:Class>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:range>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/RO_0001025"/>
            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000050"/>
        </owl:propertyChainAxiom>
        <obo:IAO_0000112 xml:lang="en">my brain is located in my head</obo:IAO_0000112> <obo:IAO_0000112 xml:lang="zh">我的大脑位于我的头内</obo:IAO_0000112>
        <obo:IAO_0000112 xml:lang="en">this rat is located in this cage</obo:IAO_0000112> <obo:IAO_0000112 xml:lang="zh">这只老鼠位于这个笼子里</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">a relation between two independent continuants, the target and the location, in which the target is entirely within the location</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">一种关系，存在于两个独立持续体之间，即目标和位置，其中目标完全位于位置之内</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Location as a relation between instances: The primitive instance-level relation c located_in r at t reflects the fact that each continuant is at any given time associated with exactly one spatial region, namely its exact location. Following we can use this relation to define a further instance-level location relation - not between a continuant and the region which it exactly occupies, but rather between one continuant and another. c is located in c1, in this sense, whenever the spatial region occupied by c is part_of the spatial region occupied by c1.    Note that this relation comprehends both the relation of exact location between one continuant and another which obtains when r and r1 are identical (for example, when a portion of fluid exactly fills a cavity), as well as those sorts of inexact location relations which obtain, for example, between brain and head or between ovum and uterus</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">作为实例间关系的位置：原始的实例级关系c located_in r at t反映了每个持续体在任何给定时间都与恰好一个空间区域相关联的事实，即其精确位置。接下来我们可以利用这一关系来定义另一种实例级位置关系——不是在一个持续体与其精确占据的区域之间，而是在一个持续体与另一个持续体之间。c位于c1中，在这种意义上，当c占据的空间区域是c1占据的空间区域的一部分时成立。注意，这一关系既包含一个持续体与另一个持续体之间的精确位置关系（当r和r1相同时，例如当一部分流体恰好填满一个腔体），也包含那些非精确位置关系，例如脑与头之间或卵子与子宫之间的关系。</obo:IAO_0000116>
        <obo:IAO_0000116 xml:lang="en">Most location relations will only hold at certain times, but this is difficult to specify in OWL. See http://purl.obolibrary.org/obo/ro/docs/temporal-semantics/</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">大多数位置关系只在特定时间成立，但这一点在OWL中难以指定。请参见 http://purl.obolibrary.org/obo/ro/docs/temporal-semantics/</obo:IAO_0000116>
        <rdfs:label xml:lang="en">located in</rdfs:label> <rdfs:label xml:lang="zh">位于</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/RO_0002082 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/RO_0002082">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <obo:IAO_0000115 xml:lang="en">x simultaneous with y iff ω(x) = ω(y) and ω(α ) = ω(α), where α is a function that maps a process to a start point, and ω is a function that maps a process to an end point and '=' indicates the same instance in time.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">x与y同时当且仅当ω(x)=ω(y)且ω(α)=ω(α)，其中α是将过程映射到起始点的函数，ω是将过程映射到终止点的函数，'='表示同一时间实例。</obo:IAO_0000115>
        <rdfs:comment xml:lang="en">t1 simultaneous_with t2 iff:=  t1 before_or_simultaneous_with t2  and not (t1 before t2)</rdfs:comment>
        <rdfs:label xml:lang="en">simultaneous with</rdfs:label> <rdfs:label xml:lang="zh">与...同时</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/RO_0002223 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/RO_0002223">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
        <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/RO_0002224"/>
        <obo:IAO_0000115 xml:lang="en">inverse of starts with</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">始于的逆关系</obo:IAO_0000115>
        <obo:IAO_0000119>Allen</obo:IAO_0000119>
        <rdfs:label xml:lang="en">starts</rdfs:label> <rdfs:label xml:lang="zh">开始</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/RO_0002224 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/RO_0002224">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <obo:IAO_0000112 xml:lang="en">Every insulin receptor signaling pathway starts with the binding of a ligand to the insulin receptor</obo:IAO_0000112> <obo:IAO_0000112 xml:lang="zh">每个胰岛素受体信号传导途径始于配体与胰岛素受体的结合</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">x starts with y if and only if x has part y and the time point at which x starts is equivalent to the time point at which y starts. Formally: α(y) = α(x) ∧ ω(y) &lt; ω(x), where α is a function that maps a process to a start point, and ω is a function that maps a process to an end point.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">x以y开始当且仅当x以y为部分且x开始的时间点等于y开始的时间点。形式化地：α(y)=α(x) ∧ ω(y)&lt;ω(x)，其中α是将过程映射到起始点的函数，ω是将过程映射到终止点的函数。</obo:IAO_0000115>
        <rdfs:label xml:lang="en">starts with</rdfs:label> <rdfs:label xml:lang="zh">始于</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/RO_0002229 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/RO_0002229">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
        <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/RO_0002230"/>
        <obo:IAO_0000115 xml:lang="en">inverse of ends with</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">以...结束的逆关系</obo:IAO_0000115>
        <rdfs:label xml:lang="en">ends</rdfs:label> <rdfs:label xml:lang="zh">结束</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/RO_0002230 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/RO_0002230">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <obo:IAO_0000115 xml:lang="en">x ends with y if and only if x has part y and the time point at which x ends is equivalent to the time point at which y ends. Formally: α(y) &gt; α(x) ∧ ω(y) = ω(x), where α is a function that maps a process to a start point, and ω is a function that maps a process to an end point.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">x以y结束当且仅当x以y为部分且x结束的时间点等于y结束的时间点。形式化地：α(y)&gt;α(x) ∧ ω(y)=ω(x)，其中α是将过程映射到起始点的函数，ω是将过程映射到终止点的函数。</obo:IAO_0000115>
        <rdfs:label xml:lang="en">ends with</rdfs:label> <rdfs:label xml:lang="zh">以...结束</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/RO_0002233 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/RO_0002233">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/RO_0000057"/>
        <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/RO_0002352"/>
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/RO_0002224"/>
            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/RO_0002233"/>
        </owl:propertyChainAxiom>
        <obo:IAO_0000115 xml:lang="en">p has input c iff: p is a process, c is a material entity, c is a participant in p, c is present at the start of p, and the state of c is modified during p.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">p有输入c当且仅当：p是一个过程，c是一个物质实体，c是p的参与者，c在p开始时存在，且c的状态在p过程中被改变。</obo:IAO_0000115>
        <rdfs:label xml:lang="en">has input</rdfs:label> <rdfs:label xml:lang="zh">有输入</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/RO_0002234 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/RO_0002234">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/RO_0000057"/>
        <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/RO_0002353"/>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/RO_0002230"/>
            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/RO_0002234"/>
        </owl:propertyChainAxiom>
        <obo:IAO_0000115 xml:lang="en">p has output c iff c is a participant in p, c is present at the end of p, and c is not present in the same state at the beginning of p.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">p有输出c当且仅当c是p的参与者，c在p结束时存在，且c在p开始时不以相同状态存在。</obo:IAO_0000115>
        <rdfs:label xml:lang="en">has output</rdfs:label> <rdfs:label xml:lang="zh">有输出</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/RO_0002350 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/RO_0002350">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
        <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/RO_0002351"/>
        <obo:IAO_0000112 xml:lang="en">An organism that is a member of a population of organisms</obo:IAO_0000112> <obo:IAO_0000112 xml:lang="zh">属于某个生物群体的有机体</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">is member of is a mereological relation between a item and a collection.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">is member of 是一个个体与一个集合之间的部分-整体关系。</obo:IAO_0000115>
        <obo:IAO_0000119>SIO</obo:IAO_0000119>
        <rdfs:label xml:lang="en">member of</rdfs:label> <rdfs:label xml:lang="zh">属于</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/RO_0002351 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/RO_0002351">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <obo:IAO_0000115 xml:lang="en">has member is a mereological relation between a collection and an item.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">has member 是一个集合与一个个体之间的部分-整体关系。</obo:IAO_0000115>
        <obo:IAO_0000119>SIO</obo:IAO_0000119>
        <rdfs:label xml:lang="en">has member</rdfs:label> <rdfs:label xml:lang="zh">有成员</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/RO_0002352 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/RO_0002352">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/RO_0000056"/>
        <obo:IAO_0000115 xml:lang="en">inverse of has input</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">有输入的逆</obo:IAO_0000115>
        <rdfs:label xml:lang="en">input of</rdfs:label> <rdfs:label xml:lang="zh">的输入</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/RO_0002353 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/RO_0002353">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/RO_0000056"/>
        <obo:IAO_0000115 xml:lang="en">inverse of has output</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">有输出的逆</obo:IAO_0000115>
        <rdfs:label xml:lang="en">output of</rdfs:label> <rdfs:label xml:lang="zh">的输出</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/RO_0009006 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/RO_0009006">
        <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/RO_0009007"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/BFO_0000020"/>
        <obo:IAO_0000112 xml:lang="en">A mass measurement assay measures an material's mass characteristic. A radioactivity detection assay measures the amount of radiation (alpha, beta or gamma ray emmissions) coming from a material.</obo:IAO_0000112> <obo:IAO_0000112 xml:lang="zh">质量测量测定法测量材料的质量特性。放射性检测测定法测量来自材料的辐射量（α、β或γ射线发射）。</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">A relation between an assay and a characteristic, in which the assay generates a data item which is a measure of a characteristic.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">测定法与特性之间的关系，其中测定法生成一个作为特性度量的数据项。</obo:IAO_0000115>
        <rdfs:label xml:lang="en">assay measures characteristic</rdfs:label> <rdfs:label xml:lang="zh">测定法测量特性</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/RO_0009007 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/RO_0009007">
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/BFO_0000020"/>
        <obo:IAO_0000115 xml:lang="en">Inverse of 'assay measures characteristic'</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">“测定法测量特性”的逆</obo:IAO_0000115>
        <rdfs:label xml:lang="en">characteristic measured by assay</rdfs:label> <rdfs:label xml:lang="zh">由测定法测量的特性</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/STATO_0000102 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/STATO_0000102">
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000055"/>
            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/RO_0000059"/>
        </owl:propertyChainAxiom>
        <obo:IAO_0000115 xml:lang="en">relationship between a planned process and the plan specification that it carries out; it is defined as equivalent to the composed relationship (realizes o concretizes)</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">计划过程与其执行的计划规范之间的关系；它被定义为与组合关系（实现 o 具体化）等价。</obo:IAO_0000115>
        <obo:IAO_0000119>AGB</obo:IAO_0000119>
        <rdfs:label xml:lang="en">executes</rdfs:label> <rdfs:label xml:lang="zh">执行</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pmd/co/PMD_0000004 -->

    <owl:ObjectProperty rdf:about="https://w3id.org/pmd/co/PMD_0000004">
        <rdfs:label xml:lang="en">is subject of</rdfs:label> <rdfs:label xml:lang="zh">是...的主题</rdfs:label>
        <skos:definition xml:lang="en">Inverse of 'is about'.</skos:definition> <skos:definition xml:lang="zh">“关于”的逆。</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pmd/co/PMD_0000009 -->

    <owl:ObjectProperty rdf:about="https://w3id.org/pmd/co/PMD_0000009">
        <owl:inverseOf rdf:resource="https://w3id.org/pmd/co/PMD_0025006"/>
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:range rdf:resource="https://w3id.org/pmd/co/PMD_0000008"/>
        <rdfs:label xml:lang="en">has process attribute</rdfs:label> <rdfs:label xml:lang="zh">具有过程属性</rdfs:label>
        <rdfs:seeAlso xml:lang="en">has process attribute from OEO https://openenergyplatform.org/ontology/oeo/OEO_00000500</rdfs:seeAlso>
        <skos:definition xml:lang="en">A relation between a process and a process attribute that depends on it.</skos:definition> <skos:definition xml:lang="zh">一个过程与依赖于该过程的过程属性之间的关系。</skos:definition>
        <skos:example xml:lang="en">Tensile testing process has process attribute tensile rate</skos:example> <skos:example xml:lang="zh">拉伸测试过程具有过程属性拉伸速率</skos:example>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pmd/co/PMD_0000069 -->

    <owl:ObjectProperty rdf:about="https://w3id.org/pmd/co/PMD_0000069">
        <owl:inverseOf rdf:resource="https://w3id.org/pmd/co/PMD_0000070"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
        <rdfs:domain>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000002"/>
                    <owl:Class>
                        <owl:complementOf rdf:resource="https://w3id.org/pmd/co/PMD_0000068"/>
                    </owl:Class>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://w3id.org/pmd/co/PMD_0000068"/>
        <rdfs:label xml:lang="en">has state</rdfs:label> <rdfs:label xml:lang="zh">有状态</rdfs:label>
        <skos:definition xml:lang="en">relates an anchor continuant to a temporally qualified continuant that represents a specific temporal phase of its existence.</skos:definition> <skos:definition xml:lang="zh">将锚定持续实体与表示其存在特定时间阶段的时间限定持续实体关联起来。</skos:definition>
        <PMD_0001032>https://github.com/materialdigital/core-ontology/issues/185</PMD_0001032>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pmd/co/PMD_0000070 -->

    <owl:ObjectProperty rdf:about="https://w3id.org/pmd/co/PMD_0000070">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:label xml:lang="en">is state of</rdfs:label> <rdfs:label xml:lang="zh">是……的状态</rdfs:label>
        <skos:definition xml:lang="en">relates a temporally qualified continuant to the unique anchor continuant that it is a temporal phase of</skos:definition> <skos:definition xml:lang="zh">将时间限定持续实体与其作为时间阶段的唯一锚定持续实体关联起来</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pmd/co/PMD_0000077 -->

    <owl:ObjectProperty rdf:about="https://w3id.org/pmd/co/PMD_0000077">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/pmd/co/PMD_0000004"/>
        <rdfs:label xml:lang="en">specified by value</rdfs:label> <rdfs:label xml:lang="zh">由值指定</rdfs:label>
        <skos:definition xml:lang="en">A relation between an entity and a value specification which is about this entity.</skos:definition> <skos:definition xml:lang="zh">实体与关于该实体的值规范之间的关系。</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pmd/co/PMD_0001026 -->

    <owl:ObjectProperty rdf:about="https://w3id.org/pmd/co/PMD_0001026">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/pmd/co/PMD_0000004"/>
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/BFO_0000004"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/IAO_0000030"/>
        <rdfs:label xml:lang="en">complies with</rdfs:label> <rdfs:label xml:lang="zh">符合</rdfs:label>
        <rdfs:label xml:lang="de">entspricht</rdfs:label> <rdfs:label xml:lang="zh">对应</rdfs:label>
        <skos:definition xml:lang="en">complies with is a relation between an independent continuant and an information content entity (e.g., specification or objective) that it conforms to.</skos:definition> <skos:definition xml:lang="zh">符合是独立持续实体与其所遵循的信息内容实体（例如规范或目标）之间的关系。</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pmd/co/PMD_0001028 -->

    <owl:ObjectProperty rdf:about="https://w3id.org/pmd/co/PMD_0001028">
        <owl:inverseOf rdf:resource="https://w3id.org/pmd/co/PMD_0001029"/>
        <rdfs:label xml:lang="en">in response to</rdfs:label> <rdfs:label xml:lang="zh">响应于</rdfs:label>
        <skos:definition xml:lang="en">inverse of responds with</skos:definition> <skos:definition xml:lang="zh">以……响应的逆关系</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pmd/co/PMD_0001029 -->

    <owl:ObjectProperty rdf:about="https://w3id.org/pmd/co/PMD_0001029">
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/BFO_0000017"/>
        <rdfs:label xml:lang="en">responds with</rdfs:label> <rdfs:label xml:lang="zh">以……响应</rdfs:label>
        <skos:definition xml:lang="en">The realizable entity must be "stimulated" by some Stimulus in order to respond with the Response. The bearer of the realizable entity must participate in Stimulation as well as in Response.</skos:definition> <skos:definition xml:lang="zh">可实现实体必须被某些刺激“激发”才能以响应回应。可实现实体的承载者必须同时参与刺激和响应。</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pmd/co/PMD_0020020 -->

    <owl:ObjectProperty rdf:about="https://w3id.org/pmd/co/PMD_0020020">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/BFO_0000040"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/BFO_0000040"/>
        <rdfs:label xml:lang="en">interacts with</rdfs:label> <rdfs:label xml:lang="zh">与……相互作用</rdfs:label>
        <skos:definition xml:lang="en">A relation between participants of a process indicating that some of the participants SDCs are affected during the process due to the interaction of the participants.</skos:definition> <skos:definition xml:lang="zh">过程参与者之间的关系，指示由于参与者的相互作用，过程中某些参与者的SDC受到影响。</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pmd/co/PMD_0020021 -->

    <owl:ObjectProperty rdf:about="https://w3id.org/pmd/co/PMD_0020021">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/pmd/co/PMD_0020020"/>
        <rdfs:domain>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000087"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020134"/>
            </owl:Restriction>
        </rdfs:domain>
        <rdfs:range>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000087"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020135"/>
            </owl:Restriction>
        </rdfs:range>
        <rdfs:label xml:lang="en">causally influences</rdfs:label> <rdfs:label xml:lang="zh">因果影响</rdfs:label>
        <skos:definition xml:lang="en">An entity (that is bearer of some stimulation role) causally influences another entity (that is bearer of the stimulation target role) in a process iff  the target objects qualites (and/or realizable entities?) are altered in a manner that is significant in the given context/domain of discourse..</skos:definition> <skos:definition xml:lang="zh">一个实体（具有某些刺激角色）在过程中因果影响另一个实体（具有刺激目标角色），当且仅当目标对象的特质（和/或可实现实体？）以在给定上下文/论域中显著的方式被改变。</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pmd/co/PMD_0020127 -->

    <owl:ObjectProperty rdf:about="https://w3id.org/pmd/co/PMD_0020127">
        <rdfs:domain rdf:resource="https://w3id.org/pmd/co/PMD_0000008"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/BFO_0000020"/>
        <rdfs:comment xml:lang="en">Despite has characteristic from RO does not have any domain constraints, it is still not possible to directly connect an instance of a process with an instance of a SDC. 

First, SDC is dependent on a IC. As RO does not have "bearer of" object property, the "has characteristic" implies that the domain should be an IC. 

Second, characteristic of is a functional property. Thus, two triples SDC_1 characteristc of IC_1 and SDC_2  characteristc of Process_1 (where IC_1 participates in Process_1), cannot exist simultaneously. 
An example of such case can be "Temperature of during the annealing process was 1000°C". Temperature is an SDC of some participant of the annealing, however it is not clear whether it is an SDC of an oven or of a sample in the oven. If we assert triple Annealing--&gt; has characteristic --&gt; Temperature 1000°C, then the correct triple connecting temperature SDC with either oven or specimen cannot exist.</rdfs:comment>
        <rdfs:label xml:lang="en">refers to</rdfs:label> <rdfs:label xml:lang="zh">指称</rdfs:label>
        <skos:definition xml:lang="en">a relation between a process attribute and an SDC of some participant in a process</skos:definition> <skos:definition xml:lang="zh">过程属性与过程中某参与者SDC之间的关系</skos:definition>
        <skos:example xml:lang="en">a relation to between a process attribute an a SDC of some participant in a process.</skos:example> <skos:example xml:lang="zh">过程属性与过程中某参与者SDC之间的关系。</skos:example>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pmd/co/PMD_0025006 -->

    <owl:ObjectProperty rdf:about="https://w3id.org/pmd/co/PMD_0025006">
        <rdfs:label xml:lang="en">process attribute of</rdfs:label> <rdfs:label xml:lang="zh">……的过程属性</rdfs:label>
        <skos:definition xml:lang="en">A relation between a process attribute and a process, which "bears" the attribute.</skos:definition> <skos:definition xml:lang="zh">过程属性与“承载”该属性的过程之间的关系。</skos:definition>
        <skos:example xml:lang="en">Tensile rate is a process attribute of tensile test</skos:example> <skos:example xml:lang="zh">拉伸速率是拉伸试验的过程属性</skos:example>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pmd/co/PMD_0025013 -->

    <owl:ObjectProperty rdf:about="https://w3id.org/pmd/co/PMD_0025013">
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:label xml:lang="en">changes quality</rdfs:label> <rdfs:label xml:lang="zh">改变特质</rdfs:label>
        <skos:definition xml:lang="en">indicates that a process changes a quality</skos:definition> <skos:definition xml:lang="zh">指示过程改变了一个特质</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pmd/co/PMD_0025998 -->

    <owl:ObjectProperty rdf:about="https://w3id.org/pmd/co/PMD_0025998">
        <owl:inverseOf rdf:resource="https://w3id.org/pmd/co/PMD_0025999"/>
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/BFO_0000004"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/BFO_0000145"/>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000051"/>
            <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0025998"/>
        </owl:propertyChainAxiom>
        <rdfs:label xml:lang="en">has relational quality</rdfs:label> <rdfs:label xml:lang="zh">具有关系特质</rdfs:label>
        <skos:definition xml:lang="en">a relation between an independent continuant (the bearer) and a relational quality, in which the quality specifically depends on the bearer for its existence</skos:definition> <skos:definition xml:lang="zh">一个独立持续存在物（承载者）与一种关系性质之间的关系，其中该性质专门依赖于承载者而存在。</skos:definition>
        <skos:example xml:lang="en">material has relational quality mass proportion m, and portion of iron has the same relational quality mass proportion m</skos:example> <skos:example xml:lang="zh">材料具有关系性质质量比例m，且铁的一部分具有相同的关系性质质量比例m。</skos:example>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pmd/co/PMD_0025999 -->

    <owl:ObjectProperty rdf:about="https://w3id.org/pmd/co/PMD_0025999">
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0025999"/>
            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000050"/>
        </owl:propertyChainAxiom>
        <obo:IAO_0000116 xml:lang="en">The 'relational quality of' is more strict that 'quality of' from RO, since domain is 'relational quality'. The motivtion to introduce an object property for relational qualities is the following:
RO's 'quality of' is functional i.e., a-&gt;b, a-&gt;c =&gt; b=c. The functionality is relevant for most of the SDC -&gt; IC triples, expect for relational qualities, which per definiton can be simultaneously inherited in &gt;=2 ICs. Thus,  'relational quality of'  has the same intention to connect SDC to IC, however, without cardinality constraints.</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">“关系性质 of”比RO中的“性质 of”更为严格，因为其定义域是“关系性质”。引入关系性质的对象属性的动机如下：RO的“性质 of”是函数性的，即a-&gt;b，a-&gt;c =&gt; b=c。该函数性对于大多数SDC到IC的三元组是相关的，但关系性质除外，根据定义，关系性质可以同时被两个或更多IC继承。因此，“关系性质 of”具有相同的意图将SDC连接到IC，但没有基数约束。</obo:IAO_0000116>
        <rdfs:label xml:lang="en">relational quality of</rdfs:label> <rdfs:label xml:lang="zh">关系性质 of</rdfs:label>
        <skos:definition xml:lang="en">a relation between a relational quality and an independent continuant (the bearer), in which the quality specifically depends on the bearer for its existence</skos:definition> <skos:definition xml:lang="zh">一种关系性质与一个独立持续存在物（承载者）之间的关系，其中该性质专门依赖于承载者而存在。</skos:definition>
        <skos:example xml:lang="en">mass proportion m is relational qualitiy of material, and the same mass proportion m is relational qualitiy of portion of iron</skos:example> <skos:example xml:lang="zh">质量比例m是材料的关系性质，且相同的质量比例m是铁的一部分的关系性质。</skos:example>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://purl.obolibrary.org/obo/OBI_0001937 -->

    <owl:DatatypeProperty rdf:about="http://purl.obolibrary.org/obo/OBI_0001937">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/OBI_0002135"/>
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/OBI_0001933"/>
        <obo:IAO_0000115 xml:lang="en">A relation between a value specification and a number that quantifies it.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">一个值规范与量化它的数字之间的关系。</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">A range of 'real' might be better than 'float'. For now we follow 'has measurement value' until we can consider technical issues with SPARQL queries and reasoning.</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">“实数”的范围可能比“浮点数”更好。目前我们遵循“has measurement value”，直到我们能够考虑SPARQL查询和推理的技术问题。</obo:IAO_0000116>
        <obo:IAO_0000119>OBI</obo:IAO_0000119>
        <rdfs:label xml:lang="en">has specified numeric value</rdfs:label> <rdfs:label xml:lang="zh">具有指定的数值</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://purl.obolibrary.org/obo/OBI_0002135 -->

    <owl:DatatypeProperty rdf:about="http://purl.obolibrary.org/obo/OBI_0002135">
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/OBI_0001933"/>
        <obo:IAO_0000115 xml:lang="en">A relation between a value specification and a literal.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">一个值规范与一个字面量之间的关系。</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">This is not an RDF/OWL object property. It is intended to link a value found in e.g. a database column of 'M' (the literal) to an instance of a value specification class, which can then be linked to indicate that this is about the biological gender of a human subject.</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">这不是RDF/OWL对象属性。它旨在将例如数据库列中的值'M'（字面量）链接到值规范类的实例，然后可以链接以指示这涉及人类受试者的生物学性别。</obo:IAO_0000116>
        <obo:IAO_0000119>OBI</obo:IAO_0000119>
        <rdfs:label xml:lang="en">has specified value</rdfs:label> <rdfs:label xml:lang="zh">具有指定的值</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.w3.org/2006/time#inXSDDateTime -->

    <owl:DatatypeProperty rdf:about="http://www.w3.org/2006/time#inXSDDateTime">
        <rdfs:label xml:lang="es">en fecha-tiempo XSD</rdfs:label> <rdfs:label xml:lang="zh">在XSD日期时间中</rdfs:label>
        <rdfs:label xml:lang="en">in XSD Date-Time</rdfs:label> <rdfs:label xml:lang="zh">在XSD日期时间中</rdfs:label>
        <skos:definition xml:lang="es">Posición de un instante, expresado utilizando xsd:dateTime.</skos:definition> <skos:definition xml:lang="zh">一个瞬间的位置，使用xsd:dateTime表示。</skos:definition>
        <skos:definition xml:lang="en">Position of an instant, expressed using xsd:dateTime</skos:definition> <skos:definition xml:lang="zh">一个瞬间的位置，使用xsd:dateTime表示。</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0001008 -->

    <owl:DatatypeProperty rdf:about="https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0001008">
        <rdfs:comment xml:lang="en">A relation between an information content entity and its specific url.</rdfs:comment>
        <rdfs:label xml:lang="en">has url</rdfs:label> <rdfs:label xml:lang="zh">具有url</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/pmd/co/PMD_0000006 -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/pmd/co/PMD_0000006">
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/IAO_0000030"/>
        <rdfs:label xml:lang="en">has value</rdfs:label> <rdfs:label xml:lang="zh">具有值</rdfs:label>
        <skos:definition xml:lang="en">data property that relates an information content entity to a literal</skos:definition> <skos:definition xml:lang="zh">将信息内容实体与字面量关联的数据属性</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/pmd/co/PMD_0001857 -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/pmd/co/PMD_0001857">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/pmd/co/PMD_0000006"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
        <rdfs:label xml:lang="en">has parameter position</rdfs:label> <rdfs:label xml:lang="zh">具有参数位置</rdfs:label>
        <skos:definition xml:lang="en">specifies the position of a parameter in a programming function</skos:definition> <skos:definition xml:lang="zh">指定编程函数中参数的位置</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/pmd/co/PMD_0001877 -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/pmd/co/PMD_0001877">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/pmd/co/PMD_0000006"/>
        <rdfs:label xml:lang="en">has default literal value</rdfs:label> <rdfs:label xml:lang="zh">具有默认字面量值</rdfs:label>
        <skos:definition xml:lang="en">specifies a default value</skos:definition> <skos:definition xml:lang="zh">指定默认值</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://purl.obolibrary.org/obo/BFO_0000001 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000001">
        <rdfs:label xml:lang="en">entity</rdfs:label> <rdfs:label xml:lang="zh">实体</rdfs:label>
        <skos:definition xml:lang="en">(Elucidation) An entity is anything that exists or has existed or will exist</skos:definition> <skos:definition xml:lang="zh">(阐述) 实体是任何存在、曾经存在或将要存在的事物。</skos:definition>
        <skos:example xml:lang="en">Julius Caesar; the Second World War; your body mass index; Verdi's Requiem</skos:example> <skos:example xml:lang="zh">Julius Caesar; the Second World War; 你的身体质量指数; Verdi's Requiem</skos:example>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000002 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000002">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000001"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:allValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000002"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="http://purl.obolibrary.org/obo/BFO_0000003"/>
        <owl:disjointWith>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000003"/>
            </owl:Restriction>
        </owl:disjointWith>
        <rdfs:label xml:lang="en">continuant</rdfs:label> <rdfs:label xml:lang="zh">持续体</rdfs:label>
        <skos:definition xml:lang="en">(Elucidation) A continuant is an entity that persists, endures, or continues to exist through time while maintaining its identity</skos:definition> <skos:definition xml:lang="zh">(Elucidation) 持续体是一种在一段时间内持续、耐久或继续存在并保持其身份的实体</skos:definition>
        <skos:example xml:lang="en">A human being; a tennis ball; a cave; a region of space; someone's temperature</skos:example> <skos:example xml:lang="zh">人类；网球；洞穴；空间区域；某人的温度</skos:example>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000003 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000003">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000001"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:allValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000003"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000002"/>
            </owl:Restriction>
        </owl:disjointWith>
        <rdfs:label xml:lang="en">occurrent</rdfs:label> <rdfs:label xml:lang="zh">发生体</rdfs:label>
        <skos:definition xml:lang="en">(Elucidation) An occurrent is an entity that unfolds itself in time or it is the start or end of such an entity or it is a temporal or spatiotemporal region</skos:definition> <skos:definition xml:lang="zh">(Elucidation) 发生体是一种在时间中展开自身的实体，或者是这种实体的开始或结束，或者是一个时间或时空区域</skos:definition>
        <skos:example xml:lang="en">As for process, history, process boundary, spatiotemporal region, zero-dimensional temporal region, one-dimensional temporal region, temporal interval, temporal instant.</skos:example> <skos:example xml:lang="zh">至于过程、历史、过程边界、时空区域、零维时间区域、一维时间区域、时间间隔、时间瞬间。</skos:example>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000004 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000004">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000002"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:allValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000004"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="http://purl.obolibrary.org/obo/BFO_0000020"/>
        <owl:disjointWith rdf:resource="http://purl.obolibrary.org/obo/BFO_0000031"/>
        <rdfs:label xml:lang="en">independent continuant</rdfs:label> <rdfs:label xml:lang="zh">独立持续体</rdfs:label>
        <skos:definition xml:lang="en">b is an independent continuant =Def b is a continuant &amp; there is no c such that b specifically depends on c or b generically depends on c</skos:definition> <skos:definition xml:lang="zh">b是独立持续体 =Def b是持续体 且 不存在c使得b特异依赖于c或b一般依赖于c</skos:definition>
        <skos:example xml:lang="en">An atom; a molecule; an organism; a heart; a chair; the bottom right portion of a human torso; a leg; the interior of your mouth; a spatial region; an orchestra</skos:example> <skos:example xml:lang="zh">原子；分子；生物体；心脏；椅子；人体躯干的右下部分；腿；口腔内部；空间区域；管弦乐队</skos:example>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000006 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000006">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000141"/>
        <rdfs:label xml:lang="en">spatial region</rdfs:label> <rdfs:label xml:lang="zh">空间区域</rdfs:label>
        <skos:definition xml:lang="en">(Elucidation) A spatial region is a continuant entity that is a continuant part of the spatial projection of a portion of spacetime at a given time</skos:definition> <skos:definition xml:lang="zh">(Elucidation) 空间区域是一种持续体实体，它是给定时间下一部分时空的空间投影的持续体部分</skos:definition>
        <skos:example xml:lang="en">As for zero-dimensional spatial region, one-dimensional spatial region, two-dimensional spatial region, three-dimensional spatial region</skos:example> <skos:example xml:lang="zh">至于零维空间区域、一维空间区域、二维空间区域、三维空间区域</skos:example>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000008 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000008">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000003"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000132"/>
                <owl:allValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000008"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000139"/>
                <owl:allValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000008"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">temporal region</rdfs:label> <rdfs:label xml:lang="zh">时间区域</rdfs:label>
        <skos:definition xml:lang="en">(Elucidation) A temporal region is an occurrent over which processes can unfold</skos:definition> <skos:definition xml:lang="zh">(Elucidation) 时间区域是一种发生体，过程可以在其上展开</skos:definition>
        <skos:example xml:lang="en">As for zero-dimensional temporal region and one-dimensional temporal region</skos:example> <skos:example xml:lang="zh">至于零维时间区域和一维时间区域</skos:example>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000009 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000009">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000006"/>
        <rdfs:label xml:lang="en">two-dimensional spatial region</rdfs:label> <rdfs:label xml:lang="zh">二维空间区域</rdfs:label>
        <skos:definition xml:lang="en">(Elucidation) A two-dimensional spatial region is a spatial region that is a whole consisting of a surface together with zero or more surfaces which may have spatial regions of lower dimension as parts</skos:definition> <skos:definition xml:lang="zh">(Elucidation) 二维空间区域是一种空间区域，它是一个由表面以及零个或多个表面组成的整体，这些表面可能具有更低维度的空间区域作为部分</skos:definition>
        <skos:example xml:lang="en">The surface of a sphere-shaped part of space; an infinitely thin plane in space</skos:example> <skos:example xml:lang="zh">空间球形部分的表面；空间中无限薄的平面</skos:example>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000011 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000011">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000003"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000132"/>
                <owl:allValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000011"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000139"/>
                <owl:allValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000011"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">spatiotemporal region</rdfs:label> <rdfs:label xml:lang="zh">时空区域</rdfs:label>
        <skos:definition xml:lang="en">(Elucidation) A spatiotemporal region is an occurrent that is an occurrent part of spacetime</skos:definition> <skos:definition xml:lang="zh">(Elucidation) 时空区域是一种发生体，它是时空的发生体部分</skos:definition>
        <skos:example xml:lang="en">The spatiotemporal region occupied by the development of a cancer tumour; the spatiotemporal region occupied by an orbiting satellite</skos:example> <skos:example xml:lang="zh">癌症肿瘤发展所占据的时空区域；轨道卫星所占据的时空区域</skos:example>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000015 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000015">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000003"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000117"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000015"/>
                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000035"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000132"/>
                <owl:allValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000139"/>
                <owl:allValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">process</rdfs:label> <rdfs:label xml:lang="zh">过程</rdfs:label>
        <skos:definition xml:lang="en">(Elucidation) p is a process means p is an occurrent that has some temporal proper part and for some time t, p has some material entity as participant</skos:definition> <skos:definition xml:lang="zh">(Elucidation) p是过程意味着p是一种发生体，它具有某个时间真部分，并且在某个时间t，p以某个物质实体作为参与者</skos:definition>
        <skos:example xml:lang="en">An act of selling; the life of an organism; a process of sleeping; a process of cell-division; a beating of the heart; a process of meiosis; the taxiing of an aircraft; the programming of a computer</skos:example> <skos:example xml:lang="zh">一次销售行为；生物体的生命；睡眠过程；细胞分裂过程；心脏搏动；减数分裂过程；飞机滑行；计算机编程</skos:example>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000016 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000016">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000017"/>
        <owl:disjointWith rdf:resource="http://purl.obolibrary.org/obo/BFO_0000023"/>
        <rdfs:label xml:lang="en">disposition</rdfs:label> <rdfs:label xml:lang="zh">倾向性</rdfs:label>
        <skos:definition xml:lang="en">(Elucidation) A disposition b is a realizable entity such that if b ceases to exist then its bearer is physically changed &amp; b's realization occurs when and because this bearer is in some special physical circumstances &amp; this realization occurs in virtue of the bearer's physical make-up</skos:definition> <skos:definition xml:lang="zh">(释义) 倾向性b是一种可实现实体，其特点为：若b停止存在，则其载体发生物理变化；b的实现发生于且因为该载体处于某些特殊物理环境；并且该实现依据载体的物理构成而发生。</skos:definition>
        <skos:example xml:lang="en">An atom of element X has the disposition to decay to an atom of element Y; the cell wall is disposed to transport cellular material through endocytosis and exocytosis; certain people have a predisposition to colon cancer; children are innately disposed to categorize objects in certain ways</skos:example> <skos:example xml:lang="zh">元素X的原子具有衰变为元素Y的原子的倾向性；细胞壁具有通过内吞和外排作用运输细胞物质的倾向性；某些人具有结肠癌的易感性；儿童天生具有以特定方式对物体进行分类的倾向性。</skos:example>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000017 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000017">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000020"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:allValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000017"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:label xml:lang="en">realizable entity</rdfs:label> <rdfs:label xml:lang="zh">可实现实体</rdfs:label>
        <skos:definition xml:lang="en">(Elucidation) A realizable entity is a specifically dependent continuant that inheres in some independent continuant which is not a spatial region &amp; which is of a type some instances of which are realized in processes of a correlated type</skos:definition> <skos:definition xml:lang="zh">(释义) 可实现实体是一种特定依赖连续体，它内在于某个非空间区域的独立连续体中，且其类型的一些实例在相关类型的过程中得以实现。</skos:definition>
        <skos:example xml:lang="en">The role of being a doctor; the role of this boundary to delineate where Utah and Colorado meet; the function of your reproductive organs; the disposition of your blood to coagulate; the disposition of this piece of metal to conduct electricity</skos:example> <skos:example xml:lang="zh">作为医生的角色；该边界界定犹他州和科罗拉多州交界处的角色；你生殖器官的功能；你血液凝固的倾向性；这块金属导电的倾向性。</skos:example>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000018 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000018">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000006"/>
        <rdfs:label xml:lang="en">zero-dimensional spatial region</rdfs:label> <rdfs:label xml:lang="zh">零维空间区域</rdfs:label>
        <skos:definition xml:lang="en">(Elucidation) A zero-dimensional spatial region is one or a collection of more than one spatially disjoint points in space</skos:definition> <skos:definition xml:lang="zh">(释义) 零维空间区域是一个或多个在空间上不相交的点的集合。</skos:definition>
        <skos:example xml:lang="en">The spatial region occupied at some time instant by the North Pole</skos:example> <skos:example xml:lang="zh">北极在某个时间瞬间所占有的空间区域。</skos:example>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000019 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000019">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000020"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:allValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">quality</rdfs:label> <rdfs:label xml:lang="zh">质量</rdfs:label>
        <skos:definition xml:lang="en">(Elucidation) A quality is a specifically dependent continuant that, in contrast to roles and dispositions, does not require any further process in order to be realized</skos:definition> <skos:definition xml:lang="zh">(释义) 质量是一种特定依赖连续体，与角色和倾向性不同，它不需要任何进一步的过程即可实现。</skos:definition>
        <skos:example xml:lang="en">The colour of a tomato; the ambient temperature of this portion of air; the length of the circumference of your waist; the shape of your nose; the shape of your nostril; the mass of this piece of gold</skos:example> <skos:example xml:lang="zh">西红柿的颜色；这部分空气的环境温度；你腰围的长度；你鼻子的形状；你鼻孔的形状；这块金子的质量。</skos:example>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000020 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000020">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000002"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:allValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000020"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="http://purl.obolibrary.org/obo/BFO_0000031"/>
        <rdfs:label xml:lang="en">specifically dependent continuant</rdfs:label> <rdfs:label xml:lang="zh">特定依赖连续体</rdfs:label>
        <skos:definition xml:lang="en">b is a specifically dependent continuant =Def b is a continuant &amp; there is some independent continuant c which is not a spatial region &amp; which is such that b specifically depends on c</skos:definition> <skos:definition xml:lang="zh">b是特定依赖连续体当且仅当b是连续体，并且存在某个独立连续体c，c不是空间区域，且b特定依赖于c。</skos:definition>
        <skos:example xml:lang="en">(with multiple bearers) John's love for Mary; the ownership relation between John and this statue; the relation of authority between John and his subordinates</skos:example> <skos:example xml:lang="zh">(具有多个载体) 约翰对玛丽的爱；约翰与这座雕像之间的所有权关系；约翰与其下属之间的权威关系。</skos:example>
        <skos:example xml:lang="en">(with one bearer) The mass of this tomato; the pink colour of a medium rare piece of grilled filet mignon at its centre; the smell of this portion of mozzarella; the disposition of this fish to decay; the role of being a doctor; the function of this heart to pump blood; the shape of this hole</skos:example> <skos:example xml:lang="zh">(具有单个载体) 这个番茄的质量；一块五分熟烤菲力牛排中心部位的粉红色；这部分马苏里拉奶酪的气味；这条鱼腐烂的倾向性；作为医生的角色；这个心脏泵血的功能；这个洞的形状。</skos:example>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000023 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000023">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000017"/>
        <rdfs:label xml:lang="en">role</rdfs:label> <rdfs:label xml:lang="zh">角色</rdfs:label>
        <skos:definition xml:lang="en">(Elucidation) A role b is a realizable entity such that b exists because there is some single bearer that is in some special physical, social, or institutional set of circumstances in which this bearer does not have to be &amp; b is not such that, if it ceases to exist, then the physical make-up of the bearer is thereby changed</skos:definition> <skos:definition xml:lang="zh">(释义) 角色b是一种可实现实体，其存在是因为存在某个单一载体处于某些特殊的物理、社会或制度环境中，而该载体并非必须处于这些环境中；并且b并不具有这样的性质：如果b停止存在，则载体的物理构成因此发生改变。</skos:definition>
        <skos:example xml:lang="en">The priest role; the student role; the role of subject in a clinical trial; the role of a stone in marking a property boundary; the role of a boundary to demarcate two neighbouring administrative territories; the role of a building in serving as a military target</skos:example> <skos:example xml:lang="zh">神父角色；学生角色；临床试验中受试者的角色；石头标记财产边界的角色；边界划分两个相邻行政区域的角色；建筑物作为军事目标的角色。</skos:example>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000024 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000024">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000040"/>
        <rdfs:label xml:lang="en">fiat object part</rdfs:label> <rdfs:label xml:lang="zh">任意对象部分</rdfs:label>
        <skos:definition xml:lang="en">(Elucidation) A fiat object part b is a material entity &amp; such that if b exists then it is continuant part of some object c &amp; demarcated from the remainder of c by one or more fiat surfaces</skos:definition> <skos:definition xml:lang="zh">(释义) 任意对象部分b是一种物质实体，其存在条件是：b是某个对象c的连续体部分，并且由一个或多个任意表面与c的其余部分分隔。</skos:definition>
        <skos:example xml:lang="en">The upper and lower lobes of the left lung; the dorsal and ventral surfaces of the body; the Western hemisphere of the Earth; the FMA:regional parts of an intact human body</skos:example> <skos:example xml:lang="zh">左肺的上叶和下叶；身体的背侧和腹侧表面；地球的西半球；FMA：完整人体的区域部分。</skos:example>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000026 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000026">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000006"/>
        <rdfs:label xml:lang="en">one-dimensional spatial region</rdfs:label> <rdfs:label xml:lang="zh">一维空间区域</rdfs:label>
        <skos:definition xml:lang="en">(Elucidation) A one-dimensional spatial region is a whole consisting of a line together with zero or more lines which may have points as parts</skos:definition> <skos:definition xml:lang="zh">(释义) 一维空间区域是一个整体，由一条线以及零条或多条线组成，这些线可能以点为部分。</skos:definition>
        <skos:example xml:lang="en">An edge of a cube-shaped portion of space; a line connecting two points; two parallel lines extended in space</skos:example> <skos:example xml:lang="zh">立方体形状空间区域的一条边；连接两点的直线；空间中延伸的两条平行线。</skos:example>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000027 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000027">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000040"/>
        <rdfs:label xml:lang="en">object aggregate</rdfs:label> <rdfs:label xml:lang="zh">对象聚合</rdfs:label>
        <skos:definition xml:lang="en">(Elucidation) An object aggregate is a material entity consisting exactly of a plurality (≥1) of objects as member parts which together form a unit</skos:definition> <skos:definition xml:lang="zh">(阐明) 对象聚合是一种物质实体，由恰好多个（≥1）作为成员部分的对象组成，这些对象共同形成一个单元。</skos:definition>
        <skos:example xml:lang="en">The aggregate of the musicians in a symphony orchestra and their instruments; the aggregate of bearings in a constant velocity axle joint; the nitrogen atoms in the atmosphere; a collection of cells in a blood biobank</skos:example> <skos:example xml:lang="zh">交响乐团中音乐家及其乐器的聚合；等速万向节中轴承的聚合；大气中的氮原子；血液生物样本库中的细胞集合。</skos:example>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000028 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000028">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000006"/>
        <rdfs:label xml:lang="en">three-dimensional spatial region</rdfs:label> <rdfs:label xml:lang="zh">三维空间区域</rdfs:label>
        <skos:definition xml:lang="en">(Elucidation) A three-dimensional spatial region is a whole consisting of a spatial volume together with zero or more spatial volumes which may have spatial regions of lower dimension as parts</skos:definition> <skos:definition xml:lang="zh">(阐明) 三维空间区域是一个整体，由一个空间体积以及零个或多个空间体积组成，这些空间体积可能具有更低维度的空间区域作为部分。</skos:definition>
        <skos:example xml:lang="en">A cube-shaped region of space; a sphere-shaped region of space; the region of space occupied by all and only the planets in the solar system at some point in time</skos:example> <skos:example xml:lang="zh">一个立方体形状的空间区域；一个球体形状的空间区域；在某一时间点由太阳系中所有且仅有行星占据的空间区域。</skos:example>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000029 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000029">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000141"/>
        <rdfs:label xml:lang="en">site</rdfs:label> <rdfs:label xml:lang="zh">位点</rdfs:label>
        <skos:definition xml:lang="en">(Elucidation) A site is a three-dimensional immaterial entity whose boundaries either (partially or wholly) coincide with the boundaries of one or more material entities or have locations determined in relation to some material entity</skos:definition> <skos:definition xml:lang="zh">(阐明) 位点是一个三维的非物质实体，其边界与一个或多个物质实体的边界（部分或全部）重合，或者其位置相对于某个物质实体确定。</skos:definition>
        <skos:example xml:lang="en">A hole in a portion of cheese; a rabbit hole; the Grand Canyon; the Piazza San Marco; the kangaroo-joey-containing hole of a kangaroo pouch; your left nostril (a fiat part - the opening - of your left nasal cavity); the lumen of your gut; the hold of a ship; the interior of the trunk of your car; hole in an engineered floor joist</skos:example> <skos:example xml:lang="zh">一块奶酪中的洞；兔子洞；Grand Canyon；Piazza San Marco；袋鼠育儿袋中装有幼袋鼠的洞；你的左鼻孔（左鼻腔的一个独立部分——开口）；肠腔；船舱；汽车后备箱内部；工程地板托梁上的洞。</skos:example>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000030 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000030">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000040"/>
        <rdfs:label xml:lang="en">object</rdfs:label> <rdfs:label xml:lang="zh">对象</rdfs:label>
        <skos:definition xml:lang="en">(Elucidation) An object is a material entity which manifests causal unity &amp; is of a type instances of which are maximal relative to the sort of causal unity manifested</skos:definition> <skos:definition xml:lang="zh">(阐明) 对象是一种物质实体，表现出因果统一性，并且其类型实例相对于所表现的因果统一性种类是最大的。</skos:definition>
        <skos:example xml:lang="en">An organism; a fish tank; a planet; a laptop; a valve; a block of marble; an ice cube</skos:example> <skos:example xml:lang="zh">一个生物体；一个鱼缸；一颗行星；一台笔记本电脑；一个阀门；一块大理石；一个冰块。</skos:example>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000031 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000031">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000002"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:allValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000031"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">generically dependent continuant</rdfs:label> <rdfs:label xml:lang="zh">泛型依赖持续体</rdfs:label>
        <skos:definition xml:lang="en">(Elucidation) A generically dependent continuant is an entity that exists in virtue of the fact that there is at least one of what may be multiple copies which is the content or the pattern that multiple copies would share</skos:definition> <skos:definition xml:lang="zh">(阐明) 泛型依赖持续体是一种实体，其存在基于这样一个事实：至少存在一个可能是多个副本的内容或模式，这些副本将共享该内容或模式。</skos:definition>
        <skos:example xml:lang="en">The pdf file on your laptop; the pdf file that is a copy thereof on my laptop; the sequence of this protein molecule; the sequence that is a copy thereof in that protein molecule; the content that is shared by a string of dots and dashes written on a page and the transmitted Morse code signal; the content of a sentence; an engineering blueprint</skos:example> <skos:example xml:lang="zh">你笔记本电脑上的PDF文件；我笔记本电脑上该PDF文件的副本；该蛋白质分子的序列；该蛋白质分子中该序列的副本；一页纸上书写的一串点划与传输的Morse代码信号共享的内容；一个句子的内容；一份工程蓝图。</skos:example>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000034 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000034">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000016"/>
        <rdfs:label xml:lang="en">function</rdfs:label> <rdfs:label xml:lang="zh">功能</rdfs:label>
        <skos:definition xml:lang="en">(Elucidation) A function is a disposition that exists in virtue of its bearer's physical make-up &amp; this physical make-up is something the bearer possesses because it came into being either through evolution (in the case of natural biological entities) or through intentional design (in the case of artefacts) in order to realize processes of a certain sort</skos:definition> <skos:definition xml:lang="zh">(阐明) 功能是一种倾向，其存在依赖于其承载者的物理构成，并且该物理构成是承载者由于通过进化（对于自然生物实体）或有意图的设计（对于人工制品）而具有的，以实现某种过程。</skos:definition>
        <skos:example xml:lang="en">The function of a hammer to drive in nails; the function of a heart pacemaker to regulate the beating of a heart through electricity</skos:example> <skos:example xml:lang="zh">锤子用来钉钉子的功能；心脏起搏器通过电调节心跳的功能。</skos:example>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000035 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000035">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000003"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000117"/>
                <owl:allValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000035"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000121"/>
                <owl:allValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000035"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000132"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000015"/>
                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000035"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000139"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000015"/>
                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000035"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">process boundary</rdfs:label> <rdfs:label xml:lang="zh">过程边界</rdfs:label>
        <skos:definition xml:lang="en">p is a process boundary =Def p is a temporal part of a process &amp; p has no proper temporal parts</skos:definition> <skos:definition xml:lang="zh">p 是一个过程边界，定义为 p 是一个过程的时间部分，并且 p 没有适当的时间部分。</skos:definition>
        <skos:example xml:lang="en">The boundary between the 2nd and 3rd year of your life</skos:example> <skos:example xml:lang="zh">你生命中第二年和第三年之间的边界。</skos:example>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000038 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000038">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000008"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000121"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000038"/>
                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000148"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000139"/>
                <owl:allValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000038"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="http://purl.obolibrary.org/obo/BFO_0000148"/>
        <rdfs:label xml:lang="en">one-dimensional temporal region</rdfs:label> <rdfs:label xml:lang="zh">一维时间区域</rdfs:label>
        <skos:definition xml:lang="en">(Elucidation) A one-dimensional temporal region is a temporal region that is a whole that has a temporal interval and zero or more temporal intervals and temporal instants as parts</skos:definition> <skos:definition xml:lang="zh">(阐明) 一维时间区域是一种时间区域，它是一个整体，具有一个时间间隔以及零个或多个时间间隔和时间瞬间作为部分。</skos:definition>
        <skos:example xml:lang="en">The temporal region during which a process occurs</skos:example> <skos:example xml:lang="zh">一个过程发生的时间区域。</skos:example>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000040 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000040">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000004"/>
        <owl:disjointWith rdf:resource="http://purl.obolibrary.org/obo/BFO_0000141"/>
        <obo:IAO_0000115 xml:lang="en">An independent continuant that is spatially extended whose identity is independent of that of other entities and can be maintained through time.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">一个在空间上延展的独立持续体，其身份独立于其他实体，并能随时间维持。</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Elucidation: An independent continuant that is spatially extended whose identity is independent of that of other entities and can be maintained through time.</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">阐述：一种独立连续体，空间上扩展，其身份独立于其他实体，且能随时间维持。</obo:IAO_0000116>
        <rdfs:label xml:lang="en">material entity</rdfs:label> <rdfs:label xml:lang="zh">物质实体</rdfs:label>
        <skos:definition xml:lang="en">(Elucidation) A material entity is an independent continuant has some portion of matter as continuant part</skos:definition> <skos:definition xml:lang="zh">(阐述) 物质实体是一种独立连续体，具有某部分物质作为连续体部分。</skos:definition>
        <skos:example xml:lang="en">A human being; the undetached arm of a human being; an aggregate of human beings</skos:example> <skos:example xml:lang="zh">一个人；一个人的未分离的手臂；一群人的集合。</skos:example>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000140 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000140">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000141"/>
        <rdfs:label xml:lang="en">continuant fiat boundary</rdfs:label> <rdfs:label xml:lang="zh">连续体虚边界</rdfs:label>
        <skos:definition xml:lang="en">(Elucidation) A continuant fiat boundary b is an immaterial entity that is of zero, one or two dimensions &amp; such that there is no time t when b has a spatial region as continuant part &amp; whose location is determined in relation to some material entity</skos:definition> <skos:definition xml:lang="zh">(阐述) 连续体虚边界b是一种非物质实体，维度为0、1或2，且不存在时间t使得b具有空间区域作为连续体部分，其位置由某些物质实体决定。</skos:definition>
        <skos:example xml:lang="en">As for fiat point, fiat line, fiat surface</skos:example> <skos:example xml:lang="zh">至于虚点、虚线、虚面。</skos:example>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000141 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000141">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000004"/>
        <rdfs:label xml:lang="en">immaterial entity</rdfs:label> <rdfs:label xml:lang="zh">非物质实体</rdfs:label>
        <skos:definition xml:lang="en">b is an immaterial entity =Def b is an independent continuant which is such that there is no time t when it has a material entity as continuant part</skos:definition> <skos:definition xml:lang="zh">b是一种非物质实体 =定义 b是一种独立连续体，使得不存在时间t使得它具有一个物质实体作为连续体部分。</skos:definition>
        <skos:example xml:lang="en">As for fiat point, fiat line, fiat surface, site</skos:example> <skos:example xml:lang="zh">至于虚点、虚线、虚面、位置。</skos:example>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000142 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000142">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000140"/>
        <rdfs:label xml:lang="en">fiat line</rdfs:label> <rdfs:label xml:lang="zh">虚线</rdfs:label>
        <skos:definition xml:lang="en">(Elucidation) A fiat line is a one-dimensional continuant fiat boundary that is continuous</skos:definition> <skos:definition xml:lang="zh">(阐述) 虚线是一维连续体虚边界，是连续的。</skos:definition>
        <skos:example xml:lang="en">The Equator; all geopolitical boundaries; all lines of latitude and longitude; the median sulcus of your tongue; the line separating the outer surface of the mucosa of the lower lip from the outer surface of the skin of the chin</skos:example> <skos:example xml:lang="zh">赤道；所有地理政治边界；所有纬线和经线；舌正中沟；下唇黏膜外表面与下巴皮肤外表面的分界线。</skos:example>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000145 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000145">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:label xml:lang="en">relational quality</rdfs:label> <rdfs:label xml:lang="zh">关系性质</rdfs:label>
        <skos:definition xml:lang="en">b is a relational quality =Def b is a quality &amp; there exists c and d such that c and d are not identical &amp; b specifically depends on c &amp; b specifically depends on d</skos:definition> <skos:definition xml:lang="zh">b是一种关系性质 =定义 b是一种性质，且存在c和d，c和d不相同，且b特异地依赖于c，b特异地依赖于d。</skos:definition>
        <skos:example xml:lang="en">A marriage bond; an instance of love; an obligation between one person and another</skos:example> <skos:example xml:lang="zh">婚姻纽带；爱的实例；一个人与另一个人之间的义务。</skos:example>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000146 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000146">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000140"/>
        <rdfs:label xml:lang="en">fiat surface</rdfs:label> <rdfs:label xml:lang="zh">虚面</rdfs:label>
        <skos:definition xml:lang="en">(Elucidation) A fiat surface is a two-dimensional continuant fiat boundary that is self-connected</skos:definition> <skos:definition xml:lang="zh">(阐述) 虚面是二维连续体虚边界，是自连接的。</skos:definition>
        <skos:example xml:lang="en">The surface of the Earth; the plane separating the smoking from the non-smoking zone in a restaurant</skos:example> <skos:example xml:lang="zh">地球表面；餐厅中分隔吸烟区和非吸烟区的平面。</skos:example>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000147 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000147">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000140"/>
        <rdfs:label xml:lang="en">fiat point</rdfs:label> <rdfs:label xml:lang="zh">虚点</rdfs:label>
        <skos:definition xml:lang="en">(Elucidation) A fiat point is a zero-dimensional continuant fiat boundary that consists of a single point</skos:definition> <skos:definition xml:lang="zh">(阐述) 虚点是零维连续体虚边界，包含单个点。</skos:definition>
        <skos:example xml:lang="en">The geographic North Pole; the quadripoint where the boundaries of Colorado, Utah, New Mexico and Arizona meet; the point of origin of some spatial coordinate system</skos:example> <skos:example xml:lang="zh">地理北极；科罗拉多、犹他、新墨西哥和亚利桑那州边界交汇的四界点；某个空间坐标系的原点。</skos:example>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000148 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000148">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000008"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000121"/>
                <owl:allValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000148"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">zero-dimensional temporal region</rdfs:label> <rdfs:label xml:lang="zh">零维时间区域</rdfs:label>
        <skos:definition xml:lang="en">(Elucidation) A zero-dimensional temporal region is a temporal region that is a whole consisting of one or more separated temporal instants as parts</skos:definition> <skos:definition xml:lang="zh">(阐述) 零维时间区域是一个时间区域，作为整体由若干个分离的时间瞬间作为部分构成。</skos:definition>
        <skos:example xml:lang="en">A temporal region that is occupied by a process boundary; the moment at which a finger is detached in an industrial accident</skos:example> <skos:example xml:lang="zh">被过程边界占据的时间区域；工业事故中断指的时刻。</skos:example>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000182 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000182">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:label xml:lang="en">history</rdfs:label> <rdfs:label xml:lang="zh">历史</rdfs:label>
        <skos:definition xml:lang="en">(Elucidation) A history is a process that is the sum of the totality of processes taking place in the spatiotemporal region occupied by the material part of a material entity</skos:definition> <skos:definition xml:lang="zh">(阐述) 历史是一个过程，它是发生在物质实体的物质部分所占据的时空区域中的所有过程的总和</skos:definition>
        <skos:example xml:lang="en">The life of an organism from the beginning to the end of its existence</skos:example> <skos:example xml:lang="zh">生物从存在开始到结束的生命</skos:example>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000202 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000202">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000038"/>
        <rdfs:label xml:lang="en">temporal interval</rdfs:label> <rdfs:label xml:lang="zh">时间间隔</rdfs:label>
        <skos:definition xml:lang="en">(Elucidation) A temporal interval is a one-dimensional temporal region that is continuous, thus without gaps or breaks</skos:definition> <skos:definition xml:lang="zh">(阐述) 时间间隔是一维的、连续的时间区域，没有间隙或中断</skos:definition>
        <skos:example xml:lang="en">The year 2018.</skos:example> <skos:example xml:lang="zh">2018年</skos:example>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000203 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000203">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000148"/>
        <rdfs:label xml:lang="en">temporal instant</rdfs:label> <rdfs:label xml:lang="zh">时间瞬时</rdfs:label>
        <skos:definition xml:lang="en">(Elucidation) A temporal instant is a zero-dimensional temporal region that has no proper temporal part</skos:definition> <skos:definition xml:lang="zh">(阐述) 时间瞬时是零维的时间区域，没有符合的时间部分</skos:definition>
        <skos:example xml:lang="en">The millennium</skos:example> <skos:example xml:lang="zh">千年</skos:example>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/CHEBI_137980 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CHEBI_137980">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CHEBI_33250"/>
        <obo:IAO_0000115 xml:lang="en">An atom of an element that exhibits properties that are between those of metals and nonmetals, or that has a mixture of them. The term generally includes boron, silicon, germanium, arsenic, antimony, and tellurium, while carbon, aluminium, selenium, polonium, and astatine are less commonly included.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">一种元素的原子，其性质介于金属和非金属之间，或兼有两者。该术语通常包括硼、硅、锗、砷、锑、碲，而碳、铝、硒、钋、砹较少被包括。</obo:IAO_0000115>
        <rdfs:label xml:lang="en">metalloid atom</rdfs:label> <rdfs:label xml:lang="zh">类金属原子</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/CHEBI_17051 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CHEBI_17051">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CHEBI_23367"/>
        <rdfs:label xml:lang="en">fluoride</rdfs:label> <rdfs:label xml:lang="zh">氟化物</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/CHEBI_18248 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CHEBI_18248">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CHEBI_33521"/>
        <obo:IAO_0000115 xml:lang="en">An iron group element atom that has atomic number 26.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">原子序数为26的铁族元素原子</obo:IAO_0000115>
        <rdfs:label xml:lang="en">iron atom</rdfs:label> <rdfs:label xml:lang="zh">铁原子</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/CHEBI_18291 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CHEBI_18291">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CHEBI_33521"/>
        <rdfs:label xml:lang="en">manganese atom</rdfs:label> <rdfs:label xml:lang="zh">锰原子</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/CHEBI_194531 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CHEBI_194531">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CHEBI_33521"/>
        <obo:IAO_0000115 xml:lang="en">A carbon group element atom with a symbol Fl and atomic number 114.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">符号为Fl、原子序数为114的碳族元素原子</obo:IAO_0000115>
        <rdfs:label xml:lang="en">flerovium atom</rdfs:label> <rdfs:label xml:lang="zh">𫓧原子</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/CHEBI_194533 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CHEBI_194533">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CHEBI_33521"/>
        <obo:IAO_0000115 xml:lang="en">A boron group element atom with a symbol Nh and atomic number 113.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">符号为Nh、原子序数为113的硼族元素原子</obo:IAO_0000115>
        <rdfs:label xml:lang="en">nihonium atom</rdfs:label> <rdfs:label xml:lang="zh">鉨原子</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/CHEBI_194535 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CHEBI_194535">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CHEBI_33521"/>
        <obo:IAO_0000115 xml:lang="en">A pnictogen atom with a symbol Mc and atomic number 115.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">符号为Mc、原子序数为115的氮族元素原子</obo:IAO_0000115>
        <rdfs:label xml:lang="en">moscovium atom</rdfs:label> <rdfs:label xml:lang="zh">镆原子</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/CHEBI_194537 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CHEBI_194537">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CHEBI_33303"/>
        <obo:IAO_0000115 xml:lang="en">A chalcogen atom with a symbol Lv and atomic number 116.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">符号为Lv、原子序数为116的氧族元素原子</obo:IAO_0000115>
        <rdfs:label xml:lang="en">livermorium atom</rdfs:label> <rdfs:label xml:lang="zh">𫟷原子</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/CHEBI_194539 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CHEBI_194539">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CHEBI_25585"/>
        <obo:IAO_0000115 xml:lang="en">A halogen atom with a symbol Ts and atomic number 117.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">符号为Ts、原子序数为117的卤素原子</obo:IAO_0000115>
        <rdfs:label xml:lang="en">tennessine atom</rdfs:label> <rdfs:label xml:lang="zh">𫟶原子</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/CHEBI_194541 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CHEBI_194541">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CHEBI_23367"/>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CHEBI_25585"/>
        <obo:IAO_0000115 xml:lang="en">A p-block element atom with a symbol Og and atomic number 118.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">符号为Og、原子序数为118的p区元素原子。</obo:IAO_0000115>
        <rdfs:label xml:lang="en">oganesson atom</rdfs:label> <rdfs:label xml:lang="zh">气奥原子</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/CHEBI_22927 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CHEBI_22927">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CHEBI_25585"/>
        <rdfs:label xml:lang="en">bromine atom</rdfs:label> <rdfs:label xml:lang="zh">溴原子</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/CHEBI_22977 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CHEBI_22977">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CHEBI_33521"/>
        <rdfs:label xml:lang="en">cadmium atom</rdfs:label> <rdfs:label xml:lang="zh">镉原子</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/CHEBI_22984 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CHEBI_22984">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CHEBI_33521"/>
        <rdfs:label xml:lang="en">calcium atom</rdfs:label> <rdfs:label xml:lang="zh">钙原子</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/CHEBI_23116 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CHEBI_23116">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CHEBI_25585"/>
        <rdfs:label xml:lang="en">chlorine atom</rdfs:label> <rdfs:label xml:lang="zh">氯原子</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/CHEBI_23367 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CHEBI_23367">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CHEBI_24431"/>
        <obo:IAO_0000115 xml:lang="en">Any constitutionally or isotopically distinct atom, molecule, ion, ion pair, radical, radical ion, complex, conformer etc., identifiable as a separately distinguishable entity.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">任何在结构上或同位素上不同的原子、分子、离子、离子对、自由基、自由基离子、络合物、构象异构体等，可识别为可单独区分的实体。</obo:IAO_0000115>
        <rdfs:label xml:lang="en">molecular entity</rdfs:label> <rdfs:label xml:lang="zh">分子实体</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/CHEBI_24061 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CHEBI_24061">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CHEBI_25585"/>
        <rdfs:label xml:lang="en">fluorine atom</rdfs:label> <rdfs:label xml:lang="zh">氟原子</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/CHEBI_24431 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CHEBI_24431">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000040"/>
        <obo:IAO_0000115 xml:lang="en">A chemical entity is a physical entity of interest in chemistry including molecular entities, parts thereof, and chemical substances.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">化学实体是化学中感兴趣的物理实体，包括分子实体、其部分以及化学物质。</obo:IAO_0000115>
        <rdfs:label xml:lang="en">chemical entity</rdfs:label> <rdfs:label xml:lang="zh">化学实体</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/CHEBI_24433 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CHEBI_24433">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CHEBI_24431"/>
        <obo:IAO_0000115 xml:lang="en">A defined linked collection of atoms or a single atom within a molecular entity.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">分子实体中定义的原子集合或单个原子。</obo:IAO_0000115>
        <rdfs:label xml:lang="en">group</rdfs:label> <rdfs:label xml:lang="zh">基团</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/CHEBI_24859 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CHEBI_24859">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CHEBI_25585"/>
        <obo:IAO_0000115 xml:lang="en">Chemical element with atomic number 53.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">原子序数为53的化学元素。</obo:IAO_0000115>
        <rdfs:label xml:lang="en">iodine atom</rdfs:label> <rdfs:label xml:lang="zh">碘原子</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/CHEBI_25016 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CHEBI_25016">
