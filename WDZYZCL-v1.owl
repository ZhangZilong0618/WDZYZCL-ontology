                                    </owl:Restriction>
                                </owl:intersectionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">non-oxide composite</rdfs:label> <rdfs:label xml:lang="zh">非氧化物复合材料</rdfs:label>
        <skos:definition xml:lang="en">ceramic matrix composite that consists of non-oxide ceramic phases (typically carbides, nitrides, or borides) for both the matrix and the reinforcement</skos:definition> <skos:definition xml:lang="zh">由非氧化物陶瓷相（通常是碳化物、氮化物或硼化物）组成的陶瓷基复合材料，基体和增强体均为非氧化物</skos:definition>
        <skos:example xml:lang="en">Silicon Carbide (SiC) Matrix Composite; Carbon-Carbon (C/C) Composite</skos:example> <skos:example xml:lang="zh">碳化硅(SiC)基复合材料; 碳-碳(C/C)复合材料</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050079 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050079">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050078"/>
        <rdfs:label xml:lang="en">silicon carbide matrix composite</rdfs:label> <rdfs:label xml:lang="zh">碳化硅基复合材料</rdfs:label>
        <skos:definition xml:lang="en">non-oxide composite that is built with silicon carbide as the primary matrix reinforced by other ceramic phases</skos:definition> <skos:definition xml:lang="zh">以碳化硅为主要基体，其他陶瓷相增强的非氧化物复合材料</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050080 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050080">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050078"/>
        <rdfs:label xml:lang="en">carbon-silicon carbide composite</rdfs:label> <rdfs:label xml:lang="zh">碳-碳化硅复合材料</rdfs:label>
        <skos:definition xml:lang="en">non-oxide composite that consists of a carbon matrix reinforced with silicon carbide, enhancing high-temperature performance</skos:definition> <skos:definition xml:lang="zh">由碳基体被碳化硅增强的非氧化物复合材料，提高高温性能</skos:definition>
    </owl:Class>
    


