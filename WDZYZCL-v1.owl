                                    </owl:Restriction>
                                </owl:intersectionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">polymer matrix composite</rdfs:label> <rdfs:label xml:lang="zh">聚合物基复合材料</rdfs:label>
        <skos:definition xml:lang="en">composite consisting of a polymer matrix and one or more reinforcement materials</skos:definition> <skos:definition xml:lang="zh">由聚合物基体与一种或多种增强材料组成的复合材料</skos:definition>
        <PMD_0050117>PMC</PMD_0050117>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000122 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000122">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000023"/>
        <rdfs:label xml:lang="en">laminate ply role</rdfs:label> <rdfs:label xml:lang="zh">层压铺层角色</rdfs:label>
        <skos:definition xml:lang="en">a single two-dimensional sheet that provides a specific high-strength orientation within a multi-layered stack</skos:definition> <skos:definition xml:lang="zh">单个二维片材，在多层堆叠中提供特定的高强度方向</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000123 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000123">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000300"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/pmd/co/PMD_0000006"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">doc string</rdfs:label> <rdfs:label xml:lang="zh">文档字符串</rdfs:label>
        <skos:definition xml:lang="en">A docstring is a textual entity that describes an associated section of some source code</skos:definition> <skos:definition xml:lang="zh">文档字符串是描述某些源代码相关部分的文本实体</skos:definition>
        <PMD_0001032>https://github.com/materialdigital/core-ontology/issues/270</PMD_0001032>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000124 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000124">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000023"/>
        <rdfs:label xml:lang="en">sandwich sheet</rdfs:label> <rdfs:label xml:lang="zh">夹芯面板</rdfs:label>
        <rdfs:label xml:lang="en">sandwich sheet role</rdfs:label> <rdfs:label xml:lang="zh">夹芯面板角色</rdfs:label>
        <skos:definition xml:lang="en">a stiff, strong material that carries bending loads through tensile and compressive stresses when integrated into a panel assembly</skos:definition> <skos:definition xml:lang="zh">一种坚硬、坚固的材料，当集成到面板组件中时，通过拉伸和压缩应力承受弯曲载荷</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000125 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000125">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000023"/>
        <rdfs:label xml:lang="en">sandwich core</rdfs:label> <rdfs:label xml:lang="zh">夹芯芯层</rdfs:label>
        <rdfs:label xml:lang="en">sandwich core role</rdfs:label> <rdfs:label xml:lang="zh">夹芯芯层角色</rdfs:label>
        <skos:definition xml:lang="en">a lightweight, low-density material that maintains the separation of face sheets and withstands transverse shear stresses</skos:definition> <skos:definition xml:lang="zh">一种轻质低密度材料，保持面板分离并承受横向剪切应力</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000127 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000127">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000000"/>
        <rdfs:label xml:lang="en">mineral</rdfs:label> <rdfs:label xml:lang="zh">矿物</rdfs:label>
        <skos:definition xml:lang="en">A mineral is a naturally occurring material characterized by a defined chemical composition and a specific crystal structure, formed through natural geological or biological processes.</skos:definition> <skos:definition xml:lang="zh">矿物是天然存在的材料，具有确定的化学成分和特定的晶体结构，通过自然地质或生物过程形成。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000501 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000501">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000027"/>
        <rdfs:label xml:lang="en">1D</rdfs:label> <rdfs:label xml:lang="zh">一维</rdfs:label>
        <skos:definition xml:lang="en">1D is a data item representing a one-dimensional structure or model representing a single linear dimension, often used in material science simulations or analysis.</skos:definition> <skos:definition xml:lang="zh">1D是表示一维结构或模型的数据项，代表单一线性维度，常用于材料科学模拟或分析。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000502 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000502">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000027"/>
        <rdfs:label xml:lang="en">2D</rdfs:label> <rdfs:label xml:lang="zh">二维</rdfs:label>
        <skos:definition xml:lang="en">A two-dimensional data item is a representation or analysis, commonly applied in studying planar material properties or surface phenomena.</skos:definition> <skos:definition xml:lang="zh">二维数据项是一种表示或分析，通常应用于研究平面材料特性或表面现象。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000503 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000503">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020243"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000417"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/IAO_0000109"/>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000312"/>
                                <owl:someValuesFrom>
                                    <owl:Class>
                                        <owl:intersectionOf rdf:parseType="Collection">
                                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000015"/>
                                            <owl:Restriction>
                                                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/STATO_0000102"/>
                                                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/IAO_0000104"/>
                                            </owl:Restriction>
                                        </owl:intersectionOf>
                                    </owl:Class>
                                </owl:someValuesFrom>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000116 xml:lang="en">TODO: axiom needs refinement</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">TODO: 公理需要细化</obo:IAO_0000116>
        <rdfs:label xml:lang="en">ASTM grainsize</rdfs:label> <rdfs:label xml:lang="zh">ASTM晶粒度</rdfs:label>
        <skos:definition xml:lang="en">The ASTM grain size is a quality that is measured through a process that follows the ASTM standard.</skos:definition> <skos:definition xml:lang="zh">ASTM晶粒度是一种通过遵循ASTM标准的过程测量的品质。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000504 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000504">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000933"/>
        <rdfs:label xml:lang="de">Ab Initio MD Simulation</rdfs:label> <rdfs:label xml:lang="zh">从头算分子动力学模拟</rdfs:label>
        <rdfs:label xml:lang="en">ab initio molecular dynamics simulation</rdfs:label> <rdfs:label xml:lang="zh">从头算分子动力学模拟</rdfs:label>
        <skos:definition xml:lang="en">A simulation process that uses quantum mechanical calculations to predict the behavior of molecular systems without empirical parameters.</skos:definition> <skos:definition xml:lang="zh">一种使用量子力学计算来预测分子系统行为而无经验参数的模拟过程。</skos:definition>
        <skos:definition xml:lang="de">Ein Simulationsprozess, der quantenmechanische Berechnungen verwendet, um das Verhalten molekularer Systeme ohne empirische Parameter vorherzusagen.</skos:definition> <skos:definition xml:lang="zh">一种使用量子力学计算来预测分子系统行为而无经验参数的模拟过程。</skos:definition>
        <skos:example xml:lang="en">Simulating the electronic structure and dynamics of a new alloy to predict its mechanical properties.</skos:example> <skos:example xml:lang="zh">模拟新合金的电子结构和动力学以预测其力学性能。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000505 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000505">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000506"/>
        <rdfs:label xml:lang="en">acoustic absorption coefficient</rdfs:label> <rdfs:label xml:lang="zh">声吸收系数</rdfs:label>
        <skos:definition xml:lang="en">The acoustic absorption coefficient is an acoustic property representing a measure of how much sound energy is absorbed by a material per unit area.</skos:definition> <skos:definition xml:lang="zh">声吸收系数是一种声学特性，表示单位面积材料吸收声能量的度量。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000506 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000506">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000005"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000517"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">acoustic property</rdfs:label> <rdfs:label xml:lang="zh">声学特性</rdfs:label>
        <skos:definition xml:lang="en">An acoustic property is a material property representing characteristics of a material that determine its interaction with sound waves, such as absorption, reflection, and transmission.</skos:definition> <skos:definition xml:lang="zh">声学特性是一种材料特性，表示材料决定其与声波相互作用的特性，如吸收、反射和透射。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000507 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000507">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBI_0000070"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0009006"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000506"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="de">Akustische Eigenschaften Analyseverfahren</rdfs:label> <rdfs:label xml:lang="zh">声学特性分析方法</rdfs:label>
        <rdfs:label xml:lang="en">acoustical property analyzing process</rdfs:label> <rdfs:label xml:lang="zh">声学特性分析过程</rdfs:label>
        <skos:definition xml:lang="en">An assay, that measures the acoustic properties of materials by analyzing how sound waves interact with the material. This process involves generating sound waves and observing their reflection, transmission, absorption, or scattering to determine properties such as acoustic impedance, absorption coefficient, and sound speed.</skos:definition> <skos:definition xml:lang="zh">一种通过分析声波与材料相互作用来测量材料声学特性的分析方法。该过程涉及产生声波并观察其反射、透射、吸收或散射，以确定声阻抗、吸收系数和声速等特性。</skos:definition>
        <skos:definition xml:lang="de">Eine Analyse, die die akustischen Eigenschaften von Materialien misst, indem es analysiert, wie Schallwellen mit dem Material interagieren. Dieser Prozess umfasst die Erzeugung von Schallwellen und die Beobachtung ihrer Reflexion, Übertragung, Absorption oder Streuung, um Eigenschaften wie akustische Impedanz, Absorptionskoeffizient und Schallgeschwindigkeit zu bestimmen.</skos:definition> <skos:definition xml:lang="zh">一种通过分析声波与材料相互作用来测量材料声学特性的分析过程。该过程包括产生声波并观察其反射、透射、吸收或散射，以确定声阻抗、吸收系数和声速等特性。</skos:definition>
        <skos:example xml:lang="en">For example, acoustic emission testing (AET) is used to monitor the release of energy from a material under stress, which can indicate the onset of failure or the presence of defects.</skos:example> <skos:example xml:lang="zh">例如，声发射测试（AET）用于监测材料在应力下释放的能量，这可以指示失效的开始或缺陷的存在。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000508 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000508">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000602"/>
        <rdfs:label xml:lang="de">Additive Fertigungsgerät</rdfs:label> <rdfs:label xml:lang="zh">增材制造设备</rdfs:label>
        <rdfs:label xml:lang="en">additive manufacturing device</rdfs:label> <rdfs:label xml:lang="zh">增材制造设备</rdfs:label>
        <skos:definition xml:lang="en">A device used for manufacturing objects layer by layer through additive processes such as 3D printing.</skos:definition> <skos:definition xml:lang="zh">一种通过增材工艺（如3D打印）逐层制造物体的设备。</skos:definition>
        <skos:definition xml:lang="de">Ein Gerät zur Herstellung von Objekten Schicht für Schicht durch additive Verfahren wie 3D-Druck.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000509 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000509">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000849"/>
        <rdfs:label xml:lang="de">Adhäsionsprüfverfahren</rdfs:label> <rdfs:label xml:lang="zh">附着力测试方法</rdfs:label>
        <rdfs:label xml:lang="en">adhesion testing process</rdfs:label> <rdfs:label xml:lang="zh">附着力测试过程</rdfs:label>
        <skos:definition xml:lang="en">A mechanical property analyzing process that measures the strength of adhesion between two bonded surfaces, assessing the quality of adhesive joints.</skos:definition> <skos:definition xml:lang="zh">一种测量两个粘合表面之间粘附强度的力学性能分析过程，用于评估粘接接头的质量。</skos:definition>
        <skos:definition xml:lang="de">Ein Mechanische Eigenschaften Analyseverfahren, das die Stärke der Haftung zwischen zwei verklebten Oberflächen misst und die Qualität der Klebeverbindungen bewertet.</skos:definition> <skos:definition xml:lang="zh">一种机械性能分析方法，测量两个粘合表面之间的粘附强度并评估粘接质量。</skos:definition>
        <skos:example xml:lang="en">Adhesion testing of epoxy bonds in composite materials to ensure structural integrity in aircraft components.</skos:example> <skos:example xml:lang="zh">复合材料中环氧粘接的附着力测试，以确保飞机部件的结构完整性。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000510 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000510">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000603"/>
        <obo:IAO_0000112 xml:lang="en">A screwdriver used to adjust a grub screw.</obo:IAO_0000112> <obo:IAO_0000112 xml:lang="zh">用于调整紧定螺钉的螺丝刀。</obo:IAO_0000112>
        <rdfs:label xml:lang="de">Einstellungsgeräterolle</rdfs:label> <rdfs:label xml:lang="zh">调整装置角色</rdfs:label>
        <rdfs:label xml:lang="en">adjustment device role</rdfs:label> <rdfs:label xml:lang="zh">调整装置角色</rdfs:label>
        <skos:definition xml:lang="en">A device role that is used to adjust another device (SubjectOfAdjustmentRole). The role is realized in an adjustment process.</skos:definition> <skos:definition xml:lang="zh">一种用于调整另一设备（被调整角色）的设备角色。该角色在调整过程中实现。</skos:definition>
        <skos:definition xml:lang="de">Rolle eines Gerätes, das zum Einstellen eines anderen Gerätes (SubjectOfAdjustmentRole) verwendet wird. Die Rolle wird in einem Einstellungsprozess realisiert.</skos:definition> <skos:definition xml:lang="zh">用于调整其他设备（受调整角色）的设备的角色。该角色在调整过程中实现。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000512 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000512">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/pmd/co/PMD_0000077"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/pmd/co/PMD_0020116"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020131"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/pmd/co/PMD_0000077"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020116"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">aggregate state</rdfs:label> <rdfs:label xml:lang="zh">聚集状态</rdfs:label>
        <skos:definition xml:lang="en">an intensive quality representing the physical state of a material, such as solid, liquid, or gasous</skos:definition> <skos:definition xml:lang="zh">一种表示材料物理状态的强度性质，例如固态、液态或气态。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000513 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000513">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:label xml:lang="de">Alterungsprozess</rdfs:label> <rdfs:label xml:lang="zh">老化过程</rdfs:label>
        <rdfs:label xml:lang="en">aging process</rdfs:label> <rdfs:label xml:lang="zh">时效过程</rdfs:label>
        <skos:definition xml:lang="de">Das Aging oder Auslagern ist ein Anlassvorgang, der den Martensit (Härtungsgefüge) wieder duktil und verformbar macht. Dabei wird ein Agingvorgang genutzt, nämlich die Bildung von Ausscheidungen in Form von FeXCY - Carbiden</skos:definition> <skos:definition xml:lang="zh">时效或析出是一种回火过程，使马氏体（硬化组织）再次变得具有延展性和可变形性。其中利用时效过程，即形成FeXCY碳化物形式的析出物。</skos:definition>
        <skos:definition xml:lang="en">The process of hardening an alloy by a method that causes a constituent to precipitate from solid solution.</skos:definition> <skos:definition xml:lang="zh">通过使成分从固溶体中析出的方法来硬化合金的过程。</skos:definition>
        <skos:example xml:lang="en">The Process of austenitizing and quenching a steel alloy to achieve a martensitic microstructure for hardness increase.</skos:example> <skos:example xml:lang="zh">将钢合金进行奥氏体化和淬火以获得马氏体微观结构从而提高硬度的过程。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000517 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000517">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020215"/>
        <rdfs:label xml:lang="en">acoustic wave</rdfs:label> <rdfs:label xml:lang="zh">声波</rdfs:label>
        <skos:definition xml:lang="en">a mechanical wave of pressure disturbances that propagates through a medium by local compression and rarefaction</skos:definition> <skos:definition xml:lang="zh">一种通过局部压缩和稀疏在介质中传播的压力扰动的机械波。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000518 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000518">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:label xml:lang="en">impact</rdfs:label> <rdfs:label xml:lang="zh">冲击</rdfs:label>
        <skos:definition xml:lang="en">impact is a short-duration, high-force interaction porcess between two bodies in contact</skos:definition> <skos:definition xml:lang="zh">冲击是两个接触物体之间短时间、高作用力的相互作用过程。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000519 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000519">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:label xml:lang="en">flow of electric charge</rdfs:label> <rdfs:label xml:lang="zh">电荷流动</rdfs:label>
        <skos:definition xml:lang="en">is the process of movement of charged particles</skos:definition> <skos:definition xml:lang="zh">是带电粒子运动的过程。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000520 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000520">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:label xml:lang="en">heat flow</rdfs:label> <rdfs:label xml:lang="zh">热流</rdfs:label>
        <skos:definition xml:lang="en">is a process in which transfer of thermal energy between or within material entities occurs</skos:definition> <skos:definition xml:lang="zh">是热能传递发生在材料实体之间或内部的过程。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000521 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000521">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:label xml:lang="en">generation of magnetic field</rdfs:label> <rdfs:label xml:lang="zh">磁场的产生</rdfs:label>
        <skos:definition xml:lang="en">is a process that occurs as a reaction to change of elctric field or movement of charges and produces a magnetic field</skos:definition> <skos:definition xml:lang="zh">是作为对电场变化或电荷运动的反应而产生的过程，并产生磁场。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000522 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000522">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:label xml:lang="en">mechanical process</rdfs:label> <rdfs:label xml:lang="zh">机械过程</rdfs:label>
        <skos:definition xml:lang="en">is a process in which forces, moments, or imposed displacements to objects or object aggregates occur and/or the equivalent (stresses, strains) to materials or portions of matter</skos:definition> <skos:definition xml:lang="zh">是一种过程，其中力、力矩或对物体或物体集合的施加位移发生，和/或对材料或物质部分的等效（应力、应变）发生。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000524 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000524">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000833"/>
        <rdfs:label xml:lang="de">Assemblierungsprozess</rdfs:label> <rdfs:label xml:lang="zh">组装过程</rdfs:label>
        <rdfs:label xml:lang="en">assembling process</rdfs:label> <rdfs:label xml:lang="zh">装配过程</rdfs:label>
        <skos:definition xml:lang="en">An assembling process is a manufacturing process that mounts or demounts components.</skos:definition> <skos:definition xml:lang="zh">装配过程是一种制造过程，用于安装或拆卸组件。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000525 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000525">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000855"/>
        <rdfs:label xml:lang="de">Atomkraftmikroskop</rdfs:label> <rdfs:label xml:lang="zh">原子力显微镜</rdfs:label>
        <rdfs:label xml:lang="en">atomic force microscope</rdfs:label> <rdfs:label xml:lang="zh">原子力显微镜</rdfs:label>
        <skos:definition xml:lang="en">A microscope that maps the surface topography of materials at the nanoscale by scanning it with a mechanical probe.</skos:definition> <skos:definition xml:lang="zh">一种显微镜，通过用机械探针扫描材料表面，在纳米尺度上绘制材料表面形貌。</skos:definition>
        <skos:definition xml:lang="de">Ein Mikroskop, das die Oberflächentopographie von Materialien im Nanobereich durch Abtasten mit einer mechanischen Sonde kartiert.</skos:definition> <skos:definition xml:lang="zh">一种通过机械探针扫描来绘制纳米尺度材料表面形貌的显微镜。</skos:definition>
        <PMD_0050117 xml:lang="en">AFM</PMD_0050117>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000526 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000526">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000027"/>
        <rdfs:label xml:lang="en">atomic structure</rdfs:label> <rdfs:label xml:lang="zh">原子结构</rdfs:label>
        <skos:definition xml:lang="en">The atomic structure is an object aggregate that describes the arrangement and composition of atoms in a material, influencing its physical and chemical properties.</skos:definition> <skos:definition xml:lang="zh">原子结构是一种对象集合，描述了材料中原子的排列和组成，影响其物理和化学性质。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000527 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000527">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000862"/>
        <rdfs:label xml:lang="de">Atomistische Monte Carlo Simulation</rdfs:label> <rdfs:label xml:lang="zh">原子级蒙特卡洛模拟</rdfs:label>
        <rdfs:label xml:lang="en">atomistic monte carlo simulation</rdfs:label> <rdfs:label xml:lang="zh">原子 Monte Carlo 模拟</rdfs:label>
        <skos:definition xml:lang="en">A monte carlo simulation process that focuses on the atomic scale, where the properties and behaviors of materials are modeled by considering individual atoms and their interactions.</skos:definition> <skos:definition xml:lang="zh">一种 Monte Carlo 模拟过程，专注于原子尺度，通过考虑单个原子及其相互作用来模拟材料的性质和行为。</skos:definition>
        <skos:definition xml:lang="de">Ein Monte Carlo Simulationsprozess, der sich auf die atomare Skala konzentriert, bei dem die Eigenschaften und das Verhalten von Materialien durch die Betrachtung einzelner Atome und ihrer Wechselwirkungen modelliert werden.</skos:definition> <skos:definition xml:lang="zh">一种专注于原子尺度的蒙特卡洛模拟过程，通过考虑单个原子及其相互作用来模拟材料的特性和行为。</skos:definition>
        <skos:example xml:lang="en">Simulating the behavior of electrons in a new alloy to predict its electrical conductivity.</skos:example> <skos:example xml:lang="zh">模拟新合金中电子的行为以预测其电导率。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000528 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000528">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000920"/>
        <rdfs:label xml:lang="de">Bandsäge</rdfs:label> <rdfs:label xml:lang="zh">带锯是一种使用连续、无端锯条（呈带状）的锯。这种锯条通常是一条窄而灵活的钢带，沿一侧有齿。带锯安装成封闭环状，并由两个轮子引导，其中至少一个轮子被驱动。带锯的工作原理使其能够精确高效地切割各种材料，包括木材、金属和塑料。</rdfs:label>
        <rdfs:label xml:lang="en">bandsaw</rdfs:label> <rdfs:label xml:lang="zh">带锯</rdfs:label>
        <skos:definition xml:lang="en">A band saw is a type of saw that uses a continuous, endless saw blade in the form of a band. This blade is usually a narrow, flexible steel blade with teeth along one edge. The band saw is mounted in a closed loop and is guided by two wheels, at least one of which is driven. The operation of the band saw enables precise and efficient cuts to be made in a variety of materials, including wood, metal and plastic.</skos:definition> <skos:definition xml:lang="zh">带锯是一种使用连续的、环状的锯条的锯。这种锯条通常是一条窄而柔韧的钢带，沿一边有齿。带锯安装在封闭回路中，由两个轮子引导，至少一个轮子被驱动。带锯的操作能够对多种材料（包括木材、金属和塑料）进行精确高效的切割。</skos:definition>
        <skos:definition xml:lang="de">Eine Bandsäge ist eine Art von Säge, die ein kontinuierliches, endloses Sägeblatt in Form eines Bands verwendet. Dieses Sägeblatt ist in der Regel eine schmale, flexible Stahlklinge mit Zähnen entlang einer Kante. Die Bandsäge ist in eine geschlossene Schleife montiert und wird über zwei Räder geführt, von denen mindestens eines angetrieben wird. Die Funktionsweise der Bandsäge ermöglicht präzise und effiziente Schnitte in unterschiedlichen Materialien, einschließlich Holz, Metall und Kunststoff.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000529 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000529">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000602"/>
        <rdfs:label xml:lang="de">Biegeversuchmaschine</rdfs:label> <rdfs:label xml:lang="zh">一种通过施加负载并测量变形来测试材料抗弯强度和柔韧性的设备。</rdfs:label>
        <rdfs:label xml:lang="en">bending testing machine</rdfs:label> <rdfs:label xml:lang="zh">弯曲试验机</rdfs:label>
        <skos:definition xml:lang="en">A device used to test the bending strength and flexibility of materials by applying a load and measuring deformation.</skos:definition> <skos:definition xml:lang="zh">一种通过施加载荷并测量变形来测试材料的弯曲强度和柔韧性的设备。</skos:definition>
        <skos:definition xml:lang="de">Ein Gerät zur Prüfung der Biegefestigkeit und Flexibilität von Materialien durch Anwendung einer Last und Messung der Verformung.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000530 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000530">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000849"/>
        <rdfs:label xml:lang="de">Biegeprüfverfahren</rdfs:label> <rdfs:label xml:lang="zh">一种机械性能分析方法，测量材料对弯曲力的抵抗力，并确定其抗弯强度和刚度。</rdfs:label>
        <rdfs:label xml:lang="en">bending testing process</rdfs:label> <rdfs:label xml:lang="zh">弯曲测试过程</rdfs:label>
        <skos:definition xml:lang="en">A mechanical property analyzing process that measures the resistance of a material to bending forces, determining its flexural strength and stiffness.</skos:definition> <skos:definition xml:lang="zh">一种力学性能分析过程，测量材料对弯曲力的抵抗能力，确定其弯曲强度和刚度。</skos:definition>
        <skos:definition xml:lang="de">Ein Mechanische Eigenschaften Analyseverfahren, das den Widerstand eines Materials gegen Biegekräfte misst und seine Biegefestigkeit und Steifigkeit bestimmt.</skos:definition>
        <skos:example xml:lang="en">Testing the flexural strength of a plastic beam to ensure it can withstand the required load in an engineering application.</skos:example> <skos:example xml:lang="zh">测试塑料梁的弯曲强度，以确保其能够承受工程应用中所需的载荷。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000531 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000531">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000532"/>
        <rdfs:label xml:lang="de">Analyseverfahren der Biokompatibilität</rdfs:label> <rdfs:label xml:lang="zh">一种生物性能分析方法，评估材料与活体组织的相容性，以确保不会引起不良反应。</rdfs:label>
        <rdfs:label xml:lang="en">biocompatibility analyzing process</rdfs:label> <rdfs:label xml:lang="zh">生物相容性分析过程</rdfs:label>
        <skos:definition xml:lang="en">A biological property analyzing process that evaluates the compatibility of a material with living tissues to ensure it does not provoke an adverse biological response.</skos:definition> <skos:definition xml:lang="zh">一种生物属性分析过程，评估材料与活体组织的相容性，以确保不会引起不良生物反应。</skos:definition>
        <skos:definition xml:lang="en">An example of a biocompatibility analyzing process is an in vitro cell culture test, where cells are cultured in the presence of the implant material to observe any cytotoxic effects, such as changes in cell morphology, proliferation rate, or cell viability.</skos:definition> <skos:definition xml:lang="zh">生物相容性分析过程的一个例子是体外细胞培养测试，将细胞在植入材料存在下培养，观察任何细胞毒性效应，例如细胞形态、增殖率或细胞活力的变化。</skos:definition>
        <skos:definition xml:lang="de">Ein Biologisches Eigenschaften Analyseverfahren, das die Verträglichkeit eines Materials mit lebenden Geweben bewertet, um sicherzustellen, dass es keine nachteilige biologische Reaktion hervorruft.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000532 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000532">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBI_0000070"/>
        <rdfs:label xml:lang="de">Biologische Eigenschaften Analyseverfahren</rdfs:label> <rdfs:label xml:lang="zh">一种分析，研究材料与生物系统的相互作用，包括生物相容性、降解性、毒性以及材料对活生物体和细胞的影响。</rdfs:label>
        <rdfs:label xml:lang="en">biological property analyzing process</rdfs:label> <rdfs:label xml:lang="zh">生物属性分析过程</rdfs:label>
        <skos:definition xml:lang="en">An assay that examines the interaction of materials with biological systems, including biocompatibility, biodegradability, toxicity, and the effects of materials on living organisms and cells.</skos:definition> <skos:definition xml:lang="zh">一种检测方法，检查材料与生物系统的相互作用，包括生物相容性、生物降解性、毒性以及材料对生物体和细胞的影响。</skos:definition>
        <skos:definition xml:lang="de">Eine Analyse, die die Wechselwirkung von Materialien mit biologischen Systemen untersucht, einschließlich Biokompatibilität, Abbaubarkeit, Toxizität und der Auswirkungen von Materialien auf lebende Organismen und Zellen.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000534 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000534">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000023"/>
        <obo:IAO_0000119 xml:lang="en">“Blank.” Merriam-Webster.com Dictionary, Merriam-Webster, https://www.merriam-webster.com/dictionary/blank. Accessed 25 Nov. 2022.</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">“空白。” Merriam-Webster.com词典，Merriam-Webster，https://www.merriam-webster.com/dictionary/blank。访问日期2022年11月25日。</obo:IAO_0000119>
        <rdfs:label xml:lang="de">Rohling-Rolle</rdfs:label> <rdfs:label xml:lang="zh">毛坯辊</rdfs:label>
        <rdfs:label xml:lang="en">blank role</rdfs:label> <rdfs:label xml:lang="zh">毛坯角色</rdfs:label>
        <skos:definition xml:lang="en">Role of an object, which is realized in a preparation process</skos:definition> <skos:definition xml:lang="zh">物体的角色，在准备过程中实现。</skos:definition>
        <skos:example xml:lang="en">Some portion of material, which to be made into something by a further operation.</skos:example> <skos:example xml:lang="zh">一种材料的一部分，通过进一步操作制成某物。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000535 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000535">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020164"/>
        <rdfs:label xml:lang="en">boiling point</rdfs:label> <rdfs:label xml:lang="zh">沸点</rdfs:label>
        <skos:definition xml:lang="en">The boiling point is a state of matter boundary realized by transition form the liquid state to the gaseous state (or vice versa).</skos:definition> <skos:definition xml:lang="zh">沸点是一种物质状态的边界，由液态到气态（或反之）的转变实现。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000536 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000536">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000537"/>
        <rdfs:label xml:lang="en">Brinell 2.5 62.5 ISO 6506</rdfs:label> <rdfs:label xml:lang="zh">布氏硬度 2.5 62.5 ISO 6506</rdfs:label>
        <skos:definition xml:lang="en">A brinell hardness measured with 2.5mm diameter ball and a load of 62.5 kgf.</skos:definition> <skos:definition xml:lang="zh">一种布氏硬度，使用直径2.5mm的球和62.5 kgf的载荷测量。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000537 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000537">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000789"/>
        <rdfs:label xml:lang="en">brinell hardness</rdfs:label> <rdfs:label xml:lang="zh">布氏硬度</rdfs:label>
        <skos:definition xml:lang="en">An indentation hardness scalar representing a measure of material hardness obtained by indenting the material with a steel or tungsten carbide ball under a specific load.</skos:definition> <skos:definition xml:lang="zh">一种压痕硬度标量，表示通过在特定载荷下用钢球或碳化钨球压入材料所获得的材料硬度度量。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000538 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000538">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000027"/>
                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000030"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://w3id.org/pmd/co/PMD_0000965"/>
        <rdfs:label xml:lang="en">bulk</rdfs:label> <rdfs:label xml:lang="zh">体</rdfs:label>
        <skos:definition xml:lang="en">The bulk is a fiat object part that describes the volume or mass of material considered as a whole, often in contrast to surface or interface phenomena.</skos:definition> <skos:definition xml:lang="zh">整体是一个抽象对象部分，描述作为整体考虑的材料体积或质量，通常与表面或界面现象相对。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000539 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000539">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000618"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000052"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000027"/>
                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000030"/>
                            <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000538"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">bulk modulus</rdfs:label> <rdfs:label xml:lang="zh">体积模量</rdfs:label>
        <skos:definition xml:lang="en">The bulk modulus is an elastic modulus representing a measure of a material's resistance to uniform compression.</skos:definition> <skos:definition xml:lang="zh">体积模量是一种弹性模量，表示材料抵抗均匀压缩的能力。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000540 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000540">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000550"/>
        <rdfs:label xml:lang="de">Brennen</rdfs:label> <rdfs:label xml:lang="zh">燃烧</rdfs:label>
        <rdfs:label xml:lang="en">burning</rdfs:label> <rdfs:label xml:lang="zh">燃烧</rdfs:label>
        <skos:altLabel xml:lang="en">Firing</skos:altLabel> <skos:altLabel xml:lang="zh">烧制</skos:altLabel>
        <skos:definition xml:lang="de">Ein Stoffeigenschaftsänderungsprozess, der das Brennen beinhaltet, bezieht sich in der Regel auf die Anwendung großer Hitze, die oft zu einer Verbrennung oder thermischen Zersetzung führt, um die physikalischen oder chemischen Eigenschaften eines Materials zu verändern, was zu Veränderungen wie Härtung, Änderung der chemischen Zusammensetzung oder Verringerung der Masse führt,</skos:definition> <skos:definition xml:lang="zh">一个包含燃烧的材料属性改变过程，通常指施加高温，往往导致燃烧或热分解，以改变材料的物理或化学性质，导致诸如硬化、化学成分改变或质量减少等变化，</skos:definition>
        <skos:definition xml:lang="en">a 'changing properties of material' process that involves burning typically refers to the application of high heat, often resulting in combustion or thermal degradation, to alter the physical or chemical properties of a material, leading to changes like hardening, alteration in chemical composition, or reduction in mass,</skos:definition> <skos:definition xml:lang="zh">一个包含燃烧的“材料属性改变”过程，通常指施加高温，往往导致燃烧或热降解，以改变材料的物理或化学性质，导致诸如硬化、化学成分改变或质量减少等变化，</skos:definition>
        <skos:example xml:lang="en">Firing in Pottery</skos:example> <skos:example xml:lang="zh">陶器烧制</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000541 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000541">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000648"/>
        <rdfs:label xml:lang="de">CNC-Maschine</rdfs:label> <rdfs:label xml:lang="zh">CNC机床</rdfs:label>
        <rdfs:label xml:lang="en">cnc machine</rdfs:label> <rdfs:label xml:lang="zh">CNC机床</rdfs:label>
        <skos:definition xml:lang="en">A CNC machine is a forming machine that uses computer numerical control to precisely control machining tools for cutting, drilling, milling, and other tasks.</skos:definition> <skos:definition xml:lang="zh">CNC机床是一种使用计算机数控精确控制加工工具进行切割、钻孔、铣削等任务的成形机床。</skos:definition>
        <skos:definition xml:lang="de">Eine CNC-Maschine ist eine Formmaschine, die zur präzisen Steuerung von Bearbeitungswerkzeugen für Schneid-, Bohr-, Fräs- und andere Aufgaben computergestützte numerische Steuerung verwendet.</skos:definition> <skos:definition xml:lang="zh">CNC机床是一种成形机床，它使用计算机数控精确控制加工工具进行切割、钻孔、铣削和其他任务。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000542 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000542">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000541"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0001011"/>
        <rdfs:label xml:lang="de">CNC-Schweißmaschine</rdfs:label> <rdfs:label xml:lang="zh">CNC焊接机床</rdfs:label>
        <rdfs:label xml:lang="en">cnc welding machine</rdfs:label> <rdfs:label xml:lang="zh">CNC焊接机床</rdfs:label>
        <skos:definition xml:lang="en">A cnc machine that performs welding operations.</skos:definition> <skos:definition xml:lang="zh">一种执行焊接操作的CNC机床。</skos:definition>
        <skos:definition xml:lang="de">Eine CNC-Schweißmaschine ist eine CNC-Maschine, die Schweißoperationen ausführt.</skos:definition> <skos:definition xml:lang="zh">CNC焊接机床是一种执行焊接操作的CNC机床。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000543 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000543">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000603"/>
        <rdfs:label xml:lang="de">Kalibrierungsgeräterolle</rdfs:label> <rdfs:label xml:lang="zh">校准设备角色</rdfs:label>
        <rdfs:label xml:lang="en">calibration device role</rdfs:label> <rdfs:label xml:lang="zh">校准设备角色</rdfs:label>
        <skos:definition xml:lang="en">A device role that is used for calibration of itself or another device, which has the "Subject Of Calibration Role". The role is realized in a calibration process.</skos:definition> <skos:definition xml:lang="zh">一种设备角色，用于校准自身或另一个具有“校准主体角色”的设备。该角色在校准过程中实现。</skos:definition>
        <skos:definition xml:lang="de">Rolle eines Geräts, das zum Kalibrieren sich selbst oder eines anderen Gerätes, das die "Subject Of Calibration Role" inne hat, verwendet wird. Die Rolle wird in einem Kalibrierungsprozess realisiert.</skos:definition> <skos:definition xml:lang="zh">一种设备角色，用于校准自身或另一个具有“校准主体角色”的设备。该角色在校准过程中实现。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000544 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000544">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000602"/>
        <obo:IAO_0000119 xml:lang="en">https://www.merriam-webster.com/dictionary/caliper</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">卡尺</obo:IAO_0000119>
        <rdfs:label xml:lang="de">Messschieber</rdfs:label> <rdfs:label xml:lang="zh">卡尺</rdfs:label>
        <rdfs:label xml:lang="en">caliper</rdfs:label> <rdfs:label xml:lang="zh">卡尺</rdfs:label>
        <skos:definition xml:lang="en">A measuring device having two usually adjustable arms, legs, or jaws used especially to measure the dimensions of objects, such as diameters or thicknesses</skos:definition> <skos:definition xml:lang="zh">一种测量装置，通常有两个可调节的臂、腿或爪，特别用于测量物体的尺寸，如直径或厚度。</skos:definition>
        <skos:definition xml:lang="de">Messgerät mit zwei in der Regel verstellbaren Armen, Schenkeln oder Klemmbacken, das vor allem zur Messung der Abmessungen von Gegenständen, wie z. B. des Durchmessers oder der Dicke, verwendet wird</skos:definition> <skos:definition xml:lang="zh">一种通常具有两个可调节臂、腿或钳口的测量仪器，主要用于测量物体的尺寸，例如直径或厚度。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000546 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000546">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000000"/>
        <obo:IAO_0000116 xml:lang="en">Classified by morphology.</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">按形态分类。</obo:IAO_0000116>
        <rdfs:label xml:lang="en">ceramic</rdfs:label> <rdfs:label xml:lang="zh">陶瓷</rdfs:label>
        <skos:definition xml:lang="en">Ceramics are engineered materials described as non-metallic, inorganic materials characterized by high hardness, brittleness, and heat resistance, commonly used in engineering applications.</skos:definition> <skos:definition xml:lang="zh">陶瓷是工程材料，被描述为非金属无机材料，具有高硬度、脆性和耐热性，常用于工程应用。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000547 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000547">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020136"/>
        <rdfs:label xml:lang="en">change of aggregate state</rdfs:label> <rdfs:label xml:lang="zh">物态变化</rdfs:label>
        <skos:definition xml:lang="en">a phase transformation (change of phase) involving the collective state of particles in portion of matter</skos:definition> <skos:definition xml:lang="zh">一种相变（物相变化），涉及物质中粒子的集体状态。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000549 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000549">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:label xml:lang="en">change of temperature</rdfs:label> <rdfs:label xml:lang="zh">温度变化</rdfs:label>
        <skos:definition xml:lang="en">change of temperature is a process in which a particpant changes its temperature</skos:definition> <skos:definition xml:lang="zh">温度变化是参与者改变其温度的过程。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000550 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000550">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000833"/>
        <obo:IAO_0000119 xml:lang="en">Official definition can be found in: DIN 8580:2003-9 Fertigungsverfahren, Page 5, 3.1.6 Stoffeigenschaften ändern - Definition</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">官方定义可参见：DIN 8580:2003-9 Fertigungsverfahren, 第5页, 3.1.6 Stoffeigenschaften ändern - 定义</obo:IAO_0000119>
        <obo:IAO_0000119 xml:lang="de">Offizielle Definition findet man in: DIN 8580:2003-9 Fertigungsverfahren, Seite 5, 3.1.6 Stoffeigenschaften ändern - Definition</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">官方定义可在以下位置找到：DIN 8580:2003-9 Fertigungsverfahren, 第5页, 3.1.6 Stoffeigenschaften ändern - 定义</obo:IAO_0000119>
        <rdfs:label xml:lang="de">Stoffeigenschaft Ändern</rdfs:label> <rdfs:label xml:lang="zh">材料属性改变</rdfs:label>
        <rdfs:label xml:lang="en">changing properties of material</rdfs:label> <rdfs:label xml:lang="zh">改变材料属性</rdfs:label>
        <skos:altLabel xml:lang="en">Changing Of Material  Properties</skos:altLabel> <skos:altLabel xml:lang="zh">材料属性改变</skos:altLabel>
        <skos:altLabel xml:lang="en">Property Alteration</skos:altLabel> <skos:altLabel xml:lang="zh">属性改变</skos:altLabel>
        <skos:definition xml:lang="en">A manufacturing process that modifies the characteristics of the material from which a workpiece is made, including by processes at the submicroscopic or atomic scale, such as atomic diffusion, dislocation formation and movement in the atomic lattice or chemical reactions, whereby the resulting shape changes are not characteristic of these processes.</skos:definition> <skos:definition xml:lang="zh">一种制造过程，改变工件材料的特性，包括在亚微观或原子尺度上的过程，如原子扩散、原子晶格中的位错形成和运动或化学反应，由此产生的形状变化不是这些过程的特征。</skos:definition>
        <skos:definition xml:lang="de">Ein Herstellungsprozess, der die Merkmale des Materials, aus dem ein Werkstück gefertigt ist, modifiziert, was unter anderem durch Vorgänge im submikroskopischen oder atomaren Bereich erfolgt, wie etwa durch Atomdiffusion, die Versetzungsentstehung und -bewegung im Atomgitter oder durch chemische Reaktionen, wobei die dabei auftretenden Formveränderungen nicht charakteristisch für diese Verfahren sind.</skos:definition> <skos:definition xml:lang="zh">一种制造过程，修改工件材料的特性，通过亚微观或原子尺度上的过程，如原子扩散、原子晶格中的位错形成和运动或化学反应，其中发生的形状变化不是这些过程的特征。</skos:definition>
        <skos:example xml:lang="en">Heat Treatment</skos:example> <skos:example xml:lang="zh">热处理</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000551 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000551">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0025001"/>
        <rdfs:comment xml:lang="en">See the editor note of composition to understand the difference between composition and chemical composition.

See the pattern example of composition to underatand the difference between composition and proportion.</rdfs:comment>
        <rdfs:label xml:lang="en">chemical composition</rdfs:label> <rdfs:label xml:lang="zh">化学成分</rdfs:label>
        <skos:definition xml:lang="en">The chemical composition is an intensive quality of a portion of matter which describes the types and proportions of pure chemical elements in the portion of matter, and it is a subject of some chemical composition data item.</skos:definition> <skos:definition xml:lang="zh">化学成分是物质的一种强度性质，描述了物质中纯化学元素的类型和比例，并且是某些化学成分数据项的主题。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
        <PMD_0000064 xml:lang="en">Material has quality chemical composition. Chemical composition is a subject of chemical composition data item. Chemical composition data item has members fraction value specifications (which have a numeral and a unit). Material has part portion of carbon. Material has relational quality mass proportion. Portion of carbon  has relational quality mass proportion. Mass propotion is specified by value fraction value specification. Same approach for all chemical elements.</PMD_0000064>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000552 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000552">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000957"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0009006"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000551"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="de">Analyseverfahren für die chemische Zusammensetzung</rdfs:label> <rdfs:label xml:lang="zh">化学成分分析过程</rdfs:label>
        <rdfs:label xml:lang="en">chemical composition analyzing process</rdfs:label> <rdfs:label xml:lang="zh">化学成分分析过程</rdfs:label>
        <skos:definition xml:lang="en">A structural property analyzing process that determines the chemical composition of a material by identifying and quantifying its constituent elements and compounds.</skos:definition> <skos:definition xml:lang="zh">一种结构性质分析过程，通过识别和量化材料中的组成元素和化合物来确定其化学成分。</skos:definition>
        <skos:definition xml:lang="de">Ein Struktur Eigenschaften Analyseverfahren, das die chemische Zusammensetzung eines Materials bestimmt, indem es dessen Bestandteile und Verbindungen identifiziert und quantifiziert.</skos:definition> <skos:definition xml:lang="zh">一种结构性质分析过程，通过识别和量化材料的组成和化合物来确定其化学成分。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000553 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000553">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020131"/>
        <rdfs:label xml:lang="en">chemical potential</rdfs:label> <rdfs:label xml:lang="zh">化学势</rdfs:label>
        <skos:definition xml:lang="en">an intensive quality of a thermodynamic system describing the energy change associated with the addition of a small quantity of a substance to a system at constant temperature and pressure.</skos:definition> <skos:definition xml:lang="zh">热力学系统的一种强度性质，描述了在恒定温度和压力下向系统添加少量物质时相关的能量变化。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000554 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000554">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBI_0000070"/>
        <rdfs:label xml:lang="de">Chemische Eigenschaften Analyseverfahren</rdfs:label> <rdfs:label xml:lang="zh">化学性质分析方法</rdfs:label>
        <rdfs:label xml:lang="en">chemical property analyzing process</rdfs:label> <rdfs:label xml:lang="zh">化学性质分析过程</rdfs:label>
        <skos:definition xml:lang="en">An assay that determines the chemical composition, reactivity, and chemical stability of materials, including the identification and quantification of chemical elements and compounds.</skos:definition> <skos:definition xml:lang="zh">一种测定材料化学组成、反应性和化学稳定性的分析方法，包括化学元素和化合物的定性和定量分析。</skos:definition>
        <skos:definition xml:lang="de">Eine Analyse, die die chemische Zusammensetzung, Reaktivität und chemische Stabilität von Materialien bestimmt, einschließlich der Identifizierung und Quantifizierung chemischer Elemente und Verbindungen.</skos:definition> <skos:definition xml:lang="zh">一种确定材料化学组成、反应性和化学稳定性的分析方法，包括化学元素和化合物的识别与定量。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000555 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000555">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000034"/>
        <rdfs:label xml:lang="de">Chromatographiefunktion</rdfs:label> <rdfs:label xml:lang="zh">色谱功能</rdfs:label>
        <rdfs:label xml:lang="en">chromatography function</rdfs:label> <rdfs:label xml:lang="zh">色谱功能</rdfs:label>
        <skos:definition xml:lang="en">A function performed to separate compounds in a mixture based on their distribution between a stationary phase and a mobile phase.</skos:definition> <skos:definition xml:lang="zh">一种基于混合物中化合物在固定相和流动相之间分布而将其分离的功能。</skos:definition>
        <skos:definition xml:lang="de">Eine Funktion, die durchgeführt wird, um Verbindungen in einer Mischung basierend auf ihrer Verteilung zwischen einer stationären Phase und einer mobilen Phase zu trennen.</skos:definition> <skos:definition xml:lang="zh">一种基于化合物在固定相和流动相之间分配而分离混合物中化合物的功能。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000556 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000556">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000957"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0009006"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020101"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0009006"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0025001"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="de">Chromatographieverfahren</rdfs:label> <rdfs:label xml:lang="zh">色谱方法</rdfs:label>
        <rdfs:label xml:lang="en">chromatography process</rdfs:label> <rdfs:label xml:lang="zh">色谱过程</rdfs:label>
        <skos:definition xml:lang="en">A structural property analyzing process that enables the separation and analysis of compounds in a mixture by their distribution between a mobile and a stationary phase.</skos:definition> <skos:definition xml:lang="zh">一种结构性质分析过程，通过化合物在流动相和固定相之间的分布来实现混合物中化合物的分离和分析。</skos:definition>
        <skos:definition xml:lang="de">Ein Struktur Eigenschaften Analyseverfahren, das die Trennung und Analyse von Verbindungen in einem Gemisch durch ihre Verteilung zwischen einer mobilen und einer stationären Phase ermöglicht.</skos:definition> <skos:definition xml:lang="zh">一种结构性质分析方法，通过化合物在流动相和固定相之间的分配实现混合物中化合物的分离和分析。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000557 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000557">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000602"/>
        <rdfs:label xml:lang="de">Chromatographiesystem</rdfs:label> <rdfs:label xml:lang="zh">色谱系统</rdfs:label>
        <rdfs:label xml:lang="en">chromatography system</rdfs:label> <rdfs:label xml:lang="zh">色谱系统</rdfs:label>
        <skos:definition xml:lang="en">A device used for separating mixtures into individual components using a chromatographic column and a mobile phase.</skos:definition> <skos:definition xml:lang="zh">一种使用色谱柱和流动相将混合物分离成单个组分的装置。</skos:definition>
        <skos:definition xml:lang="de">Ein Gerät zur Trennung von Gemischen in einzelne Komponenten unter Verwendung einer chromatographischen Säule und einer mobilen Phase.</skos:definition> <skos:definition xml:lang="zh">一种利用色谱柱和流动相将混合物分离成单个组分的设备。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000558 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000558">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000920"/>
        <rdfs:label xml:lang="de">Kreissäge</rdfs:label> <rdfs:label xml:lang="zh">圆锯</rdfs:label>
        <rdfs:label xml:lang="en">circular saw</rdfs:label> <rdfs:label xml:lang="zh">圆锯</rdfs:label>
        <skos:definition xml:lang="de">Die Kreissäge ist eine elektrische oder motorisierte Säge, die durch ein rundes, kreisförmiges Sägeblatt angetrieben wird. Das Sägeblatt einer Kreissäge ist mit Zähnen entlang seines Randes ausgestattet, die dazu dienen, das Material zu schneiden, wenn es in die Säge eingespeist wird. Kreissägen sind vielseitige Werkzeuge und können für verschiedene Materialien wie Holz, Metall, Kunststoff und sogar Gestein verwendet werden, abhängig vom spezifischen Sägeblatt, das installiert ist.</skos:definition> <skos:definition xml:lang="zh">圆锯是一种电动或动力锯，由一个圆形锯片驱动。圆锯的锯片沿其边缘设有齿，用于在材料送入锯时进行切割。圆锯是多功能工具，可根据安装的特定锯片用于各种材料，如木材、金属、塑料甚至岩石。</skos:definition>
        <skos:definition xml:lang="en">The circular saw is an electric or motorized saw that is powered by a round, circular saw blade. The blade of a circular saw is equipped with teeth along its edge that are used to cut the material as it is fed into the saw. Circular saws are versatile tools and can be used for different materials such as wood, metal, plastic and even rock, depending on the specific saw blade that is installed.</skos:definition> <skos:definition xml:lang="zh">圆锯是一种电动或机动锯，由圆形锯片驱动。圆锯的锯片边缘带有齿，用于切割送入锯中的材料。圆锯是多功能工具，根据安装的锯片不同，可用于木材、金属、塑料甚至岩石等多种材料。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000559 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000559">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000558"/>
        <rdfs:label xml:lang="de">Tischkreissäge</rdfs:label> <rdfs:label xml:lang="zh">台锯</rdfs:label>
        <rdfs:label xml:lang="en">circular table saw</rdfs:label> <rdfs:label xml:lang="zh">台式圆锯</rdfs:label>
        <skos:definition xml:lang="en">A stationary circular saw that is built into a table top. It is often used in workshops for precise wood cuts.</skos:definition> <skos:definition xml:lang="zh">一种安装在桌面上的固定式圆锯。常用于车间进行精确的木材切割。</skos:definition>
        <skos:definition xml:lang="de">Eine stationäre Kreissäge, die in eine Tischplatte eingebaut ist. Sie wird oft in Werkstätten für präzise Holzschnitte verwendet.</skos:definition> <skos:definition xml:lang="zh">一种固定式圆锯，安装在台面上。常用于车间进行精确的木工切割。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000560 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000560">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000927"/>
        <obo:IAO_0000119 xml:lang="en">Official definition can be found in: DIN 8592</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">官方定义见：DIN 8592</obo:IAO_0000119>
        <obo:IAO_0000119 xml:lang="de">Offizielle Definition findet man in: DIN 8592</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">官方定义见：DIN 8592</obo:IAO_0000119>
        <rdfs:label xml:lang="de">Reinigen</rdfs:label> <rdfs:label xml:lang="zh">清洁</rdfs:label>
        <rdfs:label xml:lang="en">cleaning</rdfs:label> <rdfs:label xml:lang="zh">清洁</rdfs:label>
        <skos:definition xml:lang="en">A separating process that involves removing unwanted material from a surface through cleaning methods, which may include processes like blasting, washing, or chemical cleaning.</skos:definition> <skos:definition xml:lang="zh">一种分离过程，涉及通过清洁方法从表面去除不需要的材料，这些方法可能包括喷砂、清洗或化学清洁等过程。</skos:definition>
        <skos:definition xml:lang="de">Ein Trennprozess, bei dem unerwünschtes Material von einer Oberfläche durch Reinigungsmethoden entfernt wird, die Verfahren wie Strahlen, Waschen oder chemische Reinigung umfassen können.</skos:definition> <skos:definition xml:lang="zh">一种分离过程，通过清洁方法从表面去除不需要的材料，这些方法可能包括喷砂、清洗或化学清洁。</skos:definition>
        <skos:example xml:lang="en">Chemical Cleaning, Mechanical Cleaning</skos:example> <skos:example xml:lang="zh">化学清洁，机械清洁</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000561 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000561">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000602"/>
        <rdfs:label xml:lang="de">Reinigungsgerät</rdfs:label> <rdfs:label xml:lang="zh">清洁设备</rdfs:label>
        <rdfs:label xml:lang="en">cleaning device</rdfs:label> <rdfs:label xml:lang="zh">清洁设备</rdfs:label>
        <skos:definition xml:lang="en">A device used for removing contaminants from materials or surfaces.</skos:definition> <skos:definition xml:lang="zh">一种用于从材料或表面去除污染物的设备。</skos:definition>
        <skos:definition xml:lang="de">Ein Gerät zum Entfernen von Verunreinigungen von Materialien oder Oberflächen.</skos:definition> <skos:definition xml:lang="zh">一种用于从材料或表面去除污染物的设备。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000562 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000562">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000866"/>
        <rdfs:label xml:lang="de">Coarse Grained Simulation</rdfs:label> <rdfs:label xml:lang="zh">粗粒化模拟</rdfs:label>
        <rdfs:label xml:lang="en">coarse grained simulation</rdfs:label> <rdfs:label xml:lang="zh">粗粒化模拟</rdfs:label>
        <skos:definition xml:lang="de">Ein Multiskalensimulation Prozess, der das System vereinfacht, indem Atome oder Moleküle zu größeren Partikeln zusammengefasst werden, wodurch die Rechenkomplexität verringert wird und die Untersuchung größerer Systeme oder längerer Zeitskalen ermöglicht wird.</skos:definition> <skos:definition xml:lang="zh">一种多尺度模拟过程，通过将原子或分子分组为更大的粒子来简化系统，从而降低计算复杂性，允许研究更大的系统或更长的时标。</skos:definition>
        <skos:definition xml:lang="en">Multiscale simulation process that simplifies the system by grouping atoms or molecules into larger particles, thereby reducing computational complexity and allowing for the study of larger systems or longer time scales</skos:definition> <skos:definition xml:lang="zh">一种多尺度模拟过程，通过将原子或分子分组为更大的粒子来简化系统，从而降低计算复杂性，并允许研究更大的系统或更长的时标。</skos:definition>
        <skos:example xml:lang="en">In materials science, coarse-grained simulations are often used to study the mechanical properties of polymers. For instance, in the simulation of polymer chains, each segment of the chain might represent a group of several monomers, rather than modeling every single atom. This approach allows researchers to investigate the behavior of polymeric materials over larger scales and longer time periods, such as the viscoelastic properties of a polymer melt.</skos:example> <skos:example xml:lang="zh">在材料科学中，粗粒化模拟常用于研究聚合物的力学性能。例如，在聚合物链的模拟中，每个链段可能代表多个单体的组合，而不是对每个原子进行建模。这种方法使研究人员能够在更大的尺度和更长的时间周期内研究聚合物材料的行为，例如聚合物熔体的粘弹性。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000563 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000563">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000833"/>
        <obo:IAO_0000119 xml:lang="en">Official definition can be found in: DIN 8580:2003-9 Fertigungsverfahren, Page 5, 3.1.5 Beschichten - Definition</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">官方定义见：DIN 8580:2003-9 制造工艺，第5页，3.1.5 涂覆 - 定义</obo:IAO_0000119>
        <obo:IAO_0000119 xml:lang="de">Offizielle Definition findet man in: DIN 8580:2003-9 Fertigungsverfahren, Seite 5, 3.1.5 Beschichten - Definition</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">官方定义见：DIN 8580:2003-9 制造工艺，第5页，3.1.5 涂覆 - 定义</obo:IAO_0000119>
        <rdfs:label xml:lang="de">Beschichten</rdfs:label> <rdfs:label xml:lang="zh">涂覆</rdfs:label>
        <rdfs:label xml:lang="en">coating</rdfs:label> <rdfs:label xml:lang="zh">涂覆</rdfs:label>
        <skos:definition xml:lang="en">A manufacturing process that aims to deposit a permanently adhering layer of a material without a form onto a workpiece, whereby the immediate state of the coating material directly before application is essential.</skos:definition> <skos:definition xml:lang="zh">一种制造过程，旨在将一层无定形材料永久附着地沉积到工件上，其中涂层材料在施加前的即时状态至关重要。</skos:definition>
        <skos:definition xml:lang="de">Ein Herstellungsprozess, der darauf abzielt, eine dauerhaft haftende Schicht aus einem Material ohne Form auf ein Werkstück aufzubringen, wobei der unmittelbare Zustand des Beschichtungsmaterials direkt vor dem Auftragen entscheidend ist.</skos:definition> <skos:definition xml:lang="zh">一种制造过程，旨在将一层无定形材料永久附着地沉积到工件上，其中涂层材料在施加前的即时状态至关重要。</skos:definition>
        <skos:example xml:lang="en">Chemical Vapour Deposition, Physical Vapour Deposition</skos:example> <skos:example xml:lang="zh">化学气相沉积，物理气相沉积</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000564 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000564">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000575"/>
        <rdfs:label xml:lang="de">Beschichtungsanwendungsfunktion</rdfs:label> <rdfs:label xml:lang="zh">涂覆应用功能</rdfs:label>
        <rdfs:label xml:lang="en">coating application function</rdfs:label> <rdfs:label xml:lang="zh">涂覆应用功能</rdfs:label>
        <skos:definition xml:lang="en">A coating application function is a coating function that is realized in applying a coating to a surface.</skos:definition> <skos:definition xml:lang="zh">涂覆应用功能是一种涂覆功能，通过将涂层施加到表面来实现。</skos:definition>
        <skos:definition xml:lang="de">Eine Unterfunktion der Beschichtung, die durchgeführt wird, um eine Beschichtung auf eine Oberfläche aufzutragen.</skos:definition> <skos:definition xml:lang="zh">涂层的一个子功能，用于将涂层施加到表面上。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000565 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000565">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000563"/>
        <rdfs:label xml:lang="de">Beschichten Durch Löten</rdfs:label> <rdfs:label xml:lang="zh">通过焊接进行涂覆</rdfs:label>
        <rdfs:label xml:lang="en">coating by soldering</rdfs:label> <rdfs:label xml:lang="zh">钎焊涂层</rdfs:label>
        <skos:definition xml:lang="en">A coating process that involves applying a coating using soldering techniques.</skos:definition> <skos:definition xml:lang="zh">一种使用钎焊技术施加涂层的涂层工艺。</skos:definition>
        <skos:definition xml:lang="de">Ein Beschichtungsprozess, der das Auftragen einer Beschichtung mittels Löten beinhaltet.</skos:definition> <skos:definition xml:lang="zh">一种通过焊接涂覆涂层的涂覆过程。</skos:definition>
        <skos:example xml:lang="en">Applying a protective solder layer on electronic circuit boards.</skos:example> <skos:example xml:lang="zh">在电子电路板上施加保护性焊料层。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000566 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000566">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000563"/>
        <rdfs:label xml:lang="de">Beschichten Durch Schweissen</rdfs:label> <rdfs:label xml:lang="zh">通过焊接进行涂覆</rdfs:label>
        <rdfs:label xml:lang="en">coating by welding</rdfs:label> <rdfs:label xml:lang="zh">焊接涂层</rdfs:label>
        <skos:definition xml:lang="en">A coating process that involves applying a coating using welding techniques.</skos:definition> <skos:definition xml:lang="zh">一种使用焊接技术施加涂层的涂层工艺。</skos:definition>
        <skos:definition xml:lang="de">Ein Beschichtungsprozess, der das Auftragen einer Beschichtung mittels Schweißen beinhaltet.</skos:definition> <skos:definition xml:lang="zh">一种涉及通过焊接施加涂层的涂覆工艺。</skos:definition>
        <skos:example xml:lang="en">Cladding a metal surface with a corrosion-resistant alloy using weld overlay.</skos:example> <skos:example xml:lang="zh">使用堆焊层将耐腐蚀合金包覆在金属表面。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000567 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000567">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000602"/>
        <rdfs:label xml:lang="de">Beschichtungsgerät</rdfs:label> <rdfs:label xml:lang="zh">涂覆设备</rdfs:label>
        <rdfs:label xml:lang="en">coating device</rdfs:label> <rdfs:label xml:lang="zh">涂层设备</rdfs:label>
        <skos:definition xml:lang="en">A device used for applying a coating or layer to materials to enhance their properties or appearance.</skos:definition> <skos:definition xml:lang="zh">一种用于在材料上施加涂层或层以增强其性能或外观的设备。</skos:definition>
        <skos:definition xml:lang="de">Ein Gerät zum Auftragen einer Beschichtung oder Schicht auf Materialien zur Verbesserung ihrer Eigenschaften oder ihres Aussehens.</skos:definition> <skos:definition xml:lang="zh">一种用于在材料上施加涂层或层以改善其性能或外观的设备。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000569 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000569">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000563"/>
        <rdfs:label xml:lang="de">Beschichten Aus Dem Gasförmigen Oder Dampfförmigen Zustand</rdfs:label> <rdfs:label xml:lang="zh">从气态或蒸气态涂覆</rdfs:label>
        <rdfs:label xml:lang="en">coating from the gaseous or vapour state</rdfs:label> <rdfs:label xml:lang="zh">气态或蒸汽态涂层</rdfs:label>
        <skos:altLabel xml:lang="de">Vakuumbeschichten</skos:altLabel> <skos:altLabel xml:lang="zh">真空涂覆</skos:altLabel>
        <skos:definition xml:lang="en">A coating process that involves applying a coating from a gaseous or vapor state.</skos:definition> <skos:definition xml:lang="zh">一种从气态或蒸汽态施加涂层的涂层工艺。</skos:definition>
        <skos:definition xml:lang="de">Ein Beschichtungsprozess, der das Auftragen einer Beschichtung aus einem gasförmigen oder dampfförmigen Zustand beinhaltet.</skos:definition> <skos:definition xml:lang="zh">一种涉及从气态或蒸气态施加涂层的涂覆工艺。</skos:definition>
        <skos:example xml:lang="en">Applying a thin film of material using chemical vapor deposition (CVD).</skos:example> <skos:example xml:lang="zh">使用化学气相沉积（CVD）施加材料薄膜。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000570 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000570">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000563"/>
        <rdfs:label xml:lang="de">Beschichten Aus Dem Körnigen Oder Pulverförmigen Zustand</rdfs:label> <rdfs:label xml:lang="zh">从颗粒或粉末态涂覆</rdfs:label>
        <rdfs:label xml:lang="en">coating from the granular or powdery state</rdfs:label> <rdfs:label xml:lang="zh">颗粒态或粉末态涂层</rdfs:label>
        <skos:definition xml:lang="en">A coating process that involves applying a coating from a granular or powdery state.</skos:definition> <skos:definition xml:lang="zh">一种从颗粒态或粉末态施加涂层的涂层工艺。</skos:definition>
        <skos:definition xml:lang="de">Ein Beschichtungsprozess, der das Auftragen einer Beschichtung aus einem körnigen oder pulverförmigen Zustand beinhaltet.</skos:definition> <skos:definition xml:lang="zh">一种涉及从颗粒或粉末态施加涂层的涂覆工艺。</skos:definition>
        <skos:example xml:lang="en">Powder coating of metal parts.</skos:example> <skos:example xml:lang="zh">金属部件的粉末喷涂</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000571 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000571">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000563"/>
        <rdfs:label xml:lang="de">Beschichten Aus Dem Ionisierten Zustand</rdfs:label> <rdfs:label xml:lang="zh">从电离态涂覆</rdfs:label>
        <rdfs:label xml:lang="en">coating from the ionized state</rdfs:label> <rdfs:label xml:lang="zh">从电离状态涂覆</rdfs:label>
        <skos:definition xml:lang="en">A coating process that involves applying a coating from an ionized state.</skos:definition> <skos:definition xml:lang="zh">一种涉及从电离状态施加涂层的涂覆工艺。</skos:definition>
        <skos:definition xml:lang="de">Ein Beschichtungsprozess, der das Auftragen einer Beschichtung aus einem ionisierten Zustand beinhaltet.</skos:definition> <skos:definition xml:lang="zh">一种涉及从电离态施加涂层的涂覆工艺。</skos:definition>
        <skos:example xml:lang="en">Plasma spraying of ceramic coatings.</skos:example> <skos:example xml:lang="zh">陶瓷涂层的等离子喷涂</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000572 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000572">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000563"/>
        <rdfs:label xml:lang="de">Beschichten Aus Dem Flüssigen Zustand</rdfs:label> <rdfs:label xml:lang="zh">液态涂覆</rdfs:label>
        <rdfs:label xml:lang="en">coating from the liquid state</rdfs:label> <rdfs:label xml:lang="zh">从液态涂覆</rdfs:label>
        <skos:definition xml:lang="en">A coating process that involves applying a coating from a liquid state.</skos:definition> <skos:definition xml:lang="zh">一种涉及从液态施加涂层的涂覆工艺。</skos:definition>
        <skos:definition xml:lang="de">Ein Beschichtungsprozess, der das Auftragen einer Beschichtung aus einem flüssigen Zustand beinhaltet.</skos:definition> <skos:definition xml:lang="zh">一种涂覆工艺，涉及从液态施加涂层。</skos:definition>
        <skos:example xml:lang="en">Electroplating of metals.</skos:example> <skos:example xml:lang="zh">金属电镀</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000573 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000573">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000563"/>
        <rdfs:label xml:lang="de">Beschichten Aus Dem Plastischen Zustand</rdfs:label> <rdfs:label xml:lang="zh">塑性状态涂覆</rdfs:label>
        <rdfs:label xml:lang="en">coating from the plastic state</rdfs:label> <rdfs:label xml:lang="zh">从塑性状态涂覆</rdfs:label>
        <skos:definition xml:lang="en">A coating process that involves applying a coating from a plastic state.</skos:definition> <skos:definition xml:lang="zh">一种涉及从塑性状态施加涂层的涂覆工艺。</skos:definition>
        <skos:definition xml:lang="de">Ein Beschichtungsprozess, der das Auftragen einer Beschichtung aus einem plastischen Zustand beinhaltet.</skos:definition> <skos:definition xml:lang="zh">一种涂覆工艺，涉及从塑性状态施加涂层。</skos:definition>
        <skos:example xml:lang="en">Applying a plastic film through hot melt coating.</skos:example> <skos:example xml:lang="zh">通过热熔涂覆施加塑料薄膜</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000574 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000574">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000563"/>
        <rdfs:label xml:lang="de">Beschichten Aus Dem Breiigen Oder Pastösen Zustand</rdfs:label> <rdfs:label xml:lang="zh">糊状或膏状涂覆</rdfs:label>
        <rdfs:label xml:lang="en">coating from the pulpy or pasty state</rdfs:label> <rdfs:label xml:lang="zh">从浆状或糊状状态涂覆</rdfs:label>
        <skos:definition xml:lang="en">A coating process that involves applying a coating from a pulpy or pasty state.</skos:definition> <skos:definition xml:lang="zh">一种涉及从浆状或糊状状态施加涂层的涂覆工艺。</skos:definition>
        <skos:definition xml:lang="de">Ein Beschichtungsprozess, der das Auftragen einer Beschichtung aus einem breiigen oder pastösen Zustand beinhaltet.</skos:definition> <skos:definition xml:lang="zh">一种涂覆工艺，涉及从糊状或膏状状态施加涂层。</skos:definition>
        <skos:example xml:lang="en">Painting, a protective layer of plaster on walls.</skos:example> <skos:example xml:lang="zh">涂刷，墙上的保护性灰泥层</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000575 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000575">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000034"/>
        <rdfs:label xml:lang="de">Beschichtungsfunktion</rdfs:label> <rdfs:label xml:lang="zh">涂覆功能</rdfs:label>
        <rdfs:label xml:lang="en">coating function</rdfs:label> <rdfs:label xml:lang="zh">涂覆功能</rdfs:label>
        <skos:definition xml:lang="en">A function performed to apply a layer or coating to a surface to enhance its properties or appearance.</skos:definition> <skos:definition xml:lang="zh">一种用于在表面上施加层或涂层以改善其性能或外观的功能。</skos:definition>
        <skos:definition xml:lang="de">Eine Funktion, die ausgeführt wird, um eine Schicht oder Beschichtung auf eine Oberfläche aufzutragen, um deren Eigenschaften oder Aussehen zu verbessern.</skos:definition> <skos:definition xml:lang="zh">一种用于在表面上施加层或涂层以改善其性能或外观的功能。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000576 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000576">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000602"/>
        <rdfs:label xml:lang="de">Farbmessgerät</rdfs:label> <rdfs:label xml:lang="zh">颜色测量仪</rdfs:label>
        <rdfs:label xml:lang="en">colorimeter</rdfs:label> <rdfs:label xml:lang="zh">色度计</rdfs:label>
        <skos:definition xml:lang="en">A device used to measure the color of a sample, often used in quality control and material analysis.</skos:definition> <skos:definition xml:lang="zh">一种用于测量样品颜色的设备，常用于质量控制和材料分析。</skos:definition>
        <skos:definition xml:lang="de">Ein Gerät zur Messung der Farbe einer Probe, häufig verwendet in der Qualitätskontrolle und Materialanalyse.</skos:definition> <skos:definition xml:lang="zh">一种用于测量样品颜色的设备，常用于质量控制和材料分析。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000577 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000577">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000890"/>
        <rdfs:label xml:lang="en">composite</rdfs:label> <rdfs:label xml:lang="zh">复合材料</rdfs:label>
        <skos:definition xml:lang="en">An object aggregate that consists of two or more bonded materials with dissimilar physical or chemical properties which are used to complement each other where the parts remain seperate and distinct in the resulting object aggregate.</skos:definition> <skos:definition xml:lang="zh">一种由两种或多种具有不同物理或化学性质的粘结材料组成的物体聚合体，它们相互补充，并且在最终物体聚合体中各部分保持分离和独立。</skos:definition>
        <skos:example xml:lang="en">carbon fibre reinforced polymer
laminated glass
wood
hard metal composites for abrasive tools</skos:example> <skos:example xml:lang="zh">碳纤维增强聚合物
夹层玻璃
木材
用于磨具的硬质合金复合材料</skos:example>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000578 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000578">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000806"/>
        <obo:IAO_0000119 xml:lang="en">Official definition can be found in: DIN 8593-1</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">官方定义见：DIN 8593-1</obo:IAO_0000119>
        <obo:IAO_0000119 xml:lang="de">Offizielle Definition findet man in: DIN 8593-1</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">官方定义见：DIN 8593-1</obo:IAO_0000119>
        <rdfs:label xml:lang="de">Zusammensetzen</rdfs:label> <rdfs:label xml:lang="zh">组装</rdfs:label>
        <rdfs:label xml:lang="en">compounding</rdfs:label> <rdfs:label xml:lang="zh">复合</rdfs:label>
        <skos:altLabel xml:lang="en">Putting Together</skos:altLabel> <skos:altLabel xml:lang="zh">装配</skos:altLabel>
        <skos:definition xml:lang="en">A joining process that involves assembling various components or sub-assemblies to form a complex unit, commonly used in manufacturing processes where multiple parts are put together to create a final product.</skos:definition> <skos:definition xml:lang="zh">一种涉及组装各种部件或子组件以形成复杂单元的连接过程，常用于多个零件组合在一起以创建最终产品的制造过程中。</skos:definition>
        <skos:definition xml:lang="de">Ein Füge Prozess, bei dem verschiedene Komponenten oder Unterbaugruppen zu einer komplexen Einheit zusammengefügt werden. Es wird üblicherweise in Fertigungsprozessen verwendet, bei denen mehrere Teile zu einem Endprodukt zusammengefügt werden.</skos:definition> <skos:definition xml:lang="zh">一种连接过程，将不同的组件或子组件连接成一个复杂的单元。通常用于制造过程中，将多个零件组装成最终产品。</skos:definition>
        <skos:example xml:lang="en">Interlocking, Layering</skos:example> <skos:example xml:lang="zh">互锁、分层</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000579 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000579">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000602"/>
        <rdfs:label xml:lang="de">Compoundiermaschine</rdfs:label> <rdfs:label xml:lang="zh">混合机</rdfs:label>
        <rdfs:label xml:lang="en">compounding machine</rdfs:label> <rdfs:label xml:lang="zh">复合机</rdfs:label>
        <skos:definition xml:lang="en">A device used for mixing or compounding materials to achieve desired properties.</skos:definition> <skos:definition xml:lang="zh">一种用于混合或复合材料以达到所需性能的设备。</skos:definition>
        <skos:definition xml:lang="de">Ein Gerät zur Mischung oder Compoundierung von Materialien, um gewünschte Eigenschaften zu erreichen.</skos:definition> <skos:definition xml:lang="zh">一种用于混合或复合材料的设备，以实现所需的性能。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000580 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000580">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000602"/>
        <rdfs:label xml:lang="de">Druckprüfmaschine</rdfs:label> <rdfs:label xml:lang="zh">压力试验机</rdfs:label>
        <rdfs:label xml:lang="en">compression testing machine</rdfs:label> <rdfs:label xml:lang="zh">压缩试验机</rdfs:label>
        <skos:definition xml:lang="en">A device used to test the compressive strength of materials by applying a compressive force.</skos:definition> <skos:definition xml:lang="zh">一种通过施加压缩力来测试材料抗压强度的设备。</skos:definition>
        <skos:definition xml:lang="de">Ein Gerät zur Prüfung der Druckfestigkeit von Materialien durch Anwendung einer Druckkraft.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000581 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000581">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000849"/>
        <rdfs:label xml:lang="de">Druckprüfverfahren</rdfs:label> <rdfs:label xml:lang="zh">压力试验方法</rdfs:label>
        <rdfs:label xml:lang="en">compression testing process</rdfs:label> <rdfs:label xml:lang="zh">压缩试验过程</rdfs:label>
        <skos:definition xml:lang="en">A mechanical property analyzing processs that determines a material's behavior under compressive forces, measuring its compressive strength and modulus.</skos:definition> <skos:definition xml:lang="zh">一种力学性能分析过程，通过压缩力测定材料的行为，测量其抗压强度和压缩模量。</skos:definition>
        <skos:definition xml:lang="de">Ein Mechanische Eigenschaften Analyseverfahren, das das Verhalten eines Materials unter Druckkräften bestimmt und seine Druckfestigkeit und seinen Druckmodul misst.</skos:definition> <skos:definition xml:lang="zh">一种机械性能分析方法，用于确定材料在压力作用下的行为，并测量其抗压强度和压缩模量。</skos:definition>
        <skos:example xml:lang="en">Compression testing of concrete samples to ensure they meet the required strength standards for construction.</skos:example> <skos:example xml:lang="zh">混凝土试样的压缩测试，以确保其符合建筑所需的强度标准。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000582 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000582">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000602"/>
        <rdfs:label xml:lang="de">Computer</rdfs:label> <rdfs:label xml:lang="zh">计算机</rdfs:label>
        <rdfs:label xml:lang="en">computing device</rdfs:label> <rdfs:label xml:lang="zh">计算设备</rdfs:label>
        <skos:definition xml:lang="en">A device that provides an execution environment for, e.g., simulation processes or prediction models.
A computing system can be virtual (e.g., a container or virtual machine) or physical (e.g., a bare-metal servers), uses digital representations of objects as inputs and produces digital measurements, such as simulation results or predictions, as outputs.</skos:definition> <skos:definition xml:lang="zh">一种为例如仿真过程或预测模型提供执行环境的设备。计算系统可以是虚拟的（例如容器或虚拟机）或物理的（例如裸金属服务器），使用对象的数字表示作为输入，并产生数字测量结果，例如仿真结果或预测，作为输出。</skos:definition>
        <skos:definition xml:lang="de">Ein Gerät, das eine Ausführungsumgebung bspw. für Simulationsprozesse oder Vorhersagemodelle bereitstellt.
Ein Rechenknoten kann virtuell (bspw. ein Container oder eine virtuelle Maschine) oder physisch (z. B. ein Bare-Metal-Server) ausgestaltet sein und verwendet in der Regel digitale Repräsentationen von Objekten als Eingaben und erzeugt digitale Messungen, wie z.B. Simulationsergebnisse oder Vorhersagen, als Ausgaben.</skos:definition> <skos:definition xml:lang="zh">一种提供执行环境的设备，例如用于模拟过程或预测模型。
计算节点可以是虚拟的（例如容器或虚拟机）或物理的（例如裸机服务器），通常使用对象的数字表示作为输入，并生成数字测量值，例如模拟结果或预测，作为输出。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000583 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000583">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/COB_0000035"/>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000293"/>
                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/IAO_0000030"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000299"/>
                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/IAO_0000030"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <obo:IAO_0000116 xml:lang="en">The subclass trees of "Computing Process" are currently still proposals and serve as a working basis for the discussion round with the simulation/workflow domain experts.</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">“计算过程”的子类树目前仍是提案，并作为与仿真/工作流领域专家讨论的基础。</obo:IAO_0000116>
        <rdfs:label xml:lang="de">Datenverarbeitung</rdfs:label> <rdfs:label xml:lang="zh">数据处理</rdfs:label>
        <rdfs:label xml:lang="de">Rechenprozess</rdfs:label> <rdfs:label xml:lang="zh">计算过程</rdfs:label>
        <rdfs:label xml:lang="en">computing process</rdfs:label> <rdfs:label xml:lang="zh">计算过程</rdfs:label>
        <skos:definition xml:lang="en">A process that involves the systematic use of computational methods and tools to perform simulations, analyses, or data transformations to achieve specific scientific or engineering goals.</skos:definition> <skos:definition xml:lang="zh">一种过程，涉及系统性地使用计算方法与工具来执行仿真、分析或数据转换，以实现特定的科学或工程目标。</skos:definition>
        <skos:definition xml:lang="de">Ein Prozess, der die systematische Verwendung von rechnerischen Methoden und Werkzeugen umfasst, um Simulationen, Analysen oder Datenumwandlungen durchzuführen, um spezifische wissenschaftliche oder technische Ziele zu erreichen.</skos:definition> <skos:definition xml:lang="zh">一个过程，包括系统性地使用计算方法和工具，进行模拟、分析或数据转换，以实现特定的科学或技术目标。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000584 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000584">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000833"/>
        <rdfs:label xml:lang="de">Konditionierungsprozess</rdfs:label> <rdfs:label xml:lang="zh">调节过程</rdfs:label>
        <rdfs:label xml:lang="en">conditioning process</rdfs:label> <rdfs:label xml:lang="zh">调节过程</rdfs:label>
        <skos:definition xml:lang="en">A conditioning process is a manufacturing process that sets a material entity to predefined environmental conditions.</skos:definition> <skos:definition xml:lang="zh">调节过程是一种制造过程，将材料实体设定为预定义的环境条件。</skos:definition>
        <skos:definition xml:lang="de">Diese Aktivität beschreibt den Prozess und die Maßnahmen, die ergriffen werden, um einen materiellen Gegenstand auf vordefinierte Umgebungsbedingungen einzustellen.</skos:definition> <skos:definition xml:lang="zh">此活动描述了为使一个物质对象适应预定义环境条件而采取的过程和措施。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000585 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000585">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000931"/>
        <rdfs:label xml:lang="en">continuous simulation</rdfs:label> <rdfs:label xml:lang="zh">连续仿真</rdfs:label>
        <skos:definition xml:lang="en">A simulation method specification where changes in a system are modeled continuously over time.</skos:definition> <skos:definition xml:lang="zh">一种仿真方法规范，其中系统的变化随时间连续建模。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000586 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000586">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000802"/>
        <rdfs:label xml:lang="en">absorption of corpuscular radiation</rdfs:label> <rdfs:label xml:lang="zh">粒子辐射吸收</rdfs:label>
        <skos:definition xml:lang="en">process of taking up corpuscular radiation by a material entity</skos:definition> <skos:definition xml:lang="zh">材料实体吸收粒子辐射的过程</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000587 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000587">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000635"/>
        <rdfs:label xml:lang="en">crack growth</rdfs:label> <rdfs:label xml:lang="zh">裂纹扩展</rdfs:label>
        <skos:definition xml:lang="en">The crack growth is an evolution of damage describing the progressive extension of a crack in a material under stress.</skos:definition> <skos:definition xml:lang="zh">裂纹扩展是一种损伤演化，描述材料在应力作用下裂纹的逐渐延伸。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000588 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000588">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000602"/>
        <rdfs:label xml:lang="de">Kriechprüfmaschine</rdfs:label> <rdfs:label xml:lang="zh">蠕变试验机</rdfs:label>
        <rdfs:label xml:lang="en">creep testing machine</rdfs:label> <rdfs:label xml:lang="zh">蠕变试验机</rdfs:label>
        <skos:definition xml:lang="en">A device used to test the creep behavior of materials under constant stress at high temperatures.</skos:definition> <skos:definition xml:lang="zh">用于在高温和恒定应力下测试材料蠕变行为的设备。</skos:definition>
        <skos:definition xml:lang="de">Ein Gerät zur Prüfung des Kriechverhaltens von Materialien unter konstanter Belastung bei hohen Temperaturen.</skos:definition> <skos:definition xml:lang="zh">一种用于测试材料在高温下恒定载荷下蠕变行为的设备。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000589 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000589">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000849"/>
        <rdfs:label xml:lang="de">Kriechprüfverfahren</rdfs:label> <rdfs:label xml:lang="zh">蠕变试验方法</rdfs:label>
        <rdfs:label xml:lang="en">creep testing process</rdfs:label> <rdfs:label xml:lang="zh">蠕变测试过程</rdfs:label>
        <skos:definition xml:lang="en">A mechanical property analyzing process that evaluates a material's deformation over time under constant stress and temperature, determining its creep behavior.</skos:definition> <skos:definition xml:lang="zh">一种机械性能分析过程，评估材料在恒定应力和温度下随时间变化的变形，从而确定其蠕变行为。</skos:definition>
        <skos:definition xml:lang="de">Ein Mechanische Eigenschaften Analyseverfahren, das die Verformung eines Materials über die Zeit unter konstanter Belastung und Temperatur bewertet und sein Kriechverhalten bestimmt.</skos:definition> <skos:definition xml:lang="zh">一种机械性能分析方法，评估材料在恒定载荷和温度下随时间变化的变形，并确定其蠕变行为。</skos:definition>
        <skos:example xml:lang="en">Creep testing of turbine blades to ensure they can withstand prolonged high temperatures without deforming.</skos:example> <skos:example xml:lang="zh">对涡轮叶片进行蠕变测试，以确保其能够承受长时间高温而不变形。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000590 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000590">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000968"/>
        <rdfs:label xml:lang="de">Kryogefrierschrank</rdfs:label> <rdfs:label xml:lang="zh">低温冷冻柜</rdfs:label>
        <rdfs:label xml:lang="en">cryogenic freezer</rdfs:label> <rdfs:label xml:lang="zh">低温冷冻箱</rdfs:label>
        <skos:definition xml:lang="en">A cryogenic freezer is a temperature change device that preserves materials at extremely low temperatures, often below -150°C.</skos:definition> <skos:definition xml:lang="zh">低温冷冻箱是一种温度变化设备，用于在极低温度（通常低于-150°C）下保存材料。</skos:definition>
        <skos:definition xml:lang="en">A device used to preserve materials at extremely low temperatures, typically below -150°C.</skos:definition> <skos:definition xml:lang="zh">一种用于在极低温度（通常低于-150°C）下保存材料的设备。</skos:definition>
        <skos:definition xml:lang="de">Ein Gerät, das verwendet wird, um Materialien bei extrem niedrigen Temperaturen zu konservieren, typischerweise unter -150°C.</skos:definition> <skos:definition xml:lang="zh">一种用于在极低温度（通常低于-150°C）下保存材料的设备。</skos:definition>
        <skos:definition xml:lang="de">Ein Kryogefrierschrank ist ein Temperaturwechselgerät, das Materialien bei extrem niedrigen Temperaturen konserviert, oft unter -150°C.</skos:definition> <skos:definition xml:lang="zh">低温冷冻柜是一种温度变化设备，用于在极低温度（通常低于-150°C）下保存材料。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000591 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000591">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/pmd/co/PMD_0000077"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/pmd/co/PMD_0020099"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020131"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/pmd/co/PMD_0000077"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020099"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">The finite set of periodic geometric arrangements is described e.g. by the 14 possible Bravais Lattices in three-dimensional space.</rdfs:comment>
        <rdfs:label xml:lang="en">crystal structure</rdfs:label> <rdfs:label xml:lang="zh">晶体结构</rdfs:label>
        <skos:definition xml:lang="en">an intensive qualtty of a crystal that embodies the periodic geometric arrangement of entities in a crystal lattice.</skos:definition> <skos:definition xml:lang="zh">晶体的一个强度性质，体现了晶格中实体的周期性几何排列。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000592 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000592">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000034"/>
        <rdfs:label xml:lang="de">Trennen Funktion</rdfs:label> <rdfs:label xml:lang="zh">分离功能</rdfs:label>
        <rdfs:label xml:lang="en">cut function</rdfs:label> <rdfs:label xml:lang="zh">切割功能</rdfs:label>
        <skos:altLabel xml:lang="de">Schneidfunktion</skos:altLabel> <skos:altLabel xml:lang="zh">切割功能</skos:altLabel>
        <skos:definition xml:lang="en">A function performed to separate or divide materials using cutting devices.</skos:definition> <skos:definition xml:lang="zh">使用切割设备分离或分割材料的功能。</skos:definition>
        <skos:definition xml:lang="de">Eine Funktion, die ausgeführt wird, um Materialien mit Schneidgeräten zu trennen oder zu teilen.</skos:definition> <skos:definition xml:lang="zh">一种使用切割设备对材料进行分离或分割的功能。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000594 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000594">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000933"/>
        <rdfs:label xml:lang="de">Deep Learning</rdfs:label> <rdfs:label xml:lang="zh">深度学习</rdfs:label>
        <rdfs:label xml:lang="en">deep learning</rdfs:label> <rdfs:label xml:lang="zh">深度学习</rdfs:label>
        <skos:definition xml:lang="en">A simulation process that employs artificial neural networks with many layers to model complex patterns in data.</skos:definition> <skos:definition xml:lang="zh">一种使用多层人工神经网络对数据中的复杂模式进行建模的模拟过程。</skos:definition>
        <skos:definition xml:lang="de">Ein Simulationsprozess, der künstliche neuronale Netze mit vielen Schichten verwendet, um komplexe Muster in Daten zu modellieren.</skos:definition> <skos:definition xml:lang="zh">一种使用多层人工神经网络对数据中的复杂模式进行建模的模拟过程。</skos:definition>
        <skos:example xml:lang="en">Using deep learning to predict the formation of defects in crystalline materials.</skos:example> <skos:example xml:lang="zh">利用深度学习预测晶体材料中缺陷的形成。</skos:example>
        <PMD_0050117>DL</PMD_0050117>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000595 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000595">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020131"/>
        <rdfs:label xml:lang="en">defect density</rdfs:label> <rdfs:label xml:lang="zh">一种表示材料中单位体积或面积内缺陷数量的强度性质，可影响其力学和电子特性。</rdfs:label>
        <skos:definition xml:lang="en">an intensive quality describing the number of defects per unit volume or area in a material, which can affect its mechanical and electronic properties</skos:definition> <skos:definition xml:lang="zh">一种描述材料单位体积或面积内缺陷数量的强度性质，可能影响其力学和电子性能。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000596 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000596">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:label xml:lang="en">deformation</rdfs:label> <rdfs:label xml:lang="zh">变形是指在应力或力的作用下，材料形状、尺寸或结构发生变化的过程。</rdfs:label>
        <skos:definition xml:lang="en">The deformation is a process describing a change in the shape, size, or structure of a material often under the influence of stress or force.</skos:definition> <skos:definition xml:lang="zh">变形是描述材料在应力或力作用下形状、尺寸或结构变化的过程。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000597 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000597">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020131"/>
        <rdfs:label xml:lang="en">density</rdfs:label> <rdfs:label xml:lang="zh">密度是一种通用的强度性质，表示单位体积内物质的质量。</rdfs:label>
        <skos:definition xml:lang="en">The density is a universal intensive quality representing the unit mass of a portion of matter per unit volume.</skos:definition> <skos:definition xml:lang="zh">密度是一种普遍的强度性质，表示单位体积物质的质量。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000601 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000601">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000931"/>
        <rdfs:label xml:lang="en">deterministic simulation</rdfs:label> <rdfs:label xml:lang="zh">一种模拟方法规范，其中结果通过已知关系精确确定，无随机变化。</rdfs:label>
        <skos:definition xml:lang="en">A simulation method specification where outcomes are precisely determined through known relationships without random variability.</skos:definition> <skos:definition xml:lang="zh">一种模拟方法规范，其中结果通过已知关系精确确定，无随机变量。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000602 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000602">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
        <rdfs:label xml:lang="de">Gerät</rdfs:label>
        <rdfs:label xml:lang="en">device</rdfs:label> <rdfs:label xml:lang="zh">装置是一种设计用于执行特定功能或任务的对象，涉及测量、操作、处理或分析。</rdfs:label>
        <skos:definition xml:lang="en">A device is an object that is designed to perform a specific function or task involving measurement, manipulation, processing, or analysis.</skos:definition> <skos:definition xml:lang="zh">设备是一种对象，旨在执行涉及测量、操作、处理或分析的特定功能或任务。</skos:definition>
        <skos:definition xml:lang="de">Ein physisches oder virtuelles Objekt, das verwendet wird, um eine bestimmte Funktion oder Aufgabe auszuführen, häufig im Zusammenhang mit der Messung, Manipulation oder Analyse von Materialien.</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000603 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000603">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000023"/>
        <rdfs:label xml:lang="de">Rolle eines Gerätes</rdfs:label>
        <rdfs:label xml:lang="en">device role</rdfs:label> <rdfs:label xml:lang="zh">设备角色</rdfs:label>
        <skos:definition xml:lang="de">Rolle, die ein Geräte inne haben kann.</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000604 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000604">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000621"/>
        <owl:disjointWith rdf:resource="https://w3id.org/pmd/co/PMD_0000620"/>
        <rdfs:label xml:lang="en">dielectric constant</rdfs:label> <rdfs:label xml:lang="zh">介电常数是一种电学性质，表示材料在电场中储存电能能力的度量。</rdfs:label>
        <skos:definition xml:lang="en">The dielectric constant is an electrical property representing a measure of a material's ability to store electrical energy in an electric field.</skos:definition> <skos:definition xml:lang="zh">介电常数是一种电学性质，表示材料在电场中储存电能能力的度量。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000605 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000605">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000602"/>
        <rdfs:label xml:lang="de">Differential-Scanning-Kalorimeter</rdfs:label>
        <rdfs:label xml:lang="en">differential scanning calorimeter</rdfs:label> <rdfs:label xml:lang="zh">一种用于测量样品中与相变相关的热流量作为温度函数的装置。</rdfs:label>
        <skos:definition xml:lang="en">A device used to measure the heat flow associated with phase transitions in a sample as a function of temperature.</skos:definition> <skos:definition xml:lang="zh">一种用于测量样品中与相变相关的热流随温度变化的设备。</skos:definition>
        <skos:definition xml:lang="de">Ein Gerät zur Messung des Wärmeflusses, der mit Phasenübergängen in einer Probe in Abhängigkeit von der Temperatur verbunden ist.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000606 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000606">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000982"/>
        <rdfs:label xml:lang="de">Dynamische Differenzkalorimetrie-Verfahren</rdfs:label> <rdfs:label xml:lang="zh">动态差示量热法</rdfs:label>
        <rdfs:label xml:lang="en">differential scanning calorimetry process</rdfs:label> <rdfs:label xml:lang="zh">一种热性能分析过程，测量材料在加热、冷却或恒温过程中流入或流出的热流量，确定其热转变，如熔化、结晶和玻璃化转变。</rdfs:label>
        <skos:definition xml:lang="en">A thermal property analyzing process that measures the heat flow into or out of a material as it is heated, cooled, or held at a constant temperature, determining its thermal transitions such as melting, crystallization, and glass transitions.</skos:definition> <skos:definition xml:lang="zh">一种热性能分析过程，测量材料在加热、冷却或恒温过程中流入或流出的热流，确定其热转变，如熔化、结晶和玻璃化转变。</skos:definition>
        <skos:definition xml:lang="de">Ein Thermische Eigenschaften Analyseverfahren, das den Wärmestrom in oder aus einem Material misst, während es erhitzt, gekühlt oder bei konstanter Temperatur gehalten wird, um seine thermischen Übergänge wie Schmelzen, Kristallisation und Glasübergänge zu bestimmen.</skos:definition> <skos:definition xml:lang="zh">一种热特性分析方法，测量材料在加热、冷却或恒温过程中流入或流出的热流，以确定其热转变，如熔化、结晶和玻璃化转变。</skos:definition>
        <skos:example xml:lang="en">Differential scanning calorimetry of a polymer to determine its melting temperature and crystallization behavior.</skos:example> <skos:example xml:lang="zh">差示扫描量热法测定聚合物的熔融温度和结晶行为</skos:example>
        <PMD_0050117 xml:lang="en">DSC</PMD_0050117>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000607 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000607">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000982"/>
        <rdfs:label xml:lang="de">Differenzthermoanalyse-Verfahren</rdfs:label> <rdfs:label xml:lang="zh">差热分析法</rdfs:label>
        <rdfs:label xml:lang="en">differential thermal analysis process</rdfs:label> <rdfs:label xml:lang="zh">差热分析过程</rdfs:label>
        <skos:definition xml:lang="en">A thermal property analyzing process that measures the temperature difference between a sample and a reference material as they are subjected to a controlled temperature program, identifying phase transitions and reactions.</skos:definition> <skos:definition xml:lang="zh">一种热性能分析过程，测量样品和参比材料在受控温度程序下的温差，识别相变和反应。</skos:definition>
        <skos:definition xml:lang="de">Ein Thermische Eigenschaften Analyseverfahren, das die Temperaturdifferenz zwischen einer Probe und einem Referenzmaterial misst, während sie einem kontrollierten Temperaturprogramm unterzogen werden, um Phasenübergänge und Reaktionen zu identifizieren.</skos:definition> <skos:definition xml:lang="zh">一种热特性分析方法，测量样品和参比材料在受控温度程序下的温差，以识别相变和反应。</skos:definition>
        <skos:example xml:lang="en">Differential thermal analysis of a ceramic material to identify its phase transition temperatures and reaction kinetics.</skos:example> <skos:example xml:lang="zh">差热分析陶瓷材料以识别其相变温度和反应动力学</skos:example>
        <PMD_0050117 xml:lang="en">DTA</PMD_0050117>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000608 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000608">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000602"/>
        <rdfs:label xml:lang="de">Differentialthermometer</rdfs:label> <rdfs:label xml:lang="zh">差示温度计</rdfs:label>
        <rdfs:label xml:lang="en">differential thermal analyzer</rdfs:label> <rdfs:label xml:lang="zh">差热分析仪</rdfs:label>
        <skos:definition xml:lang="en">A device used to measure the temperature difference between a sample and a reference material as they are heated or cooled.</skos:definition> <skos:definition xml:lang="zh">一种用于测量样品和参比材料在加热或冷却时温差的装置。</skos:definition>
        <skos:definition xml:lang="de">Ein Gerät zur Messung des Temperaturunterschieds zwischen einer Probe und einem Referenzmaterial beim Erhitzen oder Abkühlen.</skos:definition> <skos:definition xml:lang="zh">一种用于测量加热或冷却过程中样品和参比材料温度差的装置。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000610 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000610">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000847"/>
        <rdfs:label xml:lang="de">Dimensionierungsfunktion</rdfs:label> <rdfs:label xml:lang="zh">尺寸标注功能</rdfs:label>
        <rdfs:label xml:lang="en">dimension measuring function</rdfs:label> <rdfs:label xml:lang="zh">尺寸测量功能</rdfs:label>
        <skos:definition xml:lang="en">A measuring function performed to determine the dimensions of an object or material.</skos:definition> <skos:definition xml:lang="zh">一种用于确定物体或材料尺寸的测量功能。</skos:definition>
        <skos:definition xml:lang="de">Eine Messfunktion um die Abmessungen eines Objekts oder Materials zu bestimmen.</skos:definition> <skos:definition xml:lang="zh">一种测量功能，用于确定物体或材料的尺寸。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000611 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000611">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000957"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0009006"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020132"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="de">Dimensions Messprozess</rdfs:label> <rdfs:label xml:lang="zh">尺寸测量过程</rdfs:label>
        <rdfs:label xml:lang="en">dimension measuring process</rdfs:label> <rdfs:label xml:lang="zh">尺寸测量过程</rdfs:label>
        <skos:definition xml:lang="en">A structural property analyzing process that determines the physical dimensions of a material or object, such as length, width, height, diameter, and thickness, with high accuracy and precision.</skos:definition> <skos:definition xml:lang="zh">一种结构性能分析过程，以高精度和准确度确定材料或物体的物理尺寸，如长度、宽度、高度、直径和厚度。</skos:definition>
        <skos:definition xml:lang="de">Ein Struktur Eigenschaften Analyseverfahren, das die physikalischen Dimensionen eines Materials oder Objekts, wie Länge, Breite, Höhe, Durchmesser und Dicke, mit hoher Genauigkeit und Präzision bestimmt.</skos:definition> <skos:definition xml:lang="zh">一种结构特性分析方法，用于高精度、高精确度地确定材料或物体的物理尺寸，如长度、宽度、高度、直径和厚度。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000612 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000612">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000927"/>
        <obo:IAO_0000119 xml:lang="en">Official definition can be found in: DIN 8591</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">官方定义见：DIN 8591</obo:IAO_0000119>
        <obo:IAO_0000119 xml:lang="de">Offizielle Definition findet man in: DIN 8591</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">官方定义见：DIN 8591</obo:IAO_0000119>
        <rdfs:label xml:lang="de">Zerlegen</rdfs:label> <rdfs:label xml:lang="zh">拆卸</rdfs:label>
        <rdfs:label xml:lang="en">disassembling</rdfs:label> <rdfs:label xml:lang="zh">拆卸</rdfs:label>
        <skos:definition xml:lang="en">A separating process that involves disassembling a composite or assembled unit into its constituent parts or sections.</skos:definition> <skos:definition xml:lang="zh">一种分离过程，涉及将复合或组装单元分解为其组成部分或部分。</skos:definition>
        <skos:definition xml:lang="de">Ein Trennprozess, bei dem eine zusammengesetzte oder montierte Einheit in ihre Einzelteile oder Abschnitte zerlegt wird.</skos:definition> <skos:definition xml:lang="zh">一种分离过程，将组合或装配的单元拆解成其单个零件或部分。</skos:definition>
        <skos:example xml:lang="en">Dismantling, Emptying</skos:example> <skos:example xml:lang="zh">拆卸、清空</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000613 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000613">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000931"/>
        <rdfs:label xml:lang="en">discrete-event simulation</rdfs:label> <rdfs:label xml:lang="zh">离散事件仿真</rdfs:label>
        <skos:definition xml:lang="en">A simulation method specification where events are processed at distinct points in time, commonly used for modeling systems with discrete state changes.</skos:definition> <skos:definition xml:lang="zh">一种仿真方法规范，其中事件在离散的时间点处理，常用于建模具有离散状态变化的系统。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000614 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000614">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000927"/>
        <obo:IAO_0000119 xml:lang="en">Official definition can be found in: DIN 8588</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">官方定义可参见：DIN 8588</obo:IAO_0000119>
        <obo:IAO_0000119 xml:lang="de">Offizielle Definition findet man in: DIN 8588</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">官方定义见：DIN 8588</obo:IAO_0000119>
        <rdfs:label xml:lang="de">Zerteilen</rdfs:label> <rdfs:label xml:lang="zh">分割</rdfs:label>
        <rdfs:label xml:lang="en">dividing</rdfs:label> <rdfs:label xml:lang="zh">分割</rdfs:label>
        <skos:definition xml:lang="en">A separating process that involves separating material into distinct parts using techniques like shear cutting, splitting, tearing, or breaking, typically employed in processes where precise control over the cut is less critical.</skos:definition> <skos:definition xml:lang="zh">一种分离过程，涉及使用剪切、劈裂、撕裂或断裂等技术将材料分离成不同的部分，通常用于对切割精度要求不高的工艺中。</skos:definition>
        <skos:definition xml:lang="de">Ein Trennprozess, bei dem das Material durch Techniken wie Scherschneiden, Spalten, Reißen oder Brechen in verschiedene Teile zerlegt wird. Es wird in der Regel bei Prozessen eingesetzt, bei denen eine genaue Kontrolle über den Schnitt weniger wichtig ist.</skos:definition> <skos:definition xml:lang="zh">一种分离过程，通过剪切、劈裂、撕裂或断裂等技术将材料分割成不同部分。通常用于对切割精确控制要求不高的工艺中。</skos:definition>
        <skos:example xml:lang="en">Shearing, Cracking</skos:example> <skos:example xml:lang="zh">剪切，开裂</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000615 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000615">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000648"/>
        <rdfs:label xml:lang="de">Bohrmaschine</rdfs:label> <rdfs:label xml:lang="zh">钻床</rdfs:label>
        <rdfs:label xml:lang="en">drilling machine</rdfs:label> <rdfs:label xml:lang="zh">钻床</rdfs:label>
        <skos:definition xml:lang="en">A forming machine that creates holes in a workpiece by means of a rotating drill bit.</skos:definition> <skos:definition xml:lang="zh">一种通过旋转钻头在工作件上形成孔洞的成形机床。</skos:definition>
        <skos:definition xml:lang="de">Eine Formmaschine, die Löcher in einem Werkstück durch ein sich drehendes Bohrwerkzeug erzeugt.</skos:definition> <skos:definition xml:lang="zh">一种成形机床，通过旋转的钻孔工具在工件上形成孔。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000616 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000616">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000849"/>
        <rdfs:label xml:lang="de">Dynamisch-mechanische Analyse-Verfahren</rdfs:label> <rdfs:label xml:lang="zh">动态力学分析方法</rdfs:label>
        <rdfs:label xml:lang="en">dynamic mechanical analysis process</rdfs:label> <rdfs:label xml:lang="zh">动态力学分析过程</rdfs:label>
        <skos:definition xml:lang="en">A mechanical property analyzing process that measures the mechanical properties of a material as a function of temperature, time, frequency, and stress, determining its viscoelastic behavior.</skos:definition> <skos:definition xml:lang="zh">一种力学性能分析过程，测量材料的力学性能随温度、时间、频率和应力的变化，确定其粘弹性行为。</skos:definition>
        <skos:definition xml:lang="de">Ein Mechanische Eigenschaften Analyseverfahren, welcher die mechanischen Eigenschaften eines Materials in Abhängigkeit von Temperatur, Zeit, Frequenz und Spannung misst und dessen viskoelastisches Verhalten bestimmt.</skos:definition> <skos:definition xml:lang="zh">一种力学性能分析程序，用于测量材料在温度、时间、频率和应力作用下的力学性能，并确定其粘弹性行为。</skos:definition>
        <skos:example xml:lang="en">Dynamic mechanical analysis of a rubber compound to assess its stiffness and damping properties over a range of temperatures.</skos:example> <skos:example xml:lang="zh">对橡胶混合物进行动态力学分析，以评估其在温度范围内的刚度和阻尼特性。</skos:example>
        <PMD_0050117 xml:lang="en">DMA</PMD_0050117>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000617 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000617">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000602"/>
        <rdfs:label xml:lang="de">Dynamischer mechanischer Analysator</rdfs:label> <rdfs:label xml:lang="zh">动态力学分析仪</rdfs:label>
        <rdfs:label xml:lang="en">dynamic mechanical analyzer</rdfs:label> <rdfs:label xml:lang="zh">动态力学分析仪</rdfs:label>
        <skos:definition xml:lang="en">A device used to measure the mechanical properties of materials as a function of temperature, frequency, and time.</skos:definition> <skos:definition xml:lang="zh">一种用于测量材料力学性能随温度、频率和时间变化的设备。</skos:definition>
        <skos:definition xml:lang="de">Ein Gerät zur Messung der mechanischen Eigenschaften von Materialien als Funktion von Temperatur, Frequenz und Zeit.</skos:definition> <skos:definition xml:lang="zh">一种用于测量材料力学性能随温度、频率和时间变化的设备。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000618 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000618">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000949"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000052"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000027"/>
                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000030"/>
                            <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000538"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">elastic modulus</rdfs:label> <rdfs:label xml:lang="zh">弹性模量</rdfs:label>
        <skos:definition xml:lang="en">represents a material's stiffness, defined as the ratio of stress to strain in the elastic deformation region.</skos:definition> <skos:definition xml:lang="zh">表示材料的刚度，定义为弹性变形区域内应力与应变的比值。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000619 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000619">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020148"/>
        <rdfs:label xml:lang="en">electric potential</rdfs:label> <rdfs:label xml:lang="zh">电势</rdfs:label>
        <skos:definition xml:lang="en">an extensvie quality describing the amount of work needed to move a unit charge from a reference point to a specific location in an electric field.</skos:definition> <skos:definition xml:lang="zh">一种描述在电场中将单位电荷从参考点移动到特定位置所需功的广泛性质。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000620 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000620">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000621"/>
        <rdfs:label xml:lang="en">electrical conductivity</rdfs:label> <rdfs:label xml:lang="zh">电导率</rdfs:label>
        <skos:definition xml:lang="en">The electrical conductivity is an electrical property describing the ability of a material to conduct electric current, influenced by its structure and composition.</skos:definition> <skos:definition xml:lang="zh">电导率是一种电性质，描述材料传导电流的能力，受其结构和组成影响。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000621 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000621">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000005"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000519"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">electrical property</rdfs:label> <rdfs:label xml:lang="zh">电性质</rdfs:label>
        <skos:definition xml:lang="en">An electrical property is a material property that represents the characteristics of a material that determine its behavior under the influence of an electric field, such as conductivity, resistivity, and permittivity.</skos:definition> <skos:definition xml:lang="zh">电性质是一种材料性质，代表材料在电场作用下决定其行为的特性，如电导率、电阻率和介电常数。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000622 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000622">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBI_0000070"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0009006"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000621"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="de">Elektrische Eigenschaften Analyseverfahren</rdfs:label> <rdfs:label xml:lang="zh">电性能分析程序</rdfs:label>
        <rdfs:label xml:lang="en">electrical property analyzing process</rdfs:label> <rdfs:label xml:lang="zh">电性质分析过程</rdfs:label>
        <skos:definition xml:lang="en">An assay that determines the electrical properties of materials, including electrical conductivity, resistivity, dielectric strength, and electrical charge storage capabilities.</skos:definition> <skos:definition xml:lang="zh">一种测定材料电性质的分析方法，包括电导率、电阻率、介电强度和电荷存储能力。</skos:definition>
        <skos:definition xml:lang="de">Eine Analyse, die die elektrischen Eigenschaften von Materialien bestimmt, einschließlich elektrischer Leitfähigkeit, Widerstand, dielektrischer Festigkeit und elektrischer Ladungsspeicherkapazitäten.</skos:definition> <skos:definition xml:lang="zh">一种分析，用于确定材料的电性能，包括电导率、电阻、介电强度和电荷存储容量。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000623 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000623">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0001011"/>
        <rdfs:label xml:lang="de">Elektronenstrahlschweißmaschine</rdfs:label> <rdfs:label xml:lang="zh">电子束焊机</rdfs:label>
        <rdfs:label xml:lang="en">electron beam welding machine</rdfs:label> <rdfs:label xml:lang="zh">电子束焊接机</rdfs:label>
        <skos:definition xml:lang="en">An electron beam welding machine is a welding device that uses a high-velocity electron beam to fuse materials together, typically in a vacuum environment.</skos:definition> <skos:definition xml:lang="zh">电子束焊接机是一种焊接设备，使用高速电子束将材料熔合在一起，通常在真空环境中进行。</skos:definition>
        <skos:definition xml:lang="de">Eine Elektronenstrahlschweißmaschine ist ein Schweißgerät, das einen hochgeschwindigen Elektronenstrahl verwendet, um Materialien miteinander zu verschmelzen, typischerweise in einer Vakuumumgebung.</skos:definition> <skos:definition xml:lang="zh">电子束焊机是一种焊接设备，利用高速电子束将材料熔合在一起，通常在真空环境中进行。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000624 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000624">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000855"/>
        <obo:IAO_0000119 xml:lang="en">“Electron microscope.” Merriam-Webster.com Dictionary, Merriam-Webster, https://www.merriam-webster.com/dictionary/electron%20microscope. Accessed 24 Nov. 2022.</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">“Electron microscope.” Merriam-Webster.com Dictionary, Merriam-Webster, https://www.merriam-webster.com/dictionary/electron%20microscope. 访问于 24 Nov. 2022。</obo:IAO_0000119>
        <rdfs:label xml:lang="de">Elektronenmikroskop</rdfs:label> <rdfs:label xml:lang="zh">电子显微镜</rdfs:label>
        <rdfs:label xml:lang="en">electron microscope</rdfs:label> <rdfs:label xml:lang="zh">电子显微镜</rdfs:label>
        <skos:definition xml:lang="en">A microscope that uses a beam of electrons to create high-resolution images of a sample's surface or structure.</skos:definition> <skos:definition xml:lang="zh">一种使用电子束创建样品表面或结构高分辨率图像的显微镜。</skos:definition>
        <skos:definition xml:lang="en">An electron-optical instrument in which a beam of electrons is used to produce an enlarged image of a minute object.</skos:definition> <skos:definition xml:lang="zh">一种电子光学仪器，使用电子束产生微小物体的放大图像。</skos:definition>
        <skos:definition xml:lang="de">Ein Gerät, das einen Elektronenstrahl verwendet, um hochauflösende Bilder der Oberfläche oder Struktur einer Probe zu erstellen.</skos:definition> <skos:definition xml:lang="zh">一种利用电子束生成样品表面或结构高分辨率图像的设备。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000625 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000625">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000856"/>
        <rdfs:label xml:lang="de">Elektronenmikroskopie</rdfs:label> <rdfs:label xml:lang="zh">电子显微术</rdfs:label>
        <rdfs:label xml:lang="en">electron microscopy</rdfs:label> <rdfs:label xml:lang="zh">电子显微术</rdfs:label>
        <skos:definition xml:lang="en">A microscopy process that uses a beam of electrons to create an image of an object, allowing for high-resolution visualization of the material's surface and internal structures.</skos:definition> <skos:definition xml:lang="zh">一种使用电子束创建物体图像的显微术过程，能够高分辨率可视化材料表面和内部结构。</skos:definition>
        <skos:definition xml:lang="de">Ein Mikroskopieverfahren, das einen Elektronenstrahl verwendet, um ein Bild eines Objekts zu erzeugen, wodurch eine hochauflösende Visualisierung der Oberfläche und der inneren Strukturen des Materials ermöglicht wird.</skos:definition> <skos:definition xml:lang="zh">一种使用电子束生成物体图像的显微技术，可实现材料表面和内部结构的高分辨率可视化。</skos:definition>
        <skos:example xml:lang="en">An example of an electron microscopy process is Scanning Electron Microscopy (SEM), which provides detailed images of the surface topography and composition of a material. Another example is Transmission Electron Microscopy (TEM), which can visualize the internal structure of a sample at atomic resolution.</skos:example> <skos:example xml:lang="zh">电子显微术的一个例子是扫描电子显微镜（SEM），它提供材料表面形貌和成分的详细图像。另一个例子是透射电子显微镜（TEM），它可以原子分辨率可视化样品的内部结构。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000626 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000626">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000945"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0009006"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000595"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="de">Elektronenspektroskopie</rdfs:label> <rdfs:label xml:lang="zh">电子能谱学</rdfs:label>
        <rdfs:label xml:lang="en">electron spectroscopy</rdfs:label> <rdfs:label xml:lang="zh">电子能谱学</rdfs:label>
        <skos:definition xml:lang="en">A spectroscopy process, that studies the energy distribution of electrons emitted from a sample when it is irradiated with electromagnetic radiation or bombarded with particles.</skos:definition> <skos:definition xml:lang="zh">一种光谱过程，研究样品在受到电磁辐射照射或粒子轰击时发射出的电子的能量分布。</skos:definition>
        <skos:definition xml:lang="de">Ein Spektroskopie Verfahren, das die Energieverteilung von Elektronen untersucht, die aus einer Probe emittiert werden, wenn diese mit elektromagnetischer Strahlung bestrahlt oder mit Teilchen bombardiert wird.</skos:definition> <skos:definition xml:lang="zh">一种光谱学方法，研究样品在受到电磁辐射照射或粒子轰击时发射的电子的能量分布。</skos:definition>
        <skos:example xml:lang="en">Examples are e.g. Auger electron spectroscopy, electron energy loss spectroscopy, secondary electron spectroscopy.</skos:example> <skos:example xml:lang="zh">例如，俄歇电子能谱、电子能量损失谱、二次电子能谱。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000628 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000628">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000629"/>
        <rdfs:label xml:lang="en">emission of corpuscular radiation</rdfs:label> <rdfs:label xml:lang="zh">微粒辐射发射</rdfs:label>
        <skos:definition xml:lang="en">The emission of corpuscular radiation is an emission of radiation describing the release of particle-based radiation, such as alpha or beta particles, from a material or system.</skos:definition> <skos:definition xml:lang="zh">微粒辐射发射是一种辐射发射，描述材料或系统释放基于粒子的辐射（如α或β粒子）的过程。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000629 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000629">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:label xml:lang="en">emission of radiation</rdfs:label> <rdfs:label xml:lang="zh">辐射发射</rdfs:label>
        <skos:definition xml:lang="en">The emission radiation is a process describing the release of energy in the form of electromagnetic waves or particles from a material.</skos:definition> <skos:definition xml:lang="zh">辐射发射是一种过程，描述材料以电磁波或粒子形式释放能量。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000630 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000630">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000629"/>
        <rdfs:label xml:lang="en">emission of wave radiation</rdfs:label> <rdfs:label xml:lang="zh">波辐射发射</rdfs:label>
        <skos:definition xml:lang="en">The emission of wave radioation is an emission of radiation describing the release of energy in the form of waves, such as electromagnetic or acoustic waves, by a material or system.</skos:definition> <skos:definition xml:lang="zh">波辐射发射是一种辐射发射，描述材料或系统以波（如电磁波或声波）形式释放能量。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000631 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000631">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000933"/>
        <rdfs:label xml:lang="de">Empirische Potential MD Simulation</rdfs:label> <rdfs:label xml:lang="zh">经验势分子动力学模拟</rdfs:label>
        <rdfs:label xml:lang="en">empirical potential molecular dynamics simulation</rdfs:label> <rdfs:label xml:lang="zh">经验势分子动力学模拟</rdfs:label>
        <skos:definition xml:lang="en">A simulation process that uses empirical potentials derived from experimental data to model the behavior of molecular systems.</skos:definition> <skos:definition xml:lang="zh">一种模拟过程，使用从实验数据推导出的经验势来建模分子系统的行为。</skos:definition>
        <skos:definition xml:lang="de">Ein Simulationsprozess, der empirische Potentiale verwendet, die aus experimentellen Daten abgeleitet sind, um das Verhalten molekularer Systeme zu modellieren.</skos:definition> <skos:definition xml:lang="zh">一种使用从实验数据推导的经验势来模拟分子系统行为的模拟过程。</skos:definition>
        <skos:example xml:lang="en">Simulating the diffusion of atoms in a crystal using Lennard-Jones potentials.</skos:example> <skos:example xml:lang="zh">使用Lennard-Jones势模拟晶体中原子的扩散。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000633 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000633">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000602"/>
        <rdfs:label xml:lang="de">Umweltschrank</rdfs:label> <rdfs:label xml:lang="zh">环境试验箱</rdfs:label>
        <rdfs:label xml:lang="en">environmental chamber</rdfs:label> <rdfs:label xml:lang="zh">环境试验箱</rdfs:label>
        <skos:definition xml:lang="en">A device used to simulate environmental conditions such as temperature, humidity, and pressure to test materials and devices.</skos:definition> <skos:definition xml:lang="zh">一种用于模拟温度、湿度和压力等环境条件以测试材料和设备的装置。</skos:definition>
        <skos:definition xml:lang="de">Ein Gerät zur Simulation von Umweltbedingungen wie Temperatur, Feuchtigkeit und Druck zur Prüfung von Materialien und Geräten.</skos:definition> <skos:definition xml:lang="zh">一种模拟温度、湿度、压力等环境条件以测试材料和设备的装置。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000634 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000634">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000023"/>
        <rdfs:label xml:lang="en">workflow executor role</rdfs:label> <rdfs:label xml:lang="zh">工作流执行者角色</rdfs:label>
        <skos:definition xml:lang="en">A role that inheres in an agent and is realized by the agent’s participation in a workflow run, in which the agent carries out, controls, or is responsible for the execution of a workflow according to a workflow definition.</skos:definition> <skos:definition xml:lang="zh">一种固有于代理的角色，通过代理参与工作流运行而实现，在该运行中，代理根据工作流定义执行、控制或负责工作流的执行。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000635 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000635">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:label xml:lang="en">evolution of damage</rdfs:label> <rdfs:label xml:lang="zh">损伤演化</rdfs:label>
        <skos:definition xml:lang="en">An evolution of damage is a process representing the progression of material degradation under mechanical, thermal, or chemical stresses.</skos:definition> <skos:definition xml:lang="zh">损伤演化是表示材料在机械、热或化学应力下退化进展的过程。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000636 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000636">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000602"/>
        <obo:IAO_0000119 xml:lang="en">“Extensometer.” Merriam-Webster.com Dictionary, Merriam-Webster, https://www.merriam-webster.com/dictionary/extensometer. Accessed 5 Dec. 2022.</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">“Extensometer.” Merriam-Webster.com词典, Merriam-Webster, https://www.merriam-webster.com/dictionary/extensometer. 访问于2022年12月5日。</obo:IAO_0000119>
        <rdfs:label xml:lang="en">extensometer</rdfs:label> <rdfs:label xml:lang="zh">引伸计</rdfs:label>
        <skos:definition xml:lang="en">A device for measuring minute deformations of test specimens caused by tension, compression, bending, or twisting.</skos:definition> <skos:definition xml:lang="zh">用于测量试件因拉伸、压缩、弯曲或扭转引起的微小变形的装置。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000637 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000637">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000602"/>
        <rdfs:label xml:lang="de">Materialermüdungsprüfmaschine</rdfs:label> <rdfs:label xml:lang="zh">材料疲劳试验机</rdfs:label>
        <rdfs:label xml:lang="en">fatigue testing machine</rdfs:label> <rdfs:label xml:lang="zh">疲劳试验机</rdfs:label>
        <skos:definition xml:lang="en">A device used to test the fatigue resistance of materials by subjecting them to repeated stress cycles.</skos:definition> <skos:definition xml:lang="zh">一种通过对材料施加重复应力循环来测试其疲劳抗性的设备。</skos:definition>
        <skos:definition xml:lang="de">Ein Gerät zur Prüfung der Ermüdungsresistenz von Materialien, indem diese wiederholten Belastungszyklen ausgesetzt werden.</skos:definition> <skos:definition xml:lang="zh">一种通过使材料承受重复载荷循环来测试材料抗疲劳性能的设备。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000638 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000638">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000849"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000117"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0025020"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="de">Ermüdungsprüfverfahren</rdfs:label> <rdfs:label xml:lang="zh">疲劳试验方法</rdfs:label>
        <rdfs:label xml:lang="en">fatigue testing process</rdfs:label> <rdfs:label xml:lang="zh">疲劳测试过程</rdfs:label>
        <skos:altLabel xml:lang="en">S-N testing process</skos:altLabel> <skos:altLabel xml:lang="zh">S-N测试过程</skos:altLabel>
        <skos:altLabel xml:lang="en">fatigue testing series</skos:altLabel> <skos:altLabel xml:lang="zh">疲劳测试系列</skos:altLabel>
        <skos:definition xml:lang="de">Ein Mechanische Eigenschaften Analyseverfahren, das die Fähigkeit eines Materials bewertet, zyklischen Belastungen standzuhalten, und seine Ermüdungslebensdauer und -grenze bestimmt.</skos:definition> <skos:definition xml:lang="zh">一种机械性能分析过程，评估材料承受循环载荷的能力，并确定其疲劳寿命和疲劳极限。</skos:definition>
        <skos:definition xml:lang="en">Fatigue testing process is a  mechanical property analyzing process that assesses a material's ability to withstand cyclic loading, determining its fatigue life and endurance limit. It must have occurent parts single fatigue tests.</skos:definition> <skos:definition xml:lang="zh">疲劳测试过程是一种力学性能分析过程，评估材料承受循环载荷的能力，确定其疲劳寿命和疲劳极限。它必须包含单次疲劳试验作为发生部分。</skos:definition>
        <skos:example xml:lang="en">Fatigue testing of metal components in bridges to predict their lifespan under repetitive loading conditions.</skos:example> <skos:example xml:lang="zh">对桥梁中的金属部件进行疲劳测试，以预测其在重复载荷条件下的寿命。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000639 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000639">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000852"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020026"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">ferrous metal</rdfs:label> <rdfs:label xml:lang="zh">黑色金属</rdfs:label>
        <skos:definition xml:lang="en">metal that has iron as primary constituent</skos:definition> <skos:definition xml:lang="zh">以铁为主要成分的金属</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000641 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000641">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000806"/>
        <obo:IAO_0000119 xml:lang="en">Official definition can be found in: DIN 8593-2</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">官方定义可见于：DIN 8593-2</obo:IAO_0000119>
        <obo:IAO_0000119 xml:lang="de">Offizielle Definition findet man in: DIN 8593-2</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">官方定义见：DIN 8593-2</obo:IAO_0000119>
        <rdfs:label xml:lang="de">Füllen</rdfs:label> <rdfs:label xml:lang="zh">填充</rdfs:label>
        <rdfs:label xml:lang="en">filling</rdfs:label> <rdfs:label xml:lang="zh">填充</rdfs:label>
        <skos:definition xml:lang="en">A joining process that involves the use of a filler material to connect parts.</skos:definition> <skos:definition xml:lang="zh">一种使用填充材料连接零件的连接工艺。</skos:definition>
        <skos:definition xml:lang="de">Ein Füge Prozess, bei dem ein Füllmaterial verwendet wird, um Teile zu verbinden.</skos:definition> <skos:definition xml:lang="zh">一种连接过程，使用填充材料来连接零件。</skos:definition>
        <skos:example xml:lang="en">Impregnating, Soaking</skos:example> <skos:example xml:lang="zh">浸渍、浸泡</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000642 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000642">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000602"/>
        <rdfs:label xml:lang="de">Durchflusszytometer</rdfs:label> <rdfs:label xml:lang="zh">流式细胞仪</rdfs:label>
        <rdfs:label xml:lang="en">flow cytometer</rdfs:label> <rdfs:label xml:lang="zh">流式细胞仪</rdfs:label>
        <skos:definition xml:lang="en">A flow cytometer is a device used to measure the physical and chemical characteristics of a population of cells or particles.</skos:definition> <skos:definition xml:lang="zh">流式细胞仪是一种用于测量细胞或颗粒群体的物理和化学特性的设备。</skos:definition>
        <skos:definition xml:lang="de">Ein Durchflusszytometer ist ein Gerät, das verwendet wird, um die physikalischen und chemischen Eigenschaften einer Zell- oder Partikelpopulation zu messen.</skos:definition> <skos:definition xml:lang="zh">流式细胞仪是一种用于测量细胞或颗粒群体的物理和化学特性的设备。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000644 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000644">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000847"/>
        <rdfs:label xml:lang="de">Kraftmessfunktion</rdfs:label> <rdfs:label xml:lang="zh">力测量功能</rdfs:label>
        <rdfs:label xml:lang="en">force measuring function</rdfs:label> <rdfs:label xml:lang="zh">力测量功能</rdfs:label>
        <skos:definition xml:lang="en">A measuring function performed to determine the force applied to or by an object.</skos:definition> <skos:definition xml:lang="zh">一种用于确定施加在物体上或由物体施加的力的测量功能。</skos:definition>
        <skos:definition xml:lang="de">Eine Messfunktion um die auf ein Objekt ausgeübte oder von ihm ausgeübte Kraft zu bestimmen.</skos:definition> <skos:definition xml:lang="zh">一种测量功能，用于确定施加在物体上或由物体施加的力。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000645 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000645">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:label xml:lang="en">formation of notch or scratch</rdfs:label> <rdfs:label xml:lang="zh">缺口或划痕的形成</rdfs:label>
        <skos:definition xml:lang="en">The formation of (a) notch or (a) scratch is a process that describes the creation of small surface imperfections, which can influence a material's mechanical properties.</skos:definition> <skos:definition xml:lang="zh">缺口或划痕的形成是描述产生微小表面缺陷的过程，这些缺陷会影响材料的机械性能。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000646 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000646">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000833"/>
        <obo:IAO_0000119 xml:lang="en">Official definition can be found in: DIN 8580:2003-9 Fertigungsverfahren, Page 4, 3.1.2 Umformen - Definition</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">官方定义见: DIN 8580:2003-9 Fertigungsverfahren, 第4页, 3.1.2 Umformen - 定义</obo:IAO_0000119>
        <obo:IAO_0000119 xml:lang="de">Offizielle Definition findet man in: DIN 8580:2003-9 Fertigungsverfahren, Seite 4, 3.1.2 Umformen - Definition</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">官方定义见：DIN 8580:2003-9 制造过程，第4页，3.1.2 成形 - 定义</obo:IAO_0000119>
        <rdfs:label xml:lang="de">Umformen</rdfs:label> <rdfs:label xml:lang="zh">成形</rdfs:label>
        <rdfs:label xml:lang="en">forming</rdfs:label> <rdfs:label xml:lang="zh">成形</rdfs:label>
        <skos:altLabel xml:lang="en">Shaping</skos:altLabel> <skos:altLabel xml:lang="zh">成形</skos:altLabel>
        <skos:definition xml:lang="en">A manufacturing process that changes the shape of a solid body through plastic deformation while retaining both mass and structural integrity.</skos:definition> <skos:definition xml:lang="zh">一种通过塑性变形改变固体形状，同时保持质量和结构完整性的制造过程。</skos:definition>
        <skos:definition xml:lang="de">Ein Herstellungsprozess, der durch plastische Umformung die Gestalt eines festen Körpers verändert, wobei sowohl die Masse als auch die strukturelle Integrität erhalten bleiben.</skos:definition> <skos:definition xml:lang="zh">一种通过塑性变形改变固体形状的制造过程，同时保持质量和结构完整性。</skos:definition>
        <skos:example xml:lang="en">Tension Forming, Compression Forming</skos:example> <skos:example xml:lang="zh">拉伸成形, 压缩成形</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000647 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000647">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000646"/>
        <obo:IAO_0000119 xml:lang="en">Official definition can be found in: DIN 8586</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">官方定义见: DIN 8586</obo:IAO_0000119>
        <dcterms:source xml:lang="de">Offizielle Definition findet man in: DIN 8586</dcterms:source>
        <rdfs:label xml:lang="de">Biegeumformen</rdfs:label> <rdfs:label xml:lang="zh">弯曲成形</rdfs:label>
        <rdfs:label xml:lang="en">forming by bending</rdfs:label> <rdfs:label xml:lang="zh">弯曲成形</rdfs:label>
        <skos:definition xml:lang="en">A forming process that involves bending materials, typically used in manipulating sheets, tubes, or profiles into curved shapes or angles, common in metalworking and fabrication industries.</skos:definition> <skos:definition xml:lang="zh">一种涉及弯曲材料的成形过程，通常用于将板材、管材或型材加工成弯曲形状或角度，常见于金属加工和制造行业。</skos:definition>
        <skos:definition xml:lang="de">Ein Umform Prozess, der das Biegen von Materialien beinhaltet und typischerweise bei der Bearbeitung von Blechen, Rohren oder Profilen zu gekrümmten Formen oder Winkeln eingesetzt wird, wie es in der Metallverarbeitung und in der verarbeitenden Industrie üblich ist.</skos:definition> <skos:definition xml:lang="zh">一种涉及材料弯曲的成形过程，通常用于将板材、管材或型材加工成弯曲形状或角度，常见于金属加工和制造业。</skos:definition>
        <skos:example xml:lang="en">Bending With Linear Die Movement, Bending With Rotary Die Movement</skos:example> <skos:example xml:lang="zh">线性模具运动弯曲, 旋转模具运动弯曲</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000648 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000648">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000602"/>
        <rdfs:label xml:lang="de">Formmaschine</rdfs:label> <rdfs:label xml:lang="zh">成形机</rdfs:label>
        <rdfs:label xml:lang="en">forming machine</rdfs:label> <rdfs:label xml:lang="zh">成形机</rdfs:label>
        <skos:definition xml:lang="en">A device used for shaping materials under various conditions, including tensile, compressive, and shearing.</skos:definition> <skos:definition xml:lang="zh">一种用于在各种条件下（包括拉伸、压缩和剪切）成形材料的设备。</skos:definition>
        <skos:definition xml:lang="de">Ein Gerät zur Formgebung von Materialien unter verschiedenen Bedingungen, einschließlich Zug-, Druck- und Scherbedingungen.</skos:definition> <skos:definition xml:lang="zh">一种在各种条件下（包括拉伸、压缩和剪切条件）对材料进行成形的设备。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000649 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000649">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000646"/>
        <obo:IAO_0000119 xml:lang="en">Official definition can be found in: DIN 8584-1</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">官方定义见: DIN 8584-1</obo:IAO_0000119>
        <dcterms:source xml:lang="de">Offizielle Definition findet man in: DIN 8584-1</dcterms:source>
        <rdfs:label xml:lang="de">Zugdruckumformen</rdfs:label> <rdfs:label xml:lang="zh">拉伸压缩成形</rdfs:label>
        <rdfs:label xml:lang="en">forming under compressive and tensile conditions</rdfs:label> <rdfs:label xml:lang="zh">在压缩和拉伸条件下成形</rdfs:label>
        <skos:definition xml:lang="en">A forming process that involves applying both tensile and compressive forces to a material.</skos:definition> <skos:definition xml:lang="zh">一种对材料同时施加拉力和压力的成形过程。</skos:definition>
        <skos:definition xml:lang="de">Ein Umform Prozess, bei dem sowohl Zug- als auch Druckkräfte auf ein Material ausgeübt werden.</skos:definition> <skos:definition xml:lang="zh">一种同时对材料施加拉伸和压缩力的成形过程。</skos:definition>
        <skos:example xml:lang="en">Stripping, Deep Drawing, Spinning</skos:example> <skos:example xml:lang="zh">拉拔、深拉、旋压</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000650 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000650">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000646"/>
        <obo:IAO_0000119 xml:lang="en">Official definition can be found in: DIN 8583-1</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">官方定义见：DIN 8583-1</obo:IAO_0000119>
        <dcterms:source xml:lang="de">Offizielle Definition findet man in: DIN 8583-1</dcterms:source>
        <rdfs:label xml:lang="de">Druckumformen</rdfs:label> <rdfs:label xml:lang="zh">压缩成形</rdfs:label>
        <rdfs:label xml:lang="en">forming under compressive conditions</rdfs:label> <rdfs:label xml:lang="zh">在压缩条件下成形</rdfs:label>
        <skos:definition xml:lang="en">A forming process that involves deforming materials under compressive forces, commonly used in techniques like rolling and die forming where metal is shaped by applying pressure.</skos:definition> <skos:definition xml:lang="zh">一种在压力下使材料变形的成形过程，常用于轧制和模具成形等技术，通过施加压力使金属成形。</skos:definition>
        <skos:definition xml:lang="de">Ein Umform Prozess, bei dem Materialien unter Druck verformt werden. Er wird üblicherweise bei Techniken wie Walzen und  Gesenkformen eingesetzt, bei denen Metall durch Druck in Form gebracht wird.</skos:definition> <skos:definition xml:lang="zh">一种在压力下使材料变形的成形过程。通常用于轧制和模压成形等技术，其中金属通过压力成形。</skos:definition>
        <skos:example xml:lang="en">Rolling, Coining</skos:example> <skos:example xml:lang="zh">轧制、压印</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000651 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000651">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000646"/>
        <obo:IAO_0000119 xml:lang="en">Official definition can be found in: DIN 8587</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">官方定义见：DIN 8587</obo:IAO_0000119>
        <dcterms:source xml:lang="de">Offizielle Definition findet man in: DIN 8587</dcterms:source>
        <rdfs:label xml:lang="de">Schubumformen</rdfs:label> <rdfs:label xml:lang="zh">剪切成形</rdfs:label>
        <rdfs:label xml:lang="en">forming under shearing conditions</rdfs:label> <rdfs:label xml:lang="zh">在剪切条件下成形</rdfs:label>
        <skos:definition xml:lang="en">A forming process that involves displacement or twisting materials to achieve deformation, often used in operations where materials are shaped by applying torsional forces.</skos:definition> <skos:definition xml:lang="zh">一种通过位移或扭转材料实现变形的成形过程，常用于通过施加扭转力使材料成形的操作。</skos:definition>
        <skos:definition xml:lang="de">Ein Umform Prozess, bei dem Werkstoffe durch Verschieben oder Verdrehen verformt werden. Es wird häufig bei Verfahren verwendet, bei denen Werkstoffe durch Anwendung von Torsionskräften geformt werden.</skos:definition> <skos:definition xml:lang="zh">一种成形过程，其中材料通过移动或扭转发生变形。常用于通过施加扭力来成形材料的方法。</skos:definition>
        <skos:example xml:lang="en">Twisting, Displacement</skos:example> <skos:example xml:lang="zh">扭转、位移</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000652 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000652">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000646"/>
        <obo:IAO_0000119 xml:lang="en">Official definition can be found in: DIN 8585-1</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">官方定义见：DIN 8585-1</obo:IAO_0000119>
        <obo:IAO_0000119 xml:lang="de">Offizielle Definition findet man in: DIN 8585-1</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">官方定义见：DIN 8585-1</obo:IAO_0000119>
        <rdfs:label xml:lang="de">Zugumformen</rdfs:label> <rdfs:label xml:lang="zh">拉伸成形</rdfs:label>
        <rdfs:label xml:lang="en">forming under tensile conditions</rdfs:label> <rdfs:label xml:lang="zh">在拉伸条件下成形</rdfs:label>
        <skos:definition xml:lang="en">A forming process that involves stretching or elongating materials to achieve desired dimensions or shapes.</skos:definition> <skos:definition xml:lang="zh">一种通过拉伸或伸长材料以达到所需尺寸或形状的成形过程。</skos:definition>
        <skos:definition xml:lang="de">Ein Umform Prozess, bei dem Materialien gestreckt oder gedehnt werden, um die gewünschten Abmessungen oder Formen zu erreichen.</skos:definition> <skos:definition xml:lang="zh">一种成形过程，其中材料被拉伸或延展以达到所需的尺寸或形状。</skos:definition>
        <skos:example xml:lang="en">Expanding, Stretch Forming</skos:example> <skos:example xml:lang="zh">膨胀、拉伸成形</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000653 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000653">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000849"/>
        <rdfs:label xml:lang="de">Bruchzähigkeitsprüfverfahren</rdfs:label> <rdfs:label xml:lang="zh">断裂韧性测试方法</rdfs:label>
        <rdfs:label xml:lang="en">fracture toughness testing process</rdfs:label> <rdfs:label xml:lang="zh">断裂韧性测试过程</rdfs:label>
        <skos:definition xml:lang="en">A mechanical property analyzing process that assesses a material's ability to resist crack propagation, determining its fracture toughness.</skos:definition> <skos:definition xml:lang="zh">一种机械性能分析过程，评估材料抵抗裂纹扩展的能力，从而确定其断裂韧性。</skos:definition>
        <skos:definition xml:lang="de">Ein Mechanische Eigenschaften Analyseverfahren, das die Fähigkeit eines Materials bewertet, der Rissausbreitung zu widerstehen, und seine Bruchzähigkeit bestimmt.</skos:definition> <skos:definition xml:lang="zh">一种机械性能分析方法，评估材料抵抗裂纹扩展的能力，并确定其断裂韧性。</skos:definition>
        <skos:example xml:lang="en">Measuring the fracture toughness of ceramic materials used in aerospace components to ensure reliability under stress.</skos:example> <skos:example xml:lang="zh">测量用于航空航天组件的陶瓷材料的断裂韧性，以确保在应力下的可靠性。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000654 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000654">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000000"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:intersectionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000030"/>
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000085"/>
                                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000034"/>
                                    </owl:Restriction>
                                </owl:intersectionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000000"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000030"/>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000085"/>
                                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000034"/>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000116 xml:lang="en">Classified by the role in a system.</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">根据在系统中的作用分类。</obo:IAO_0000116>
        <rdfs:label xml:lang="en">functional material</rdfs:label> <rdfs:label xml:lang="zh">功能材料</rdfs:label>
        <skos:definition xml:lang="en">A functional material F is an engineered material which has the disposition to be used for an object O (O consists of F) and O's function is other/more than mechanical load carrying.</skos:definition> <skos:definition xml:lang="zh">功能材料F是一种工程材料，具有用于物体O（O由F构成）的倾向，且O的功能不仅仅是/除了机械承载。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000655 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000655">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000602"/>
        <obo:IAO_0000119 xml:lang="en">“Furnace.” Merriam-Webster.com Dictionary, Merriam-Webster, https://www.merriam-webster.com/dictionary/furnace. Accessed 13 Jan. 2023.</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">“Furnace.”《Merriam-Webster在线词典》，Merriam-Webster，https://www.merriam-webster.com/dictionary/furnace。访问日期：2023年1月13日。</obo:IAO_0000119>
        <rdfs:label xml:lang="de">Ofen</rdfs:label> <rdfs:label xml:lang="zh">炉</rdfs:label>
        <rdfs:label xml:lang="en">furnace</rdfs:label> <rdfs:label xml:lang="zh">熔炉</rdfs:label>
        <skos:definition xml:lang="en">A device that generates and contains high-intensity thermal energy within an insulated enclosure.</skos:definition> <skos:definition xml:lang="zh">一种在绝缘外壳内产生并容纳高热量热能的设备。</skos:definition>
        <skos:definition xml:lang="de">Ein Gerät, das hochintensive thermische Energie innerhalb eines isolierten Gehäuses erzeugt und speichert.</skos:definition> <skos:definition xml:lang="zh">一种在隔热外壳内产生并储存高强度热能的装置。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000656 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000656">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000556"/>
        <rdfs:label xml:lang="de">Gaschromatographie Verfahren</rdfs:label> <rdfs:label xml:lang="zh">气相色谱法</rdfs:label>
        <rdfs:label xml:lang="en">gas chromatography process</rdfs:label> <rdfs:label xml:lang="zh">气相色谱过程</rdfs:label>
        <skos:definition xml:lang="en">A chromatography process that separates and analyzes compounds that can be vaporized without decomposition, using a gas as the mobile phase and a solid or liquid stationary phase.</skos:definition> <skos:definition xml:lang="zh">一种色谱过程，使用气体作为流动相，固体或液体作为固定相，分离和分析可被汽化而不分解的化合物。</skos:definition>
        <skos:definition xml:lang="de">Ein Chromatographieverfahren, das Verbindungen trennt und analysiert, die ohne Zersetzung verdampft werden können, indem ein Gas als mobile Phase und eine feste oder flüssige stationäre Phase verwendet wird.</skos:definition> <skos:definition xml:lang="zh">一种色谱方法，使用气体作为流动相，固体或液体作为固定相，分离和分析能够在无分解的情况下蒸发的化合物。</skos:definition>
        <skos:example xml:lang="en">Gas chromatography is used to analyze the composition of volatile organic compounds in a polymer matrix.</skos:example> <skos:example xml:lang="zh">气相色谱法用于分析聚合物基质中挥发性有机化合物的组成。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000657 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000657">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000557"/>
        <rdfs:label xml:lang="de">Gaschromatographiesystem</rdfs:label> <rdfs:label xml:lang="zh">气相色谱系统</rdfs:label>
        <rdfs:label xml:lang="en">gas chromatography system</rdfs:label> <rdfs:label xml:lang="zh">气相色谱系统</rdfs:label>
        <skos:definition xml:lang="en">A chromatography system used for separating and analyzing compounds in a gas mixture using a chromatographic column.</skos:definition> <skos:definition xml:lang="zh">一种色谱系统，使用色谱柱分离和分析气体混合物中的化合物。</skos:definition>
        <skos:definition xml:lang="de">Ein Chromatographiesystem zur Trennung und Analyse von Verbindungen in einem Gasgemisch unter Verwendung einer chromatographischen Säule.</skos:definition> <skos:definition xml:lang="zh">一种色谱系统，使用色谱柱分离和分析气体混合物中的化合物。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000658 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000658">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000556"/>
        <rdfs:label xml:lang="de">Gel-Permeations-Chromatographie Verfahren</rdfs:label> <rdfs:label xml:lang="zh">凝胶渗透色谱法</rdfs:label>
        <rdfs:label xml:lang="en">gel permeation chromatography process</rdfs:label> <rdfs:label xml:lang="zh">凝胶渗透色谱过程</rdfs:label>
        <skos:definition xml:lang="en">A chromatography process that separates molecules based on their size by passing the sample through a porous gel matrix, also known as size exclusion chromatography.</skos:definition> <skos:definition xml:lang="zh">一种色谱过程，通过将样品通过多孔凝胶基质，根据分子大小进行分离，也称为尺寸排阻色谱法。</skos:definition>
        <skos:definition xml:lang="de">Ein Chromatographieverfahren, das Moleküle basierend auf ihrer Größe trennt, indem die Probe durch eine poröse Gelmatrix geleitet wird, auch bekannt als Größenausschlusschromatographie.</skos:definition> <skos:definition xml:lang="zh">一种色谱方法，通过将样品通过多孔凝胶基质，根据分子大小分离分子，也称为尺寸排阻色谱法。</skos:definition>
        <skos:example xml:lang="en">Gel permeation chromatography is used to determine the molecular weight distribution of a polymer sample.</skos:example> <skos:example xml:lang="zh">凝胶渗透色谱法用于测定聚合物样品的分子量分布。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000659 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000659">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000557"/>
        <rdfs:label xml:lang="de">Gelpermeations-Chromatographiesystem</rdfs:label> <rdfs:label xml:lang="zh">凝胶渗透色谱系统</rdfs:label>
        <rdfs:label xml:lang="en">gel permeation chromatography system</rdfs:label> <rdfs:label xml:lang="zh">凝胶渗透色谱系统</rdfs:label>
        <skos:definition xml:lang="en">A chromatography system used for separating and analyzing polymers based on their molecular size using gel permeation chromatography.</skos:definition> <skos:definition xml:lang="zh">一种基于分子大小使用凝胶渗透色谱法分离和分析聚合物的色谱系统。</skos:definition>
        <skos:definition xml:lang="de">Ein Chromatographiesystem zur Trennung und Analyse von Polymeren basierend auf ihrer Molekülgröße durch Gelpermeationschromatographie.</skos:definition> <skos:definition xml:lang="zh">一种通过凝胶渗透色谱法根据分子大小分离和分析聚合物的色谱系统。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000660 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000660">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000594"/>
        <rdfs:label xml:lang="de">Generatives Deep Learning</rdfs:label> <rdfs:label xml:lang="zh">生成式深度学习</rdfs:label>
        <rdfs:label xml:lang="en">generative deep learning</rdfs:label> <rdfs:label xml:lang="zh">生成式深度学习</rdfs:label>
        <skos:definition xml:lang="en">A deep learning process that involves creating models capable of generating new data instances that resemble the training data.</skos:definition> <skos:definition xml:lang="zh">一种深度学习过程，涉及创建能够生成与训练数据相似的新数据实例的模型。</skos:definition>
        <skos:definition xml:lang="de">Ein Deep Learning-Prozess, der Modelle erstellt, die in der Lage sind, neue Dateninstanzen zu erzeugen, die den Trainingsdaten ähneln.</skos:definition> <skos:definition xml:lang="zh">一个深度学习过程，创建能够生成与训练数据相似的新数据实例的模型。</skos:definition>
        <skos:example xml:lang="en">Using generative adversarial networks to design new molecular structures with desired properties, such as improved conductivity or strength.</skos:example> <skos:example xml:lang="zh">使用生成对抗网络设计具有所需性能（如改进的导电性或强度）的新分子结构。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000661 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000661">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000000"/>
        <obo:IAO_0000116 xml:lang="en">Classified by morphology.</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">按形态分类。</obo:IAO_0000116>
        <rdfs:comment xml:lang="en">It is often composed of silica-based compounds.</rdfs:comment>
        <rdfs:label xml:lang="en">glass</rdfs:label> <rdfs:label xml:lang="zh">玻璃</rdfs:label>
        <skos:definition xml:lang="en">A glass is an engineered material present as an amorphous solid typically formed by rapid cooling of a melt.</skos:definition> <skos:definition xml:lang="zh">玻璃是一种工程材料，呈非晶态固体，通常由熔体快速冷却形成。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000662 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000662">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000806"/>
        <obo:IAO_0000119 xml:lang="en">Official definition can be found in: DIN 8593-8</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">官方定义见：DIN 8593-8</obo:IAO_0000119>
        <obo:IAO_0000119 xml:lang="de">Offizielle Definition findet man in: DIN 8593-8</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">官方定义见：DIN 8593-8</obo:IAO_0000119>
        <rdfs:label xml:lang="de">Kleben</rdfs:label> <rdfs:label xml:lang="zh">粘接</rdfs:label>
        <rdfs:label xml:lang="en">glueing</rdfs:label> <rdfs:label xml:lang="zh">粘接</rdfs:label>
        <skos:altLabel xml:lang="en">Bonding</skos:altLabel> <skos:altLabel xml:lang="zh">粘接</skos:altLabel>
        <skos:definition xml:lang="en">A joining process that involves using adhesives to bond materials together, suitable for a wide range of materials including metals, plastics, and composites, and used in various applications from automotive to aerospace.</skos:definition> <skos:definition xml:lang="zh">一种使用胶粘剂将材料粘合在一起的连接工艺，适用于包括金属、塑料和复合材料在内的多种材料，用于从汽车到航空航天等各种应用。</skos:definition>
        <skos:definition xml:lang="de">Ein Füge Prozess, bei dem Klebstoffe verwendet werden, um Materialien miteinander zu verbinden. Es eignet sich für eine Vielzahl von Materialien, darunter Metalle, Kunststoffe und Verbundstoffe, und wird in verschiedenen Anwendungen von der Automobilindustrie bis zur Luft- und Raumfahrt eingesetzt.</skos:definition> <skos:definition xml:lang="zh">一种使用粘合剂将材料连接在一起的接合工艺。适用于多种材料，包括金属、塑料和复合材料，并广泛应用于从汽车工业到航空航天等领域。</skos:definition>
        <skos:example xml:lang="en">Bonding With Physically Hardening Adhesives, Bonding With Chemically Hardening Adhesives (Reaction Bonding)</skos:example> <skos:example xml:lang="zh">物理硬化胶粘剂粘接，化学硬化胶粘剂粘接（反应粘接）</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000663 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000663">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020003"/>
        <rdfs:label xml:lang="en">crystallite</rdfs:label> <rdfs:label xml:lang="zh">微晶</rdfs:label>
        <rdfs:label xml:lang="de">kristallit</rdfs:label> <rdfs:label xml:lang="zh">微晶</rdfs:label>
        <skos:altLabel xml:lang="de">Korn</skos:altLabel> <skos:altLabel xml:lang="zh">晶粒</skos:altLabel>
        <skos:altLabel xml:lang="en">grain</skos:altLabel> <skos:altLabel xml:lang="zh">晶粒</skos:altLabel>
        <skos:definition xml:lang="en">A crystal grain is a crystal that is part of a polycrystal.</skos:definition> <skos:definition xml:lang="zh">晶粒是多晶体中的一个晶体。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000665 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000665">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000602"/>
        <rdfs:label xml:lang="de">Gravimetrischer Analysator</rdfs:label> <rdfs:label xml:lang="zh">重量分析仪</rdfs:label>
        <rdfs:label xml:lang="en">gravimetric analyzer</rdfs:label> <rdfs:label xml:lang="zh">重量分析仪</rdfs:label>
        <skos:definition xml:lang="en">A device used to measure the mass of a sample to determine its composition or concentration.</skos:definition> <skos:definition xml:lang="zh">一种通过测量样品质量来确定其组成或浓度的装置。</skos:definition>
        <skos:definition xml:lang="de">Ein Gerät zur Messung der Masse einer Probe zur Bestimmung ihrer Zusammensetzung oder Konzentration.</skos:definition> <skos:definition xml:lang="zh">一种通过测量样品质量以确定其组成或浓度的设备。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000666 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000666">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000957"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0009006"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020102"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0009006"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020133"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="de">Gravimetrisches Analyseverfahren</rdfs:label> <rdfs:label xml:lang="zh">重量分析法</rdfs:label>
        <rdfs:label xml:lang="en">gravimetrical analyzing process</rdfs:label> <rdfs:label xml:lang="zh">重量分析过程</rdfs:label>
        <skos:definition xml:lang="en">A structural property analyzing process that measures the quantity of a substance by its mass, often involving the precipitation, filtration, drying, and weighing of the substance.</skos:definition> <skos:definition xml:lang="zh">一种结构性质分析过程，通过物质的质量来测量其数量，通常包括沉淀、过滤、干燥和称重。</skos:definition>
        <skos:definition xml:lang="de">Ein Struktur Eigenschaften Analyseverfahren, das die Menge einer Substanz durch ihre Masse misst und dabei häufig die Fällung, Filtration, Trocknung und Wägung der Substanz umfasst.</skos:definition> <skos:definition xml:lang="zh">一种结构性能分析方法，通过物质的质量测量其数量，通常包括沉淀、过滤、干燥和称重步骤。</skos:definition>
        <skos:example xml:lang="en">An example of a Gravimetrical Analyzing Process is the determination of sulfate content in a sample by precipitating it as barium sulfate, filtering, drying, and weighing the precipitate.</skos:example> <skos:example xml:lang="zh">重量分析过程的一个例子是通过将样品中的硫酸盐沉淀为硫酸钡，然后过滤、干燥并称重沉淀物来确定样品中的硫酸盐含量。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000667 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000667">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000648"/>
        <rdfs:label xml:lang="de">Schleifmaschine</rdfs:label> <rdfs:label xml:lang="zh">磨床</rdfs:label>
        <rdfs:label xml:lang="en">grinding machine</rdfs:label> <rdfs:label xml:lang="zh">磨床</rdfs:label>
        <skos:definition xml:lang="en">A grinding machine is a forming machine that uses an abrasive wheel to remove material from the surface of a workpiece, typically for finishing or precision work.</skos:definition> <skos:definition xml:lang="zh">磨床是一种使用砂轮从工件表面去除材料的成形机床，通常用于精加工或精密加工。</skos:definition>
        <skos:definition xml:lang="de">Eine Schleifmaschine ist eine Formmaschine, die ein Schleifrad verwendet, um Material von der Oberfläche eines Werkstücks zu entfernen, typischerweise für Feinarbeiten oder Präzisionsarbeiten.</skos:definition> <skos:definition xml:lang="zh">磨床是一种成型机床，使用砂轮去除工件表面材料，通常用于精加工或精密加工。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000668 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000668">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000602"/>
        <obo:IAO_0000119 xml:lang="en">https://www.merriam-webster.com/dictionary/grips</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">握把</obo:IAO_0000119>
        <rdfs:label xml:lang="de">Halterungsklemmen</rdfs:label> <rdfs:label xml:lang="zh">安装夹钳</rdfs:label>
        <rdfs:label xml:lang="en">grips</rdfs:label> <rdfs:label xml:lang="zh">夹具</rdfs:label>
        <skos:definition xml:lang="de">Diese Gerät beschreibt ein Bauelement / Teil, mit dem etwas, normalerweise ein materielles Objekt, fest gegriffen oder eingespannt wird. Typischerweise sind Halterungen, Klemm- bzw. Spannsysteme Teil eines Befestigungssystems (Prozessknoten), das sich auf ein Prüfsystem bezieht.</skos:definition> <skos:definition xml:lang="zh">该装置描述了一种构件/零件，用于牢固抓取或夹持某物（通常为实体物体）。通常，支架、夹紧或张紧系统属于与测试系统相关的固定系统（过程节点）的一部分。</skos:definition>
        <skos:definition xml:lang="en">This device is a part by which something, usually a tangible object, is grasped. Typically, grips are part of a mounting system (processing node) referring to a testing system.</skos:definition> <skos:definition xml:lang="zh">该设备是一个部件，用于抓取某物（通常是实物）。通常，夹具是安装系统（处理节点）的一部分，涉及测试系统。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000767 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000767">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000920"/>
        <rdfs:label xml:lang="de">Bügelsäge</rdfs:label> <rdfs:label xml:lang="zh">弓锯</rdfs:label>
        <rdfs:label xml:lang="en">hacksaw</rdfs:label> <rdfs:label xml:lang="zh">钢锯</rdfs:label>
        <skos:definition xml:lang="en">A hacksaw is a hand saw designed for cutting various materials, particularly metal. It consists of a fine-toothed blade, tensioned in a frame, and a handle. The frame of a hacksaw is typically C-shaped, allowing the blade to be easily replaced when necessary. Hacksaws are commonly used in metalworking and other applications where a controlled and precise cut through metal is required. The fine teeth on the hacksaw blade enable it to cut through metal with efficiency, and the tensioned frame provides stability during the cutting process. Hacksaws are versatile tools and are often used for tasks such as cutting pipes, rods, and metal sheets. They are available in different sizes and tooth configurations to suit various cutting needs.</skos:definition> <skos:definition xml:lang="zh">钢锯是一种手锯，设计用于切割各种材料，特别是金属。它由一个细齿锯条（张紧在框架中）和一个手柄组成。钢锯的框架通常呈C形，便于在必要时轻松更换锯条。钢锯常用于金属加工和其他需要精确控制切割金属的应用。细齿锯条能高效切割金属，张紧的框架在切割过程中提供稳定性。钢锯是多功能工具，常用于切割管道、棒材和金属板材等任务。它们有不同的尺寸和齿形配置，以适应各种切割需求。</skos:definition>
        <skos:definition xml:lang="de">Eine Bügelsäge ist eine Art Handsäge zum Schneiden verschiedener Materialien, insbesondere Metall. Sie besteht aus einem fein gezahnten Blatt, das in einem Rahmen gespannt ist, und einem Griff. Der Rahmen einer Bügelsäge ist in der Regel C-förmig, so dass das Blatt bei Bedarf leicht ausgewechselt werden kann. Bügelsägen werden häufig bei der Metallbearbeitung und anderen Anwendungen eingesetzt, bei denen ein kontrollierter und präziser Schnitt durch Metall erforderlich ist. Die feinen Zähne des Sägeblatts ermöglichen ein effizientes Schneiden durch Metall, und der gespannte Rahmen sorgt für Stabilität während des Schneidens. Bügelsägen sind vielseitige Werkzeuge und werden häufig für Aufgaben wie das Schneiden von Rohren, Stangen und Blechen verwendet. Sie sind in verschiedenen Größen und Zahnkonfigurationen erhältlich, um verschiedenen Schneidanforderungen gerecht zu werden.</skos:definition> <skos:definition xml:lang="zh">弓锯是一种用于切割各种材料（特别是金属）的手锯。它由安装在框架中的细齿锯条和手柄组成。弓锯的框架通常呈C形，便于根据需要轻松更换锯条。弓锯常用于金属加工及其他需要精确控制切割金属的应用中。锯条的细齿能高效切割金属，张紧的框架在切割过程中提供稳定性。弓锯是一种多功能工具，常用于切割管材、棒材和板材等任务。它们有多种尺寸和齿形配置，以满足不同的切割需求。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000768 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000768">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000008"/>
        <rdfs:label xml:lang="en">half-life</rdfs:label> <rdfs:label xml:lang="zh">半衰期</rdfs:label>
        <skos:definition xml:lang="en">The half-life is a process attribute describing the time it takes for a material entity or a quality of a material entity to reduce its initial value to a half</skos:definition> <skos:definition xml:lang="zh">半衰期是一种过程属性，描述材料实体或其质量将其初始值减少到一半所需的时间。</skos:definition>
        <skos:example xml:lang="en">radioactive decay, material degradation</skos:example> <skos:example xml:lang="zh">放射性衰变，材料降解</skos:example>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000769 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000769">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000016"/>
        <rdfs:label xml:lang="en">hand holdable disposition</rdfs:label> <rdfs:label xml:lang="zh">手持式倾向</rdfs:label>
        <rdfs:label xml:lang="de">in der Hand haltbar</rdfs:label> <rdfs:label xml:lang="zh">手持式</rdfs:label>
        <skos:definition xml:lang="de">Disposion eines Objektes, das per Hand gehalten, betrieben oder verwendet werden kann.</skos:definition> <skos:definition xml:lang="zh">一种可通过手持操作或使用的物体的配置。</skos:definition>
        <skos:definition xml:lang="en">Disposition of an object that can be hold, operated or used manually.</skos:definition> <skos:definition xml:lang="zh">可手持操作或使用的物体的特性</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000770 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000770">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0001999"/>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000558"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000091"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000769"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="de">Handkreissäge</rdfs:label> <rdfs:label xml:lang="zh">手持圆锯</rdfs:label>
        <rdfs:label xml:lang="en">hand circular saw</rdfs:label> <rdfs:label xml:lang="zh">手持圆锯</rdfs:label>
        <skos:definition xml:lang="en">A handheld circular saw is a portable circular saw that is guided by hand. It is well suited for precise cuts in construction and woodwork.</skos:definition> <skos:definition xml:lang="zh">手持圆锯是一种便携式圆锯，由手引导操作。它非常适合在建筑和木工中进行精确切割。</skos:definition>
        <skos:definition xml:lang="de">Die Handkreissäge is eine tragbare Kreissäge, die von Hand geführt wird. Sie eignet sich gut für präzise Schnitte bei Bau- und Holzarbeiten.</skos:definition> <skos:definition xml:lang="zh">手持圆锯是一种便携式圆锯，由手动引导。它非常适合建筑和木工中的精确切割。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000771 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000771">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0001999"/>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000920"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000091"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000769"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="de">Handsäge</rdfs:label> <rdfs:label xml:lang="zh">手锯</rdfs:label>
        <rdfs:label xml:lang="en">handsaw</rdfs:label> <rdfs:label xml:lang="zh">手锯</rdfs:label>
        <skos:definition xml:lang="de">Die Handsäge ist eine manuell betriebene Säge, die dazu dient, verschiedene Materialien, insbesondere Holz, zu schneiden. Diese Art von Säge besteht typischerweise aus einem langen, dünnen Blatt mit Zähnen, das an einem Griff befestigt ist. Der Griff ermöglicht es dem Benutzer, die Säge von Hand zu führen und den Schnitt durch Vor- und Zurückbewegen des Blatts zu erzeugen. Handsägen sind in verschiedenen Ausführungen erhältlich, je nach der beabsichtigten Anwendung. Es gibt beispielsweise Handsägen für Holz, Metall oder Kunststoff, und sie können unterschiedliche Zahngeometrien und Blattlängen aufweisen, um optimal auf verschiedene Schneidanforderungen abgestimmt zu sein.</skos:definition> <skos:definition xml:lang="zh">手锯是一种手动操作的锯子，用于切割各种材料，特别是木材。这种锯通常由一个带有齿的长而薄的锯片和一个手柄组成。手柄使使用者能够手动引导锯子，并通过前后移动锯片产生切割。手锯有多种类型，取决于预期用途。例如，有用于木材、金属或塑料的手锯，它们可能具有不同的齿形和锯片长度，以最佳地适应不同的切割要求。</skos:definition>
        <skos:definition xml:lang="en">The handsaw is a manually operated saw that is used to cut various materials, especially wood. This type of saw typically consists of a long, thin blade with teeth attached to a handle. The handle allows the user to guide the saw by hand and make the cut by moving the blade back and forth. Handsaws are available in different designs, depending on the intended application. For example, there are handsaws for wood, metal or plastic, and they can have different tooth geometries and blade lengths to best suit different cutting requirements.</skos:definition> <skos:definition xml:lang="zh">手锯是一种手动操作的锯，用于切割各种材料，尤其是木材。这种锯通常由一个长而薄的带有齿的刀片和一个手柄组成。手柄允许用户用手引导锯，并通过前后移动刀片进行切割。根据预期用途，手锯有不同的设计。例如，有用于木材、金属或塑料的手锯，它们可以有不同的齿形和刀片长度，以最佳适应不同的切割要求。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000772 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000772">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000550"/>
        <rdfs:label xml:lang="de">Verfestigen Durch Umformen</rdfs:label> <rdfs:label xml:lang="zh">通过形变强化</rdfs:label>
        <rdfs:label xml:lang="en">hardening by forming</rdfs:label> <rdfs:label xml:lang="zh">成形硬化</rdfs:label>
        <skos:definition xml:lang="en">A changing properties of material process, that involves altering material properties by mechanical deformation.</skos:definition> <skos:definition xml:lang="zh">一种通过机械变形改变材料特性的过程。</skos:definition>
        <skos:definition xml:lang="de">Ein Stoffeigenschaft Ändern Prozess, der die Eigenschaften des Materials durch mechanische Verformung verändert.</skos:definition> <skos:definition xml:lang="zh">一种改变材料属性的过程，通过机械变形改变材料的性质。</skos:definition>
        <skos:example xml:lang="en">Sheet Metal Rolling to Achieve Higher Strength.</skos:example> <skos:example xml:lang="zh">金属板材轧制以获得更高强度。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000773 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000773">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000848"/>
        <rdfs:label xml:lang="en">hardness</rdfs:label> <rdfs:label xml:lang="zh">硬度</rdfs:label>
        <skos:definition xml:lang="en">The hardness is a mechanical property used as a measure of a material's resistance to localized plastic deformation, often tested by indentation or scratch methods.</skos:definition> <skos:definition xml:lang="zh">硬度是一种机械性能，用于衡量材料抵抗局部塑性变形的能力，通常通过压痕或划痕方法测试。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000774 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000774">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000775"/>
        <rdfs:label xml:lang="de">Härteprüfgerät</rdfs:label> <rdfs:label xml:lang="zh">硬度测试仪</rdfs:label>
        <rdfs:label xml:lang="en">hardness tester</rdfs:label> <rdfs:label xml:lang="zh">硬度计</rdfs:label>
        <skos:definition xml:lang="en">A hardness tester is a hardness testing machine that measures the resistance of a material to deformation, typically by indentation.</skos:definition> <skos:definition xml:lang="zh">硬度计是一种测量材料抵抗变形能力的硬度测试机器，通常通过压入法进行。</skos:definition>
        <skos:definition xml:lang="de">Ein Härteprüfgerät ist eine Härteprüfmaschine, die den Widerstand eines Materials gegen Verformung, typischerweise durch Eindrücken, misst.</skos:definition> <skos:definition xml:lang="zh">硬度测试仪是一种硬度测试机，用于测量材料对变形的抵抗力，通常通过压入方式。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000775 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000775">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000602"/>
        <rdfs:label xml:lang="de">Härteprüfmaschine</rdfs:label> <rdfs:label xml:lang="zh">硬度测试机</rdfs:label>
        <rdfs:label xml:lang="en">hardness testing machine</rdfs:label> <rdfs:label xml:lang="zh">硬度试验机</rdfs:label>
        <skos:definition xml:lang="en">A device used to measure the hardness of materials through various testing methods such as indentation or scratch tests.</skos:definition> <skos:definition xml:lang="zh">一种用于通过压痕或划痕等各种测试方法测量材料硬度的设备。</skos:definition>
        <skos:definition xml:lang="de">Ein Gerät zur Messung der Härte von Materialien durch verschiedene Prüfmethoden wie Eindrück- oder Kratzversuche.</skos:definition> <skos:definition xml:lang="zh">一种通过不同测试方法（如压痕或划痕测试）测量材料硬度的设备。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000776 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000776">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000849"/>
        <rdfs:label xml:lang="de">Härteprüfverfahren</rdfs:label> <rdfs:label xml:lang="zh">硬度测试方法</rdfs:label>
        <rdfs:label xml:lang="en">hardness testing process</rdfs:label> <rdfs:label xml:lang="zh">硬度测试过程</rdfs:label>
        <skos:definition xml:lang="en">A mechanical property analyzing process that measures a material's resistance to deformation, typically using indentation methods to determine hardness.</skos:definition> <skos:definition xml:lang="zh">一种力学性能分析过程，通过测量材料抵抗变形的能力，通常使用压痕法来确定硬度。</skos:definition>
        <skos:definition xml:lang="de">Ein Mechanische Eigenschaften Analyseverfahren, das den Widerstand eines Materials gegen Verformung misst und typischerweise Eindringverfahren verwendet, um die Härte zu bestimmen.</skos:definition> <skos:definition xml:lang="zh">一种力学性能分析方法，通过测量材料对变形的抵抗力，通常使用压入法测定硬度。</skos:definition>
        <skos:example xml:lang="en">Hardness testing of steel using the Rockwell method to classify its grade for industrial applications.</skos:example> <skos:example xml:lang="zh">使用洛氏方法对钢进行硬度测试，以对其工业应用等级进行分类。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000777 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000777">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000981"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/pmd/co/PMD_0001029"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000549"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://w3id.org/pmd/co/PMD_0000978"/>
        <rdfs:label xml:lang="en">heat capacity</rdfs:label> <rdfs:label xml:lang="zh">热容</rdfs:label>
        <skos:definition xml:lang="en">The heat capacity is a thermal property describing the amount of heat energy required to raise the temperature of a material by a given amount.</skos:definition> <skos:definition xml:lang="zh">热容是描述将材料温度升高一定量所需热能的热学性质。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000778 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000778">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000833"/>
        <obo:IAO_0000112 xml:lang="en">Mixing two fluids. Adding salt into water.</obo:IAO_0000112> <obo:IAO_0000112 xml:lang="zh">混合两种流体。将盐加入水中。</obo:IAO_0000112>
        <rdfs:label xml:lang="en">mixing</rdfs:label> <rdfs:label xml:lang="zh">混合</rdfs:label>
        <skos:definition xml:lang="en">A material processing with the objective to combine two or more material entities as input into a single material entity as output.</skos:definition> <skos:definition xml:lang="zh">一种材料加工过程，旨在将两个或多个材料实体作为输入组合成一个单一材料实体作为输出。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000779 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000779">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000550"/>
        <obo:IAO_0000119 xml:lang="en">Official definition can be found in: DIN EN ISO 4885:2018 Wärmebehandlung Page 21, 3.108 Wärmebehandlung - Definition</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">官方定义见：DIN EN ISO 4885:2018 Wärmebehandlung 第21页, 3.108 Wärmebehandlung - 定义</obo:IAO_0000119>
        <obo:IAO_0000119 xml:lang="de">Offizielle Definition findet man in: DIN EN ISO 4885:2018 Wärmebehandlung Seite 21, 3.108 Wärmebehandlung - Definition</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">官方定义见：DIN EN ISO 4885:2018 热处理 第21页，3.108 热处理 - 定义</obo:IAO_0000119>
        <rdfs:label xml:lang="de">Wärmebehandlung</rdfs:label> <rdfs:label xml:lang="zh">热处理</rdfs:label>
        <rdfs:label xml:lang="en">heat treatment</rdfs:label> <rdfs:label xml:lang="zh">热处理</rdfs:label>
        <skos:altLabel xml:lang="de">Wärmebehandeln</skos:altLabel> <skos:altLabel xml:lang="zh">热处理</skos:altLabel>
        <skos:definition xml:lang="en">A changing properties of material process in which a solid (ferrous) product is fully or partially exposed to specific time-temperature sequences through a series of process steps with the aim of modifying its properties and/or its internal structure.</skos:definition> <skos:definition xml:lang="zh">一种改变材料特性的过程，其中固态（含铁）产品通过一系列工艺步骤完全或部分暴露于特定的时间-温度序列，旨在改变其特性和/或内部结构。</skos:definition>
        <skos:definition xml:lang="de">Ein Stoffeigenschaft Ändern Prozess, bei dem durch eine Reihe von Verfahrensschritten ein festes (Eisen-)Produkt ganz oder teilweise bestimmten Zeit-Temperatur-Abfolgen ausgesetzt wird, mit dem Ziel, seine Eigenschaften und/oder seine innere Struktur zu modifizieren.</skos:definition> <skos:definition xml:lang="zh">一种改变材料特性的过程，通过一系列工艺步骤将固态（铁）产品全部或部分暴露于特定的时间-温度序列，目的是修改其性质和/或内部结构。</skos:definition>
        <skos:example xml:lang="en">Annealing, Ageing, Hardening</skos:example> <skos:example xml:lang="zh">退火、时效、淬火</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000780 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000780">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000602"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000085"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:unionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000054"/>
                                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000055"/>
                                </owl:unionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000602"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000085"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000054"/>
                            <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000055"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="de">Wärmebehandlungsgerät</rdfs:label> <rdfs:label xml:lang="zh">热处理设备</rdfs:label>
        <rdfs:label xml:lang="en">heat treatment device</rdfs:label> <rdfs:label xml:lang="zh">热处理设备</rdfs:label>
        <skos:definition xml:lang="en">A device used for treating materials through heating and cooling processes to alter their properties.</skos:definition> <skos:definition xml:lang="zh">一种用于通过加热和冷却过程处理材料以改变其特性的设备。</skos:definition>
        <skos:definition xml:lang="de">Ein Gerät zur Behandlung von Materialien durch Erwärmungs- und Abkühlungsprozesse zur Veränderung ihrer Eigenschaften.</skos:definition> <skos:definition xml:lang="zh">一种通过加热和冷却过程处理材料以改变其特性的设备。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000781 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000781">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000034"/>
        <rdfs:label xml:lang="de">Wärmebehandlungsfunktion</rdfs:label> <rdfs:label xml:lang="zh">热处理功能</rdfs:label>
        <rdfs:label xml:lang="en">heat treatment function</rdfs:label> <rdfs:label xml:lang="zh">热处理功能</rdfs:label>
        <skos:definition xml:lang="en">A function performed to alter the properties of materials through controlled heating and cooling processes.</skos:definition> <skos:definition xml:lang="zh">通过受控加热和冷却过程改变材料性能的功能。</skos:definition>
        <skos:definition xml:lang="de">Eine Funktion, die durchgeführt wird, um die Eigenschaften von Materialien durch kontrollierte Wärme- und Abkühlungsprozesse zu verändern.</skos:definition> <skos:definition xml:lang="zh">一种通过控制的加热和冷却过程来改变材料特性的功能。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000782 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000782">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000556"/>
        <rdfs:label xml:lang="de">Hochleistungsflüssigkeitschromatographie Verfahren</rdfs:label> <rdfs:label xml:lang="zh">高效液相色谱法</rdfs:label>
        <rdfs:label xml:lang="en">high-performance liquid chromatography process</rdfs:label> <rdfs:label xml:lang="zh">高效液相色谱过程</rdfs:label>
        <skos:definition xml:lang="en">A chromatography process that separates, identifies, and quantifies components in a liquid sample using high pressure to pass the sample through a column packed with a stationary phase.</skos:definition> <skos:definition xml:lang="zh">一种色谱过程，通过高压使液体样品通过装有固定相的色谱柱，从而分离、鉴定和定量样品中的组分。</skos:definition>
        <skos:definition xml:lang="de">Ein Chromatographieverfahren, das Komponenten in einer flüssigen Probe trennt, identifiziert und quantifiziert, indem hoher Druck verwendet wird, um die Probe durch eine mit einer stationären Phase gefüllte Säule zu leiten.</skos:definition> <skos:definition xml:lang="zh">一种色谱方法，通过使用高压将液体样品通过填充有固定相的色谱柱，从而分离、识别和定量液体样品中的组分。</skos:definition>
        <skos:example xml:lang="en">High-performance liquid chromatography is used to analyze the purity and concentration of pharmaceutical compounds in a formulation.</skos:example> <skos:example xml:lang="zh">高效液相色谱用于分析制剂中药用化合物的纯度和浓度。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000783 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000783">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000933"/>
        <rdfs:label xml:lang="de">Hochdurchsatzsimulation</rdfs:label> <rdfs:label xml:lang="zh">高通量模拟</rdfs:label>
        <rdfs:label xml:lang="en">high throughput simulation</rdfs:label> <rdfs:label xml:lang="zh">高通量模拟</rdfs:label>
        <skos:definition xml:lang="en">A simulation process that performs a large number of simulations automatically to explore a wide range of conditions.</skos:definition> <skos:definition xml:lang="zh">一种自动执行大量模拟以探索广泛条件的模拟过程。</skos:definition>
        <skos:definition xml:lang="de">Ein Simulationsprozess, der eine große Anzahl von Simulationen automatisch durchführt, um eine breite Palette von Bedingungen zu erkunden.</skos:definition> <skos:definition xml:lang="zh">一种自动执行大量模拟以探索广泛条件的模拟过程。</skos:definition>
        <skos:example xml:lang="en">Screening thousands of potential material compounds to identify those with optimal properties for battery applications.</skos:example> <skos:example xml:lang="zh">筛选数千种潜在材料化合物，以确定具有最佳电池应用性能的那些。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000784 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000784">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000557"/>
        <rdfs:label xml:lang="de">Hochleistungsflüssigkeitschromatographiesystem</rdfs:label> <rdfs:label xml:lang="zh">高性能液相色谱系统</rdfs:label>
        <rdfs:label xml:lang="en">high performance liquid chromatography system</rdfs:label> <rdfs:label xml:lang="zh">高效液相色谱系统</rdfs:label>
        <skos:definition xml:lang="en">A chromatography system used for separating, identifying, and quantifying compounds in liquid samples through high performance liquid chromatography.</skos:definition> <skos:definition xml:lang="zh">一种通过高效液相色谱分离、鉴定和定量液体样品中化合物的色谱系统。</skos:definition>
        <skos:definition xml:lang="de">Ein Chromatographiesystem zur Trennung, Identifizierung und Quantifizierung von Verbindungen in Flüssigkeitsproben durch Hochleistungsflüssigkeitschromatographie.</skos:definition> <skos:definition xml:lang="zh">一种通过高性能液相色谱对液体样品中的化合物进行分离、鉴定和定量的色谱系统。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000785 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000785">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000657"/>
        <rdfs:label xml:lang="de">Hochtemperatur-Gaschromatographiesystem</rdfs:label> <rdfs:label xml:lang="zh">高温气相色谱系统</rdfs:label>
        <rdfs:label xml:lang="en">high temperature gas chromatography system</rdfs:label> <rdfs:label xml:lang="zh">高温气相色谱系统</rdfs:label>
        <skos:definition xml:lang="en">A gas chromatography system used for separating and analyzing compounds in a gas mixture at high temperatures using a chromatographic column.</skos:definition> <skos:definition xml:lang="zh">一种气相色谱系统，使用色谱柱在高温下分离和分析气体混合物中的化合物。</skos:definition>
        <skos:definition xml:lang="de">Ein Gaschromatographiesystem zur Trennung und Analyse von Verbindungen in einem Gasgemisch bei hohen Temperaturen unter Verwendung einer chromatographischen Säule.</skos:definition> <skos:definition xml:lang="zh">一种使用色谱柱在高温下对气体混合物中的化合物进行分离和分析的气相色谱系统。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000786 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000786">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000931"/>
        <rdfs:label xml:lang="en">hybrid simulation</rdfs:label> <rdfs:label xml:lang="zh">混合模拟</rdfs:label>
        <skos:definition xml:lang="en">A simulation method specification that combines physical and computational models to analyze material behavior.</skos:definition> <skos:definition xml:lang="zh">一种结合物理模型和计算模型来分析材料行为的模拟方法规范。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000788 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000788">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000849"/>
        <rdfs:label xml:lang="de">Schlagprüfverfahren</rdfs:label> <rdfs:label xml:lang="zh">冲击试验方法</rdfs:label>
        <rdfs:label xml:lang="en">impact testing process</rdfs:label> <rdfs:label xml:lang="zh">冲击测试过程</rdfs:label>
        <skos:definition xml:lang="en">A mechanical property analyzing process that determines a material's ability to absorb energy and withstand impact forces, typically using pendulum or drop-weight testers.</skos:definition> <skos:definition xml:lang="zh">一种机械性能分析过程，用于确定材料吸收能量和承受冲击力的能力，通常使用摆锤或落锤测试仪。</skos:definition>
        <skos:definition xml:lang="de">Ein Mechanische Eigenschaften Analyseverfahren, das die Fähigkeit eines Materials bestimmt, Energie zu absorbieren und Schlagkräfte zu widerstehen, typischerweise unter Verwendung von Pendel- oder Fallgewichtsprüfgeräten.</skos:definition> <skos:definition xml:lang="zh">一种机械性能分析方法，用于确定材料吸收能量和抵抗冲击力的能力，通常使用摆锤或落锤试验设备。</skos:definition>
        <skos:example xml:lang="en">Impact testing of helmet materials to ensure they provide adequate protection against head injuries.</skos:example> <skos:example xml:lang="zh">对头盔材料进行冲击测试，以确保其提供足够的头部伤害防护。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000789 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000789">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000773"/>
        <rdfs:label xml:lang="en">indentation hardness</rdfs:label> <rdfs:label xml:lang="zh">压痕硬度</rdfs:label>
        <skos:definition xml:lang="en">The indentation hardness is a hardness representing the resistance of a material to deformation from an indenter, used to assess surface hardness.</skos:definition> <skos:definition xml:lang="zh">压痕硬度是一种表示材料抵抗压头变形能力的硬度，用于评估表面硬度。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000790 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000790">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000877"/>
        <owl:disjointWith rdf:resource="https://w3id.org/pmd/co/PMD_0000911"/>
        <rdfs:comment xml:lang="en">e.g., air into glass</rdfs:comment>
        <rdfs:label xml:lang="en">refraction (optical)</rdfs:label> <rdfs:label xml:lang="zh">折射（光学）</rdfs:label>
        <skos:definition xml:lang="en">Optical property which describes the bending of light as it passes from one medium into another due to a change in the light’s speed.</skos:definition> <skos:definition xml:lang="zh">光学性质，描述光因速度变化而从一个介质进入另一个介质时发生的弯曲。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000791 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000791">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000655"/>
        <rdfs:label xml:lang="de">Induktionsofen</rdfs:label> <rdfs:label xml:lang="zh">感应炉</rdfs:label>
        <rdfs:label xml:lang="en">induction furnace</rdfs:label> <rdfs:label xml:lang="zh">感应炉</rdfs:label>
        <skos:definition xml:lang="en">An induction furnace is a furnace that heats materials using electromagnetic induction, generating heat directly within the material.</skos:definition> <skos:definition xml:lang="zh">感应炉是一种利用电磁感应加热材料的炉子，热量直接在材料内部产生。</skos:definition>
        <skos:definition xml:lang="de">Ein Induktionsofen ist ein Ofen, der Materialien durch elektromagnetische Induktion erhitzt, wobei die Wärme direkt im Material erzeugt wird.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000794 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000794">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000602"/>
        <rdfs:label xml:lang="de">Spritzgießmaschine</rdfs:label> <rdfs:label xml:lang="zh">注塑机</rdfs:label>
        <rdfs:label xml:lang="en">injection molding machine</rdfs:label> <rdfs:label xml:lang="zh">注塑机</rdfs:label>
        <skos:definition xml:lang="en">An injection molding machine is a device used to produce plastic parts by injecting molten plastic into molds under high pressure.</skos:definition> <skos:definition xml:lang="zh">注塑机是一种通过将熔融塑料在高压下注入模具来生产塑料零件的设备。</skos:definition>
        <skos:definition xml:lang="de">Eine Spritzgießmaschine ist ein Gerät, das verwendet wird, um Kunststoffteile durch Einspritzen von geschmolzenem Kunststoff in Formen unter hohem Druck herzustellen.</skos:definition> <skos:definition xml:lang="zh">注塑机是一种通过高压将熔融塑料注入模具来生产塑料零件的设备。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000795 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000795">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000556"/>
        <rdfs:label xml:lang="de">Ionenaustauschchromatographie Verfahren</rdfs:label> <rdfs:label xml:lang="zh">离子交换色谱法</rdfs:label>
        <rdfs:label xml:lang="en">ion exchange chromatography process</rdfs:label> <rdfs:label xml:lang="zh">离子交换色谱过程</rdfs:label>
        <skos:definition xml:lang="en">A chromatography process that separates ions and polar molecules based on their charge by using an ion exchange resin to attract and retain the ions from the sample.</skos:definition> <skos:definition xml:lang="zh">一种色谱过程，根据电荷分离离子和极性分子，使用离子交换树脂吸引并保留样品中的离子。</skos:definition>
        <skos:definition xml:lang="de">Ein Chromatographieverfahren, das Ionen und polare Moleküle basierend auf ihrer Ladung trennt, indem ein Ionenaustauscherharz verwendet wird, um die Ionen aus der Probe anzuziehen und zu halten.</skos:definition> <skos:definition xml:lang="zh">一种色谱方法，基于电荷分离离子和极性分子，使用离子交换树脂吸引并保留样品中的离子。</skos:definition>
        <skos:example xml:lang="en">Ion exchange chromatography is used to purify and separate proteins in a solution for material characterization.</skos:example> <skos:example xml:lang="zh">离子交换色谱用于纯化和分离溶液中的蛋白质，以进行材料表征。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000796 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000796">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000557"/>
        <rdfs:label xml:lang="de">Ionenaustausch-Chromatographiesystem</rdfs:label> <rdfs:label xml:lang="zh">离子交换色谱系统</rdfs:label>
        <rdfs:label xml:lang="en">ion exchange chromatography system</rdfs:label> <rdfs:label xml:lang="zh">离子交换色谱系统</rdfs:label>
        <skos:definition xml:lang="en">A chromatography system used for separating ions in a sample using ion exchange resins in a chromatographic column.</skos:definition> <skos:definition xml:lang="zh">一种色谱系统，用于在色谱柱中使用离子交换树脂分离样品中的离子。</skos:definition>
        <skos:definition xml:lang="de">Ein Chromatographiesystem zur Trennung von Ionen in einer Probe unter Verwendung von Ionenaustauschharzen in einer chromatographischen Säule.</skos:definition> <skos:definition xml:lang="zh">一种色谱系统，使用色谱柱中的离子交换树脂分离样品中的离子。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000797 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000797">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000855"/>
        <rdfs:label xml:lang="de">Ionenmikroskop</rdfs:label> <rdfs:label xml:lang="zh">离子显微镜</rdfs:label>
        <rdfs:label xml:lang="en">ion microscope</rdfs:label> <rdfs:label xml:lang="zh">离子显微镜</rdfs:label>
        <skos:definition xml:lang="en">A microscope that uses ions to create high-resolution images of the surface or structure of a sample.</skos:definition> <skos:definition xml:lang="zh">一种使用离子创建样品表面或结构高分辨率图像的显微镜。</skos:definition>
        <skos:definition xml:lang="de">Ein Mikroskop, das Ionen verwendet, um hochauflösende Bilder der Oberfläche oder Struktur einer Probe zu erstellen.</skos:definition> <skos:definition xml:lang="zh">一种使用离子产生样品表面或结构高分辨率图像的显微镜。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000798 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000798">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000856"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0009006"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0025001"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="de">Ionenmikroskopie</rdfs:label> <rdfs:label xml:lang="zh">离子显微术</rdfs:label>
        <rdfs:label xml:lang="en">ion microscopy</rdfs:label> <rdfs:label xml:lang="zh">离子显微术</rdfs:label>
        <skos:definition xml:lang="en">A microscopy process that uses a focused beam of ions to image a specimen, providing high-resolution images and compositional information, often used for surface analysis and depth profiling.</skos:definition> <skos:definition xml:lang="zh">一种使用聚焦离子束对样品成像的显微过程，提供高分辨率图像和成分信息，常用于表面分析和深度剖析。</skos:definition>
        <skos:definition xml:lang="de">Ein Mikroskopieverfahren, das einen fokussierten Ionenstrahl verwendet, um ein Bild einer Probe zu erzeugen, hochauflösende Bilder und Zusammensetzungsinformationen liefert und häufig für Oberflächenanalysen und Tiefenprofilierung verwendet wird.</skos:definition> <skos:definition xml:lang="zh">一种显微术方法，使用聚焦离子束产生样品图像，提供高分辨率图像和成分信息，常用于表面分析和深度剖析。</skos:definition>
        <skos:example xml:lang="en">An example of an ion microscopy process is Helium Ion Microscopy (HIM), which offers high-resolution imaging with minimal sample damage, or Field Ion Microscopy, which provides atomic-level resolution imaging by using a strong electric field to ionize atoms at the surface of a sharp tip, or Focused Ion Beam Scanning Electron Microscopy (FIB-SEM), which allows for high-precision material removal and imaging by using a focused beam of ions to mill the sample surface while simultaneously capturing detailed SEM images.</skos:example> <skos:example xml:lang="zh">离子显微过程的一个例子是氦离子显微镜（HIM），它能以最小的样品损伤提供高分辨率成像；或场离子显微镜，它通过使用强电场电离尖锐尖端表面的原子来提供原子级分辨率成像；或聚焦离子束扫描电子显微镜（FIB-SEM），它通过使用聚焦离子束铣削样品表面同时捕获详细的SEM图像，实现高精度材料去除和成像。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000799 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000799">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000602"/>
        <rdfs:label xml:lang="de">Ionen-Spektrometer</rdfs:label> <rdfs:label xml:lang="zh">离子光谱仪</rdfs:label>
        <rdfs:label xml:lang="en">ion spectrometer</rdfs:label> <rdfs:label xml:lang="zh">离子光谱仪</rdfs:label>
        <skos:definition xml:lang="en">A device used for analyzing ions in a sample to determine their composition and concentration.</skos:definition> <skos:definition xml:lang="zh">一种用于分析样品中离子以确定其组成和浓度的设备。</skos:definition>
        <skos:definition xml:lang="de">Ein Gerät zur Analyse von Ionen in einer Probe zur Bestimmung ihrer Zusammensetzung und Konzentration.</skos:definition> <skos:definition xml:lang="zh">一种用于分析样品中离子以确定其组成和浓度的设备。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000800 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000800">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000945"/>
        <rdfs:label xml:lang="de">Ionenspektroskopie</rdfs:label> <rdfs:label xml:lang="zh">离子光谱学</rdfs:label>
        <rdfs:label xml:lang="en">ion spectroscopy</rdfs:label> <rdfs:label xml:lang="zh">离子光谱学</rdfs:label>
        <skos:definition xml:lang="en">A spectroscopy process, that analyzes the properties and behavior of ions in a sample by measuring their interaction with electromagnetic fields or other ions.</skos:definition> <skos:definition xml:lang="zh">一种光谱过程，通过测量离子与电磁场或其他离子的相互作用来分析样品中离子的性质和行为。</skos:definition>
        <skos:definition xml:lang="de">Ein Spektroskopie Verfahren, das die Eigenschaften und das Verhalten von Ionen in einer Probe analysiert, indem es ihre Wechselwirkung mit elektromagnetischen Feldern oder anderen Ionen misst.</skos:definition> <skos:definition xml:lang="zh">一种光谱学方法，通过测量离子与电磁场或其他离子的相互作用来分析样品中离子的性质和行為。</skos:definition>
        <skos:example xml:lang="en">Examples are e.g. ion mobility spectroscopy, ion-beam spectroscopy.</skos:example> <skos:example xml:lang="zh">例如，离子迁移谱、离子束光谱学。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000801 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000801">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000550"/>
        <rdfs:label xml:lang="de">Bestrahlen</rdfs:label> <rdfs:label xml:lang="zh">辐照</rdfs:label>
        <rdfs:label xml:lang="en">irradiating</rdfs:label> <rdfs:label xml:lang="zh">辐照</rdfs:label>
        <skos:definition xml:lang="en">A changing properties of material process that employs radiation exposure, to alter and enhance a material's physical or chemical attributes.</skos:definition> <skos:definition xml:lang="zh">一种通过辐射暴露来改变和增强材料物理或化学属性的材料性质变化过程。</skos:definition>
        <skos:definition xml:lang="de">Ein Stoffeigenschaft Ändern Prozess, bei dem die physikalischen oder chemischen Eigenschaften eines Materials durch Bestrahlung verändert und verbessert werden.</skos:definition> <skos:definition xml:lang="zh">一种改变物质性质的过程，通过辐照改变和改善材料的物理或化学性质。</skos:definition>
        <skos:example xml:lang="en">Polymer Curing</skos:example> <skos:example xml:lang="zh">聚合物固化</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000802 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000802">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:label xml:lang="en">absorption of radiation</rdfs:label> <rdfs:label xml:lang="zh">辐射吸收</rdfs:label>
        <skos:definition xml:lang="en">process of taking up radiation by a material entity</skos:definition> <skos:definition xml:lang="zh">材料实体吸收辐射的过程</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000803 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000803">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000602"/>
        <rdfs:label xml:lang="de">Irradiationsgerät</rdfs:label> <rdfs:label xml:lang="zh">辐照设备</rdfs:label>
        <rdfs:label xml:lang="en">irradiation device</rdfs:label> <rdfs:label xml:lang="zh">辐照装置</rdfs:label>
        <skos:definition xml:lang="en">A device used for exposing materials to radiation to induce changes in their properties.</skos:definition> <skos:definition xml:lang="zh">用于将材料暴露于辐射中以引起其性能变化的装置。</skos:definition>
        <skos:definition xml:lang="de">Ein Gerät zum Aussetzen von Materialien gegenüber Strahlung zur Induktion von Veränderungen ihrer Eigenschaften.</skos:definition> <skos:definition xml:lang="zh">一种将材料暴露于辐射以诱导其性质变化的设备。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000805 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000805">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000034"/>
        <rdfs:label xml:lang="de">Irradiationsfunktion</rdfs:label> <rdfs:label xml:lang="zh">辐照功能</rdfs:label>
        <rdfs:label xml:lang="en">irradiation function</rdfs:label> <rdfs:label xml:lang="zh">辐照功能</rdfs:label>
        <skos:definition xml:lang="en">A function performed to expose materials to radiation for altering their properties.</skos:definition> <skos:definition xml:lang="zh">为改变材料性能而将其暴露于辐射中所执行的功能。</skos:definition>
        <skos:definition xml:lang="de">Eine Funktion, die durchgeführt wird, um Materialien Strahlung auszusetzen, um deren Eigenschaften zu verändern.</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000806 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000806">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000833"/>
        <obo:IAO_0000119 xml:lang="en">Official definition can be found in: DIN 8580:2003-9 Fertigungsverfahren, Page 5, 3.1.4 Fügen - Definition &amp; DIN 8593-0</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">官方定义见：DIN 8580:2003-9 Fertigungsverfahren，第5页，3.1.4 Fügen - 定义及DIN 8593-0</obo:IAO_0000119>
        <obo:IAO_0000119 xml:lang="de">Offizielle Definition findet man in: DIN 8580:2003-9 Fertigungsverfahren, Seite 5, 3.1.4 Fügen - Definition &amp; DIN 8593-0</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">官方定义参见：DIN 8580:2003-9 制造工艺，第5页，3.1.4 连接 - 定义 &amp; DIN 8593-0</obo:IAO_0000119>
        <rdfs:label xml:lang="de">Fügen</rdfs:label> <rdfs:label xml:lang="zh">连接</rdfs:label>
        <rdfs:label xml:lang="en">joining</rdfs:label> <rdfs:label xml:lang="zh">连接</rdfs:label>
        <skos:definition xml:lang="en">A manufacturing process that enables the continuous bonding or joining of two or more workpieces with a specific, fixed shape or of such workpieces with a shapeless material, whereby the cohesion is created at specific points and reinforced overall.</skos:definition> <skos:definition xml:lang="zh">一种制造过程，能够实现两个或多个具有特定固定形状的工件，或此类工件与无形材料的持续结合或连接，其中在特定点产生内聚力并整体增强。</skos:definition>
        <skos:definition xml:lang="de">Ein Herstellungsprozess, der das dauerhafte Verbinden oder das Zusammenfügen von zwei oder mehr Werkstücken mit spezifischer, fester Form oder von solchen Werkstücken mit einem formlosen Material ermöglicht, wobei der Zusammenhalt an spezifischen Stellen erzeugt und insgesamt verstärkt wird.</skos:definition> <skos:definition xml:lang="zh">一种制造工艺，能够永久性地将两个或多个具有特定固体形状的工件，或者将这些工件与无定形材料连接或接合起来，在特定位置产生结合力并整体增强。</skos:definition>
        <skos:example xml:lang="en">Joining By Welding, Assembling</skos:example> <skos:example xml:lang="zh">通过焊接、装配进行连接</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000807 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000807">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000806"/>
        <obo:IAO_0000119 xml:lang="en">Official definition can be found in: DIN 8593-4</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">官方定义见：DIN 8593-4</obo:IAO_0000119>
        <obo:IAO_0000119 xml:lang="de">Offizielle Definition findet man in: DIN 8593-4</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">官方定义见：DIN 8593-4</obo:IAO_0000119>
        <rdfs:label xml:lang="de">Fügen durch Urformen</rdfs:label> <rdfs:label xml:lang="zh">通过原形制造进行连接</rdfs:label>
        <rdfs:label xml:lang="en">joining by primary shaping</rdfs:label> <rdfs:label xml:lang="zh">通过初始成形进行连接</rdfs:label>
        <skos:altLabel xml:lang="en">Joining By Master Forming</skos:altLabel> <skos:altLabel xml:lang="zh">通过主成形进行连接</skos:altLabel>
        <skos:definition xml:lang="en">A joining process that involves creating a part or component in its final shape from a liquid or semi-liquid material.</skos:definition> <skos:definition xml:lang="zh">一种连接过程，涉及从液态或半液态材料制造最终形状的零件或部件。</skos:definition>
        <skos:definition xml:lang="de">Ein Fügeverfahren, bei dem ein Teil oder eine Komponente aus einem flüssigen oder halbflüssigen Material in seine endgültige Form gebracht wird.</skos:definition> <skos:definition xml:lang="zh">一种连接方法，其中零件或组件由液态或半液态材料成形为其最终形状。</skos:definition>
        <skos:example xml:lang="en">Pouring, Embedding, Encasing</skos:example> <skos:example xml:lang="zh">浇注、嵌入、封装</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000808 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000808">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000806"/>
        <obo:IAO_0000119 xml:lang="en">Official definition can be found in: DIN 8593-5</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">官方定义见：DIN 8593-5</obo:IAO_0000119>
        <obo:IAO_0000119 xml:lang="de">Offizielle Definition findet man in: DIN 8593-5</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">官方定义见：DIN 8593-5</obo:IAO_0000119>
        <rdfs:label xml:lang="de">Fügen Durch Umformen</rdfs:label> <rdfs:label xml:lang="zh">通过变形连接</rdfs:label>
        <rdfs:label xml:lang="en">joining by shaping</rdfs:label> <rdfs:label xml:lang="zh">通过成形连接</rdfs:label>
        <skos:altLabel xml:lang="en">Joining By Forming</skos:altLabel> <skos:altLabel xml:lang="zh">通过成形连接</skos:altLabel>
        <skos:definition xml:lang="en">A joining process that involves deforming one or more components to achieve a mechanical interlock or fit, commonly used for press-fit joints, crimping, or swaging.</skos:definition> <skos:definition xml:lang="zh">一种通过变形一个或多个部件以实现机械互锁或配合的连接工艺，常用于压配接头、压接或型锻。</skos:definition>
        <skos:definition xml:lang="de">Ein Füge Prozess, bei dem eine oder mehrere Komponenten verformt werden, um eine mechanische Verriegelung oder Passung zu erreichen, die üblicherweise für Pressverbindungen, Crimpen oder Schmieden verwendet wird.</skos:definition> <skos:definition xml:lang="zh">一种连接过程，其中对单个或多个组件进行变形以实现机械锁定或配合，通常用于压配连接、压接或锻造。</skos:definition>
        <skos:example xml:lang="en">Joining By Riveting, Joining By Forming Wire-Shaped Bodies</skos:example> <skos:example xml:lang="zh">铆接连接，线材成形连接</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000809 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000809">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000806"/>
        <obo:IAO_0000119 xml:lang="en">Official definition can be found in: DIN 8593-7</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">官方定义见：DIN 8593-7</obo:IAO_0000119>
        <obo:IAO_0000119 xml:lang="de">Offizielle Definition findet man in: DIN 8593-7</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">官方定义见：DIN 8593-7</obo:IAO_0000119>
        <rdfs:label xml:lang="de">Fügen Durch Löten</rdfs:label> <rdfs:label xml:lang="zh">通过钎焊连接</rdfs:label>
        <rdfs:label xml:lang="en">joining by soldering</rdfs:label> <rdfs:label xml:lang="zh">通过钎焊连接</rdfs:label>
        <skos:definition xml:lang="en">A joining process that involves using a filler material (solder) to join metal parts by melting the solder between them without melting the base materials, a technique widely used in electronics and plumbing. This process creates a strong, conductive bond suitable for various applications.</skos:definition> <skos:definition xml:lang="zh">一种使用填充材料（焊料）连接金属部件的连接工艺，通过熔化焊料在部件之间而不熔化基材，该技术广泛应用于电子和管道工程。该工艺形成牢固、导电的连接，适用于各种应用。</skos:definition>
        <skos:definition xml:lang="de">Ein Füge Prozess, bei dem ein Füllmaterial (Lot) verwendet wird, um Metallteile zu verbinden, indem das Lot zwischen ihnen geschmolzen wird, ohne die Grundmaterialien zu schmelzen. Diese Technik wird häufig in der Elektronik und im Sanitärbereich eingesetzt. Durch dieses Verfahren entsteht eine starke, leitfähige Verbindung, die für verschiedene Anwendungen geeignet ist.</skos:definition> <skos:definition xml:lang="zh">一种使用填充材料（焊料）连接金属部件的工艺，通过熔化位于部件之间的焊料而不熔化基材。该技术常用于电子和管道领域。此工艺形成牢固且导电的连接，适用于多种应用。</skos:definition>
        <skos:example xml:lang="en">Joint Soft Soldering, Joint Hard Soldering</skos:example> <skos:example xml:lang="zh">软钎焊连接，硬钎焊连接</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000810 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000810">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000806"/>
        <obo:IAO_0000119 xml:lang="en">Official definition can be found in: DIN 8593-6</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">官方定义见：DIN 8593-6</obo:IAO_0000119>
        <obo:IAO_0000119 xml:lang="de">Offizielle Definition findet man in: DIN 8593-6</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">官方定义见：DIN 8593-6</obo:IAO_0000119>
        <rdfs:label xml:lang="de">Fügen Durch Schweißen</rdfs:label> <rdfs:label xml:lang="zh">通过焊接连接</rdfs:label>
        <rdfs:label xml:lang="en">joining by welding</rdfs:label> <rdfs:label xml:lang="zh">通过焊接连接</rdfs:label>
        <skos:definition xml:lang="en">A joining process that involves fusing two or more metal parts by applying heat, pressure, or both, often with the addition of a filler material. This method creates a permanent and strong bond, essential in manufacturing and construction for durable structures and components.</skos:definition> <skos:definition xml:lang="zh">一种通过施加热量、压力或两者同时作用使两个或多个金属部件熔合的连接工艺，通常加入填充材料。该方法形成永久且牢固的连接，对于制造和建筑中耐用结构和部件至关重要。</skos:definition>
        <skos:definition xml:lang="de">Ein Füge Prozess, bei dem zwei oder mehr Metallteile durch Anwendung von Hitze, Druck oder beidem verschmolzen werden, oft unter Zugabe eines Füllstoffs. Durch dieses Verfahren entsteht eine dauerhafte und starke Verbindung, die in der Fertigung und im Bauwesen für dauerhafte Strukturen und Komponenten unerlässlich ist.</skos:definition> <skos:definition xml:lang="zh">一种通过施加热量、压力或两者同时作用，将两个或多个金属部件熔合在一起的连接工艺，通常添加填充材料。此工艺形成持久且牢固的连接，对制造和建筑中的永久结构和部件至关重要。</skos:definition>
        <skos:example xml:lang="en">Pressure Welding, Fusion Welding</skos:example> <skos:example xml:lang="zh">压力焊接，熔焊</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000811 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000811">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000602"/>
        <rdfs:label xml:lang="de">Verbindungsgerät</rdfs:label> <rdfs:label xml:lang="zh">连接设备</rdfs:label>
        <rdfs:label xml:lang="en">joining device</rdfs:label> <rdfs:label xml:lang="zh">连接装置</rdfs:label>
        <skos:definition xml:lang="en">A general device used for joining materials through various methods, including welding and soldering.</skos:definition> <skos:definition xml:lang="zh">一种用于通过各种方法（包括焊接和钎焊）连接材料的通用装置。</skos:definition>
        <skos:definition xml:lang="de">Ein allgemeines Gerät zum Verbinden von Materialien durch verschiedene Methoden, einschließlich Schweißen und Löten.</skos:definition> <skos:definition xml:lang="zh">一种通过多种方法（包括焊接和钎焊）连接材料的通用设备。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000812 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000812">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000034"/>
        <rdfs:label xml:lang="de">Verbindungsfunktion</rdfs:label> <rdfs:label xml:lang="zh">连接功能</rdfs:label>
        <rdfs:label xml:lang="en">joining function</rdfs:label> <rdfs:label xml:lang="zh">连接功能</rdfs:label>
        <skos:definition xml:lang="en">A function performed to connect or bond materials together through various methods such as welding or soldering.</skos:definition> <skos:definition xml:lang="zh">一种通过焊接或钎焊等各种方法将材料连接或粘合在一起的功能。</skos:definition>
        <skos:definition xml:lang="de">Eine Funktion, die ausgeführt wird, um Materialien durch verschiedene Methoden wie Schweißen oder Löten zu verbinden.</skos:definition> <skos:definition xml:lang="zh">一种执行的功能，用于通过焊接或钎焊等方法连接材料。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000813 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000813">
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000602"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000085"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000592"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="de">Messer</rdfs:label> <rdfs:label xml:lang="zh">刀</rdfs:label>
        <rdfs:label xml:lang="en">knife</rdfs:label> <rdfs:label xml:lang="zh">刀</rdfs:label>
        <skos:definition xml:lang="en">A tool with a sharp edge, typically made of metal, used for cutting food, materials, or other substances.</skos:definition> <skos:definition xml:lang="zh">一种带有锋利边缘的工具，通常由金属制成，用于切割食物、材料或其他物质。</skos:definition>
        <skos:definition xml:lang="de">Ein Werkzeug mit einer scharfen Schneide, üblicherweise aus Metall, das zum Schneiden von Lebensmitteln, Materialien oder anderen Substanzen verwendet wird.</skos:definition> <skos:definition xml:lang="zh">一种带有锋利刃口的工具，通常由金属制成，用于切割食物、材料或其他物质。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000816 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000816">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000945"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0009006"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000512"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0009006"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000591"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="de">Laserspektroskopie</rdfs:label> <rdfs:label xml:lang="zh">一种使用激光研究材料特性的光谱学方法。</rdfs:label>
        <rdfs:label xml:lang="en">laser spectroscopy</rdfs:label> <rdfs:label xml:lang="zh">激光光谱学</rdfs:label>
        <skos:definition xml:lang="en">A spectroscopy process, that uses laser light to probe the properties of materials.</skos:definition> <skos:definition xml:lang="zh">一种使用激光来探测材料特性的光谱学过程。</skos:definition>
        <skos:definition xml:lang="de">Ein Spektroskopie Verfahren, das Laserlicht verwendet, um die Eigenschaften von Materialien zu untersuchen.</skos:definition>
        <skos:example xml:lang="en">Examples are e.g. laser absorption spectroscopy, laser emission spectroscopy, ultra-fast laser spectroscopy.</skos:example> <skos:example xml:lang="zh">示例包括例如激光吸收光谱、激光发射光谱、超快激光光谱。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000817 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000817">
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000602"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000085"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000592"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="de">Laserschneider</rdfs:label> <rdfs:label xml:lang="zh">一种使用激光束在木材、塑料、金属等不同材料上进行精确切割的设备。</rdfs:label>
        <rdfs:label xml:lang="en">lasercutter</rdfs:label> <rdfs:label xml:lang="zh">激光切割机</rdfs:label>
        <skos:definition xml:lang="en">A device that utilizes laser beams to create precise cuts in various materials such as wood, plastic, metal, etc.</skos:definition> <skos:definition xml:lang="zh">一种利用激光束在各种材料（如木材、塑料、金属等）上进行精确切割的设备。</skos:definition>
        <skos:definition xml:lang="de">Ein Gerät, das Laserstrahlen verwendet, um präzise Schnitte in verschiedenen Materialien wie Holz, Kunststoff, Metall usw. zu erzeugen.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000818 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000818">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000648"/>
        <rdfs:label xml:lang="de">Drehmaschine</rdfs:label> <rdfs:label xml:lang="zh">车床是一种成型机床，它使工件绕其轴线旋转，以执行切削、磨削、钻孔或变形等各种操作。</rdfs:label>
        <rdfs:label xml:lang="en">lathe</rdfs:label> <rdfs:label xml:lang="zh">车床</rdfs:label>
        <skos:definition xml:lang="en">A lathe is a forming machine that rotates a workpiece on its axis to perform various operations such as cutting, sanding, drilling, or deformation.</skos:definition> <skos:definition xml:lang="zh">车床是一种成形机器，它使工件绕其轴线旋转，以执行各种操作，如切削、打磨、钻孔或变形。</skos:definition>
        <skos:definition xml:lang="de">Eine Drehmaschine ist eine Formmaschine, das ein Werkstück um seine Achse dreht, um verschiedene Operationen wie Schneiden, Schleifen, Bohren oder Verformung durchzuführen.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000819 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000819">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000875"/>
        <rdfs:label xml:lang="de">Lichtmikroskopie</rdfs:label> <rdfs:label xml:lang="zh">一种使用可见光和透镜来放大和可视化样品的光学显微镜方法，从而能够研究材料的微观结构和形态。</rdfs:label>
        <rdfs:label xml:lang="en">light microscopy</rdfs:label> <rdfs:label xml:lang="zh">光学显微术</rdfs:label>
        <skos:definition xml:lang="en">An optical microscopy process that uses visible light and lenses to magnify and visualize specimens, enabling the study of the microstructure and morphology of materials.</skos:definition> <skos:definition xml:lang="zh">一种使用可见光和透镜来放大和可视化样本的光学显微术过程，从而能够研究材料的微观结构和形态。</skos:definition>
        <skos:definition xml:lang="de">Ein optisches Mikroskopieverfahren, das sichtbares Licht und Linsen verwendet, um Proben zu vergrößern und zu visualisieren, wodurch die Untersuchung der Mikrostruktur und Morphologie von Materialien ermöglicht wird.</skos:definition>
        <skos:example xml:lang="en">An example of a light microscopy process is Confocal Laser Scanning Microscopy, which uses laser light to scan specimens and create high-resolution, three-dimensional images. Another example is Fluorescence Microscopy, which uses fluorescent dyes to label specific components of the specimen, allowing for the visualization of structures that are otherwise difficult to see. A third example is Polarized Light Microscopy, which utilizes polarized light to enhance contrast in samples with birefringent properties, such as crystalline materials.</skos:example> <skos:example xml:lang="zh">光学显微术的一个示例是Confocal Laser Scanning Microscopy，它使用激光扫描样本并创建高分辨率的三维图像。另一个示例是Fluorescence Microscopy，它使用荧光染料标记样本的特定成分，从而可视化原本难以看到的结构。第三个示例是Polarized Light Microscopy，它利用偏振光增强具有双折射特性的样本（如晶体材料）的对比度。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000820 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000820">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000602"/>
        <obo:IAO_0000119 xml:lang="en">https://en.wikipedia.org/wiki/Load_cell</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">称重传感器</obo:IAO_0000119>
        <rdfs:label xml:lang="de">Kraftmessdose</rdfs:label>
        <rdfs:label xml:lang="en">load cell</rdfs:label> <rdfs:label xml:lang="zh">称重传感器</rdfs:label>
        <skos:definition xml:lang="en">A device that converts mechanical force into a measurable signal by sensing the physical deformation of a structural element.</skos:definition> <skos:definition xml:lang="zh">一种通过感测结构元件的物理变形将机械力转换为可测量信号的设备。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000821 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000821">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000933"/>
        <rdfs:label xml:lang="de">Maschinelles Lernen</rdfs:label> <rdfs:label xml:lang="zh">机器学习</rdfs:label>
        <rdfs:label xml:lang="en">machine learning</rdfs:label> <rdfs:label xml:lang="zh">机器学习</rdfs:label>
        <skos:definition xml:lang="en">A simulation process that uses algorithms to enable computers to learn from and make predictions based on data.</skos:definition> <skos:definition xml:lang="zh">一种使用算法使计算机从数据中学习并基于数据进行预测的模拟过程。</skos:definition>
        <skos:definition xml:lang="de">Ein Simulationsprozess, der Algorithmen verwendet, um Computern das Lernen aus Daten und das Treffen von Vorhersagen zu ermöglichen.</skos:definition> <skos:definition xml:lang="zh">一种模拟过程，使用算法使计算机能够从数据中学习并做出预测。</skos:definition>
        <skos:example xml:lang="en">Predicting the mechanical properties of composite materials based on their composition.</skos:example> <skos:example xml:lang="zh">基于成分预测复合材料的力学性能。</skos:example>
        <PMD_0050117>ML</PMD_0050117>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000822 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000822">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000927"/>
        <obo:IAO_0000119 xml:lang="en">Official definition can be found in: DIN 8589-0</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">官方定义可在：DIN 8589-0 中找到。</obo:IAO_0000119>
        <obo:IAO_0000119 xml:lang="de">Offizielle Definition findet man in: DIN 8589-0</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">官方定义见：DIN 8589-0</obo:IAO_0000119>
        <rdfs:label xml:lang="de">Spanen Mit Geometrisch Bestimmten Schneiden</rdfs:label> <rdfs:label xml:lang="zh">几何确定切削刃加工</rdfs:label>
        <rdfs:label xml:lang="en">machining geometrically defined</rdfs:label> <rdfs:label xml:lang="zh">几何定义加工</rdfs:label>
        <skos:definition xml:lang="en">A separating process that involves removing material with a tool that has a defined shape and sharp edges, such as in sawing and drilling operations.</skos:definition> <skos:definition xml:lang="zh">一种使用具有确定形状和锋利边缘的工具去除材料的分离过程，例如锯切和钻孔操作。</skos:definition>
        <skos:definition xml:lang="de">Ein Trennprozess, bei dem Material mit einem Werkzeug mit definierter Form und scharfen Kanten entfernt wird, wie z. B. beim Sägen und Bohren.</skos:definition> <skos:definition xml:lang="zh">一种分离过程，使用具有确定形状和锋利边缘的工具去除材料，例如锯切和钻孔。</skos:definition>
        <skos:example xml:lang="en">Drilling, Turning</skos:example> <skos:example xml:lang="zh">钻孔，车削</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000823 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000823">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000927"/>
        <obo:IAO_0000119 xml:lang="en">Official definition can be found in: DIN 8589-0</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">官方定义可在：DIN 8589-0 中找到。</obo:IAO_0000119>
        <obo:IAO_0000119 xml:lang="de">Offizielle Definition findet man in: DIN 8589-0</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">官方定义见：DIN 8589-0</obo:IAO_0000119>
        <rdfs:label xml:lang="de">Spanen Mit Geometrisch Unbestimmten Schneiden</rdfs:label> <rdfs:label xml:lang="zh">几何不确定切削刃加工</rdfs:label>
        <rdfs:label xml:lang="en">machining geometrically undefined</rdfs:label> <rdfs:label xml:lang="zh">几何非定义加工</rdfs:label>
        <skos:definition xml:lang="en">A separating process that involves removing material using tools with undefined cutting edges, such as grinding or abrasive machining, where the exact shape of the cutting part isn't clearly defined.</skos:definition> <skos:definition xml:lang="zh">一种使用具有不确定切削刃的工具去除材料的分离过程，例如磨削或磨料加工，其中切削部分的精确形状未明确定义。</skos:definition>
        <skos:definition xml:lang="de">Ein Trennprozess, bei dem Material mit Werkzeugen mit undefinierten Schneiden abgetragen wird, wie z. B. beim Schleifen oder bei der abrasiven Bearbeitung, bei der die genaue Form des zu schneidenden Teils nicht klar definiert ist.</skos:definition> <skos:definition xml:lang="zh">一种分离过程，使用未定义切削刃的工具去除材料，例如磨削或磨料加工，其中被切削部分的精确形状未明确确定。</skos:definition>
        <skos:example xml:lang="en">Grinding, Blasting</skos:example> <skos:example xml:lang="zh">磨削，喷砂</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000825 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000825">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000005"/>
        <rdfs:label xml:lang="en">magnetic property</rdfs:label> <rdfs:label xml:lang="zh">磁性</rdfs:label>
        <skos:definition xml:lang="en">A magnetic property is a material property representing characteristics that describe how a material responds to magnetic fields, such as permeability and coercivity.</skos:definition> <skos:definition xml:lang="zh">磁性是一种材料属性，代表描述材料如何响应磁场的特性，如磁导率和矫顽力。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000826 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000826">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000550"/>
        <obo:IAO_0000119 xml:lang="de">https://industrylist.com/glossar/stoffeigenschaften-aendern/magnetisieren/</obo:IAO_0000119>
        <rdfs:label xml:lang="de">Magnetisieren</rdfs:label> <rdfs:label xml:lang="zh">磁化</rdfs:label>
        <rdfs:label xml:lang="en">magnetizing</rdfs:label> <rdfs:label xml:lang="zh">磁化</rdfs:label>
        <skos:definition xml:lang="en">A changing properties of material process in which ferromagnetic materials are exposed to an external magnetic field, causing the material to take on magnetic properties.</skos:definition> <skos:definition xml:lang="zh">一种改变材料属性的过程，其中铁磁材料暴露于外部磁场，使材料获得磁性。</skos:definition>
        <skos:definition xml:lang="de">Ein Stoffeigenschaft Ändern Prozess, bei dem ferromagnetische Stoffe einem äußeren Magnetfeld ausgesetzt werden wodurch der Stoff magnetische Eigenschaften übernimmt.</skos:definition> <skos:definition xml:lang="zh">一种改变材料属性的过程，其中铁磁材料暴露于外部磁场，使材料获得磁性。</skos:definition>
        <skos:example xml:lang="en">Static Magnetization, Pulse Magnetization.</skos:example> <skos:example xml:lang="zh">静态磁化，脉冲磁化。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000827 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000827">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000602"/>
        <rdfs:label xml:lang="de">Magnetisierungsgerät</rdfs:label> <rdfs:label xml:lang="zh">磁化设备</rdfs:label>
        <rdfs:label xml:lang="en">magnetizing device</rdfs:label> <rdfs:label xml:lang="zh">磁化装置</rdfs:label>
        <skos:definition xml:lang="en">A device used for inducing a magnetic field in materials to alter their magnetic properties.</skos:definition> <skos:definition xml:lang="zh">一种用于在材料中感应磁场以改变其磁性能的设备。</skos:definition>
        <skos:definition xml:lang="de">Ein Gerät zur Induktion eines Magnetfelds in Materialien, um deren magnetische Eigenschaften zu verändern.</skos:definition> <skos:definition xml:lang="zh">一种用于在材料中感应磁场以改变其磁性能的设备。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000828 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000828">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000034"/>
        <rdfs:label xml:lang="de">Magnetisierungsfunktion</rdfs:label> <rdfs:label xml:lang="zh">磁化功能</rdfs:label>
        <rdfs:label xml:lang="en">magnetizing function</rdfs:label> <rdfs:label xml:lang="zh">磁化功能</rdfs:label>
        <skos:definition xml:lang="en">A function performed to induce a magnetic field in materials to modify their magnetic properties.</skos:definition> <skos:definition xml:lang="zh">为了在材料中感应磁场以改变其磁性能而执行的功能。</skos:definition>
        <skos:definition xml:lang="de">Eine Funktion, die durchgeführt wird, um ein Magnetfeld in Materialien zu induzieren, um deren magnetische Eigenschaften zu verändern.</skos:definition> <skos:definition xml:lang="zh">为了在材料中感应磁场以改变其磁性能而执行的功能。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000829 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000829">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBI_0000070"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0009006"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000825"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="de">Magnetische Elektrische Eigenschaften Analyseverfahren</rdfs:label> <rdfs:label xml:lang="zh">磁电性能分析方法</rdfs:label>
        <rdfs:label xml:lang="en">magneto electrical property analyzing process</rdfs:label> <rdfs:label xml:lang="zh">磁电性能分析过程</rdfs:label>
        <skos:definition xml:lang="en">An assay that investigates the magnetic and electrical properties of materials, including conductivity, resistivity, permittivity, permeability, and magnetization.</skos:definition> <skos:definition xml:lang="zh">一种分析，研究材料的磁电性能，包括电导率、电阻率、介电常数、磁导率和磁化强度。</skos:definition>
        <skos:definition xml:lang="de">Eine Analyse, die die magnetischen und elektrischen Eigenschaften von Materialien untersucht, einschließlich Leitfähigkeit, Widerstand, Permittivität, Permeabilität und Magnetisierung.</skos:definition> <skos:definition xml:lang="zh">一种分析，研究材料的磁电性能，包括电导率、电阻率、介电常数、磁导率和磁化强度。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000832 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000832">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000034"/>
        <rdfs:label xml:lang="de">Fertigungsfunktion</rdfs:label> <rdfs:label xml:lang="zh">制造功能</rdfs:label>
        <rdfs:label xml:lang="en">manufacturing function</rdfs:label> <rdfs:label xml:lang="zh">制造功能</rdfs:label>
        <skos:definition xml:lang="en">A function that inheres in devices or processes that are used to produce or assemble goods or components.</skos:definition> <skos:definition xml:lang="zh">一种固有于用于生产或组装商品或组件的设备或过程的功能。</skos:definition>
        <skos:definition xml:lang="de">Eine Funktion, die in Geräten oder Prozessen besteht, die zur Herstellung oder Montage von Waren oder Komponenten verwendet werden.</skos:definition> <skos:definition xml:lang="zh">一种固有于用于生产或组装商品或组件的设备或过程的功能。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000833 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000833">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/COB_0000035"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000293"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:unionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000027"/>
                                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000030"/>
                                </owl:unionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000299"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:unionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000027"/>
                                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000030"/>
                                </owl:unionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/COB_0000035"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000293"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000027"/>
                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000030"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000299"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000027"/>
                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000030"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Manufacturing processes alternate qualities of materials, i.e., a value specification of some quality of a material entity, which is a specified input to the process, cannot be the same as a value specification of the same quality of another material entity, which is a specified output of the process. 

Unfortunately it is not possible to write down such axiom based on OWL. Semi-working solution are the temporally qualified continuants + SPARQL constrains.</rdfs:comment>
        <rdfs:label xml:lang="de">Herstellungsprozess</rdfs:label> <rdfs:label xml:lang="zh">制造过程</rdfs:label>
        <rdfs:label xml:lang="en">manufacturing process</rdfs:label> <rdfs:label xml:lang="zh">制造过程</rdfs:label>
        <skos:definition xml:lang="en">A planned process that is driven by the primary intent to transform objects
A manufacturing process is always a transformative process.</skos:definition> <skos:definition xml:lang="zh">一种有规划的过程，其主要意图是转化对象。制造过程始终是一个转化过程。</skos:definition>
        <skos:definition xml:lang="de">Ein geplannter Prozess, der von der primären Absicht angetrieben wird, Objekte zu transformieren. Ein Herstellungsprozess ist immer ein Transformationsprozess.</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000834 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000834">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000502"/>
        <rdfs:label xml:lang="en">map</rdfs:label> <rdfs:label xml:lang="zh">地图</rdfs:label>
        <skos:definition xml:lang="en">A map is a 2D information content entity describing a representation of spatial data or relationships, often used in material science for visualizing properties or distributions.</skos:definition> <skos:definition xml:lang="zh">地图是一种二维信息内容实体，描述空间数据或关系的表示，常用于材料科学中可视化属性或分布。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000835 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000835">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000602"/>
        <rdfs:label xml:lang="de">Massenspektrometer</rdfs:label> <rdfs:label xml:lang="zh">质谱仪</rdfs:label>
        <rdfs:label xml:lang="en">mass spectrometer</rdfs:label> <rdfs:label xml:lang="zh">质谱仪</rdfs:label>
        <skos:definition xml:lang="en">A device used to measure the mass-to-charge ratio of ions to identify and quantify compounds in a sample.</skos:definition> <skos:definition xml:lang="zh">一种用于测量离子的质荷比以识别和量化样品中化合物的设备。</skos:definition>
        <skos:definition xml:lang="de">Ein Gerät zur Messung des Massen-zu-Ladung-Verhältnisses von Ionen zur Identifizierung und Quantifizierung von Verbindungen in einer Probe.</skos:definition> <skos:definition xml:lang="zh">一种测量离子质荷比以识别和量化样品中化合物的仪器。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000836 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000836">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000945"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0009006"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000597"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="de">Massenspektroskopie</rdfs:label> <rdfs:label xml:lang="zh">质谱法</rdfs:label>
        <rdfs:label xml:lang="en">mass spectrometry</rdfs:label> <rdfs:label xml:lang="zh">质谱法</rdfs:label>
        <skos:definition xml:lang="en">A spectroscopy process that measures the mass-to-charge ratio of ions to identify and quantify molecules in a sample.</skos:definition> <skos:definition xml:lang="zh">一种光谱过程，通过测量离子的质荷比来识别和量化样品中的分子。</skos:definition>
        <skos:definition xml:lang="de">Ein Spektroskopie Verfahren, das das Masse-zu-Ladung-Verhältnis von Ionen misst, um Moleküle in einer Probe zu identifizieren und zu quantifizieren.</skos:definition> <skos:definition xml:lang="zh">一种测量离子质荷比以识别和量化样品中分子的光谱学方法。</skos:definition>
        <skos:example xml:lang="en">Examples are e.g. time-of-flight mass spectroscopy, particle beam mass spectrometry.</skos:example> <skos:example xml:lang="zh">例如，time-of-flight质谱法、粒子束质谱法等。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000845 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000845">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000023"/>
        <owl:disjointWith rdf:resource="https://w3id.org/pmd/co/PMD_0020001"/>
        <owl:disjointWith rdf:resource="https://w3id.org/pmd/co/PMD_0020002"/>
        <rdfs:label xml:lang="en">matrix role</rdfs:label> <rdfs:label xml:lang="zh">基质角色</rdfs:label>
        <skos:definition xml:lang="en">Matrix is the role of a 'PortionOfConnectedMatter' that implies to host the Filler.</skos:definition> <skos:definition xml:lang="zh">基质是'PortionOfConnectedMatter'的角色，意味着承载Filler。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000847 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000847">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000034"/>
        <rdfs:label xml:lang="de">Messfunktion</rdfs:label> <rdfs:label xml:lang="zh">测量功能</rdfs:label>
        <rdfs:label xml:lang="en">measuring function</rdfs:label> <rdfs:label xml:lang="zh">测量功能</rdfs:label>
        <skos:definition xml:lang="en">A function performed to determine the magnitude, quantity, or extent of a physical property or condition.</skos:definition> <skos:definition xml:lang="zh">一种用于确定物理属性或条件的大小、数量或程度的功能。</skos:definition>
        <skos:definition xml:lang="de">Eine Funktion, die durchgeführt wird, um das Ausmaß, die Menge oder den Zustand einer physikalischen Eigenschaft zu bestimmen.</skos:definition> <skos:definition xml:lang="zh">一种用于确定物理属性的大小、数量或状态的功能。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000848 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000848">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000005"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000522"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000052"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000000"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">The axiom that mechanical property has realization some application of mechanical load treats only conventional materials and not such effects as magnetostriction etc.</rdfs:comment>
        <rdfs:label xml:lang="en">mechanical property</rdfs:label> <rdfs:label xml:lang="zh">力学性能</rdfs:label>
        <skos:definition xml:lang="en">A mechanical property is a material property which is a characteristic of material M. Mechanical property has realization in a stimulating process (in most cases, application of mechanical load), and the stimulating process is an occurent part of another process, in which an object O that is an instance of M participates.</skos:definition> <skos:definition xml:lang="zh">力学性能是一种材料属性，是材料M的特征。力学性能在刺激过程（多数情况下为施加机械载荷）中实现，该刺激过程是另一过程的发生部分，其中参与的对象O是M的一个实例。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000849 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000849">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBI_0000070"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0009006"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000848"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="de">Mechanische Eigenschaften Analyseverfahren</rdfs:label> <rdfs:label xml:lang="zh">机械性能分析方法</rdfs:label>
        <rdfs:label xml:lang="en">mechanical property analyzing process</rdfs:label> <rdfs:label xml:lang="zh">力学性能分析过程</rdfs:label>
        <skos:definition xml:lang="en">An assay that evaluates the mechanical characteristics of materials, such as strength, hardness, elasticity, and tensile properties, often through tests that measure response to forces and loads.</skos:definition> <skos:definition xml:lang="zh">一种评估材料力学特性的分析，如强度、硬度、弹性和拉伸性能，通常通过测量对力和载荷响应的测试进行。</skos:definition>
        <skos:definition xml:lang="de">Eine Analyse, die die mechanischen Eigenschaften von Materialien bewertet, wie z.B. Festigkeit, Härte, Elastizität und Zugfestigkeit, oft durch Tests, die die Reaktion auf Kräfte und Lasten messen.</skos:definition> <skos:definition xml:lang="zh">一种评估材料机械性能的分析方法，如强度、硬度、弹性和抗拉强度，通常通过测量对力和载荷的响应进行测试。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000851 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000851">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020164"/>
        <rdfs:label xml:lang="en">melting point</rdfs:label> <rdfs:label xml:lang="zh">熔点</rdfs:label>
        <skos:definition xml:lang="en">The melting point is a state of matter boundary realized by transition form the solid state to the liquid state (or vice versa).</skos:definition> <skos:definition xml:lang="zh">熔点是由固态到液态（或反之）的转变实现的状态物质边界。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000852 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000852">
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000000"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:intersectionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000663"/>
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                                        <owl:someValuesFrom>
                                            <owl:Class>
                                                <owl:intersectionOf rdf:parseType="Collection">
                                                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/CHEBI_33521"/>
                                                    <owl:Restriction>
                                                        <owl:onProperty rdf:resource="https://w3id.org/pmd/co/PMD_0025998"/>
                                                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0050002"/>
                                                    </owl:Restriction>
                                                </owl:intersectionOf>
                                            </owl:Class>
                                        </owl:someValuesFrom>
                                    </owl:Restriction>
                                </owl:intersectionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <obo:IAO_0000116 xml:lang="en">Classified by morphology.</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">按形态分类。</obo:IAO_0000116>
        <rdfs:label xml:lang="en">metal</rdfs:label> <rdfs:label xml:lang="zh">金属</rdfs:label>
        <skos:definition xml:lang="en">A metal is an engineered material representing a class of materials characterized by high electrical and thermal conductivity, ductility, and metallic bonding.</skos:definition> <skos:definition xml:lang="zh">金属是一种工程材料，代表一类具有高电导率和热导率、延展性和金属键合特性的材料。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000853 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000853">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020131"/>
        <rdfs:comment xml:lang="en">typically observed through crystallographic analysis</rdfs:comment>
        <rdfs:label xml:lang="en">crystallographic texture</rdfs:label> <rdfs:label xml:lang="zh">晶体学织构</rdfs:label>
        <skos:definition xml:lang="en">an intensive quality describing the arrangement and orientation of grains in a polychrystal</skos:definition> <skos:definition xml:lang="zh">一种描述多晶中晶粒排列和取向的强度性质</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000854 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000854">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000602"/>
        <obo:IAO_0000119 xml:lang="en">https://www.merriam-webster.com/dictionary/micrometer%20caliper</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">千分尺</obo:IAO_0000119>
        <rdfs:label xml:lang="de">Bügelmessschraube</rdfs:label> <rdfs:label xml:lang="zh">外径千分尺</rdfs:label>
        <rdfs:label xml:lang="en">micrometer gauge</rdfs:label> <rdfs:label xml:lang="zh">千分尺</rdfs:label>
        <skos:definition xml:lang="en">A measuring device for making precise measurements having a spindle moved by a finely threaded screw.</skos:definition> <skos:definition xml:lang="zh">一种通过细螺纹丝杠移动主轴进行精密测量的测量装置。</skos:definition>
        <skos:definition xml:lang="de">Diese Entität beschreibt ein Werkzeug zur Durchführung präziser Messungen mit einer Spindel, die durch eine Feingewindeschraube bewegt wird.</skos:definition> <skos:definition xml:lang="zh">该实体描述了一种工具，用于通过细螺纹丝杠移动的主轴进行精密测量。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000855 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000855">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000602"/>
        <rdfs:label xml:lang="de">Mikroskop</rdfs:label> <rdfs:label xml:lang="zh">显微镜</rdfs:label>
        <rdfs:label xml:lang="en">microscope</rdfs:label> <rdfs:label xml:lang="zh">显微镜</rdfs:label>
        <skos:definition xml:lang="en">A device used to magnify and view small objects or details that are not visible to the naked eye.</skos:definition> <skos:definition xml:lang="zh">一种用于放大和观察肉眼不可见的小物体或细节的装置。</skos:definition>
        <skos:definition xml:lang="de">Ein Gerät zur Vergrößerung und Betrachtung kleiner Objekte oder Details, die mit bloßem Auge nicht sichtbar sind.</skos:definition> <skos:definition xml:lang="zh">一种用于放大和观察肉眼不可见的小物体或细节的设备。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000856 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000856">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBI_0000070"/>
        <rdfs:label xml:lang="de">Mikroskopie Verfahren</rdfs:label> <rdfs:label xml:lang="zh">显微镜方法</rdfs:label>
        <rdfs:label xml:lang="en">microscopy process</rdfs:label> <rdfs:label xml:lang="zh">显微过程</rdfs:label>
        <skos:definition xml:lang="de">Ein Struktur Eigenschaften Analyseverfahren, das verschiedene Arten von Mikroskopietechniken verwendet, um die Mikrostruktur und Morphologie von Materialien auf verschiedenen Ebenen zu visualisieren und zu analysieren.</skos:definition> <skos:definition xml:lang="zh">一种结构性能分析方法，使用不同类型的显微镜技术在不同层面上可视化和分析材料的微观结构和形态。</skos:definition>
        <skos:definition xml:lang="en">Microscopy process that uses various types of microscopy techniques to visualize and analyze the microstructure and morphology of materials at different scales.</skos:definition> <skos:definition xml:lang="zh">一种利用多种显微技术在不同尺度上可视化和分析材料微观结构和形态的显微过程。</skos:definition>
        <skos:example xml:lang="en">Electron microscopy, which provides detailed images at high resolution; ion microscopy, which offers high-precision imaging and material milling capabilities; and optical microscopy, which uses visible light to study e.g. the microstructure of materials.</skos:example> <skos:example xml:lang="zh">电子显微镜，提供高分辨率详细图像；离子显微镜，提供高精度成像和材料铣削能力；光学显微镜，使用可见光研究例如材料的微观结构。</skos:example>
        <PMD_0050117 xml:lang="de">Mikroskopie</PMD_0050117>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000857 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000857">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000001"/>
        <rdfs:comment xml:lang="en">The focus of interest when looking at an object through the microstructure perspective is often its morphology.</rdfs:comment>
        <rdfs:label xml:lang="en">microstructure</rdfs:label> <rdfs:label xml:lang="zh">微观结构</rdfs:label>
        <skos:definition xml:lang="en">A microstructure is a portion of matter that represents the small-scale structure of a material, including grains, phases, and defects, visible under a microscope.</skos:definition> <skos:definition xml:lang="zh">微观结构是物质的一部分，代表材料的小尺度结构，包括晶粒、相和缺陷，可在显微镜下观察到。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000858 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000858">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000602"/>
        <rdfs:label xml:lang="de">Mikrotom</rdfs:label> <rdfs:label xml:lang="zh">切片机</rdfs:label>
        <rdfs:label xml:lang="en">microtome</rdfs:label> <rdfs:label xml:lang="zh">切片机</rdfs:label>
        <skos:definition xml:lang="en">A Microtome is a Measuring Device that cuts extremely thin slices of material, often for examination under a microscope.</skos:definition> <skos:definition xml:lang="zh">切片机是一种测量装置，用于切割极薄的材料切片，通常用于显微镜检查。</skos:definition>
        <skos:definition xml:lang="en">A device used to cut extremely thin slices of material, often for microscopic examination.</skos:definition> <skos:definition xml:lang="zh">一种用于切割极薄材料切片的装置，通常用于显微镜检查。</skos:definition>
        <skos:definition xml:lang="de">Ein Gerät, das verwendet wird, um extrem dünne Scheiben von Material zu schneiden, oft für mikroskopische Untersuchungen.</skos:definition> <skos:definition xml:lang="zh">一种用于切割极薄材料切片的设备，通常用于显微镜检查。</skos:definition>
        <skos:definition xml:lang="de">Ein Mikrotom ist ein Messgerät, das extrem dünne Scheiben von Material schneidet, oft zur Untersuchung unter einem Mikroskop.</skos:definition> <skos:definition xml:lang="zh">切片机是一种测量仪器，可切割极薄的材料切片，通常用于显微镜下检查。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000859 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000859">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000648"/>
        <rdfs:label xml:lang="de">Fräsmaschine</rdfs:label> <rdfs:label xml:lang="zh">铣床</rdfs:label>
        <rdfs:label xml:lang="en">milling machine</rdfs:label> <rdfs:label xml:lang="zh">铣床</rdfs:label>
        <skos:definition xml:lang="en">A milling machine is a forming machine that performs machining operations to remove material from a workpiece using rotary cutters.</skos:definition> <skos:definition xml:lang="zh">铣床是一种成形机床，使用旋转刀具对工件进行加工以去除材料。</skos:definition>
        <skos:definition xml:lang="de">Eine Fräsmaschine ist eine Formmaschine, das Bearbeitungsoperationen durchführt, um Material von einem Werkstück mithilfe von Fräsern zu entfernen.</skos:definition> <skos:definition xml:lang="zh">铣床是一种成型机床，使用铣刀对工件进行加工以去除材料。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000861 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000861">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000924"/>
        <rdfs:label xml:lang="en">Mohs hardness</rdfs:label> <rdfs:label xml:lang="zh">莫氏硬度</rdfs:label>
        <skos:definition xml:lang="en">Scalar scratch hardness scale used to rank materials based on their ability to scratch one another.</skos:definition> <skos:definition xml:lang="zh">一种标量划痕硬度标度，用于根据材料相互刮擦的能力对材料进行排序。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000862 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000862">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000933"/>
        <rdfs:label xml:lang="de">Monte Carlo Simulation</rdfs:label> <rdfs:label xml:lang="zh">蒙特卡罗模拟</rdfs:label>
        <rdfs:label xml:lang="en">monte carlo simulation</rdfs:label> <rdfs:label xml:lang="zh">蒙特卡罗模拟</rdfs:label>
        <skos:definition xml:lang="en">A simulation process that uses random sampling to solve physical and mathematical problems.</skos:definition> <skos:definition xml:lang="zh">一种使用随机抽样来解决物理和数学问题的模拟过程。</skos:definition>
        <skos:definition xml:lang="de">Ein Simulationsprozess, der zufällige Stichproben verwendet, um physikalische und mathematische Probleme zu lösen.</skos:definition> <skos:definition xml:lang="zh">一种使用随机样本来解决物理和数学问题的模拟过程。</skos:definition>
        <skos:example xml:lang="en">Predicting the diffusion behavior of atoms in a metal at high temperatures.</skos:example> <skos:example xml:lang="zh">预测高温下金属中原子的扩散行为。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000865 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000865">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000594"/>
        <rdfs:label xml:lang="de">Multimodales Deep Learning</rdfs:label> <rdfs:label xml:lang="zh">多模态深度学习</rdfs:label>
        <rdfs:label xml:lang="en">multimodal deep learning</rdfs:label> <rdfs:label xml:lang="zh">多模态深度学习</rdfs:label>
        <skos:definition xml:lang="en">A deep learning process that integrates and processes data from multiple modalities (e.g., text, images, and audio) to improve performance and gain a more comprehensive understanding.</skos:definition> <skos:definition xml:lang="zh">一种深度学习过程，集成并处理来自多种模态（例如文本、图像和音频）的数据，以提高性能并获得更全面的理解。</skos:definition>
        <skos:definition xml:lang="de">Ein Deep Learning-Prozess, der Daten aus mehreren Modalitäten (z.B. Text, Bilder und Audio) integriert und verarbeitet, um die Leistung zu verbessern und ein umfassenderes Verständnis zu erlangen.</skos:definition> <skos:definition xml:lang="zh">一种深度学习过程，整合并处理来自多种模态（如文本、图像和音频）的数据，以提高性能并获得更全面的理解。</skos:definition>
        <skos:example xml:lang="en">Combining microscopy images and spectroscopic data to predict the properties of new materials more accurately.</skos:example> <skos:example xml:lang="zh">结合显微镜图像和光谱数据，更准确地预测新材料的性能。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000866 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000866">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000933"/>
        <rdfs:label xml:lang="de">Multiskalensimulation</rdfs:label> <rdfs:label xml:lang="zh">多尺度模拟</rdfs:label>
        <rdfs:label xml:lang="en">multiscale simulation</rdfs:label> <rdfs:label xml:lang="zh">多尺度模拟</rdfs:label>
        <skos:definition xml:lang="en">A simulation process that integrates models at different scales to study a system's behavior.</skos:definition> <skos:definition xml:lang="zh">一种集成不同尺度模型以研究系统行为的模拟过程。</skos:definition>
        <skos:definition xml:lang="de">Ein Simulationsprozess, der Modelle auf verschiedenen Skalen integriert, um das Verhalten eines Systems zu untersuchen.</skos:definition> <skos:definition xml:lang="zh">一种整合不同尺度模型以研究系统行为的模拟过程。</skos:definition>
        <skos:example xml:lang="en">Studying the interaction between microstructural and macroscopic properties in metallic alloys.</skos:example> <skos:example xml:lang="zh">研究金属合金中微观结构与宏观性能之间的相互作用。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000867 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000867">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000849"/>
        <rdfs:label xml:lang="de">Nanoindentationsverfahren</rdfs:label> <rdfs:label xml:lang="zh">纳米压痕法</rdfs:label>
        <rdfs:label xml:lang="en">nanoindentation process</rdfs:label> <rdfs:label xml:lang="zh">纳米压痕过程</rdfs:label>
        <skos:definition xml:lang="en">A mechanical property analyzing processs that measures the hardness and elastic modulus of materials at the nanoscale using a sharp indenter.</skos:definition> <skos:definition xml:lang="zh">一种力学性能分析过程，使用尖锐压头在纳米尺度测量材料的硬度和弹性模量。</skos:definition>
        <skos:definition xml:lang="de">Ein Mechanische Eigenschaften Analyseverfahren, das die Härte und den elastischen Modulus von Materialien im Nanomaßstab mittels eines scharfen Eindringkörpers misst.</skos:definition> <skos:definition xml:lang="zh">一种力学性能分析方法，使用尖锐压头测量纳米尺度下材料的硬度和弹性模量。</skos:definition>
        <skos:example xml:lang="en">Nanoindentation of thin films to evaluate their mechanical properties for use in microelectronic devices.</skos:example> <skos:example xml:lang="zh">对薄膜进行纳米压痕以评估其力学性能，用于微电子器件。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000868 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000868">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000000"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000086"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0010026"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002353"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:unionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/GO_0008150"/>
                                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000110"/>
                                </owl:unionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000000"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000086"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0010026"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002353"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/GO_0008150"/>
                            <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000110"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">natural organic material</rdfs:label> <rdfs:label xml:lang="zh">天然有机材料</rdfs:label>
        <skos:definition xml:lang="en">Natural organic materials are materials derived from natural biological sources, primarily composed of carbon-based compounds.</skos:definition> <skos:definition xml:lang="zh">天然有机材料是源自天然生物来源的材料，主要由碳基化合物组成。</skos:definition>
        <skos:definition xml:lang="en">material derived from natural biological sources or processes</skos:definition> <skos:definition xml:lang="zh">源自天然生物来源或过程的材料</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
        <PMD_0001032>https://github.com/materialdigital/core-ontology/issues/354</PMD_0001032>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000869 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000869">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:label xml:lang="en">chemical reaction</rdfs:label> <rdfs:label xml:lang="zh">化学反应</rdfs:label>
        <skos:definition xml:lang="en">The occurrence of (a) chemical reaction is the process in which substances interact to form new chemical compounds or alter their molecular structure.</skos:definition> <skos:definition xml:lang="zh">（一个）化学反应的发生是物质相互作用形成新化合物或改变其分子结构的过程。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000874 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000874">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000855"/>
        <rdfs:label xml:lang="de">Optisches Mikroskop</rdfs:label> <rdfs:label xml:lang="zh">光学显微镜</rdfs:label>
        <rdfs:label xml:lang="en">optical microscope</rdfs:label> <rdfs:label xml:lang="zh">光学显微镜</rdfs:label>
        <skos:definition xml:lang="en">A microscope that uses visible light and lenses to magnify and view small objects or details.</skos:definition> <skos:definition xml:lang="zh">一种使用可见光和透镜来放大和观察小物体或细节的显微镜。</skos:definition>
        <skos:definition xml:lang="de">Ein Mikroskop, das sichtbares Licht und Linsen verwendet, um kleine Objekte oder Details zu vergrößern und zu betrachten.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000875 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000875">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000856"/>
        <rdfs:label xml:lang="de">Optische Mikroskopie</rdfs:label> <rdfs:label xml:lang="zh">光学显微术</rdfs:label>
        <rdfs:label xml:lang="en">optical microscopy</rdfs:label> <rdfs:label xml:lang="zh">光学显微术</rdfs:label>
        <skos:definition xml:lang="en">A microscopy process that uses visible light and lenses to magnify and image a specimen, widely used for examining the microstructure and morphology of materials.</skos:definition> <skos:definition xml:lang="zh">一种使用可见光和透镜来放大并成像样本的显微术工艺，广泛用于检查材料的微观结构和形态。</skos:definition>
        <skos:definition xml:lang="de">Ein Mikroskopieverfahren, das sichtbares Licht und Linsen verwendet, um eine Probe zu vergrößern und abzubilden, und weit verbreitet zur Untersuchung der Mikrostruktur und Morphologie von Materialien ist.</skos:definition> <skos:definition xml:lang="zh">一种使用可见光和透镜来放大和成像样品的显微镜方法，广泛用于研究材料的微观结构和形态。</skos:definition>
        <skos:example xml:lang="en">An example is Light Microscopy.</skos:example> <skos:example xml:lang="zh">一个例子是光学显微术。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000876 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000876">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000966"/>
        <rdfs:label xml:lang="de">Optisches Profilometer</rdfs:label> <rdfs:label xml:lang="zh">光学轮廓仪</rdfs:label>
        <rdfs:label xml:lang="en">optical profilometer</rdfs:label> <rdfs:label xml:lang="zh">光学轮廓仪</rdfs:label>
        <skos:definition xml:lang="en">An optical profilometer is a surface profilometer that measures surface profiles and roughness by analyzing the interference patterns of light reflected from a specimen's surface.</skos:definition> <skos:definition xml:lang="zh">光学轮廓仪是一种表面轮廓仪，通过分析从样本表面反射的光的干涉图案来测量表面轮廓和粗糙度。</skos:definition>
        <skos:definition xml:lang="de">Ein optisches Profilometer ist ein Gerät, das Oberflächenprofile und Rauheit misst, indem es die Interferenzmuster von Licht analysiert, das von der Oberfläche eines Präparats reflektiert wird.</skos:definition> <skos:definition xml:lang="zh">光学轮廓仪是一种通过分析从样品表面反射的光的干涉图案来测量表面轮廓和粗糙度的设备。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000877 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000877">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000005"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0001008"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">optical property</rdfs:label> <rdfs:label xml:lang="zh">光学性质</rdfs:label>
        <skos:definition xml:lang="en">An optical property is a material property representing the characteristics that describe how a material interacts with light, including reflection, refraction, and absorption.</skos:definition> <skos:definition xml:lang="zh">光学性质是一种材料属性，代表描述材料如何与光相互作用的特性，包括反射、折射和吸收。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000878 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000878">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBI_0000070"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0009006"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000877"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="de">Optische Eigenschaften Analyseverfahren</rdfs:label> <rdfs:label xml:lang="zh">光学性质分析方法</rdfs:label>
        <rdfs:label xml:lang="en">optical property analyzing process</rdfs:label> <rdfs:label xml:lang="zh">光学性质分析过程</rdfs:label>
        <skos:definition xml:lang="en">An assay that assesses the optical characteristics of materials, such as refractive index, absorption, transmission, reflectivity, and luminescence.</skos:definition> <skos:definition xml:lang="zh">一种评估材料光学特性的分析过程，例如折射率、吸收、透射、反射率和发光。</skos:definition>
        <skos:definition xml:lang="de">Eine Analyse, die die optischen Eigenschaften von Materialien bewertet, wie z.B. Brechungsindex, Absorption, Transmission, Reflexion und Lumineszenz.</skos:definition> <skos:definition xml:lang="zh">一种评估材料光学性质的分析方法，例如折射率、吸收、透射、反射和发光。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000882 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000882">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000017"/>
        <rdfs:label xml:lang="en">phase boundary (realization)</rdfs:label> <rdfs:label xml:lang="zh">相界（实现）</rdfs:label>
        <skos:definition xml:lang="en">A phase boundary is a realizable entity that is realized by the transition between distinct phases.</skos:definition> <skos:definition xml:lang="zh">相边界是一种可实现实体，通过不同相之间的转变来实现。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000883 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000883">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000550"/>
        <rdfs:label xml:lang="de">Photochemische Verfahren</rdfs:label> <rdfs:label xml:lang="zh">光化学方法</rdfs:label>
        <rdfs:label xml:lang="en">photochemical process</rdfs:label> <rdfs:label xml:lang="zh">光化学过程</rdfs:label>
        <skos:definition xml:lang="en">A changing properties of material process in which light, typically ultraviolet (UV) light is used to trigger chemical reactions. In the printing industry and some additive manufacturing methods, this light exposure is used to harden photoresists or cure inks and resins. The process relies on the specific wavelengths of light to initiate chemical changes in the material.</skos:definition> <skos:definition xml:lang="zh">一种改变材料属性的过程，其中使用光（通常是紫外（UV）光）来触发化学反应。在印刷行业和一些增材制造方法中，这种光暴露用于硬化光刻胶或固化油墨和树脂。该过程依赖于特定波长的光来引发材料中的化学变化。</skos:definition>
        <skos:definition xml:lang="de">Ein Stoffeigenschaft Ändern Prozess, bei dem Licht, in der Regel ultraviolettes (UV) Licht, zur Auslösung chemischer Reaktionen verwendet wird. In der Druckindustrie und bei einigen additiven Fertigungsverfahren wird diese Lichteinwirkung zur Härtung von Fotolacken oder zur Aushärtung von Tinten und Harzen verwendet. Das Verfahren beruht auf den spezifischen Wellenlängen des Lichts, um chemische Veränderungen im Material auszulösen.</skos:definition> <skos:definition xml:lang="zh">一种改变物质性质的过程，其中使用光（通常是紫外光）引发化学反应。在印刷行业和一些增材制造工艺中，这种光照射用于固化光刻胶或硬化油墨和树脂。该过程依赖于特定波长的光来引发材料中的化学变化。</skos:definition>
        <skos:example xml:lang="en">Exposure</skos:example> <skos:example xml:lang="zh">曝光</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000884 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000884">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000931"/>
        <rdfs:label xml:lang="en">physical simulation</rdfs:label> <rdfs:label xml:lang="zh">物理模拟</rdfs:label>
        <skos:definition xml:lang="en">A simulation method specification describing the use of computational or experimental methods to replicate physical behaviors or processes under defined conditions.</skos:definition> <skos:definition xml:lang="zh">一种模拟方法规范，描述使用计算或实验方法在定义条件下复制物理行为或过程。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000885 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000885">
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000834"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000853"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">pole figure</rdfs:label> <rdfs:label xml:lang="zh">极图</rdfs:label>
        <skos:definition xml:lang="en">A pole figure is a map depicting a 2D stereographic projection which represents crystallographic orientations of grains in a polycrystalline material in respect to the sample's reference frame.</skos:definition> <skos:definition xml:lang="zh">极图是一种描绘二维立体投影的图，表示多晶材料中晶粒相对于样品参考系的晶体学取向。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000886 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000886">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000648"/>
        <rdfs:label xml:lang="de">Poliermaschine</rdfs:label> <rdfs:label xml:lang="zh">抛光机</rdfs:label>
        <rdfs:label xml:lang="en">polishing machine</rdfs:label> <rdfs:label xml:lang="zh">抛光机</rdfs:label>
        <skos:definition xml:lang="en">A polishing machine is a forming machine that smooths the surface of a material by rubbing it with a tool, abrasive, or chemical.</skos:definition> <skos:definition xml:lang="zh">抛光机是一种成型机，通过用工具、磨料或化学品摩擦来平滑材料表面。</skos:definition>
        <skos:definition xml:lang="de">Eine Poliermaschine ist eine Formmaschine, die die Oberfläche eines Materials durch Reiben mit einem Werkzeug, Schleifmittel oder Chemikalien glättet.</skos:definition> <skos:definition xml:lang="zh">抛光机是一种通过使用工具、磨料或化学品摩擦来使材料表面光滑的成型机器。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000888 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000888">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000000"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002353"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0010033"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000000"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002353"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0010033"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000116 xml:lang="en">Classified by morphology.</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">按形态分类。</obo:IAO_0000116>
        <rdfs:label xml:lang="en">polymer</rdfs:label> <rdfs:label xml:lang="zh">聚合物</rdfs:label>
        <skos:definition xml:lang="en">A polymer is an engineered material that consists of many repeated subunits (monomers) to form long chains. The atoms within a polymer chain are bonded together by covalent bonds. The intermolecular forces between polymer chains are typically represented by van der waals forces and hydrogen bonds.</skos:definition> <skos:definition xml:lang="zh">聚合物是一种工程材料，由许多重复的亚单元（单体）组成长链。聚合物链内的原子通过共价键连接。聚合物链之间的分子间力通常由范德华力和氢键表示。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000889 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000889">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000635"/>
        <rdfs:label xml:lang="en">pore growth</rdfs:label> <rdfs:label xml:lang="zh">孔隙生长</rdfs:label>
        <skos:definition xml:lang="en">Pore growth is an evolution of damage describing the process by which voids or pores in a material increase in size, often affecting its mechanical and physical properties.</skos:definition> <skos:definition xml:lang="zh">孔隙生长是损伤演化的一种，描述材料中空洞或孔隙尺寸增大的过程，通常影响其机械和物理性能。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000890 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000890">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000027"/>
        <rdfs:label xml:lang="en">connected material entity aggregate</rdfs:label> <rdfs:label xml:lang="zh">连接的材料实体聚合体</rdfs:label>
        <skos:definition xml:lang="en">An object aggregate that is a mereological sum of separate material entities, which adhere to one another through chemical bonds or physical junctions that go beyond gravity.</skos:definition> <skos:definition xml:lang="zh">一种对象聚合体，是分离材料实体的部分学总和，这些实体通过化学键或超越重力的物理连接相互粘附。</skos:definition>
        <skos:example xml:lang="en">the atoms of a molecule, the molecules forming the membrane of a cell, the epidermis in a human body</skos:example> <skos:example xml:lang="zh">一个分子的原子，形成细胞膜的分子，人体中的表皮</skos:example>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000891 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000891">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000027"/>
        <rdfs:label xml:lang="en">disconnected material entity aggregate</rdfs:label> <rdfs:label xml:lang="zh">非连接的材料实体聚合体</rdfs:label>
        <skos:definition xml:lang="en">An object aggregate that is a mereological sum of scattered (i.e. spatially separated) material entities, which do not adhere to one another through chemical bonds or physical junctions but, instead, relate to one another merely on grounds of metric proximity. The material entities are separated from one another through space or through other material entities that do not belong to the group.</skos:definition> <skos:definition xml:lang="zh">一种对象聚合体，是分散（即空间分离）材料实体的部分学总和，这些实体不通过化学键或物理连接相互粘附，而是仅仅基于度量接近性相互关联。这些材料实体通过空间或不属于该组的其他材料实体相互分离。</skos:definition>
        <skos:example xml:lang="en">a heap of stones, a colony of honeybees, a group of synapses, the trees of a forest, the canopy of a forest, the fish of a shoal, a group of commuters on the subway, the patients in a hospital</skos:example> <skos:example xml:lang="zh">一堆石头，一群蜜蜂，一组突触，森林中的树木，森林的树冠，鱼群中的鱼，地铁上的一群通勤者，医院里的病人</skos:example>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000893 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000893">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000891"/>
        <rdfs:label xml:lang="en">powder</rdfs:label> <rdfs:label xml:lang="zh">粉末</rdfs:label>
        <skos:definition xml:lang="en">A powder is a dry, solid disconnected material entity aggregate composed of many very fine particles. These particles can flow freely when shaken or tilted.</skos:definition> <skos:definition xml:lang="zh">粉末是一种干燥、固体、非连续的材料实体聚合体，由许多非常细小的颗粒组成。这些颗粒在摇晃或倾斜时可以自由流动。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000894 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000894">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000818"/>
        <rdfs:label xml:lang="de">Präzisionsdrehmaschine</rdfs:label> <rdfs:label xml:lang="zh">精密车床</rdfs:label>
        <rdfs:label xml:lang="en">precision lathe</rdfs:label> <rdfs:label xml:lang="zh">精密车床</rdfs:label>
        <skos:definition xml:lang="en">A precision lathe is a lathe that rotates a workpiece about an axis to perform various operations such as cutting, sanding, drilling, or deformation with extreme accuracy.</skos:definition> <skos:definition xml:lang="zh">精密车床是一种围绕轴线旋转工件，以极高精度执行切割、打磨、钻孔或变形等各种操作的机床。</skos:definition>
        <skos:definition xml:lang="de">Eine Präzisionsdrehmaschine ist eine Drehmaschine, die ein Werkstück um eine Achse dreht, um verschiedene Operationen wie Schneiden, Schleifen, Bohren oder Verformung mit extremer Genauigkeit durchzuführen.</skos:definition> <skos:definition xml:lang="zh">精密车床是一种将工件绕轴旋转，以极高精度执行各种操作（如切割、磨削、钻孔或变形）的车床。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000895 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000895">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000806"/>
        <obo:IAO_0000119 xml:lang="en">Official definition can be found in: DIN 8593-3</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">官方定义见：DIN 8593-3</obo:IAO_0000119>
        <obo:IAO_0000119 xml:lang="de">Offizielle Definition findet man in: DIN 8593-3</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">官方定义见：DIN 8593-3</obo:IAO_0000119>
        <rdfs:label xml:lang="de">Anpressen - Einpressen</rdfs:label> <rdfs:label xml:lang="zh">压入 - 嵌入</rdfs:label>
        <rdfs:label xml:lang="en">pressing on - in</rdfs:label> <rdfs:label xml:lang="zh">压上 - 压入</rdfs:label>
        <skos:definition xml:lang="en">A joining process that involves mechanically pressing one component into or onto another to create a secure fit, thereby establishing a strong mechanical connection.</skos:definition> <skos:definition xml:lang="zh">一种连接工艺，通过机械方式将一个部件压入或压到另一个部件上，以形成紧密配合，从而建立牢固的机械连接。</skos:definition>
        <skos:definition xml:lang="de">Ein Füge Prozess, bei dem ein Bauteil mechanisch in oder auf ein anderes gepresst wird, um eine sichere Passung und damit eine feste mechanische Verbindung herzustellen.</skos:definition> <skos:definition xml:lang="zh">一种连接工艺，其中一个部件被机械压入或压在另一个部件上，以实现安全配合，从而形成牢固的机械连接。</skos:definition>
        <skos:example xml:lang="en">Clamps, Brackets, Wedging</skos:example> <skos:example xml:lang="zh">夹具、支架、楔入</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000896 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000896">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020131"/>
        <owl:disjointWith rdf:resource="https://w3id.org/pmd/co/PMD_0000967"/>
        <rdfs:comment xml:lang="en">The pressure is commonly measured in Pascals.</rdfs:comment>
        <rdfs:label xml:lang="en">pressure</rdfs:label> <rdfs:label xml:lang="zh">压力</rdfs:label>
        <skos:definition xml:lang="en">an intensive quality describing the force exerted per unit area in or on a material.</skos:definition> <skos:definition xml:lang="zh">一种描述作用于材料内部或表面的单位面积力的强度属性。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000898 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000898">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000847"/>
        <rdfs:label xml:lang="de">Druckmessfunktion</rdfs:label> <rdfs:label xml:lang="zh">压力测量功能</rdfs:label>
        <rdfs:label xml:lang="en">pressure measuring function</rdfs:label> <rdfs:label xml:lang="zh">压力测量功能</rdfs:label>
        <skos:definition xml:lang="en">A measuring function performed to determine the pressure of gases or liquids.</skos:definition> <skos:definition xml:lang="zh">一种用于确定气体或液体压力的测量功能。</skos:definition>
        <skos:definition xml:lang="de">Eine Messfunktion, um den Druck von Gasen oder Flüssigkeiten zu bestimmen.</skos:definition> <skos:definition xml:lang="zh">一种用于测定气体或液体压力的测量功能。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000899 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000899">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000833"/>
        <obo:IAO_0000119 xml:lang="en">Official definition can be found in: DIN 8580:2003-9 Fertigungsverfahren, Page 4, 3.1.1 Urformen - Definition</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">官方定义见：DIN 8580:2003-9 Fertigungsverfahren，第4页，3.1.1 Urformen - 定义</obo:IAO_0000119>
        <obo:IAO_0000119 xml:lang="de">Offizielle Definition findet man in: DIN 8580:2003-9 Fertigungsverfahren, Seite 4, 3.1.1 Urformen - Definition</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">官方定义见：DIN 8580:2003-9 制造工艺，第4页，3.1.1 一次成形 - 定义</obo:IAO_0000119>
        <rdfs:label xml:lang="de">Urformen</rdfs:label> <rdfs:label xml:lang="zh">一次成形</rdfs:label>
        <rdfs:label xml:lang="en">primary shaping</rdfs:label> <rdfs:label xml:lang="zh">初级成形</rdfs:label>
        <skos:altLabel xml:lang="en">Primary Forming</skos:altLabel> <skos:altLabel xml:lang="zh">原生成形</skos:altLabel>
        <skos:definition xml:lang="en">A manufacturing process that creates a defined workpiece from shapeless material by producing cohesion, whereby the characteristic properties of the material become visible in the end product.</skos:definition> <skos:definition xml:lang="zh">一种制造工艺，通过产生内聚力从无形材料中创建出确定的工件，从而使材料的特性在最终产品中显现。</skos:definition>
        <skos:definition xml:lang="de">Ein Herstellungsprozess, der aus formlosem Stoff durch das Herstellen von Kohäsion ein definiertes Werkstück schafft, wobei die charakteristischen Eigenschaften des Materials im Endprodukt sichtbar werden.</skos:definition> <skos:definition xml:lang="zh">一种制造工艺，通过建立内聚力，从无定形材料中创造出确定的工件，从而使材料的特性在最终产品中显现出来。</skos:definition>
        <skos:example xml:lang="en">Casting, Sintering</skos:example> <skos:example xml:lang="zh">铸造、烧结</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000900 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000900">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000899"/>
        <rdfs:label xml:lang="de">Urformen Durch Additive Fertigung</rdfs:label> <rdfs:label xml:lang="zh">通过增材制造进行的一次成形</rdfs:label>
        <rdfs:label xml:lang="en">primary shaping by additive manufacturing</rdfs:label> <rdfs:label xml:lang="zh">通过增材制造进行初级成型</rdfs:label>
        <skos:definition xml:lang="en">A primary shaping process that involves forming materials through additive manufacturing techniques.</skos:definition> <skos:definition xml:lang="zh">一种通过增材制造技术成型材料的初级成型工艺。</skos:definition>
        <skos:definition xml:lang="de">Ein Urformprozess, der das Formen von Materialien durch additive Fertigungstechniken beinhaltet.</skos:definition> <skos:definition xml:lang="zh">一种通过增材制造技术成型材料的原始成型工艺。</skos:definition>
        <skos:example xml:lang="en">3D printing of polymer objects.</skos:example> <skos:example xml:lang="zh">聚合物物体的3D打印。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000901 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000901">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000899"/>
        <rdfs:label xml:lang="de">Urformen Durch Schweissen</rdfs:label> <rdfs:label xml:lang="zh">通过焊接原始成型</rdfs:label>
        <rdfs:label xml:lang="en">primary shaping by welding</rdfs:label> <rdfs:label xml:lang="zh">通过焊接进行初级成型</rdfs:label>
        <skos:definition xml:lang="en">A primary shaping process that involves forming materials by welding.</skos:definition> <skos:definition xml:lang="zh">一种通过焊接成型材料的初级成型工艺。</skos:definition>
        <skos:definition xml:lang="de">Ein Urformprozess, der das Formen von Materialien durch Schweißen beinhaltet.</skos:definition> <skos:definition xml:lang="zh">一种通过焊接成型材料的原始成型工艺。</skos:definition>
        <skos:example xml:lang="en">Fabrication of steel structures using welding techniques.</skos:example> <skos:example xml:lang="zh">使用焊接技术制造钢结构。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000902 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000902">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000899"/>
        <rdfs:label xml:lang="de">Urformen Aus Dem Spanförmigen Oder Faserförmigen Zustand</rdfs:label> <rdfs:label xml:lang="zh">从屑状或纤维状状态原始成型</rdfs:label>
        <rdfs:label xml:lang="en">primary shaping from the chip or fiber state</rdfs:label> <rdfs:label xml:lang="zh">从切屑或纤维状态进行初级成型</rdfs:label>
        <skos:definition xml:lang="en">A primary shaping process that involves forming materials from a chip or fiber state.</skos:definition> <skos:definition xml:lang="zh">一种从切屑或纤维状态成型材料的初级成型工艺。</skos:definition>
        <skos:definition xml:lang="de">Ein Urformprozess, der das Formen von Materialien aus einem span- oder faserförmigen Zustand beinhaltet.</skos:definition> <skos:definition xml:lang="zh">一种从屑状或纤维状状态成型材料的原始成型工艺。</skos:definition>
        <skos:example xml:lang="en">Compression molding of wood chips into particle boards.</skos:example> <skos:example xml:lang="zh">将木屑压缩成型为刨花板。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000903 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000903">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000899"/>
        <rdfs:label xml:lang="de">Urformen Aus Dem Gasförmigen Oder Dampfförmigen Zustand</rdfs:label> <rdfs:label xml:lang="zh">从气态或蒸汽状态原始成型</rdfs:label>
        <rdfs:label xml:lang="en">primary shaping from the gaseous or vapor state</rdfs:label> <rdfs:label xml:lang="zh">从气态或蒸汽状态进行初级成型</rdfs:label>
        <skos:definition xml:lang="en">A primary shaping process that involves forming materials from a gaseous or vapor state.</skos:definition> <skos:definition xml:lang="zh">一种从气态或蒸汽状态成型材料的初级成型工艺。</skos:definition>
        <skos:definition xml:lang="de">Ein Urformprozess, der das Formen von Materialien aus einem gasförmigen oder dampfförmigen Zustand beinhaltet.</skos:definition> <skos:definition xml:lang="zh">一种从气态或蒸汽状态成型材料的原始成型工艺。</skos:definition>
        <skos:example xml:lang="en">Chemical vapor deposition (CVD) for thin film production.</skos:example> <skos:example xml:lang="zh">用于薄膜生产的化学气相沉积（CVD）。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000904 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000904">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000899"/>
        <rdfs:label xml:lang="de">Urformen Aus Dem Körnerförmigen Oder Pulverförmigen Zustand</rdfs:label> <rdfs:label xml:lang="zh">从颗粒状或粉末状状态原始成型</rdfs:label>
        <rdfs:label xml:lang="en">primary shaping from the granular or powdered state</rdfs:label> <rdfs:label xml:lang="zh">从颗粒或粉末状态进行初级成型</rdfs:label>
        <skos:definition xml:lang="en">A primary shaping process that involves forming materials from a granular or powdered state.</skos:definition> <skos:definition xml:lang="zh">一种从颗粒或粉末状态成型材料的初级成型工艺。</skos:definition>
        <skos:definition xml:lang="de">Ein Urformprozess, der das Formen von Materialien aus einem körnigen oder pulverförmigen Zustand beinhaltet.</skos:definition> <skos:definition xml:lang="zh">一种从颗粒状或粉末状状态成型材料的原始成型工艺。</skos:definition>
        <skos:example xml:lang="en">Powder metallurgy for creating metal parts.</skos:example> <skos:example xml:lang="zh">用于制造金属零件的粉末冶金。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000905 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000905">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000899"/>
        <rdfs:label xml:lang="de">Urformen Aus DemIonisierten Zustand</rdfs:label> <rdfs:label xml:lang="zh">从电离状态原始成型</rdfs:label>
        <rdfs:label xml:lang="en">primary shaping from the ionized state</rdfs:label> <rdfs:label xml:lang="zh">从电离态进行的一次成型</rdfs:label>
        <skos:definition xml:lang="en">A primary shaping process that involves forming materials from an ionized state.</skos:definition> <skos:definition xml:lang="zh">一种涉及从电离态成型材料的一次成型工艺。</skos:definition>
        <skos:definition xml:lang="de">Ein Urformprozess, der das Formen von Materialien aus einem ionisierten Zustand beinhaltet.</skos:definition> <skos:definition xml:lang="zh">一种从电离状态成型材料的原始成型过程。</skos:definition>
        <skos:example xml:lang="en">Plasma arc welding.</skos:example> <skos:example xml:lang="zh">等离子弧焊。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000906 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000906">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000899"/>
        <rdfs:label xml:lang="de">Urformen Aus Dem Flüssigen Zustand</rdfs:label> <rdfs:label xml:lang="zh">液态原始成型</rdfs:label>
        <rdfs:label xml:lang="en">primary shaping from the liquid state</rdfs:label> <rdfs:label xml:lang="zh">从液态进行的一次成型</rdfs:label>
        <skos:definition xml:lang="en">A primary shaping process that involves forming materials from a liquid state.</skos:definition> <skos:definition xml:lang="zh">一种涉及从液态成型材料的一次成型工艺。</skos:definition>
        <skos:definition xml:lang="de">Ein Urformprozess, der das Formen von Materialien aus einem flüssigen Zustand beinhaltet.</skos:definition> <skos:definition xml:lang="zh">一种从液态成型材料的原始成型过程。</skos:definition>
        <skos:example xml:lang="en">Casting of molten metal into molds.</skos:example> <skos:example xml:lang="zh">将熔融金属浇铸到模具中。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000907 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000907">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000899"/>
        <rdfs:label xml:lang="de">Urformen Aus Dem Plastischen Zustand</rdfs:label> <rdfs:label xml:lang="zh">塑性状态原始成型</rdfs:label>
        <rdfs:label xml:lang="en">primary shaping from the plastic state</rdfs:label> <rdfs:label xml:lang="zh">从塑性态进行的一次成型</rdfs:label>
        <skos:definition xml:lang="en">A primary shaping process that involves forming materials from a plastic state.</skos:definition> <skos:definition xml:lang="zh">一种涉及从塑性态成型材料的一次成型工艺。</skos:definition>
        <skos:definition xml:lang="de">Ein Urformprozess, der das Formen von Materialien aus einem plastischen Zustand beinhaltet.</skos:definition> <skos:definition xml:lang="zh">一种从塑性状态成型材料的原始成型过程。</skos:definition>
        <skos:example xml:lang="en">Thermoforming of plastic sheets.</skos:example> <skos:example xml:lang="zh">塑料板材的热成型。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000908 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000908">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000899"/>
        <rdfs:label xml:lang="de">Urformen Aus Dem Breiigen Oder Pastösen Zustand</rdfs:label> <rdfs:label xml:lang="zh">糊状或膏状状态原始成型</rdfs:label>
        <rdfs:label xml:lang="en">primary shaping from the pulpy or pasty state</rdfs:label> <rdfs:label xml:lang="zh">从浆状或糊状态进行的一次成型</rdfs:label>
        <skos:definition xml:lang="en">A primary shaping process that involves forming materials through the transition from a pulpy or pasty state into a solid form.</skos:definition> <skos:definition xml:lang="zh">一种涉及材料从浆状或糊状态转变为固态的一次成型工艺。</skos:definition>
        <skos:definition xml:lang="de">Ein Urformprozess, der das Formen von Materialien durch den Übergang aus einem breiigen oder pastösen Zustand in eine feste Form beinhaltet.</skos:definition> <skos:definition xml:lang="zh">一种通过从糊状或膏状状态转变为固体形状来成型材料的原始成型过程。</skos:definition>
        <skos:example xml:lang="en">Pottery</skos:example> <skos:example xml:lang="zh">陶器</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000910 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000910">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000773"/>
        <rdfs:label xml:lang="en">rebound hardness</rdfs:label> <rdfs:label xml:lang="zh">回弹硬度</rdfs:label>
        <skos:definition xml:lang="en">The rebound hardness is representing a measure of a material's hardness based on the height of rebound of a hammer dropped on the material.</skos:definition> <skos:definition xml:lang="zh">回弹硬度是一种基于落锤在材料上回弹高度来测量材料硬度的指标。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000911 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000911">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000877"/>
        <rdfs:label xml:lang="en">reflectivity</rdfs:label> <rdfs:label xml:lang="zh">反射率</rdfs:label>
        <skos:definition xml:lang="en">The reflectivity is an optical property that describes the proportion of incident light or radiation that a material reflects.</skos:definition> <skos:definition xml:lang="zh">反射率是一种光学属性，描述材料反射的入射光或辐射的比例。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000913 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000913">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000594"/>
        <rdfs:label xml:lang="de">Reinforcement Learning</rdfs:label> <rdfs:label xml:lang="zh">强化学习</rdfs:label>
        <rdfs:label xml:lang="en">reinforcement learning</rdfs:label> <rdfs:label xml:lang="zh">强化学习</rdfs:label>
        <skos:definition xml:lang="en">A deep learning process that involves training models to make sequences of decisions by rewarding desired actions and punishing undesired ones.</skos:definition> <skos:definition xml:lang="zh">一种深度学习过程，通过奖励期望的行为和惩罚不期望的行为来训练模型做出序列决策。</skos:definition>
        <skos:definition xml:lang="de">Ein Deep Learning Prozess, der Modelle darin trainiert, Abfolgen von Entscheidungen zu treffen, indem gewünschte Aktionen belohnt und unerwünschte bestraft werden.</skos:definition> <skos:definition xml:lang="zh">一种深度学习过程，通过奖励期望行为并惩罚不期望行为来训练模型做出一系列决策。</skos:definition>
        <skos:example xml:lang="en">Using RL to optimize the process parameters in additive manufacturing (3D printing) to achieve the desired material properties and reduce defects.</skos:example> <skos:example xml:lang="zh">使用强化学习优化增材制造（3D打印）中的工艺参数，以达到所需的材料性能并减少缺陷。</skos:example>
        <PMD_0050117>RL</PMD_0050117>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000914 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000914">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000927"/>
        <obo:IAO_0000119 xml:lang="en">Official definition can be found in: DIN 8590</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">官方定义见：DIN 8590</obo:IAO_0000119>
        <obo:IAO_0000119 xml:lang="de">Offizielle Definition findet man in: DIN 8590</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">官方定义见：DIN 8590</obo:IAO_0000119>
        <rdfs:label xml:lang="de">Abtragen</rdfs:label> <rdfs:label xml:lang="zh">去除</rdfs:label>
        <rdfs:label xml:lang="en">removing</rdfs:label> <rdfs:label xml:lang="zh">去除</rdfs:label>
        <skos:definition xml:lang="en">A separating process that involves removing material through thermal, chemical and electrochemical methods.</skos:definition> <skos:definition xml:lang="zh">一种通过热、化学和电化学方法去除材料的分离过程。</skos:definition>
        <skos:definition xml:lang="de">Ein Trennprozess, bei dem Material durch thermische, chemische und elektrochemische Methoden abgetragen wird.</skos:definition> <skos:definition xml:lang="zh">一种通过热、化学和电化学方法去除材料的分离过程。</skos:definition>
        <skos:example xml:lang="en">Electrical Discharge Machining, Thermal Ablation</skos:example> <skos:example xml:lang="zh">电火花加工，热消融</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000916 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000916">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000849"/>
        <rdfs:label xml:lang="de">Rheologische Eigenschaften Analyseverfahren</rdfs:label> <rdfs:label xml:lang="zh">流变性能分析方法</rdfs:label>
        <rdfs:label xml:lang="en">rheological property analyzing process</rdfs:label> <rdfs:label xml:lang="zh">流变性能分析过程</rdfs:label>
        <skos:definition xml:lang="en">A mechanical property analyzing process that determines the flow and deformation behavior of materials under applied forces, including viscosity, elasticity, and plasticity, often through rheometry and viscometry techniques.</skos:definition> <skos:definition xml:lang="zh">一种力学性能分析过程，确定材料在外力作用下的流动和变形行为，包括粘度、弹性和塑性，通常通过流变测量和粘度测量技术进行。</skos:definition>
        <skos:definition xml:lang="de">Ein Mechanische Eigenschaften Analyseverfahren, das das Fließ- und Deformationsverhalten von Materialien unter Einwirkung von Kräften bestimmt, einschließlich Viskosität, Elastizität und Plastizität, oft durch Rheometrie- und Viskosimetrie-Techniken.</skos:definition> <skos:definition xml:lang="zh">一种机械性能分析方法，用于确定材料在力作用下的流动和变形行为，包括粘度、弹性和塑性，通常通过流变测量和粘度测量技术。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000917 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000917">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000602"/>
        <rdfs:label xml:lang="de">Rheometer</rdfs:label> <rdfs:label xml:lang="zh">流变仪</rdfs:label>
        <rdfs:label xml:lang="en">rheometer</rdfs:label> <rdfs:label xml:lang="zh">流变仪</rdfs:label>
        <skos:definition xml:lang="en">A device used to measure the flow and deformation properties of materials, particularly liquids and semi-solids.</skos:definition> <skos:definition xml:lang="zh">一种用于测量材料（特别是液体和半固体）流动和变形特性的设备。</skos:definition>
        <skos:definition xml:lang="de">Ein Gerät zur Messung der Fließ- und Verformungseigenschaften von Materialien, insbesondere von Flüssigkeiten und Halbfeststoffen.</skos:definition> <skos:definition xml:lang="zh">一种用于测量材料（尤其是液体和半固体）流动和变形特性的设备。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000918 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000918">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000916"/>
        <rdfs:label xml:lang="de">Rheometry</rdfs:label> <rdfs:label xml:lang="zh">流变测量</rdfs:label>
        <rdfs:label xml:lang="en">rheometry</rdfs:label> <rdfs:label xml:lang="zh">流变测量</rdfs:label>
        <skos:definition xml:lang="de">Ein Rheologisches Eigenschaften Analyseverfahren, das das Fließ- und Verformungsverhalten von Materialien misst, einschließlich komplexer Flüssigkeiten und weicher Feststoffe, um umfassende Daten zu viskoelastischen Eigenschaften unter Verwendung von Rheometern zu liefern.</skos:definition> <skos:definition xml:lang="zh">一种流变性能分析方法，用于测量材料的流动和变形行为，包括复杂液体和软固体，以使用流变仪提供粘弹性能的综合数据。</skos:definition>
        <skos:definition xml:lang="en">Rheological property analyzing process that measures the flow and deformation behavior of materials, including complex fluids and soft solids, to provide comprehensive data on viscoelastic properties using rheometers.</skos:definition> <skos:definition xml:lang="zh">一种流变性能分析过程，测量材料（包括复杂流体和软固体）的流动和变形行为，使用流变仪提供关于粘弹性特性的全面数据。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000919 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000919">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000023"/>
        <obo:IAO_0000116 xml:lang="de">ANMERKUNG: Ein Sample ist ein Teil (oder das Ganze) eines Probestücks. Das Probestück wird bei der Herstellung eines industriell verwendeten Produktes gezielt für die Überprüfung des Produkteigenschaften bereitgestellt. CAVE: Diese Anmerkung beschreibt das Objekt, welches die Rolle, die durch diese owl:Class definiert wird, realisiert.
ANMERKUNG: Die exakte Wortwahl der EN 10021 wurde verallgemeinert.</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">注：样本是试件的一部分（或整体）。试件是在制造工业使用的产品时特意为检验产品性能而提供的。注意：此注释描述了实现由该owl:Class定义的角色对象。
注：EN 10021的精确措辞已被概括。</obo:IAO_0000116>
        <obo:IAO_0000116 xml:lang="en">In certain cases, the sample can be the specimen or the test piece itself.</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">在某些情况下，样品可以是试样或试件本身。</obo:IAO_0000116>
        <obo:IAO_0000116 xml:lang="de">Mitunter kann der Probenabschnitt (Sample) unmittelbar als Prüfling (Specimen) oder Probe dienen.</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">有时，样本部分可以直接用作试样或测试件。</obo:IAO_0000116>
        <obo:IAO_0000116 xml:lang="en">NOTE: A Sample is a part (or the whole) of a Sample product. The Sample product is specifically produced portion of an industrially used and traded product for the purpose of determining the properties/quality of the product. CAVE: This note describes the object, that realizes the role defined by this owl:Class.
NOTE: The wording used in EN 10021 was generalized.</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">注：样品是样品产品的一部分（或全部）。样品产品是工业使用和交易的产品中专门生产的部分，用于确定产品的性能/质量。注意：此注释描述了实现此owl:Class所定义角色的对象。
注：EN 10021中使用的措辞已泛化。</obo:IAO_0000116>
        <obo:IAO_0000119 xml:lang="en">EN 10021:2006-12 (European standardization committee: CEN/TC 459/SC 12/WG 4)</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">EN 10021:2006-12 (欧洲标准化委员会: CEN/TC 459/SC 12/WG 4)</obo:IAO_0000119>
        <rdfs:label xml:lang="de">Probe-Rolle</rdfs:label> <rdfs:label xml:lang="zh">样本角色</rdfs:label>
        <rdfs:label xml:lang="en">sample role</rdfs:label> <rdfs:label xml:lang="zh">样品角色</rdfs:label>
        <skos:definition xml:lang="en">Role of an object, which is a quantity of material taken from a (sample) product, that is sufficient for the purpose of obtaining test pieces.</skos:definition> <skos:definition xml:lang="zh">一个对象的角色，是从（样品）产品中取出的足够量的材料，以获得试件。</skos:definition>
        <skos:definition xml:lang="de">Rolle eines Objektes, das eine von einem Probestück/Material entnommene Menge ist, welche (vom Umfang her) geeignet ist Proben (Test Pieces) herzustellen.</skos:definition> <skos:definition xml:lang="zh">一个对象的作用，该对象是从试件/材料中取出的量，其（在范围上）适合制作试样（测试件）。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000920 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000920">
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000602"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000085"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000592"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">saw</rdfs:label> <rdfs:label xml:lang="zh">锯子</rdfs:label>
        <skos:definition xml:lang="en">A saw is a device used to cut materials, especially wood. It usually consists of a thin, sharp metal blade fitted with teeth and a handle or frame that allows the user to guide the saw. There are different types of saws designed for different applications, including handsaws, circular saws, hacksaws and band saws. Each type of saw is designed for specific tasks and materials to enable efficient cutting.</skos:definition> <skos:definition xml:lang="zh">锯是一种用于切割材料（尤其是木材）的工具。它通常由一个薄而锋利的金属刀片，上面带有齿，以及一个手柄或框架组成，使用者可以引导锯子。有不同类型的锯子适用于不同的应用，包括手锯、圆锯、钢锯和带锯。每种类型的锯子都针对特定任务和材料设计，以实现高效切割。</skos:definition>
        <skos:definition xml:lang="de">Eine Säge ist ein Gerät, das zum Zerteilen von Materialien, insbesondere von Holz, verwendet wird. Sie besteht in der Regel aus einem dünnen, scharfen Metallblatt, das mit Zähnen versehen ist, und einem Griff oder Rahmen, der es dem Benutzer ermöglicht, die Säge zu führen. Es gibt verschiedene Arten von Sägen, die für verschiedene Anwendungen konzipiert sind, darunter Handsägen, Kreissägen, Bügelsägen und Bandsägen. Jede Art von Säge ist auf bestimmte Aufgaben und Materialien abgestimmt, um effizientes Schneiden zu ermöglichen.</skos:definition> <skos:definition xml:lang="zh">锯是一种用于切割材料（尤其是木材）的设备。它通常由一个带有齿的薄而锋利的金属刀片和一个手柄或框架组成，使用户能够引导锯。有不同类型的锯设计用于不同的应用，包括手锯、圆锯、弓锯和带锯。每种锯都针对特定任务和材料量身定制，以实现高效切割。</skos:definition>
        <skos:definition xml:lang="de">Säge</skos:definition> <skos:definition xml:lang="zh">锯子</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000922 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000922">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000624"/>
        <rdfs:label xml:lang="de">Rasterelektronenmikroskop</rdfs:label> <rdfs:label xml:lang="zh">扫描电子显微镜</rdfs:label>
        <rdfs:label xml:lang="en">scanning electron microscope</rdfs:label> <rdfs:label xml:lang="zh">扫描电子显微镜</rdfs:label>
        <skos:definition xml:lang="en">A scanning electron microscope (SEM) is a measuring device that produces high-resolution images of a sample surface by scanning it with a focused beam of electrons.</skos:definition> <skos:definition xml:lang="zh">扫描电子显微镜（SEM）是一种测量设备，通过用聚焦的电子束扫描样品表面，产生高分辨率图像。</skos:definition>
        <skos:definition xml:lang="de">Ein Rasterelektronenmikroskop (REM) ist ein Messgerät, das hochauflösende Bilder einer Probenoberfläche erzeugt, indem es sie mit einem fokussierten Elektronenstrahl abtastet.</skos:definition> <skos:definition xml:lang="zh">扫描电子显微镜（SEM）是一种测量仪器，通过用聚焦电子束扫描样品表面来生成高分辨率图像。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000923 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000923">
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000602"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000085"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000592"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="de">Schere</rdfs:label> <rdfs:label xml:lang="zh">剪刀</rdfs:label>
        <rdfs:label xml:lang="en">pair of scissors</rdfs:label> <rdfs:label xml:lang="zh">剪刀</rdfs:label>
        <skos:definition xml:lang="en">A tool with two sharp blades that are brought together by pressure on the handles to cut paper, fabric, or other materials.</skos:definition> <skos:definition xml:lang="zh">一种工具，有两个锋利的刀片，通过按压手柄使刀片合拢来切割纸张、布料或其他材料。</skos:definition>
        <skos:definition xml:lang="de">Ein Werkzeug mit zwei scharfen Klingen, die durch Druck auf die Griffe zusammengeführt werden, um Papier, Stoff oder andere Materialien zu schneiden.</skos:definition> <skos:definition xml:lang="zh">一种具有两个锋利刀片的工具，通过按压手柄使刀片闭合，用于切割纸张、布料或其他材料。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000924 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000924">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000773"/>
        <obo:IAO_0000119 xml:lang="en">A measure of a material's resistance to deformation or scratching by a harder material.</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">材料抵抗更硬材料变形或划痕的度量。</obo:IAO_0000119>
        <rdfs:label xml:lang="en">scratch hardness</rdfs:label> <rdfs:label xml:lang="zh">划痕硬度</rdfs:label>
        <skos:definition xml:lang="en">The scratch hardness is a hardness representing a measure of a material's resistance to deformation or scratching by a harder material.</skos:definition> <skos:definition xml:lang="zh">划痕硬度是一种硬度，表示材料抵抗更硬材料变形或划痕的度量。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000925 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000925">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000602"/>
        <rdfs:label xml:lang="de">Kratzprüfmaschine</rdfs:label> <rdfs:label xml:lang="zh">划痕测试机</rdfs:label>
        <rdfs:label xml:lang="en">scratch testing machine</rdfs:label> <rdfs:label xml:lang="zh">划痕试验机</rdfs:label>
        <skos:definition xml:lang="en">A device used to test the scratch resistance of materials by applying a scratching force.</skos:definition> <skos:definition xml:lang="zh">一种通过施加刮擦力来测试材料耐刮擦性的设备。</skos:definition>
        <skos:definition xml:lang="de">Ein Gerät zur Prüfung der Kratzfestigkeit von Materialien durch Anwendung einer Kratzkraft.</skos:definition> <skos:definition xml:lang="zh">一种通过施加划痕力来测试材料抗划伤性的设备。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000926 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000926">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000849"/>
        <rdfs:label xml:lang="de">Ritzhärteprüfverfahren</rdfs:label> <rdfs:label xml:lang="zh">划痕硬度测试方法</rdfs:label>
        <rdfs:label xml:lang="en">scratch testing process</rdfs:label> <rdfs:label xml:lang="zh">划痕测试过程</rdfs:label>
        <skos:definition xml:lang="en">A mechanical property analyzing process that evaluates a material's resistance to scratching, measuring hardness and adhesion properties.</skos:definition> <skos:definition xml:lang="zh">一种评估材料抗刮擦能力并测量硬度与附着性能的力学性能分析过程。</skos:definition>
        <skos:definition xml:lang="de">Ein Mechanische Eigenschaften Analyseverfahren, das den Widerstand eines Materials gegen Kratzer bewertet und seine Härte- und Haftungseigenschaften misst.</skos:definition> <skos:definition xml:lang="zh">一种机械性能分析方法，评估材料对划痕的抵抗力，并测量其硬度和附着力特性。</skos:definition>
        <skos:example xml:lang="en">Scratch testing of a coated surface to determine the adhesion quality of the coating to the substrate.</skos:example> <skos:example xml:lang="zh">对涂层表面进行划痕测试以确定涂层与基材的附着质量。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000927 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000927">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000833"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000055"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000592"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000833"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000055"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000592"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000119 xml:lang="en">Official definition can be found in: DIN 8580:2003-9 Fertigungsverfahren, Page 4, 3.1.3 Trennen - Definition</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">官方定义见：DIN 8580:2003-9 Fertigungsverfahren，第4页，3.1.3 Trennen - 定义</obo:IAO_0000119>
        <rdfs:label xml:lang="de">Trennen</rdfs:label> <rdfs:label xml:lang="zh">分离</rdfs:label>
        <rdfs:label xml:lang="en">separating</rdfs:label> <rdfs:label xml:lang="zh">分离</rdfs:label>
        <skos:definition xml:lang="en">A manufacturing process in which the bond between objects is broken, resulting in a partial or complete reduction in cohesion.</skos:definition> <skos:definition xml:lang="zh">一种制造过程，其中物体间的结合被打破，导致内聚力部分或完全降低。</skos:definition>
        <skos:definition xml:lang="de">Ein Herstellungsprozess, bei dem die Bindung zwischen Objekten aufgehoben wird, was zu einer teilweisen oder vollständigen Verringerung der Kohäsion führt.</skos:definition> <skos:definition xml:lang="zh">一种制造过程，其中物体之间的结合被解除，导致内聚力部分或完全降低。</skos:definition>
        <skos:example xml:lang="en">Disassembling, Removal</skos:example> <skos:example xml:lang="zh">拆卸，移除</skos:example>
        <PMD_0050117 xml:lang="en">Cutting</PMD_0050117>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000928 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000928">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000602"/>
        <rdfs:label xml:lang="de">Schubprüfmaschine</rdfs:label> <rdfs:label xml:lang="zh">剪切试验机</rdfs:label>
        <rdfs:label xml:lang="en">shear testing machine</rdfs:label> <rdfs:label xml:lang="zh">剪切测试机</rdfs:label>
        <skos:definition xml:lang="en">A device used to measure the shear strength of materials by applying a shearing force and measuring deformation.</skos:definition> <skos:definition xml:lang="zh">一种通过施加剪切力并测量变形来测量材料剪切强度的设备。</skos:definition>
        <skos:definition xml:lang="de">Ein Gerät zur Messung der Scherfestigkeit von Materialien durch Anwendung einer Schubkraft und Messung der Verformung.</skos:definition> <skos:definition xml:lang="zh">一种通过施加剪切力并测量变形来测量材料剪切强度的设备。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000929 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000929">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000849"/>
        <rdfs:label xml:lang="de">Schubprüfverfahren</rdfs:label> <rdfs:label xml:lang="zh">剪切试验方法</rdfs:label>
        <rdfs:label xml:lang="en">shear testing process</rdfs:label> <rdfs:label xml:lang="zh">剪切测试过程</rdfs:label>
        <skos:definition xml:lang="en">A mechanical property analyzing process that measures a material's response to shear forces, determining its shear strength and shear modulus.</skos:definition> <skos:definition xml:lang="zh">一种测量材料对剪切力响应并确定其剪切强度与剪切模量的力学性能分析过程。</skos:definition>
        <skos:definition xml:lang="de">Ein Mechanische Eigenschaften Analyseverfahren, das die Reaktion eines Materials auf Scherkräfte misst und seine Scherfestigkeit und seinen Schermodul bestimmt.</skos:definition> <skos:definition xml:lang="zh">一种力学性能分析方法，测量材料对剪切力的反应，并确定其剪切强度和剪切模量。</skos:definition>
        <skos:example xml:lang="en">Shear testing of rivets to ensure they can hold structural components together under lateral loads.</skos:example> <skos:example xml:lang="zh">对铆钉进行剪切测试以确保其在侧向载荷下能将结构部件固定在一起。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000931 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000931">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000104"/>
        <rdfs:label xml:lang="en">simulation method specification</rdfs:label> <rdfs:label xml:lang="zh">模拟方法规范</rdfs:label>
        <skos:definition xml:lang="en">A plan specification that specifies the method of creating a computational or physical model to replicate the behavior of a material or system under specific conditions.</skos:definition> <skos:definition xml:lang="zh">一种计划规范，规定了创建计算或物理模型以在特定条件下复现材料或系统行为的方法。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000932 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000932">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000582"/>
        <rdfs:label xml:lang="de">Simulationsknoten</rdfs:label> <rdfs:label xml:lang="zh">模拟节点</rdfs:label>
        <rdfs:label xml:lang="en">simulation device</rdfs:label> <rdfs:label xml:lang="zh">仿真设备</rdfs:label>
        <skos:definition xml:lang="en">A computing device that implements foo as well as consumes and creates simulation objects and parameters.</skos:definition> <skos:definition xml:lang="zh">一个计算设备，它实现foo，同时消耗和创建模拟对象和参数。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000933 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000933">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000583"/>
        <rdfs:label xml:lang="de">Simulationsprozess</rdfs:label> <rdfs:label xml:lang="zh">模拟过程</rdfs:label>
        <rdfs:label xml:lang="en">simulation process</rdfs:label> <rdfs:label xml:lang="zh">模拟过程</rdfs:label>
        <skos:definition xml:lang="en">A computing process that models the behavior of a system over time using mathematical or computational techniques.</skos:definition> <skos:definition xml:lang="zh">一个计算过程，它使用数学或计算技术随时间模拟系统的行为。</skos:definition>
        <skos:definition xml:lang="de">Ein Datenverarbeitungsprozess, der das Verhalten eines Systems im Laufe der Zeit mit mathematischen oder rechnerischen Techniken modelliert</skos:definition> <skos:definition xml:lang="zh">一种数据处理过程，使用数学或计算技术对系统随时间的行为进行建模。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000934 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000934">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000550"/>
        <obo:IAO_0000119 xml:lang="de">https://industrylist.com/glossar/stoffeigenschaften-aendern/sintern/</obo:IAO_0000119>
        <rdfs:label xml:lang="de">Sintern</rdfs:label> <rdfs:label xml:lang="zh">烧结</rdfs:label>
        <rdfs:label xml:lang="en">sintering</rdfs:label> <rdfs:label xml:lang="zh">烧结</rdfs:label>
        <skos:definition xml:lang="en">A changing properties of materials process in which granular and powdery materials, which have already been shaped in the first step, are mixed and combined and compacted by heating.</skos:definition> <skos:definition xml:lang="zh">一种改变材料属性的过程，其中已在第一步成型的颗粒和粉末材料通过加热混合、结合并压实。</skos:definition>
        <skos:definition xml:lang="de">Ein Stoffeigenschaftsänderungsprozess, bei dem körnige und pulverförmige Stoffe, welche im ersten Schritt bereits in Form gebracht wurden, vermischt und durch Erwärmung verbunden und verdichtet werden.</skos:definition> <skos:definition xml:lang="zh">一种材料性质改变过程，其中颗粒状和粉末状物料（已在第一步成型）被混合并通过加热连接和压实。</skos:definition>
        <skos:example xml:lang="en">Metal Powder Sintering, Ceramic Sintering</skos:example> <skos:example xml:lang="zh">金属粉末烧结，陶瓷烧结</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000935 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000935">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000558"/>
        <rdfs:label xml:lang="de">Formatkreissäge</rdfs:label> <rdfs:label xml:lang="zh">格式圆锯</rdfs:label>
        <rdfs:label xml:lang="en">sizing saw</rdfs:label> <rdfs:label xml:lang="zh">定尺锯</rdfs:label>
        <skos:definition xml:lang="en">A sizing saw is an industrial circular saw designed for large cutting formats in woodworking and furniture production.</skos:definition> <skos:definition xml:lang="zh">定尺锯是一种工业圆锯，设计用于木材加工和家具生产中的大幅面切割。</skos:definition>
        <skos:definition xml:lang="de">Eine Formatkreissäge ist eine industrielle Kreissäge, die für große Schnittformate in der Holzverarbeitung und Möbelherstellung ausgelegt ist.</skos:definition> <skos:definition xml:lang="zh">格式圆锯是一种工业用圆锯，专为木材加工和家具制造中的大尺寸切割而设计。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000936 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000936">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000602"/>
        <rdfs:label xml:lang="de">Schlitten</rdfs:label> <rdfs:label xml:lang="zh">滑架</rdfs:label>
        <rdfs:label xml:lang="en">slide</rdfs:label> <rdfs:label xml:lang="zh">滑板</rdfs:label>
        <skos:definition xml:lang="en">A moving device that is guided by a part along its path, providing the mount for objects.</skos:definition> <skos:definition xml:lang="zh">一种移动装置，由零件沿其路径引导，为物体提供安装座。</skos:definition>
        <skos:definition xml:lang="de">Eine bewegliche Vorrichtung (Gerät), die von einem Teil entlang ihrer Bahn geführt wird und die Halterung für Objekte bildet.</skos:definition> <skos:definition xml:lang="zh">一种可移动装置（设备），由部件沿其轨道引导，并构成物体的支架。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000937 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000937">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000602"/>
        <rdfs:label xml:lang="de">Lötgerät</rdfs:label> <rdfs:label xml:lang="zh">钎焊设备</rdfs:label>
        <rdfs:label xml:lang="en">soldering device</rdfs:label> <rdfs:label xml:lang="zh">钎焊装置</rdfs:label>
        <skos:definition xml:lang="en">A device used for joining materials together by melting and applying a filler metal.</skos:definition> <skos:definition xml:lang="zh">一种通过熔化并施加填充金属来连接材料的设备。</skos:definition>
        <skos:definition xml:lang="de">Ein Gerät zum Verbinden von Materialien durch Schmelzen und Auftragen eines Füllmetalls.</skos:definition> <skos:definition xml:lang="zh">一种通过熔化并涂覆填充金属来连接材料的设备。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000939 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000939">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000812"/>
        <rdfs:label xml:lang="de">Lötfunktion</rdfs:label> <rdfs:label xml:lang="zh">钎焊功能</rdfs:label>
        <rdfs:label xml:lang="en">soldering function</rdfs:label> <rdfs:label xml:lang="zh">焊接功能</rdfs:label>
        <skos:definition xml:lang="en">A soldering function is a joining function that is realized in connecting materials using solder.</skos:definition> <skos:definition xml:lang="zh">焊接功能是一种连接功能，通过使用焊料连接材料来实现。</skos:definition>
        <skos:definition xml:lang="de">Eine Unterfunktion des Verbindens, die durchgeführt wird, um Materialien durch Löttechniken zu verbinden.</skos:definition> <skos:definition xml:lang="zh">连接的一个子功能，通过钎焊技术连接材料。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000940 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000940">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000602"/>
        <rdfs:label xml:lang="de">Abplatzprüfmaschine</rdfs:label> <rdfs:label xml:lang="zh">剥落试验机</rdfs:label>
        <rdfs:label xml:lang="en">spalling testing machine</rdfs:label> <rdfs:label xml:lang="zh">剥落试验机</rdfs:label>
        <skos:definition xml:lang="en">A device used to test the resistance of materials to spalling or flaking under various conditions.</skos:definition> <skos:definition xml:lang="zh">一种用于测试材料在各种条件下抗剥落或脱皮能力的设备。</skos:definition>
        <skos:definition xml:lang="de">Ein Gerät zur Prüfung der Widerstandsfähigkeit von Materialien gegenüber Abplatzungen oder Abblätterungen unter verschiedenen Bedingungen.</skos:definition> <skos:definition xml:lang="zh">一种用于测试材料在不同条件下抗剥落或脱皮能力的设备。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000941 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000941">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000849"/>
        <rdfs:label xml:lang="de">Abplatzprüfverfahren</rdfs:label> <rdfs:label xml:lang="zh">剥落测试方法</rdfs:label>
        <rdfs:label xml:lang="en">spalling testing process</rdfs:label> <rdfs:label xml:lang="zh">剥落测试过程</rdfs:label>
        <skos:definition xml:lang="en">A mechanical property analyzing process that evaluates the resistance of a material to surface spalling or flaking under high impact or thermal stresses.</skos:definition> <skos:definition xml:lang="zh">一种力学性能分析过程，评估材料在高冲击或热应力下表面剥落或脱皮的抵抗力。</skos:definition>
        <skos:definition xml:lang="de">Ein Mechanische Eigenschaften Analyseverfahren, das die Widerstandsfähigkeit eines Materials gegen Oberflächenabplatzungen oder Abblättern unter hohen Stoß- oder thermischen Belastungen bewertet.</skos:definition> <skos:definition xml:lang="zh">一种力学性能分析方法，用于评估材料在高冲击或热负荷下抵抗表面剥落或脱皮的能力。</skos:definition>
        <skos:example xml:lang="en">Spalling testing of refractory bricks used in furnaces to ensure their longevity and performance under extreme conditions.</skos:example> <skos:example xml:lang="zh">用于炉窑的耐火砖的剥落测试，以确保其在极端条件下的耐久性和性能。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000942 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000942">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020131"/>
        <rdfs:label xml:lang="en">specific surface area</rdfs:label> <rdfs:label xml:lang="zh">比表面积</rdfs:label>
        <skos:definition xml:lang="en">an intensive quality embodying the total surface area of a material per unit of mass or volume.</skos:definition> <skos:definition xml:lang="zh">一种内禀性质，表示单位质量或体积的材料的总表面积。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000944 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000944">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000602"/>
        <rdfs:label xml:lang="de">Spektrometer</rdfs:label> <rdfs:label xml:lang="zh">光谱仪</rdfs:label>
        <rdfs:label xml:lang="en">spectrometer</rdfs:label> <rdfs:label xml:lang="zh">光谱仪</rdfs:label>
        <skos:definition xml:lang="en">A spectrometer is a measuring device that measures the properties of light over a specific portion of the electromagnetic spectrum, typically to analyze the composition of a material.</skos:definition> <skos:definition xml:lang="zh">光谱仪是一种测量设备，用于测量光在电磁波谱特定部分的特性，通常用于分析材料的成分。</skos:definition>
        <skos:definition xml:lang="de">Ein Spektrometer ist ein Messgerät, das die Eigenschaften von Licht über einen bestimmten Teil des elektromagnetischen Spektrums misst, typischerweise zur Analyse der Zusammensetzung eines Materials.</skos:definition> <skos:definition xml:lang="zh">光谱仪是一种测量光在电磁波谱特定部分特性的测量仪器，通常用于分析材料的组成。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000945 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000945">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000957"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0009006"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0025001"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="de">Spektroskopie Verfahren</rdfs:label> <rdfs:label xml:lang="zh">光谱学方法</rdfs:label>
        <rdfs:label xml:lang="en">spectroscopy process</rdfs:label> <rdfs:label xml:lang="zh">光谱学过程</rdfs:label>
        <skos:definition xml:lang="en">A structural property analyzing process that measures the interaction of electromagnetic radiation with matter to determine e.g. the composition, structure, and other properties of materials.</skos:definition> <skos:definition xml:lang="zh">一种结构性能分析过程，测量电磁辐射与物质的相互作用，以确定材料的组成、结构及其他性质。</skos:definition>
        <skos:definition xml:lang="de">Ein Struktur Eigenschaften Analyseverfahren, das die Wechselwirkung von elektromagnetischer Strahlung mit Materie misst, um die Zusammensetzung, Struktur und physikalischen Eigenschaften von Materialien zu bestimmen.</skos:definition> <skos:definition xml:lang="zh">一种结构特性分析方法，通过测量电磁辐射与物质的相互作用来确定材料的组成、结构和物理性质。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000946 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000946">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000501"/>
        <owl:disjointWith rdf:resource="https://w3id.org/pmd/co/PMD_0000992"/>
        <rdfs:label xml:lang="en">spectrum</rdfs:label> <rdfs:label xml:lang="zh">频谱</rdfs:label>
        <skos:definition xml:lang="en">A spectrum is a 1-D information content entity that describes the range of wavelengths or frequencies of a physical property, often used in reference to light, sound, or electromagnetic radiation.</skos:definition> <skos:definition xml:lang="zh">频谱是一种一维信息内容实体，描述物理属性的波长或频率范围，常用于指光、声或电磁辐射。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000947 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000947">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000506"/>
        <rdfs:label xml:lang="en">speed of sound</rdfs:label> <rdfs:label xml:lang="zh">声速</rdfs:label>
        <skos:definition xml:lang="en">The speed of sound is an acoustic property representing the rate at which sound waves travel through a material, dependent on its density and elastic properties.</skos:definition> <skos:definition xml:lang="zh">声速是一种声学属性，表示声波在材料中传播的速率，取决于材料的密度和弹性性质。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000949 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000949">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000005"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/pmd/co/PMD_0001029"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000596"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://w3id.org/pmd/co/PMD_0000952"/>
        <rdfs:label xml:lang="en">stiffness</rdfs:label> <rdfs:label xml:lang="zh">刚度</rdfs:label>
        <skos:definition xml:lang="en">The stiffness is a material property describing the resistance of a material to deformation under an applied force.</skos:definition> <skos:definition xml:lang="zh">刚度是一种材料属性，描述材料在外力作用下抵抗变形的能力。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000950 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000950">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000015"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000055"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:intersectionOf rdf:parseType="Collection">
                                    <owl:Class>
                                        <owl:unionOf rdf:parseType="Collection">
                                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000016"/>
                                            <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000005"/>
                                        </owl:unionOf>
                                    </owl:Class>
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000052"/>
                                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000001"/>
                                    </owl:Restriction>
                                </owl:intersectionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000055"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <owl:Class>
                                <owl:unionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000016"/>
                                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000005"/>
                                </owl:unionOf>
                            </owl:Class>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000052"/>
                                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000001"/>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">stimulating process</rdfs:label> <rdfs:label xml:lang="zh">激励过程</rdfs:label>
        <skos:definition xml:lang="en">The stimulating process is a process describing the application of an external influence, such as force, heat, or radiation, to study material response.</skos:definition> <skos:definition xml:lang="zh">激励过程是描述施加外部影响（如力、热或辐射）以研究材料响应的过程。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000951 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000951">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000931"/>
        <rdfs:label xml:lang="en">stochastic simulation</rdfs:label> <rdfs:label xml:lang="zh">随机模拟</rdfs:label>
        <skos:definition xml:lang="en">A simulation method specification that incorporates random variables to model probabilistic systems or processes.</skos:definition> <skos:definition xml:lang="zh">一种包含随机变量以建模概率系统或过程的模拟方法规范。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000952 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000952">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000848"/>
        <rdfs:label xml:lang="en">strength</rdfs:label> <rdfs:label xml:lang="zh">强度</rdfs:label>
        <skos:definition xml:lang="en">The strength is a material property describing the maximum stress a material can withstand before failure.</skos:definition> <skos:definition xml:lang="zh">强度是一种材料属性，描述材料在失效前能承受的最大应力。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000953 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000953">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000635"/>
        <rdfs:label xml:lang="en">structural and chemical decay</rdfs:label> <rdfs:label xml:lang="zh">结构和化学衰减</rdfs:label>
        <skos:definition xml:lang="en">The structural and chemical decay is an evolution of damage describing the deterioration of a material's structure and composition over time due to environmental or operational conditions.</skos:definition> <skos:definition xml:lang="zh">结构和化学衰减是一种损伤演化，描述由于环境或操作条件导致材料结构和组成随时间退化的过程。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000955 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000955">
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000654"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:intersectionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000030"/>
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000085"/>
                                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OBI_0000379"/>
                                    </owl:Restriction>
                                </owl:intersectionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <obo:IAO_0000116 xml:lang="en">Classified by the role in a system.</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">根据在系统中的作用分类。</obo:IAO_0000116>
        <rdfs:label xml:lang="en">structural material</rdfs:label> <rdfs:label xml:lang="zh">结构材料</rdfs:label>
        <skos:definition xml:lang="en">A structural material S is an engineered material which has the disposition to be used for an object O (O consists of S) and O's function is primarily mechanical load carrying.</skos:definition> <skos:definition xml:lang="zh">结构材料S是一种工程材料，具有用于对象O（O由S组成）的倾向，且O的功能主要是机械承载。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000956 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000956">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000933"/>
        <rdfs:label xml:lang="de">Strukturoptimierungssimulation</rdfs:label> <rdfs:label xml:lang="zh">结构优化模拟</rdfs:label>
        <rdfs:label xml:lang="en">structural optimization simulation</rdfs:label> <rdfs:label xml:lang="zh">结构优化模拟</rdfs:label>
        <skos:definition xml:lang="en">A simulation process that aims to find the most stable structure of a molecular system by minimizing its energy.</skos:definition> <skos:definition xml:lang="zh">一种旨在通过最小化能量来找到分子系统最稳定结构的模拟过程。</skos:definition>
        <skos:definition xml:lang="de">Ein Simulationsprozess, der darauf abzielt, die stabilste Struktur eines molekularen Systems durch Minimierung seiner Energie zu finden.</skos:definition>
        <skos:example xml:lang="en">Optimizing the atomic structure of a catalyst to enhance its performance.</skos:example> <skos:example xml:lang="zh">优化催化剂的原子结构以增强其性能。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000957 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000957">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBI_0000070"/>
        <rdfs:label xml:lang="de">Struktur Eigenschaften Analyseverfahren</rdfs:label> <rdfs:label xml:lang="zh">结构特性分析方法</rdfs:label>
        <rdfs:label xml:lang="en">structural property analyzing process</rdfs:label> <rdfs:label xml:lang="zh">结构属性分析过程</rdfs:label>
        <skos:definition xml:lang="en">An assay that examines the external and internal structure and morphology of materials, including the arrangement of atoms, crystals, grains, and phases, often using techniques like microscopy and diffraction.</skos:definition> <skos:definition xml:lang="zh">一种分析材料外部和内部结构及形态的检测方法，包括原子、晶体、晶粒和相的排列，通常使用显微镜和衍射等技术。</skos:definition>
        <skos:definition xml:lang="de">Eine Analyse, die die äußere und innere Struktur und Morphologie von Materialien untersucht, einschließlich der Anordnung von Atomen, Kristallen, Körnern und Phasen, oft unter Verwendung von Techniken wie Mikroskopie und Beugung.</skos:definition> <skos:definition xml:lang="zh">一种分析，研究材料的外部和内部结构及形态，包括原子、晶体、晶粒和相的排列，通常使用显微镜和衍射等技术。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000959 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000959">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000603"/>
        <rdfs:label xml:lang="de">Einstellungsgegenstandsrolle</rdfs:label> <rdfs:label xml:lang="zh">调整对象角色</rdfs:label>
        <rdfs:label xml:lang="en">subject of adjustment role</rdfs:label> <rdfs:label xml:lang="zh">调整对象角色</rdfs:label>
        <skos:definition xml:lang="en">A device role that is being adjusted. The role is realized in an adjustment process.</skos:definition> <skos:definition xml:lang="zh">一种正在被调整的设备角色。该角色在调整过程中实现。</skos:definition>
        <skos:definition xml:lang="de">Rolle eines Gerätes (Einstellungsgegenstand), das eingestellt wird. Die Rolle wird ein einem Einstellungsprozess realisiert.</skos:definition> <skos:definition xml:lang="zh">被调整的设备（调整对象）的角色。该角色在调整过程中实现。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000960 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000960">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000603"/>
        <rdfs:label xml:lang="de">Kalibrierungsgegenstandsrolle</rdfs:label> <rdfs:label xml:lang="zh">校准对象角色</rdfs:label>
        <rdfs:label xml:lang="en">subject of calibration role</rdfs:label> <rdfs:label xml:lang="zh">校准对象角色</rdfs:label>
        <skos:definition xml:lang="en">A device role that is being calibrated. The role is realized in a calibration process.</skos:definition> <skos:definition xml:lang="zh">一种被校准的设备角色。该角色在校准过程中实现。</skos:definition>
        <skos:definition xml:lang="de">Rolle eines Gerätes (Kalibrierungsgegenstand), das kalibriert wird. Die Rolle wird ein einem Kalibrierungsprozess realisiert.</skos:definition> <skos:definition xml:lang="zh">被校准的设备（校准对象）的角色。该角色在校准过程中实现。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000961 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000961">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020164"/>
        <rdfs:label xml:lang="en">sublimation point</rdfs:label> <rdfs:label xml:lang="zh">升华点</rdfs:label>
        <skos:definition xml:lang="en">The sublimation point is a state of matter boundary realized by transition from the solid state to the gaseous state (or vice versa).</skos:definition> <skos:definition xml:lang="zh">升华点是由固态到气态（或反之）转变实现的物质状态边界。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000962 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000962">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000556"/>
        <rdfs:label xml:lang="en">supercritical fluid chromatography process</rdfs:label> <rdfs:label xml:lang="zh">超临界流体色谱过程</rdfs:label>
        <rdfs:label xml:lang="de">Überkritische Fluidchromatographie Verfahren</rdfs:label> <rdfs:label xml:lang="zh">超临界流体色谱法</rdfs:label>
        <skos:definition xml:lang="en">A chromatography process that utilizes a supercritical fluid as the mobile phase to separate components, offering higher speed and efficiency compared to traditional methods.</skos:definition> <skos:definition xml:lang="zh">一种利用超临界流体作为流动相分离组分的色谱过程，与传统方法相比具有更高的速度和效率。</skos:definition>
        <skos:definition xml:lang="de">Ein Chromatographieverfahren, das ein überkritisches Fluid als mobile Phase verwendet, um Komponenten zu trennen, und im Vergleich zu traditionellen Methoden eine höhere Geschwindigkeit und Effizienz bietet.</skos:definition> <skos:definition xml:lang="zh">一种色谱方法，使用超临界流体作为流动相来分离组分，与传统方法相比提供更高的速度和效率。</skos:definition>
        <skos:example xml:lang="en">Supercritical fluid chromatography is used to separate and analyze complex mixtures of polymers and plastics.</skos:example> <skos:example xml:lang="zh">超临界流体色谱用于分离和分析聚合物和塑料的复杂混合物。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000963 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000963">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000557"/>
        <rdfs:label xml:lang="en">supercritical fluid chromatography system</rdfs:label> <rdfs:label xml:lang="zh">超临界流体色谱系统</rdfs:label>
        <rdfs:label xml:lang="de">Überkritisches Fluid-Chromatographiesystem</rdfs:label> <rdfs:label xml:lang="zh">超临界流体色谱系统</rdfs:label>
        <skos:definition xml:lang="en">A chromatography system for separating and analyzing compounds using supercritical fluids as the mobile phase in chromatography.</skos:definition> <skos:definition xml:lang="zh">一种色谱系统，在色谱中使用超临界流体作为流动相来分离和分析化合物。</skos:definition>
        <skos:definition xml:lang="de">Ein Chromatographiesystem zur Trennung und Analyse von Verbindungen unter Verwendung überkritischer Flüssigkeiten als mobile Phase in der Chromatographie.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000964 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000964">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000821"/>
        <rdfs:label xml:lang="de">supervised machine learning</rdfs:label> <rdfs:label xml:lang="zh">监督式机器学习</rdfs:label>
        <rdfs:label xml:lang="en">supervised machine learning</rdfs:label> <rdfs:label xml:lang="zh">监督式机器学习</rdfs:label>
        <skos:definition xml:lang="en">A machine learning process that learns a function mapping from input data to labeled output data.</skos:definition> <skos:definition xml:lang="zh">一种机器学习过程，学习从输入数据到标记输出数据的函数映射。</skos:definition>
        <skos:definition xml:lang="de">Ein Maschinelles Lernen Prozess, der eine Funktion erlernt, die Eingabedaten auf beschriftete Ausgabedaten abbildet.</skos:definition> <skos:definition xml:lang="zh">一种机器学习过程，学习一个将输入数据映射到标记输出数据的函数。</skos:definition>
        <skos:example xml:lang="en">Training a model to predict the tensile strength of a material based on its composition and manufacturing process parameters. This involves using a dataset where the tensile strength is already known (labeled data) to train the model.</skos:example> <skos:example xml:lang="zh">训练一个模型，根据材料的成分和制造工艺参数预测其抗拉强度。这涉及使用一个已知抗拉强度的数据集（标记数据）来训练模型。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000965 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000965">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000027"/>
                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000030"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">surface layer (fiat object part)</rdfs:label> <rdfs:label xml:lang="zh">表面层（边界对象部分）</rdfs:label>
        <skos:definition xml:lang="en">A surface layer (fiat object part) is a fiat object part that is part of only object. The surface layer is the three dimensional region defining the outermost layer of an object, where surface-interactions with other material entities occur. What is considered as the surface is thus defined by the interaction process.</skos:definition> <skos:definition xml:lang="zh">表面层（边界对象部分）是仅属于物体的边界对象部分。表面层是定义物体最外层的三维区域，在该区域发生与其他物质实体的表面相互作用。因此，被认为是表面的区域由相互作用过程定义。</skos:definition>
        <skos:example xml:lang="en">When considering optical properties of a surface layer (fiat object part) of a polished piece of metal we likely consider a different three dimensional spatial region than when considering the scratch hardness properties of the same polished piece of metal.</skos:example> <skos:example xml:lang="zh">在考虑抛光金属件的表面层（边界对象部分）的光学性质时，我们可能考虑与考虑同一抛光金属件的划痕硬度性质时不同的三维空间区域。</skos:example>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000966 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000966">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000602"/>
        <rdfs:label xml:lang="de">Oberflächenprofilometer</rdfs:label> <rdfs:label xml:lang="zh">表面轮廓仪</rdfs:label>
        <rdfs:label xml:lang="en">surface profilometer</rdfs:label> <rdfs:label xml:lang="zh">表面轮廓仪</rdfs:label>
        <skos:definition xml:lang="en">A device used to measure the surface profile and texture of materials.</skos:definition> <skos:definition xml:lang="zh">一种用于测量材料表面轮廓和纹理的设备。</skos:definition>
        <skos:definition xml:lang="de">Ein Gerät zur Messung des Oberflächenprofils und der Textur von Materialien.</skos:definition> <skos:definition xml:lang="zh">一种用于测量材料表面轮廓和纹理的设备。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000967 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000967">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020131"/>
        <rdfs:comment xml:lang="en">The concept refers to an absolute temperature, not to be mistaken with temperature difference.</rdfs:comment>
        <rdfs:comment xml:lang="en">To express that an object has a temperature, the property 'intensive bearer of' can be used. It implies a chain of: object consists of some portion of matter and portion of matter bearer of some temperature.</rdfs:comment>
        <rdfs:label xml:lang="en">temperature</rdfs:label> <rdfs:label xml:lang="zh">温度</rdfs:label>
        <skos:definition xml:lang="en">The temperature is a fundamental intensive quality representing the average atomic or molcular movement or vibration of a portion of matter.</skos:definition> <skos:definition xml:lang="zh">温度是一种基本的强度性质，代表了物质部分中原子或分子的平均运动或振动。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000968 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000968">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000602"/>
        <rdfs:label xml:lang="de">Temperaturänderungswerkzeug</rdfs:label> <rdfs:label xml:lang="zh">温度变化工具</rdfs:label>
        <rdfs:label xml:lang="en">temperature change device</rdfs:label> <rdfs:label xml:lang="zh">温度变化装置</rdfs:label>
        <skos:definition xml:lang="en">A device that is used for the alteration and adjustment of the temperature of a tangible object or the environment, e.g., a furnace and cooling media.</skos:definition> <skos:definition xml:lang="zh">一种用于改变和调节有形物体或环境温度的装置，例如熔炉和冷却介质。</skos:definition>
        <skos:definition xml:lang="de">Diese Entität beschreibt allgemein jedes Werkzeug, das zur Änderung und Einstellung der Temperatur eines materiellen Objekts oder der Umgebung verwendet wird, z. B. einen Ofen und Kühlmittel.</skos:definition> <skos:definition xml:lang="zh">该实体泛指用于改变和调节物质对象或环境温度的任何工具，如炉子和冷却剂。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000969 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000969">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000034"/>
        <rdfs:label xml:lang="de">Temperaturänderungsfunktion</rdfs:label> <rdfs:label xml:lang="zh">温度变化功能</rdfs:label>
        <rdfs:label xml:lang="en">temperature change function</rdfs:label> <rdfs:label xml:lang="zh">温度变化功能</rdfs:label>
        <skos:definition xml:lang="en">A function in heat treatment performed to induce changes in temperature to alter material properties.</skos:definition> <skos:definition xml:lang="zh">热处理中的一种功能，通过引起温度变化来改变材料性能。</skos:definition>
        <skos:definition xml:lang="de">Eine Unterfunktion der Wärmebehandlung, die durchgeführt wird, um Temperaturänderungen hervorzurufen, um die Materialeigenschaften zu verändern.</skos:definition> <skos:definition xml:lang="zh">热处理的一个子功能，通过引起温度变化来改变材料属性。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000971 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000971">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000847"/>
        <rdfs:label xml:lang="de">Temperaturmessfunktion</rdfs:label> <rdfs:label xml:lang="zh">温度测量功能</rdfs:label>
        <rdfs:label xml:lang="en">temperature measuring function</rdfs:label> <rdfs:label xml:lang="zh">温度测量功能</rdfs:label>
        <skos:definition xml:lang="en">A measuring function performed to determine the temperature of an object or environment.</skos:definition> <skos:definition xml:lang="zh">一种用于确定物体或环境温度的测量功能。</skos:definition>
        <skos:definition xml:lang="de">Eine Messefunktion, die durchgeführt wird, um die Temperatur eines Objekts oder einer Umgebung zu bestimmen.</skos:definition> <skos:definition xml:lang="zh">一种测量功能，用于确定对象或环境的温度。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000972 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000972">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000005"/>
        <rdfs:label xml:lang="en">temporal property</rdfs:label> <rdfs:label xml:lang="zh">时间属性</rdfs:label>
        <skos:definition xml:lang="en">A temporal property is a material property that represents attributes related to the time-dependent behavior of a material or process.</skos:definition> <skos:definition xml:lang="zh">时间属性是一种材料属性，表示与材料或过程随时间变化的行为相关的属性。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000973 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000973">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000602"/>
        <rdfs:label xml:lang="de">Zugprüfmaschine</rdfs:label> <rdfs:label xml:lang="zh">拉伸试验机</rdfs:label>
        <rdfs:label xml:lang="en">tensile testing machine</rdfs:label> <rdfs:label xml:lang="zh">拉伸试验机</rdfs:label>
        <skos:definition xml:lang="en">A device used to test the tensile strength and elongation of materials by applying a stretching force.</skos:definition> <skos:definition xml:lang="zh">一种通过施加拉伸力来测试材料抗拉强度和伸长率的设备。</skos:definition>
        <skos:definition xml:lang="de">Ein Gerät zur Prüfung der Zugfestigkeit und Dehnung von Materialien durch Anwendung einer Dehnkraft.</skos:definition> <skos:definition xml:lang="zh">一种通过施加拉伸力来测试材料拉伸强度和伸长率的装置。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000974 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000974">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000849"/>
        <rdfs:label xml:lang="de">Zugprüfverfahren</rdfs:label> <rdfs:label xml:lang="zh">拉伸测试方法</rdfs:label>
        <rdfs:label xml:lang="en">tensile testing process</rdfs:label> <rdfs:label xml:lang="zh">拉伸测试过程</rdfs:label>
        <skos:definition xml:lang="en">A mechanical property analyzing process that determines a material's response to tensile forces, measuring its tensile strength, elongation, and Young's modulus.</skos:definition> <skos:definition xml:lang="zh">一种机械性能分析过程，确定材料对拉伸力的响应，测量其抗拉强度、伸长率和杨氏模量。</skos:definition>
        <skos:definition xml:lang="de">Ein Mechanische Eigenschaften Analyseverfahren, das die Reaktion eines Materials auf Zugkräfte bestimmt und seine Zugfestigkeit, Dehnung und seinen Elastizitätsmodul misst.</skos:definition> <skos:definition xml:lang="zh">一种机械性能分析程序，用于确定材料对拉伸力的反应，并测量其拉伸强度、延伸率和弹性模量。</skos:definition>
        <skos:example xml:lang="en">Tensile testing of polymer films to ensure they can stretch without breaking in packaging applications</skos:example> <skos:example xml:lang="zh">聚合物薄膜的拉伸测试，以确保在包装应用中能够拉伸而不断裂。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000975 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000975">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000023"/>
        <obo:IAO_0000116 xml:lang="de">ANMERKUNG: Ein Test Piece ist ein Teilstück (potenziell alles) eines Specimens, welches die Bedingungen erfüllt, die durch ein anzuwendendes Prüfverfahren gestellt werden. Ein Specimen erfüllt diese Anforderungen im Allgemeinen erst nach weiterer Bearbeitung. CAVE: Diese Anmerkung beschreibt das Objekt, welches die Rolle, die durch diese owl:Class definiert wird, realisiert.
ANMERKUNG: Die exakte Wortwahl der EN 10021 wurde verallgemeinert.</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">注：试验件是从试样（可能是整个试样）上取出的一个部分，该部分满足所采用的测试程序提出的要求。试样通常只有在进一步处理后才能满足这些要求。注意：此注释描述了实现此owl:Class所定义角色的对象。
注：EN 10021的准确措辞已被泛化。</obo:IAO_0000116>
        <obo:IAO_0000116 xml:lang="en">In certain cases, the test piece can be the sample or the specimen itself.</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">在某些情况下，试验件可以是样本或试样本身。</obo:IAO_0000116>
        <obo:IAO_0000116 xml:lang="de">Mitunter kann der Probenabschnitt (Sample) oder der Prüfling (Specimen) unmittelbar als Probe dienen.</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">有时，样本（Sample）或试样（Specimen）可以直接用作试验件。</obo:IAO_0000116>
        <obo:IAO_0000116 xml:lang="en">NOTE: A Test Piece is a piece that is taken from a specimen (potentially the whole specimen), which fulfills the requirements, that are set by the test procedure in which the test piece is about to be used. A specimen fulfills this requierements generally speaking only after further treatment/processing. CAVE: This note describes the object, that realizes the role defined by this owl:Class.
NOTE: The wording used in EN 10021 was generalized.</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">注：试验件是从试样（可能是整个试样）上取出的一个部分，该部分满足即将使用的测试程序所提出的要求。一般来说，试样只有在进一步处理/加工后才能满足这些要求。注意：此注释描述了实现此owl:Class所定义角色的对象。
注：EN 10021中使用的措辞已被泛化。</obo:IAO_0000116>
        <obo:IAO_0000119 xml:lang="en">EN 10021:2006-12 (European standardization committee: CEN/TC 459/SC 12/WG 4)</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">EN 10021:2006-12 (欧洲标准化委员会: CEN/TC 459/SC 12/WG 4)</obo:IAO_0000119>
        <rdfs:label xml:lang="de">Proben-Rolle</rdfs:label> <rdfs:label xml:lang="zh">试验件角色</rdfs:label>
        <rdfs:label xml:lang="en">test piece role</rdfs:label> <rdfs:label xml:lang="zh">试验件角色</rdfs:label>
        <skos:definition xml:lang="en">Role of object which is a part taken from a specimen or sample; the part has specified dimensions, is machined or un-machined, brought to a required condition for submission to a given test</skos:definition> <skos:definition xml:lang="zh">对象的角色，该对象是从试样或样本中取出的部分；该部分具有指定尺寸，经过加工或未加工，处于提交给给定测试所需的条件下。</skos:definition>
        <skos:definition xml:lang="de">Rolle eines Objekts, welches eine Probe ist, die aus einem Prüfling (Specimen) oder Probenabschnitt (Sample) entnommen wurde; die Probe hat festgelegte Dimensionen, kann maschinell bearbeitet sein, wurde in einen für die Verwendung in einem Prüfverfahren notwendigen Zustand gebracht</skos:definition> <skos:definition xml:lang="zh">对象的角色，该对象是从试样（Specimen）或样本（Sample）中取出的试验件；该试验件具有固定尺寸，可能经过机械加工，已处于用于测试程序所需的状态。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000976 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000976">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000034"/>
        <rdfs:label xml:lang="de">Testfunktion</rdfs:label> <rdfs:label xml:lang="zh">测试功能</rdfs:label>
        <rdfs:label xml:lang="en">testing function</rdfs:label> <rdfs:label xml:lang="zh">测试功能</rdfs:label>
        <skos:definition xml:lang="en">A function performed to assess or evaluate the properties, performance, or quality of materials or devices.</skos:definition> <skos:definition xml:lang="zh">用于评估或评价材料或设备的性能、表现或质量的功能。</skos:definition>
        <skos:definition xml:lang="de">Eine Funktion, die durchgeführt wird, um die Eigenschaften, Leistung oder Qualität von Materialien oder Geräten zu bewerten.</skos:definition> <skos:definition xml:lang="zh">用于评估材料或设备特性、性能或质量而执行的功能。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000977 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000977">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000806"/>
        <obo:IAO_0000119 xml:lang="de">Keine offizielle Definition in DIN</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">DIN中无官方定义</obo:IAO_0000119>
        <obo:IAO_0000119 xml:lang="en">No official definition in DIN</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">DIN中无官方定义</obo:IAO_0000119>
        <rdfs:label xml:lang="de">Textiles Fügen</rdfs:label> <rdfs:label xml:lang="zh">纺织品连接</rdfs:label>
        <rdfs:label xml:lang="en">textile joining</rdfs:label> <rdfs:label xml:lang="zh">纺织品连接</rdfs:label>
        <skos:definition xml:lang="en">A joining process that involves connecting textile materials.</skos:definition> <skos:definition xml:lang="zh">一种涉及连接纺织品材料的连接过程。</skos:definition>
        <skos:definition xml:lang="de">Ein Füge Prozess, bei dem textile Materialien miteinander verbunden werden.</skos:definition> <skos:definition xml:lang="zh">一种连接过程，其中纺织品材料相互连接。</skos:definition>
        <skos:example xml:lang="en">Sewing, Stapling</skos:example> <skos:example xml:lang="zh">缝纫、钉合</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000978 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000978">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000981"/>
        <rdfs:label xml:lang="en">thermal conductivity</rdfs:label> <rdfs:label xml:lang="zh">热导率</rdfs:label>
        <skos:definition xml:lang="en">The thermal conductivity is a thermal property describing the ability of a material to conduct heat.</skos:definition> <skos:definition xml:lang="zh">热导率是描述材料传导热量能力的热性能。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000979 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000979">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000982"/>
        <rdfs:label xml:lang="de">Wärmeleitfähigkeitsmessverfahren</rdfs:label> <rdfs:label xml:lang="zh">热导率测量方法</rdfs:label>
        <rdfs:label xml:lang="en">thermal conductivity measurement process</rdfs:label> <rdfs:label xml:lang="zh">热导率测量过程</rdfs:label>
        <skos:definition xml:lang="en">A thermal property analyzing process that measures the thermal conductivity of a material, determining its ability to conduct heat.</skos:definition> <skos:definition xml:lang="zh">一种热性能分析过程，测量材料的热导率，确定其导热能力。</skos:definition>
        <skos:definition xml:lang="de">Ein Thermische Eigenschaften Analyseverfahren, das die Wärmeleitfähigkeit eines Materials misst und dessen Fähigkeit bestimmt, Wärme zu leiten.</skos:definition> <skos:definition xml:lang="zh">一种热性能分析方法，用于测量材料的热导率并确定其导热能力。</skos:definition>
        <skos:example xml:lang="en">Measuring the thermal conductivity of a composite material used in aerospace applications to ensure efficient heat dissipation.</skos:example> <skos:example xml:lang="zh">测量用于航空航天应用的复合材料的热导率，以确保有效散热。</skos:example>
        <PMD_0050117 xml:lang="en">TCMP</PMD_0050117>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000980 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000980">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000847"/>
        <rdfs:label xml:lang="de">Wärmeleitfähigkeitsmessfunktion</rdfs:label> <rdfs:label xml:lang="zh">热导率测量功能</rdfs:label>
        <rdfs:label xml:lang="en">thermal conductivity measuring function</rdfs:label> <rdfs:label xml:lang="zh">热导率测量功能</rdfs:label>
        <skos:definition xml:lang="en">A measuring function that inheres in devices used to measure the thermal conductivity of materials.</skos:definition> <skos:definition xml:lang="zh">一种测量功能，存在于用于测量材料热导率的设备中。</skos:definition>
        <skos:definition xml:lang="de">Eine Funktion, die in Geräten besteht, die zur Messung der Wärmeleitfähigkeit von Materialien verwendet werden.</skos:definition> <skos:definition xml:lang="zh">一种功能，存在于用于测量材料热导率的设备中。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000981 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000981">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000005"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000520"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">thermal property</rdfs:label> <rdfs:label xml:lang="zh">热性能</rdfs:label>
        <skos:definition xml:lang="en">A thermal property is a material property representing attributes of a material that describe its behavior under temperature changes, such as thermal conductivity and expansion.</skos:definition> <skos:definition xml:lang="zh">热性能是一种材料属性，表示材料在温度变化下的行为特征，例如热导率和热膨胀。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000982 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000982">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBI_0000070"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0009006"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000981"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="de">Thermische Eigenschaften Analyseverfahren</rdfs:label> <rdfs:label xml:lang="zh">热性能分析方法</rdfs:label>
        <rdfs:label xml:lang="en">thermal property analyzing process</rdfs:label> <rdfs:label xml:lang="zh">热性能分析过程</rdfs:label>
        <skos:definition xml:lang="en">An assay that measures the thermal behavior of materials, including heat capacity, thermal conductivity, thermal expansion, and phase transitions in response to temperature changes.</skos:definition> <skos:definition xml:lang="zh">一种分析，测量材料的热行为，包括热容、热导率、热膨胀以及响应温度变化的相变。</skos:definition>
        <skos:definition xml:lang="de">Eine Analyse, die das thermische Verhalten von Materialien misst, einschließlich Wärmekapazität, Wärmeleitfähigkeit, thermischer Ausdehnung und Phasenübergängen in Reaktion auf Temperaturänderungen.</skos:definition> <skos:definition xml:lang="zh">一种测量材料热行为的分析，包括热容量、热导率、热膨胀以及随温度变化的相变。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000983 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000983">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000602"/>
        <obo:IAO_0000119 xml:lang="en">“Thermocouple.” Merriam-Webster.com Dictionary, Merriam-Webster, https://www.merriam-webster.com/dictionary/thermocouple. Accessed 13 Jan. 2023.</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">“热电偶。” Merriam-Webster.com词典，Merriam-Webster，https://www.merriam-webster.com/dictionary/thermocouple。访问于2023年1月13日。</obo:IAO_0000119>
        <rdfs:label xml:lang="de">Thermoelement</rdfs:label> <rdfs:label xml:lang="zh">热电偶</rdfs:label>
        <rdfs:label xml:lang="en">thermocouple</rdfs:label> <rdfs:label xml:lang="zh">热电偶</rdfs:label>
        <skos:definition xml:lang="en">A device for measuring temperature in which a pair of wires of dissimilar metals (such as copper and iron) are joined and the free ends of the wires are connected to an instrument (such as a voltmeter) that measures the difference in potential created at the junction of the two metals.</skos:definition> <skos:definition xml:lang="zh">一种用于测量温度的装置，其中一对不同金属（如铜和铁）的导线连接在一起，导线的自由端连接到测量两种金属接头处产生的电位差的仪器（如电压表）。</skos:definition>
        <skos:definition xml:lang="de">Ein Gerät zur Temperaturmessung, bei dem ein Paar Drähte aus unterschiedlichen Metallen (z. B. Kupfer und Eisen) verbunden und die freien Enden der Drähte mit einem Instrument (z. B. einem Voltmeter) verbunden werden, das die an der Verbindungsstelle erzeugte der beiden Metalle Potentialdifferenz misst .</skos:definition> <skos:definition xml:lang="zh">一种温度测量装置，其中一对不同金属（如铜和铁）的导线连接在一起，导线的自由端连接到仪器（如电压表），该仪器测量两种金属在连接处产生的电势差。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000984 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000984">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000968"/>
        <rdfs:label xml:lang="de">Thermocycler</rdfs:label> <rdfs:label xml:lang="zh">热循环仪</rdfs:label>
        <rdfs:label xml:lang="en">thermocycler</rdfs:label> <rdfs:label xml:lang="zh">热循环仪</rdfs:label>
        <skos:definition xml:lang="en">A thermocycler is a temperature change device that rapidly changes the temperature of a sample in cycles, often used in polymerase chain reactions (PCR).</skos:definition> <skos:definition xml:lang="zh">热循环仪是一种温度变化设备，可循环快速改变样品温度，常用于聚合酶链反应（PCR）。</skos:definition>
        <skos:definition xml:lang="de">Ein Thermocycler ist ein Temperaturwechselgerät, das die Temperatur einer Probe in Zyklen schnell ändert, oft verwendet in der Polymerase-Kettenreaktion (PCR).</skos:definition> <skos:definition xml:lang="zh">热循环仪是一种温度循环设备，可快速循环改变样品的温度，常用于聚合酶链反应（PCR）。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000986 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000986">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000982"/>
        <rdfs:label xml:lang="de">Thermogravimetrische Analyse-Verfahren</rdfs:label> <rdfs:label xml:lang="zh">热重分析法</rdfs:label>
        <rdfs:label xml:lang="en">thermogravimetric analysis process</rdfs:label> <rdfs:label xml:lang="zh">热重分析过程</rdfs:label>
        <skos:definition xml:lang="en">A thermal property analyzing process that measures the change in mass of a material as a function of temperature or time in a controlled atmosphere, determining its thermal stability and composition.</skos:definition> <skos:definition xml:lang="zh">一种热性能分析过程，测量材料在受控气氛中质量随温度或时间的变化，确定其热稳定性和组成。</skos:definition>
        <skos:definition xml:lang="de">Ein Thermische Eigenschaften Analyseverfahren, das die Massenänderung eines Materials in Abhängigkeit von Temperatur oder Zeit in einer kontrollierten Atmosphäre misst und dessen thermische Stabilität und Zusammensetzung bestimmt.</skos:definition> <skos:definition xml:lang="zh">一种热性能分析方法，在受控气氛中测量材料质量随温度或时间的变化，并确定其热稳定性和组成。</skos:definition>
        <skos:example xml:lang="en">Thermogravimetric analysis of a metal alloy to determine its oxidation stability at high temperatures.</skos:example> <skos:example xml:lang="zh">对金属合金进行热重分析，以确定其高温氧化稳定性。</skos:example>
        <PMD_0050117 xml:lang="en">TGA</PMD_0050117>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000987 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000987">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000849"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000982"/>
        <rdfs:label xml:lang="de">Thermomechanische Analyse-Verfahren</rdfs:label> <rdfs:label xml:lang="zh">热机械分析法</rdfs:label>
        <rdfs:label xml:lang="en">thermomechanical analysis process</rdfs:label> <rdfs:label xml:lang="zh">热机械分析过程</rdfs:label>
        <skos:definition xml:lang="en">A thermomechanical property analyzing process that measures the dimensional changes of a material as a function of temperature, determining its coefficient of thermal expansion.</skos:definition> <skos:definition xml:lang="zh">一种热机械性能分析过程，测量材料尺寸随温度的变化，确定其热膨胀系数。</skos:definition>
        <skos:definition xml:lang="de">Ein Thermoanalytisches Verfahren, das die Maßänderungen eines Materials als Funktion der Temperatur misst und seinen thermischen Ausdehnungskoeffizienten bestimmt.</skos:definition> <skos:definition xml:lang="zh">一种热分析方法，测量材料尺寸随温度的变化，并确定其热膨胀系数。</skos:definition>
        <skos:example xml:lang="en">Thermomechanical analysis of a polymer to ensure it maintains dimensional stability under varying temperature conditions.</skos:example> <skos:example xml:lang="zh">对聚合物进行热机械分析，以确保其在变化的温度条件下保持尺寸稳定性。</skos:example>
        <PMD_0050117 xml:lang="en">TMA</PMD_0050117>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000988 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000988">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000550"/>
        <rdfs:label xml:lang="de">Thermomechanisches Behandeln</rdfs:label> <rdfs:label xml:lang="zh">热机械处理</rdfs:label>
        <rdfs:label xml:lang="en">thermomechanical treatment</rdfs:label> <rdfs:label xml:lang="zh">热机械处理</rdfs:label>
        <skos:definition xml:lang="en">A changing properties of material process that involves the simultaneous application of heat and mechanical stresses. Thermomechanical treatment is utilized to alter and improve the material's microstructure and mechanical properties.</skos:definition> <skos:definition xml:lang="zh">一种改变材料性能的过程，同时施加热量和机械应力。热机械处理用于改变和改善材料的微观结构和机械性能。</skos:definition>
        <skos:definition xml:lang="de">Ein Stoffeigenschaft Ändern Prozess, der die gleichzeitige Anwendung von Wärme und mechanischen Spannungen beinhaltet. Die thermomechanische Behandlung wird eingesetzt, um die Mikrostruktur und die mechanischen Eigenschaften des Materials zu verändern und zu verbessern.</skos:definition> <skos:definition xml:lang="zh">一种改变材料性质的过程，涉及同时施加热量和机械应力。热机械处理用于改变和改善材料的微观结构和力学性能。</skos:definition>
        <skos:example xml:lang="en">Hot Isostatic Pressing</skos:example> <skos:example xml:lang="zh">热等静压</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000989 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000989">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000556"/>
        <rdfs:label xml:lang="de">Dünnschichtchromatographie Verfahren</rdfs:label> <rdfs:label xml:lang="zh">薄层色谱法</rdfs:label>
        <rdfs:label xml:lang="en">thin-layer chromatography process</rdfs:label> <rdfs:label xml:lang="zh">薄层色谱过程</rdfs:label>
        <skos:definition xml:lang="en">A chromatography process that separates non-volatile mixtures by applying a sample on a thin layer of an adsorbent material and using a solvent to move the components up the layer based on their affinities.</skos:definition> <skos:definition xml:lang="zh">一种色谱过程，通过将样品涂布在吸附材料的薄层上，利用溶剂根据组分亲和力将其沿薄层移动，从而分离非挥发性混合物。</skos:definition>
        <skos:definition xml:lang="de">Ein Chromatographieverfahren, das nichtflüchtige Gemische trennt, indem eine Probe auf eine dünne Schicht eines Adsorptionsmaterials aufgetragen und ein Lösungsmittel verwendet wird, um die Komponenten basierend auf ihren Affinitäten entlang der Schicht zu bewegen.</skos:definition> <skos:definition xml:lang="zh">一种色谱方法，通过将样品点在薄层吸附材料上，并使用溶剂根据各组分亲和力沿薄层移动来分离非挥发性混合物。</skos:definition>
        <skos:example xml:lang="en">Using thin-layer chromatography to analyze the composition of a polymer mixture to identify different components.</skos:example> <skos:example xml:lang="zh">使用薄层色谱分析聚合物混合物的组成，以识别不同组分。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000990 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000990">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000557"/>
        <rdfs:label xml:lang="de">Dünnschichtchromatographiesystem</rdfs:label> <rdfs:label xml:lang="zh">薄层色谱系统</rdfs:label>
        <rdfs:label xml:lang="en">thin layer chromatography system</rdfs:label> <rdfs:label xml:lang="zh">薄层色谱系统</rdfs:label>
        <skos:definition xml:lang="en">A chromatography system used for separating compounds in a sample using a thin layer of adsorbent material on a plate.</skos:definition> <skos:definition xml:lang="zh">一种色谱系统，用于使用板上的吸附材料薄层分离样品中的化合物。</skos:definition>
        <skos:definition xml:lang="de">Ein Chromatographiesystem zur Trennung von Verbindungen in einer Probe unter Verwendung einer dünnen Schicht adsorbierenden Materials auf einer Platte.</skos:definition> <skos:definition xml:lang="zh">一种色谱系统，使用板上的薄层吸附材料分离样品中的化合物。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000991 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000991">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000508"/>
        <rdfs:label xml:lang="de">3D-Drucker</rdfs:label> <rdfs:label xml:lang="zh">3D打印机</rdfs:label>
        <rdfs:label xml:lang="en">3d printer</rdfs:label> <rdfs:label xml:lang="zh">3D打印机</rdfs:label>
        <skos:definition xml:lang="en">A 3D Printer is an additive manufacturing device that creates three-dimensional objects by building them layer by layer from a digital model.</skos:definition> <skos:definition xml:lang="zh">3D打印机是一种增材制造设备，通过从数字模型逐层构建来创建三维物体。</skos:definition>
        <skos:definition xml:lang="de">Ein 3D-Drucker ist ein Gerät für die additive Fertigung, das dreidimensionale Objekte durch schichtweises Aufbauen aus einem digitalen Modell erzeugt.</skos:definition> <skos:definition xml:lang="zh">3D打印机是一种用于增材制造的设备，通过从数字模型逐层构建来生成三维物体。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000992 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000992">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000501"/>
        <rdfs:label xml:lang="en">time series</rdfs:label> <rdfs:label xml:lang="zh">时间序列</rdfs:label>
        <skos:definition xml:lang="en">A time series is a 1-D information content entity defined by a sequence of data points collected or recorded at successive time intervals, used for analyzing temporal properties or trends.</skos:definition> <skos:definition xml:lang="zh">时间序列是一种1-D信息内容实体，由按照连续时间间隔收集或记录的一系列数据点定义，用于分析时间属性或趋势。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000994 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000994">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000602"/>
        <rdfs:label xml:lang="de">Torsionsprüfmaschine</rdfs:label> <rdfs:label xml:lang="zh">扭转试验机</rdfs:label>
        <rdfs:label xml:lang="en">torsion testing machine</rdfs:label> <rdfs:label xml:lang="zh">扭转试验机</rdfs:label>
        <skos:definition xml:lang="en">A device used to test the resistance of materials to twisting forces by applying a torque and measuring the resulting deformation.</skos:definition> <skos:definition xml:lang="zh">一种通过施加扭矩并测量由此产生的变形来测试材料抵抗扭转力的装置。</skos:definition>
        <skos:definition xml:lang="de">Ein Gerät zur Prüfung des Widerstands von Materialien gegenüber Drehkräften durch Anwendung eines Drehmoments und Messung der resultierenden Verformung.</skos:definition> <skos:definition xml:lang="zh">一种通过施加扭矩并测量由此产生的变形来测试材料抵抗扭转力的设备。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000995 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000995">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000849"/>
        <rdfs:label xml:lang="de">Torsionsprüfverfahren</rdfs:label> <rdfs:label xml:lang="zh">扭转试验方法</rdfs:label>
        <rdfs:label xml:lang="en">torsion testing process</rdfs:label> <rdfs:label xml:lang="zh">扭转试验过程</rdfs:label>
        <skos:definition xml:lang="en">A mechanical property analyzing process that assesses a material's behavior when subjected to twisting forces, determining its torsional strength and shear modulus.</skos:definition> <skos:definition xml:lang="zh">一种力学性能分析过程，评估材料在受到扭转力时的行为，确定其扭转强度和剪切模量。</skos:definition>
        <skos:definition xml:lang="de">Ein Mechanische Eigenschaften Analyseverfahren, das das Verhalten eines Materials bei Torsionskräften bewertet und seine Torsionsfestigkeit und Schermodul bestimmt.</skos:definition> <skos:definition xml:lang="zh">一种机械性能分析方法，评估材料在扭转载荷下的行为并确定其扭转强度和剪切模量。</skos:definition>
        <skos:example xml:lang="en">Evaluating the torsional strength of a metal rod used in a mechanical shaft to prevent failure under rotational loads.</skos:example> <skos:example xml:lang="zh">评估用于机械轴的金属棒的扭转强度，以防止在旋转载荷下失效。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000996 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000996">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020164"/>
        <rdfs:label xml:lang="en">triple point</rdfs:label> <rdfs:label xml:lang="zh">三相点</rdfs:label>
        <skos:definition xml:lang="en">a state of matter boundary (point) realized by transition from the solid state to the liquid state or the the gaseous state (or vice versa).</skos:definition> <skos:definition xml:lang="zh">一种物质状态边界（点），通过从固态到液态或气态（或反之）的转变实现。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000997 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000997">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000561"/>
        <rdfs:label xml:lang="de">Ultraschallreiniger</rdfs:label> <rdfs:label xml:lang="zh">超声波清洗机</rdfs:label>
        <rdfs:label xml:lang="en">ultrasonic cleaner</rdfs:label> <rdfs:label xml:lang="zh">超声波清洗机</rdfs:label>
        <skos:definition xml:lang="en">A device that uses ultrasound and a cleaning solvent to clean delicate or complex items.</skos:definition> <skos:definition xml:lang="zh">一种使用超声波和清洗溶剂来清洁精密或复杂物品的装置。</skos:definition>
        <skos:definition xml:lang="en">An Ultrasonic Cleaner is a Cleaning Device that uses high-frequency sound waves and a cleaning solvent to remove contaminants from delicate or complex items.</skos:definition> <skos:definition xml:lang="zh">超声波清洗机是一种清洁设备，使用高频声波和清洗溶剂去除精密或复杂物品上的污染物。</skos:definition>
        <skos:definition xml:lang="de">Ein Gerät, das Ultraschall und ein Reinigungsmittel verwendet, um empfindliche oder komplexe Gegenstände zu reinigen.</skos:definition> <skos:definition xml:lang="zh">一种使用超声波和清洁剂来清洁精密或复杂物品的设备。</skos:definition>
        <skos:definition xml:lang="de">Ein Ultraschallreiniger ist ein Reinigungsgerät, das Hochfrequenzschallwellen und ein Reinigungsmittel verwendet, um Verunreinigungen von empfindlichen oder komplexen Gegenständen zu entfernen.</skos:definition> <skos:definition xml:lang="zh">超声波清洗机是一种清洁设备，使用高频声波和清洁剂去除精密或复杂物品上的污染物。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000998 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000998">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000602"/>
        <rdfs:label xml:lang="de">Ultraviolett-Visible-Spektrophotometer</rdfs:label> <rdfs:label xml:lang="zh">紫外-可见分光光度计</rdfs:label>
        <rdfs:label xml:lang="en">ultraviolet visible spectrophotometer</rdfs:label> <rdfs:label xml:lang="zh">紫外可见分光光度计</rdfs:label>
        <skos:definition xml:lang="en">A device used to measure the absorbance of a sample in the ultraviolet and visible regions of the electromagnetic spectrum.</skos:definition> <skos:definition xml:lang="zh">一种用于测量样品在电磁波谱紫外和可见区域吸光度的装置。</skos:definition>
        <skos:definition xml:lang="de">Ein Gerät zur Messung der Absorption einer Probe im ultravioletten und sichtbaren Bereich des elektromagnetischen Spektrums.</skos:definition> <skos:definition xml:lang="zh">一种用于测量样品在电磁波谱紫外和可见光区域吸收的仪器。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0001003 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0001003">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000821"/>
        <rdfs:label xml:lang="de">unsupervised machine learning</rdfs:label> <rdfs:label xml:lang="zh">无监督机器学习</rdfs:label>
        <rdfs:label xml:lang="en">unsupervised machine learning</rdfs:label> <rdfs:label xml:lang="zh">无监督机器学习</rdfs:label>
        <skos:definition xml:lang="en">A machine learning process that identifies patterns and relationships in data without using labeled outcomes.</skos:definition> <skos:definition xml:lang="zh">一种机器学习过程，在不使用标记结果的情况下识别数据中的模式和关系。</skos:definition>
        <skos:definition xml:lang="de">Ein Maschinelles Lernen Prozess, der Muster und Zusammenhänge in Daten identifiziert, ohne beschriftete Ergebnisse zu verwenden.</skos:definition> <skos:definition xml:lang="zh">一种机器学习过程，无需使用标注结果即可识别数据中的模式和关联。</skos:definition>
        <skos:example xml:lang="en">Using clustering algorithms to group similar materials based on their properties (e.g., hardness, elasticity, thermal conductivity) without prior knowledge of the categories. For instance, discovering new categories of alloy compositions that exhibit similar thermal properties.</skos:example> <skos:example xml:lang="zh">使用聚类算法根据材料属性（例如硬度、弹性、热导率）将相似材料分组，无需事先了解类别。例如，发现具有相似热性能的合金成分的新类别。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0001004 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0001004">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000602"/>
        <rdfs:label xml:lang="de">Viskosimeter</rdfs:label> <rdfs:label xml:lang="zh">粘度计</rdfs:label>
        <rdfs:label xml:lang="en">viscometer</rdfs:label> <rdfs:label xml:lang="zh">粘度计</rdfs:label>
        <skos:definition xml:lang="en">A device used to measure the viscosity of liquids, providing information about their flow properties.</skos:definition> <skos:definition xml:lang="zh">一种用于测量液体粘度的设备，提供关于其流动特性的信息。</skos:definition>
        <skos:definition xml:lang="de">Ein Gerät zur Messung der Viskosität von Flüssigkeiten, das Informationen über ihre Fließeigenschaften liefert.</skos:definition> <skos:definition xml:lang="zh">一种测量液体粘度的仪器，提供关于其流动特性的信息。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0001005 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0001005">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000916"/>
        <rdfs:label xml:lang="de">Viskosimetrie</rdfs:label> <rdfs:label xml:lang="zh">粘度测定法</rdfs:label>
        <rdfs:label xml:lang="en">viscometry</rdfs:label> <rdfs:label xml:lang="zh">粘度测量法</rdfs:label>
        <skos:definition xml:lang="en">A rheological property analyzing process that measures the viscosity of a fluid, which is its resistance to gradual deformation by shear or tensile stress, using viscometers or rheometers.</skos:definition> <skos:definition xml:lang="zh">一种流变特性分析过程，使用粘度计或流变仪测量流体的粘度，即流体抵抗剪切或拉伸应力逐渐变形的能力。</skos:definition>
        <skos:definition xml:lang="de">Ein Rheologisches Eigenschaften Analyseverfahren, das die Viskosität einer Flüssigkeit misst, also deren Widerstand gegen allmähliche Verformung durch Scher- oder Zugspannung, unter Verwendung von Viskosimetern oder Rheometern.</skos:definition> <skos:definition xml:lang="zh">一种流变特性分析方法，使用粘度计或流变仪测量液体的粘度，即液体对剪切或拉伸应力逐渐变形的阻力。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0001006 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0001006">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000602"/>
        <rdfs:label xml:lang="de">Wasseraufbereitungssystem</rdfs:label> <rdfs:label xml:lang="zh">水处理系统</rdfs:label>
        <rdfs:label xml:lang="en">water purification system</rdfs:label> <rdfs:label xml:lang="zh">水净化系统</rdfs:label>
        <skos:definition xml:lang="en">A water purification system is a device used to remove contaminants from water to produce clean and safe drinking water.</skos:definition> <skos:definition xml:lang="zh">水净化系统是一种用于去除水中污染物以生产清洁安全饮用水的设备。</skos:definition>
        <skos:definition xml:lang="de">Ein Wasseraufbereitungssystem ist ein Gerät, das verwendet wird, um Verunreinigungen aus Wasser zu entfernen, um sauberes und sicheres Trinkwasser herzustellen.</skos:definition> <skos:definition xml:lang="zh">水处理系统是一种用于去除水中杂质以生产清洁安全饮用水的设备。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0001007 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0001007">
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000602"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000085"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000592"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="de">Wasserstrahlschneider</rdfs:label> <rdfs:label xml:lang="zh">水刀切割机</rdfs:label>
        <rdfs:label xml:lang="en">waterjet cutter</rdfs:label> <rdfs:label xml:lang="zh">水刀切割机</rdfs:label>
        <skos:definition xml:lang="en">A device that utilizes a high-pressure stream of water or a water stream with abrasive particles to cut materials such as metal, stone, plastic, etc.</skos:definition> <skos:definition xml:lang="zh">一种利用高压水流或含有磨料颗粒的水流切割金属、石材、塑料等材料的设备。</skos:definition>
        <skos:definition xml:lang="de">Ein Gerät, das einen Hochdruckwasserstrahl oder einen Wasserstrahl mit abrasiven Partikeln verwendet, um Materialien wie Metall, Stein, Kunststoff usw. zu schneiden.</skos:definition> <skos:definition xml:lang="zh">一种使用高压水射流或带有磨料颗粒的水射流切割金属、石材、塑料等材料的设备。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0001008 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0001008">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000802"/>
        <rdfs:label xml:lang="en">absorption of wave radiation</rdfs:label> <rdfs:label xml:lang="zh">波辐射吸收</rdfs:label>
        <skos:definition xml:lang="en">process of taking up elctromagnetic radiation by a material entity</skos:definition> <skos:definition xml:lang="zh">材料实体吸收电磁辐射的过程</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0001009 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0001009">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000602"/>
        <rdfs:label xml:lang="de">Verschleißprüfmaschine</rdfs:label> <rdfs:label xml:lang="zh">磨损试验机</rdfs:label>
        <rdfs:label xml:lang="en">wear testing machine</rdfs:label> <rdfs:label xml:lang="zh">磨损试验机</rdfs:label>
        <skos:definition xml:lang="en">A device used to test the wear resistance of materials by subjecting them to abrasive conditions.</skos:definition> <skos:definition xml:lang="zh">一种通过将材料置于磨损条件下来测试其耐磨性的设备。</skos:definition>
        <skos:definition xml:lang="de">Ein Gerät zur Prüfung der Verschleißfestigkeit von Materialien durch Aussetzen dieser Bedingungen unter Abrasivbedingungen.</skos:definition> <skos:definition xml:lang="zh">一种通过将材料暴露在磨损条件下测试其耐磨性的设备。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0001010 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0001010">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000849"/>
        <rdfs:label xml:lang="de">Verschleißprüfverfahren</rdfs:label> <rdfs:label xml:lang="zh">磨损试验方法</rdfs:label>
        <rdfs:label xml:lang="en">wear testing process</rdfs:label> <rdfs:label xml:lang="zh">磨损测试过程</rdfs:label>
        <skos:definition xml:lang="en">A mechanical property analyzing process that evaluates the resistance of a material to wear and abrasion, simulating real-life conditions of friction.</skos:definition> <skos:definition xml:lang="zh">一种机械性能分析过程，评估材料对磨损和磨蚀的抵抗能力，模拟真实摩擦条件。</skos:definition>
        <skos:definition xml:lang="de">Ein Mechanische Eigenschaften Analyseverfahrenn, das den Widerstand eines Materials gegen Verschleiß und Abrieb bewertet und reale Reibungsbedingungen simuliert.</skos:definition> <skos:definition xml:lang="zh">一种评估材料耐磨损和抗磨损性能的机械性能分析方法，模拟真实的摩擦条件。</skos:definition>
        <skos:example xml:lang="en">Wear testing of automotive brake pads to ensure longevity and performance under repetitive braking conditions.</skos:example> <skos:example xml:lang="zh">汽车刹车片的磨损测试，以确保在重复制动条件下的耐久性和性能。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0001011 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0001011">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000602"/>
        <rdfs:label xml:lang="de">Schweißgerät</rdfs:label> <rdfs:label xml:lang="zh">焊接设备</rdfs:label>
        <rdfs:label xml:lang="en">welding device</rdfs:label> <rdfs:label xml:lang="zh">焊接设备</rdfs:label>
        <skos:definition xml:lang="en">A device used for joining materials by melting them together, typically with the addition of a filler material.</skos:definition> <skos:definition xml:lang="zh">一种通过熔化材料来连接材料的设备，通常添加填充材料。</skos:definition>
        <skos:definition xml:lang="de">Ein Gerät zum Verbinden von Materialien durch Schmelzen, üblicherweise unter Zugabe eines Füllmaterials.</skos:definition> <skos:definition xml:lang="zh">一种通过熔化连接材料的设备，通常添加填充材料。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0001013 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0001013">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000812"/>
        <rdfs:label xml:lang="de">Schweißfunktion</rdfs:label> <rdfs:label xml:lang="zh">焊接功能</rdfs:label>
        <rdfs:label xml:lang="en">welding function</rdfs:label> <rdfs:label xml:lang="zh">焊接功能</rdfs:label>
        <skos:definition xml:lang="en">A welding function is a joining function that is realized in fusing materials by welding.</skos:definition> <skos:definition xml:lang="zh">焊接功能是一种通过焊接熔化材料来实现的连接功能。</skos:definition>
        <skos:definition xml:lang="de">Eine Unterfunktion des Verbindens, die durchgeführt wird, um Materialien durch Schweißtechniken zu verbinden.</skos:definition> <skos:definition xml:lang="zh">连接的一个子功能，用于通过焊接技术连接材料。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0001014 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0001014">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000957"/>
        <rdfs:label xml:lang="de">Röntgen Analyseverfahren</rdfs:label> <rdfs:label xml:lang="zh">X射线分析方法</rdfs:label>
        <rdfs:label xml:lang="en">x-ray analyzing process</rdfs:label> <rdfs:label xml:lang="zh">X射线分析过程</rdfs:label>
        <skos:definition xml:lang="en">A structural property analyzing process that uses X-rays to investigate the internal structure, composition, and properties of materials by measuring the interaction of X-rays with the sample.</skos:definition> <skos:definition xml:lang="zh">一种结构性能分析过程，利用X射线通过测量X射线与样品的相互作用来研究材料的内部结构、组成和性能。</skos:definition>
        <skos:definition xml:lang="de">Ein Struktur Eigenschaften Analyseverfahren, das Röntgenstrahlen verwendet, um die innere Struktur, Zusammensetzung und Eigenschaften von Materialien zu untersuchen, indem die Wechselwirkung der Röntgenstrahlen mit der Probe gemessen wird.</skos:definition> <skos:definition xml:lang="zh">一种结构性能分析方法，使用X射线通过测量X射线与样品的相互作用来研究材料的内部结构、组成和性能。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0001015 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0001015">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0001014"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0009006"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020132"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0009006"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0050155"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="de">Röntgen-Computertomographie</rdfs:label> <rdfs:label xml:lang="zh">Röntgen-计算机断层扫描</rdfs:label>
        <rdfs:label xml:lang="en">x-ray computed tomography</rdfs:label> <rdfs:label xml:lang="zh">X射线计算机断层扫描</rdfs:label>
        <skos:definition xml:lang="en">A X-ray analyzing process, that uses X-rays to create detailed cross-sectional images of an object.</skos:definition> <skos:definition xml:lang="zh">一种X射线分析过程，利用X射线创建物体的详细横截面图像。</skos:definition>
        <skos:definition xml:lang="de">Ein Röntgenanalyseverfahren, das Röntgenstrahlen verwendet, um detaillierte Querschnittsbilder eines Objekts zu erstellen.</skos:definition> <skos:definition xml:lang="zh">一种Röntgen分析方法，使用Röntgen射线来创建物体的详细横截面图像。</skos:definition>
        <skos:example xml:lang="en">For example, X-ray Computed Tomography can be used to analyze the porosity of cement. This process allows researchers to visualize and quantify the distribution, size, and connectivity of pores within the cement.</skos:example> <skos:example xml:lang="zh">例如，X射线计算机断层扫描可用于分析水泥的孔隙率。该过程使研究人员能够可视化和量化水泥内孔隙的分布、大小和连通性。</skos:example>
        <PMD_0050117 xml:lang="en">CT</PMD_0050117>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0001016 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0001016">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0001014"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0009006"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000591"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0009006"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000853"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="de">Beugungsprozess</rdfs:label> <rdfs:label xml:lang="zh">衍射过程</rdfs:label>
        <rdfs:label xml:lang="en">x-ray diffraction process</rdfs:label> <rdfs:label xml:lang="zh">X射线衍射过程</rdfs:label>
        <skos:definition xml:lang="en">An X-ray analyzing process, that involves the interaction of X-rays with the crystalline structure of a material.</skos:definition> <skos:definition xml:lang="zh">一种X射线分析过程，涉及X射线与材料晶体结构的相互作用。</skos:definition>
        <skos:definition xml:lang="de">Ein Röntgenanalyseverfahren, das die Wechselwirkung von Röntgenstrahlen mit der kristallinen Struktur eines Materials umfasst.</skos:definition> <skos:definition xml:lang="zh">一种Röntgen分析方法，涉及Röntgen射线与材料晶体结构的相互作用。</skos:definition>
        <skos:example xml:lang="en">XRD is used to e.g. determine the crystal structure of newly synthesized compounds to determine the crystal lattice arrangement.</skos:example> <skos:example xml:lang="zh">XRD 用于例如确定新合成化合物的晶体结构，以确定晶格排列。</skos:example>
        <PMD_0050117 xml:lang="en">XRD</PMD_0050117>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0001017 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0001017">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0001014"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0009006"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000551"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="de">Röntgen-Mapping</rdfs:label> <rdfs:label xml:lang="zh">Röntgen映射</rdfs:label>
        <rdfs:label xml:lang="en">x-ray mapping</rdfs:label> <rdfs:label xml:lang="zh">X射线映射</rdfs:label>
        <skos:definition xml:lang="en">An X-ray analyzing process, that generates a spatial distribution map of the elements within a specimen by scanning the sample with an electron or X-ray beam and detecting the emitted X-rays, providing detailed compositional information across the sample's surface.</skos:definition> <skos:definition xml:lang="zh">一种X射线分析过程，通过用电子束或X射线束扫描样品并检测发射的X射线，生成样品内元素的空间分布图，提供样品表面的详细成分信息。</skos:definition>
        <skos:definition xml:lang="de">Ein Röntgenanalyseverfahren, das eine räumliche Verteilungskarte der Elemente innerhalb einer Probe erstellt, indem die Probe mit einem Elektronen- oder Röntgenstrahl abgetastet und die emittierten Röntgenstrahlen detektiert werden, wodurch detaillierte Zusammensetzungsinformationen über die Oberfläche der Probe geliefert werden.</skos:definition> <skos:definition xml:lang="zh">一种Röntgen分析方法，通过使用电子束或Röntgen束扫描样品并检测发射的Röntgen射线，创建样品内元素的空间分布图，从而提供样品表面的详细成分信息。</skos:definition>
        <skos:example xml:lang="en">An example of an X-ray Mapping process is X-ray Absorption Spectroscopy, X-ray Fluorescence, or X-ray Photoelectron Spectroscopy.</skos:example> <skos:example xml:lang="zh">X射线映射过程的一个例子是 X-ray Absorption Spectroscopy、X-ray Fluorescence 或 X-ray Photoelectron Spectroscopy。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0001018 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0001018">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0001014"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0009006"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000551"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="de">Röntgen-Mikroanalyse</rdfs:label> <rdfs:label xml:lang="zh">Röntgen微分析</rdfs:label>
        <rdfs:label xml:lang="en">x-ray microanalysis</rdfs:label> <rdfs:label xml:lang="zh">X射线微量分析</rdfs:label>
        <skos:definition xml:lang="en">An X-ray analyzing process that determines the elemental composition and chemical properties of a specimen by detecting and analyzing the characteristic X-rays emitted from the sample when it is irradiated with a focused electron beam.</skos:definition> <skos:definition xml:lang="zh">一种X射线分析过程，通过检测和分析当样品被聚焦电子束照射时发射的特征X射线，确定样品的元素组成和化学性质。</skos:definition>
        <skos:definition xml:lang="de">Ein Röntgenanalyseverfahren, das die elementare Zusammensetzung und chemischen Eigenschaften einer Probe bestimmt, indem die charakteristischen Röntgenstrahlen detektiert und analysiert werden, die von der Probe emittiert werden, wenn sie mit einem fokussierten Elektronenstrahl bestrahlt wird.</skos:definition> <skos:definition xml:lang="zh">一种Röntgen分析方法，通过检测和分析样品在聚焦电子束照射下发射的特征Röntgen射线，来确定样品的元素组成和化学性质。</skos:definition>
        <skos:example xml:lang="en">An example for X-ray Microanalysis process is Energy Dispersive X-ray Spectroscopy.</skos:example> <skos:example xml:lang="zh">X射线微量分析过程的一个例子是 Energy Dispersive X-ray Spectroscopy。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0001019 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0001019">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000945"/>
        <rdfs:label xml:lang="de">Röntgenspektroskopie</rdfs:label> <rdfs:label xml:lang="zh">Röntgen光谱学</rdfs:label>
        <rdfs:label xml:lang="en">x-ray spectroscopy</rdfs:label> <rdfs:label xml:lang="zh">X射线光谱</rdfs:label>
        <skos:definition xml:lang="en">A spectroscopy process, that analyzes the interaction of X-rays with matter to determine the material's composition and structure.</skos:definition> <skos:definition xml:lang="zh">一种光谱过程，分析X射线与物质的相互作用，以确定材料的组成和结构。</skos:definition>
        <skos:definition xml:lang="de">Ein Spektroskopie Verfahren, das die Wechselwirkung von Röntgenstrahlen mit Materie analysiert, um die Zusammensetzung und Struktur des Materials zu bestimmen.</skos:definition> <skos:definition xml:lang="zh">一种光谱学方法，分析Röntgen射线与物质的相互作用，以确定材料的组成和结构。</skos:definition>
        <skos:example xml:lang="en">Examples are e.g. X-ray absorption spectroscopy, X-ray emission spectroscopy, and X-ray reflection spectroscopy.</skos:example> <skos:example xml:lang="zh">例子包括例如 X-ray absorption spectroscopy、X-ray emission spectroscopy 和 X-ray reflection spectroscopy。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0001020 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0001020">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000602"/>
        <rdfs:label xml:lang="de">Röntgenbeugungsgerät</rdfs:label> <rdfs:label xml:lang="zh">X射线衍射仪</rdfs:label>
        <rdfs:label xml:lang="en">x-ray diffractometer</rdfs:label> <rdfs:label xml:lang="zh">X射线衍射仪</rdfs:label>
        <skos:definition xml:lang="en">An X-Ray diffractometer is a measuring device that determines the crystal structure of materials by analyzing the diffraction patterns of X-rays passed through a sample.</skos:definition> <skos:definition xml:lang="zh">X射线衍射仪是一种测量设备，通过分析穿过样品的X射线的衍射图案来确定材料的晶体结构。</skos:definition>
        <skos:definition xml:lang="de">Ein Röntgenbeugungsgerät ist ein Messgerät, das die Kristallstruktur von Materialien durch Analyse der Beugungsmuster von durch eine Probe geleiteten Röntgenstrahlen bestimmt.</skos:definition> <skos:definition xml:lang="zh">X射线衍射仪是一种测量仪器，通过分析穿过样品的X射线的衍射图案来确定材料的晶体结构。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0001021 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0001021">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000602"/>
        <rdfs:label xml:lang="de">Röntgenanalysator</rdfs:label> <rdfs:label xml:lang="zh">X射线分析仪</rdfs:label>
        <rdfs:label xml:lang="en">x-ray analyzer</rdfs:label> <rdfs:label xml:lang="zh">X射线分析仪</rdfs:label>
        <skos:definition xml:lang="en">A device used to analyze the composition and properties of materials through X-ray techniques such as diffraction or fluorescence.</skos:definition> <skos:definition xml:lang="zh">一种通过X射线技术（如衍射或荧光）分析材料组成和性质的设备。</skos:definition>
        <skos:definition xml:lang="de">Ein Gerät zur Analyse der Zusammensetzung und Eigenschaften von Materialien durch Röntgenverfahren wie Beugung oder Fluoreszenz.</skos:definition> <skos:definition xml:lang="zh">一种通过X射线方法（如衍射或荧光）分析材料成分和性质的仪器。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0001022 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0001022">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000602"/>
        <rdfs:label xml:lang="de">Röntgen-Computertomographiesystem</rdfs:label> <rdfs:label xml:lang="zh">X射线计算机断层扫描系统</rdfs:label>
        <rdfs:label xml:lang="en">x-ray computed tomography system</rdfs:label> <rdfs:label xml:lang="zh">X射线计算机断层扫描系统</rdfs:label>
        <skos:definition xml:lang="en">A device that uses X-ray computed tomography techniques to produce cross-sectional images of a material.</skos:definition> <skos:definition xml:lang="zh">一种使用X射线计算机断层扫描技术生成材料横截面图像的设备。</skos:definition>
        <skos:definition xml:lang="de">Ein Gerät, das Röntgen-Computertomographietechniken verwendet, um Querschnittsbilder eines Materials zu erstellen.</skos:definition> <skos:definition xml:lang="zh">一种使用X射线计算机断层扫描技术创建材料横截面图像的设备。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0001023 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0001023">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000602"/>
        <rdfs:label xml:lang="de">Röntgenkartierungsgerät</rdfs:label> <rdfs:label xml:lang="zh">X射线映射仪</rdfs:label>
        <rdfs:label xml:lang="en">x-ray mapping device</rdfs:label> <rdfs:label xml:lang="zh">X射线映射设备</rdfs:label>
        <skos:definition xml:lang="en">A device used for mapping the spatial distribution of elements or compounds within a material using X-ray fluorescence or diffraction techniques.</skos:definition> <skos:definition xml:lang="zh">一种使用X射线荧光或衍射技术绘制材料内部元素或化合物空间分布的设备。</skos:definition>
        <skos:definition xml:lang="de">Ein Gerät, das zur Kartierung der räumlichen Verteilung von Elementen oder Verbindungen innerhalb eines Materials mithilfe von Röntgenfluoreszenz- oder -beugungstechniken verwendet wird.</skos:definition> <skos:definition xml:lang="zh">一种使用X射线荧光或衍射技术绘制材料内部元素或化合物空间分布的设备。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0001024 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0001024">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000602"/>
        <rdfs:label xml:lang="de">Röntgenmikroanalyssystem</rdfs:label> <rdfs:label xml:lang="zh">X射线显微分析系统</rdfs:label>
        <rdfs:label xml:lang="en">x-ray microanalysis system</rdfs:label> <rdfs:label xml:lang="zh">X射线微分析系统</rdfs:label>
        <skos:definition xml:lang="en">A device used for microanalysis of materials using X-ray techniques to determine elemental composition at a microscopic scale.</skos:definition> <skos:definition xml:lang="zh">一种使用X射线技术在微观尺度上分析材料以确定元素组成的设备。</skos:definition>
        <skos:definition xml:lang="de">Ein Gerät zur Mikroanalyse von Materialien unter Verwendung von Röntgentechniken zur Bestimmung der Elementzusammensetzung auf mikroskopischer Ebene.</skos:definition> <skos:definition xml:lang="zh">一种使用X射线技术对材料进行显微分析，以确定微观尺度上元素组成的设备。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0001035 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0001035">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0025018"/>
        <rdfs:label xml:lang="en">angle</rdfs:label> <rdfs:label xml:lang="zh">角度</rdfs:label>
        <skos:definition xml:lang="en">A property that represents the measure of rotation or inclination between two intersecting lines or planes, independent of the size of the object.</skos:definition> <skos:definition xml:lang="zh">表示两条相交线或平面之间旋转或倾斜程度的属性，与物体大小无关。</skos:definition>
        <PMD_0001032 rdf:resource="https://github.com/materialdigital/core-ontology/issues/278"/>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0001036 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0001036">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000030"/>
        <rdfs:label xml:lang="en">uncertainty</rdfs:label> <rdfs:label xml:lang="zh">不确定度</rdfs:label>
        <skos:definition xml:lang="en">A quantitative indication of the doubt about a measurement result, expressing the range within which the true value is expected to lie.</skos:definition> <skos:definition xml:lang="zh">对测量结果的怀疑程度的定量指示，表示真值预期所在的区间。</skos:definition>
        <PMD_0001032 rdf:resource="https://github.com/materialdigital/core-ontology/issues/278"/>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0001039 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0001039">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/COB_0000035"/>
        <rdfs:label xml:lang="en">calibration process</rdfs:label> <rdfs:label xml:lang="zh">校准过程</rdfs:label>
        <skos:definition xml:lang="en">A process of comparing measurement values delivered by an instrument or system with known reference standards to ensure accuracy and traceability.</skos:definition> <skos:definition xml:lang="zh">将仪器或系统提供的测量值与已知参考标准进行比较，以确保准确性和可追溯性的过程。</skos:definition>
        <PMD_0001032 rdf:resource="https://github.com/materialdigital/core-ontology/issues/278"/>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0001040 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0001040">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/COB_0000035"/>
        <rdfs:label xml:lang="en">expriment designing process</rdfs:label> <rdfs:label xml:lang="zh">实验设计过程</rdfs:label>
        <skos:definition xml:lang="en">A planned process of planning and structuring experimental methods, conditions, and variables to reliably test hypotheses or obtain data.</skos:definition> <skos:definition xml:lang="zh">一种计划过程，用于规划和构建实验方法、条件和变量，以可靠地检验假设或获取数据。</skos:definition>
        <PMD_0001032 rdf:resource="https://github.com/materialdigital/core-ontology/issues/278"/>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0001042 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0001042">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/COB_0000082"/>
        <obo:IAO_0000119>https://www.britannica.com/science/sample-preparation</obo:IAO_0000119>
        <rdfs:label xml:lang="en">test piece preparation process</rdfs:label> <rdfs:label xml:lang="zh">试样制备过程</rdfs:label>
        <skos:definition xml:lang="en">A planned processes in which a representative piece of material is extracted from a larger amount and readied for analysis. </skos:definition> <skos:definition xml:lang="zh">一种计划过程，从大量材料中提取代表性试样并准备进行分析。</skos:definition>
        <PMD_0001032 rdf:resource="https://github.com/materialdigital/core-ontology/issues/278"/>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0001044 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0001044">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBI_0001933"/>
        <rdfs:label xml:lang="en">date value specification</rdfs:label> <rdfs:label xml:lang="zh">日期值规范</rdfs:label>
        <skos:definition xml:lang="en">A datum that represents a date or time interval associated with another specification.</skos:definition> <skos:definition xml:lang="zh">表示与另一个规范相关的日期或时间间隔的数据项。</skos:definition>
        <PMD_0001032 rdf:resource="https://github.com/materialdigital/core-ontology/issues/278"/>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0001046 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0001046">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020132"/>
        <rdfs:label xml:lang="en">depth</rdfs:label> <rdfs:label xml:lang="zh">深度</rdfs:label>
        <skos:definition xml:lang="en">The distance from a reference surface or point to a specific point or feature along a perpendicular or defined direction.</skos:definition> <skos:definition xml:lang="zh">从参考表面或点沿垂直或指定方向到特定点或特征的距离。</skos:definition>
        <PMD_0001032 rdf:resource="https://github.com/materialdigital/core-ontology/issues/278"/>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0001047 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0001047">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020132"/>
        <rdfs:label xml:lang="en">diagonal</rdfs:label> <rdfs:label xml:lang="zh">对角线</rdfs:label>
        <skos:definition xml:lang="en">A straight line connecting two non-adjacent corners or vertices of a polygon.</skos:definition> <skos:definition xml:lang="zh">连接多边形两个不相邻角或顶点的直线。</skos:definition>
        <PMD_0001032 rdf:resource="https://github.com/materialdigital/core-ontology/issues/278"/>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0001998 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0001998">
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000602"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000085"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000592"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">cutting device</rdfs:label> <rdfs:label xml:lang="zh">切割装置</rdfs:label>
        <skos:definition xml:lang="en">A device designed to cut, slice, divide, or sever objects.</skos:definition> <skos:definition xml:lang="zh">用于切割、切片、分割或切断物体的装置。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0001999 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0001999">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000602"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000091"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000769"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000602"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000091"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000769"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">hand held device</rdfs:label> <rdfs:label xml:lang="zh">手持设备</rdfs:label>
        <skos:definition xml:lang="en">A device that has the disposition to be grasped and operated by a human hand and is designed for manual use.</skos:definition> <skos:definition xml:lang="zh">具有被人类手部抓握和操作特性、专为手动使用而设计的装置。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0010000 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0010000">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000005"/>
        <rdfs:label xml:lang="en">corrosion resistant</rdfs:label> <rdfs:label xml:lang="zh">耐腐蚀</rdfs:label>
        <skos:definition xml:lang="en">a disposition to withstand corrosive attack to a certain extend</skos:definition> <skos:definition xml:lang="zh">在一定程度内抵抗腐蚀性侵蚀的特性</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0010001 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0010001">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000639"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020030"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">carbon steel</rdfs:label> <rdfs:label xml:lang="zh">碳钢</rdfs:label>
        <skos:definition xml:lang="en">ferrous metal that has a limited amout of carbon</skos:definition> <skos:definition xml:lang="zh">含有限量碳的黑色金属</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0010002 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0010002">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000639"/>
        <rdfs:label xml:lang="en">cast iron</rdfs:label> <rdfs:label xml:lang="zh">铸铁</rdfs:label>
        <skos:definition xml:lang="en">ferrous metal that has an amout of min 2.07 wt % carbon</skos:definition> <skos:definition xml:lang="zh">碳含量最低为2.07 wt %的黑色金属</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0010003 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0010003">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020096"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000091"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0010000"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">stainless steel</rdfs:label> <rdfs:label xml:lang="zh">不锈钢</rdfs:label>
        <skos:definition xml:lang="en">steel that contains chromium, making it resistant to corrosion (rust).</skos:definition> <skos:definition xml:lang="zh">含有铬、使其耐腐蚀（生锈）的钢。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0010004 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0010004">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020096"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000091"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0010013"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">tool steel</rdfs:label> <rdfs:label xml:lang="zh">工具钢</rdfs:label>
        <skos:definition xml:lang="en">steel with tailored mechanical properties</skos:definition> <skos:definition xml:lang="zh">具有定制机械性能的钢</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0010005 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0010005">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020096"/>
        <rdfs:label xml:lang="en">alloy steel</rdfs:label> <rdfs:label xml:lang="zh">合金钢</rdfs:label>
        <skos:definition xml:lang="en">steel that is alloyed with a variety of elements in amounts between 1.0% and 50% by weight, typically to improve its mechanical properties</skos:definition> <skos:definition xml:lang="zh">与多种元素按重量比1.0%至50%合金化的钢，通常用于改善其机械性能</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0010006 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0010006">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020096"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020029"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">chromium steel</rdfs:label> <rdfs:label xml:lang="zh">铬钢</rdfs:label>
        <skos:definition xml:lang="en">steels containing chromium as an intentional alloying element, characterized by mechanical strength and hardness suitable for engineering applications such as bearings, tools, drills, and utensils, but lacking the corrosion resistance required to qualify as stainless steel</skos:definition> <skos:definition xml:lang="zh">含有铬作为有意添加的合金元素的钢，具有适用于轴承、工具、钻头和器具等工程应用的机械强度和硬度，但缺乏作为不锈钢所需的耐腐蚀性</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0010007 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0010007">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000852"/>
        <rdfs:label xml:lang="en">non-ferrous metal</rdfs:label> <rdfs:label xml:lang="zh">有色金属</rdfs:label>
        <skos:definition xml:lang="en">metals or alloys that do not contain iron (allotropes of iron, ferrite, and so on) in appreciable amounts.</skos:definition> <skos:definition xml:lang="zh">不含有显著量铁（铁的同素异形体、铁素体等）的金属或合金。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0010012 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0010012">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0010007"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0025004"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020068"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">zinc alloy</rdfs:label> <rdfs:label xml:lang="zh">锌合金</rdfs:label>
        <skos:definition xml:lang="en">non-ferrous metal consisting primarily of zinc combined with other elements</skos:definition> <skos:definition xml:lang="zh">主要由锌与其他元素结合组成的有色金属</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0010013 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0010013">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000005"/>
        <rdfs:label xml:lang="en">hardenable</rdfs:label> <rdfs:label xml:lang="zh">可硬化的</rdfs:label>
        <skos:definition xml:lang="en">a disposition to gain a greatly increased hardness at the surface or entire volume by the process of hardening</skos:definition> <skos:definition xml:lang="zh">通过硬化过程在表面或整个体积获得大幅增加硬度的倾向</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0010014 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0010014">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000852"/>
        <rdfs:label xml:lang="en">precious metal</rdfs:label> <rdfs:label xml:lang="zh">贵金属</rdfs:label>
        <skos:definition xml:lang="en">metal that is rare, naturally occurring, and have high economic value due to their resistance to corrosion, oxidation, and chemical reaction</skos:definition> <skos:definition xml:lang="zh">稀有、天然存在且因其耐腐蚀、抗氧化和抗化学反应而具有高经济价值的金属</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0010015 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0010015">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0010014"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020040"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">gold metal</rdfs:label> <rdfs:label xml:lang="zh">金金属</rdfs:label>
        <skos:definition xml:lang="en">precious metal consisting primarily of gold</skos:definition> <skos:definition xml:lang="zh">主要由金组成的贵金属</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0010016 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0010016">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0010014"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020076"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">silver metal</rdfs:label> <rdfs:label xml:lang="zh">银金属</rdfs:label>
        <skos:definition xml:lang="en">precious metal consisting primarily of silver</skos:definition> <skos:definition xml:lang="zh">主要由银组成的贵金属</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0010017 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0010017">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0010014"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020057"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">platinum metal</rdfs:label> <rdfs:label xml:lang="zh">铂金属</rdfs:label>
        <skos:definition xml:lang="en">precious metal consisting primarily of platinum</skos:definition> <skos:definition xml:lang="zh">主要由铂组成的贵金属</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0010018 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0010018">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0010014"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020092"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">palladium metal</rdfs:label> <rdfs:label xml:lang="zh">钯金属</rdfs:label>
        <skos:definition xml:lang="en">precious metal consisting primarily of palladium</skos:definition> <skos:definition xml:lang="zh">主要由钯组成的贵金属</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0010019 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0010019">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0010014"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0010020"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">rhodium metal</rdfs:label> <rdfs:label xml:lang="zh">铑金属</rdfs:label>
        <skos:definition xml:lang="en">precious metal consisting primarily of rhodium</skos:definition> <skos:definition xml:lang="zh">主要由铑组成的贵金属</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0010020 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0010020">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0020140"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                        <owl:allValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_33359"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020140"/>
        <rdfs:comment xml:lang="en">A Portion Of Matter that consists of only rhodium atoms.</rdfs:comment>
        <rdfs:label xml:lang="en">portion of rhodium</rdfs:label> <rdfs:label xml:lang="zh">铑</rdfs:label>
        <skos:definition xml:lang="en">A 'portion of rhodium' is a 'portion of pure chemical element' that 'consists of' only chebi:rhodium atom.</skos:definition> <skos:definition xml:lang="zh">&apos;铑&apos;是&apos;一份纯化学元素&apos;，它&apos;由&apos;仅chebi:rhodium atom组成。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0010021 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0010021">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0020140"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                        <owl:allValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_30452"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020140"/>
        <rdfs:comment xml:lang="en">A Portion Of Matter that consists of only tellurium atoms.</rdfs:comment>
        <rdfs:label xml:lang="en">portion of tellurium</rdfs:label> <rdfs:label xml:lang="zh">碲</rdfs:label>
        <skos:definition xml:lang="en">A 'portion of tellurium' is a 'portion of pure chemical element' that 'consists of' only chebi:tellurium atom.</skos:definition> <skos:definition xml:lang="zh">&apos;碲&apos;是&apos;一份纯化学元素&apos;，它&apos;由&apos;仅chebi:tellurium atom组成。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0010022 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0010022">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000005"/>
        <rdfs:label xml:lang="en">containing magnetic species</rdfs:label> <rdfs:label xml:lang="zh">含有磁性物种</rdfs:label>
        <skos:definition xml:lang="en">A material property that inheres in a material entity in virtue of the presence of one or more magnetic species (e.g. ferromagnetic, paramagnetic, or diamagnetic particles or atoms), and that manifests under appropriate conditions as the ability of that material entity to exhibit a magnetic response or influence in a magnetic field.</skos:definition> <skos:definition xml:lang="zh">一种材料属性，由于存在一种或多种磁性物种（例如铁磁性、顺磁性或抗磁性颗粒或原子）而固有于材料实体中，并在适当条件下表现为该材料实体在磁场中展现磁响应或影响的能力。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0010023 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0010023">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000016"/>
        <rdfs:label xml:lang="en">bioactive</rdfs:label> <rdfs:label xml:lang="zh">生物活性</rdfs:label>
        <skos:definition xml:lang="en">A disposition that inheres in a material entity and is realized in an organismal context as a specific interaction with one or more biological systems, producing a measurable biological effect (e.g., therapeutic, toxic, or signaling outcome).</skos:definition> <skos:definition xml:lang="zh">一种固有于材料实体并在生物体环境中实现为与一个或多个生物系统的特定相互作用的倾向，产生可测量的生物效应（例如治疗性、毒性或信号转导结果）。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0010024 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0010024">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000016"/>
        <rdfs:label xml:lang="en">bioinert</rdfs:label> <rdfs:label xml:lang="zh">生物惰性</rdfs:label>
        <skos:definition xml:lang="en">a disposition to elicit minimal or no biological response when in contact with tissue or implanted</skos:definition> <skos:definition xml:lang="zh">一种在接触组织或植入时引发最小或无生物反应的倾向</skos:definition>
        <skos:example xml:lang="en">non-toxic and non-immunogenic, with little or no bonding or integration with the body.</skos:example> <skos:example xml:lang="zh">无毒且无免疫原性，与身体几乎没有结合或整合。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0010025 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0010025">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020251"/>
        <rdfs:label xml:lang="en">bioresorbable</rdfs:label> <rdfs:label xml:lang="zh">生物可吸收的</rdfs:label>
        <skos:comment xml:lang="en">being absorbed or excreted as it performs its function, often eliminating the need for removal.</skos:comment> <skos:comment xml:lang="zh">在发挥功能时被吸收或排出，通常无需取出。</skos:comment>
        <skos:definition xml:lang="en">biocompatibe and degrading and being resorbed by the body over time</skos:definition> <skos:definition xml:lang="zh">生物相容且随时间降解并被身体吸收。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0010026 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0010026">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0025001"/>
        <rdfs:label xml:lang="en">organic composition</rdfs:label> <rdfs:label xml:lang="zh">有机组成</rdfs:label>
        <skos:definition xml:lang="en">A composition characterized by a primary molecular structure of carbon atoms covalently bonded to hydrogen (C-H bonds), typically forming linear, branched, or networked chains.</skos:definition> <skos:definition xml:lang="zh">以碳原子与氢共价键合（C-H键）为主要分子结构，通常形成线性、支化或网络链的组成。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0010027 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0010027">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0025001"/>
        <rdfs:label xml:lang="en">inorganic composition</rdfs:label> <rdfs:label xml:lang="zh">无机组成</rdfs:label>
        <skos:definition xml:lang="en">material composition based on chemical elements other than those defining organic compounds, typically characterized by ionic or metallic bonding and the absence of a carbon-hydrogen ($C-H$) framework</skos:definition> <skos:definition xml:lang="zh">基于除有机化合物定义元素以外的化学元素的材料组成，通常以离子键或金属键为特征，且不含碳氢（$C-H$）骨架。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0010029 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0010029">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:label xml:lang="en">specific strength</rdfs:label> <rdfs:label xml:lang="zh">比强度</rdfs:label>
        <skos:comment xml:lang="en">SI unit for specific strength is Pa⋅m3/kg, or N⋅m/kg, which is dimensionally equivalent to m2/s2, In fiber or textile applications, tenacity is the usual measure of specific strength
</skos:comment> <skos:comment xml:lang="zh">比强度的SI单位是Pa·m³/kg或N·m/kg，量纲上等同于m²/s²。在纤维或纺织品应用中，韧性是比强度的常用度量。</skos:comment>
        <skos:definition xml:lang="en">Specific strength is a quality that inheres in a material entity and is defined as the ratio of its tensile strength to its density.</skos:definition> <skos:definition xml:lang="zh">比强度是材料实体固有的性质，定义为其抗拉强度与密度之比。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0010033 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0010033">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:label xml:lang="en">polymerization</rdfs:label> <rdfs:label xml:lang="zh">聚合反应</rdfs:label>
        <skos:definition xml:lang="en">The chemical process of reacting monomers, oligomers, or reactive precursors together to form longer macromolecular chains or three-dimensional networks</skos:definition> <skos:definition xml:lang="zh">单体、低聚物或反应性前体相互反应形成更长的大分子链或三维网络的化学过程。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0010034 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0010034">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:label xml:lang="en">curing</rdfs:label> <rdfs:label xml:lang="zh">固化</rdfs:label>
        <skos:definition xml:lang="en">The toughening or hardening of a polymer material by cross-linking of polymer chains.</skos:definition> <skos:definition xml:lang="zh">通过聚合物链的交联使聚合物材料增韧或硬化的过程。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0010099 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0010099">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000000"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000087"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0010112"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">biomedical material</rdfs:label> <rdfs:label xml:lang="zh">生物医学材料</rdfs:label>
        <skos:altLabel xml:lang="en">biomaterial</skos:altLabel> <skos:altLabel xml:lang="zh">生物材料</skos:altLabel>
        <skos:comment xml:lang="en">related to the use of a material.   it is part of objects which participates some medical processes</skos:comment> <skos:comment xml:lang="zh">与材料的使用相关。它是参与某些医疗过程的物体的一部分。</skos:comment>
        <skos:definition xml:lang="en">A non-living material intended to interface with biological systems to evaluate, treat, augment, or replace any tissue, organ, or function of the body.</skos:definition> <skos:definition xml:lang="zh">旨在与生物系统交互以评估、治疗、增强或替换任何身体组织、器官或功能的非生命材料。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0010100 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0010100">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0090000"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002351"/>
                        <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                        <owl:onClass>
                            <owl:Class>
                                <owl:intersectionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0020140"/>
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000091"/>
                                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0090001"/>
                                    </owl:Restriction>
                                </owl:intersectionOf>
                            </owl:Class>
                        </owl:onClass>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0090000"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002351"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0020140"/>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000091"/>
                                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0090001"/>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002351"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/pmd/co/PMD_0020140"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">elemental semiconductor</rdfs:label> <rdfs:label xml:lang="zh">元素半导体</rdfs:label>
        <skos:comment xml:lang="en">Primarily includes group 14 elements like Silicon, Carbon, Germanium, Tin but also Selenium (group 16) and Boron (group 13).</skos:comment> <skos:comment xml:lang="zh">主要包括第14族元素如硅、碳、锗、锡，还包括硒（第16族）和硼（第13族）。</skos:comment>
        <skos:definition xml:lang="en">semiconductor that shows semiconductive behavior as a pure element</skos:definition> <skos:definition xml:lang="zh">作为纯元素显示半导体行为的半导体。</skos:definition>
        <skos:example xml:lang="en">Silicon, Carbon, Germanium, alpha-Tin</skos:example> <skos:example xml:lang="zh">硅、碳、锗、α-锡</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0010101 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0010101">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0090000"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002351"/>
                        <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">2</owl:minQualifiedCardinality>
                        <owl:onClass rdf:resource="https://w3id.org/pmd/co/PMD_0020140"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0090000"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002351"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020140"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">compound semiconductor</rdfs:label> <rdfs:label xml:lang="zh">化合物半导体</rdfs:label>
        <skos:altLabel xml:lang="en">alloy semiconductor</skos:altLabel> <skos:altLabel xml:lang="zh">合金半导体</skos:altLabel>
        <skos:definition xml:lang="en">semiconductor which is composed of two or more pure elements</skos:definition> <skos:definition xml:lang="zh">由两种或更多纯元素组成的半导体。</skos:definition>
        <skos:example xml:lang="en">boron nitride (BN), gallium arsenide (GaAs), aluminium gallium arsenide (AlGaAs), indium gallium nitride (InGaN)</skos:example> <skos:example xml:lang="zh">氮化硼(BN)，砷化镓(GaAs)，砷化铝镓(AlGaAs)，氮化铟镓(InGaN)</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0010102 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0010102">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0090000"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000000"/>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000086"/>
                                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0010026"/>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000086"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0010026"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">organic semiconductor</rdfs:label> <rdfs:label xml:lang="zh">有机半导体</rdfs:label>
        <skos:definition xml:lang="en">semiconductor which consists of   organic (carbon based) molecules or polymer</skos:definition> <skos:definition xml:lang="zh">由有机（碳基）分子或聚合物组成的半导体</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0010103 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0010103">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0090000"/>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0010102"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002351"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:unionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0010100"/>
                                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0010101"/>
                                </owl:unionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">hybrid semiconductor</rdfs:label> <rdfs:label xml:lang="zh">混合半导体</rdfs:label>
        <skos:definition xml:lang="en">semiconductor which consists of organic semiconductors and non-organic semiconductors</skos:definition> <skos:definition xml:lang="zh">由有机半导体和非有机半导体组成的半导体</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0010112 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0010112">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000023"/>
        <rdfs:label xml:lang="en">medical application role</rdfs:label> <rdfs:label xml:lang="zh">医疗应用角色</rdfs:label>
        <skos:definition xml:lang="en">a role realized through the intentional interface with a biological system for the purpose of evaluating, treating, augmenting, or replacing any tissue, organ, or function of the body</skos:definition> <skos:definition xml:lang="zh">通过有意与生物系统接口来实现的角色，目的是评估、治疗、增强或替代身体的任何组织、器官或功能</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0011023 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0011023">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050055"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020067"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">magnesia ceramic</rdfs:label> <rdfs:label xml:lang="zh">氧化镁陶瓷</rdfs:label>
        <skos:definition xml:lang="en">oxide ceramic consisting primarily of magnesium oxide</skos:definition> <skos:definition xml:lang="zh">主要由氧化镁组成的氧化物陶瓷</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0011032 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0011032">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050062"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020050"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">silicide ceramic</rdfs:label> <rdfs:label xml:lang="zh">硅化物陶瓷</rdfs:label>
        <skos:definition xml:lang="en">non-oxide ceramic consisting of a silicon and another element</skos:definition> <skos:definition xml:lang="zh">由硅和另一种元素组成的非氧化物陶瓷</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0011034 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0011034">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000120"/>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:intersectionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000546"/>
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000087"/>
                                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020001"/>
                                    </owl:Restriction>
                                </owl:intersectionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:intersectionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000852"/>
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000087"/>
                                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000845"/>
                                    </owl:Restriction>
                                </owl:intersectionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">cermet</rdfs:label> <rdfs:label xml:lang="zh">金属陶瓷</rdfs:label>
        <skos:altLabel xml:lang="en">ceramic-metal composite</skos:altLabel> <skos:altLabel xml:lang="zh">陶瓷-金属复合材料</skos:altLabel>
        <skos:definition xml:lang="en">metal matrix composite material consisting of a ceramic phase (typically carbides or nitrides) bonded with a continuous metallic phase</skos:definition> <skos:definition xml:lang="zh">由陶瓷相（通常是碳化物或氮化物）与连续金属相结合组成的金属基复合材料</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020000 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020000">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000040"/>
        <rdfs:label xml:lang="en">phase (thermodynamic)</rdfs:label> <rdfs:label xml:lang="zh">相（热力学）</rdfs:label>
        <skos:definition xml:lang="en">A thermodynamic phase is a material entity that forms a homogeneous portion of matter within a thermodynamic system and is characterized by uniform thermodynamic properties.</skos:definition> <skos:definition xml:lang="zh">热力学相是一种物质实体，在热力学系统中形成均匀的物质部分，并以均匀的热力学性质为特征。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020001 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020001">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000023"/>
        <rdfs:label xml:lang="en">filler role</rdfs:label> <rdfs:label xml:lang="zh">填料角色</rdfs:label>
        <skos:definition xml:lang="en">Filler is the role of a 'PortionOfDisconnectedMatter' that implies being hosted in a matrix.</skos:definition> <skos:definition xml:lang="zh">填料是'非连续物质部分'的角色，意味着被基质容纳。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020002 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020002">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000023"/>
        <rdfs:label xml:lang="en">precipitate role</rdfs:label> <rdfs:label xml:lang="zh">析出相角色</rdfs:label>
        <skos:definition xml:lang="en">Precipitate is the role of a portion of matter that implies being hosted in a matrix and the Precipitate derives from the matrix or the Precipitate derives from the thing that the matrix derives from.</skos:definition> <skos:definition xml:lang="zh">析出相是一种物质部分的角色，意味着被基质容纳，且析出相来源于基质或来源于基质所来源的东西。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020003 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020003">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000086"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000591"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">crystal</rdfs:label> <rdfs:label xml:lang="zh">晶体</rdfs:label>
        <skos:definition xml:lang="en">A crystal is an object that has a quality "crystal structure".</skos:definition> <skos:definition xml:lang="zh">晶体是具有'晶体结构'属性的物体。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020004 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020004">
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/IAO_0000027"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0025001"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002351"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0025997"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000116 xml:lang="en">See editior note of composition to underatand the difference between composition and chemical composition data items.

To understand the difference between the composition and the composition data item, one has to understand the difference between SDCs and GDCs in BFO. A triple "material entity has quality compsition", conveys the fact such quality exists without telling us what are fractions of compounds in this material entity. A triple "compostion is subject of composition data item" conveys that there's an information about values of these fractions. Think of comosition data item as a pdf where the composition is documented.</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">请参阅编辑说明以理解组成与化学组成数据项之间的区别。

要理解组成与组成数据项之间的区别，必须先理解BFO中SDC和GDC的区别。三元组“材料实体具有属性组成”传达了该属性存在的事实，但没有告诉我们该材料实体中化合物的比例。三元组“组成是组成数据项的主体”传达了有关这些比例值的信息。将组成数据项视为记录组成的PDF。</obo:IAO_0000116>
        <rdfs:comment xml:lang="en">These portions of other matters do not have to be portions of specific chemical elements, i.e., atomic composition, but rather portions of other substances, such as nitric acid and water.</rdfs:comment>
        <rdfs:label xml:lang="en">composition data item</rdfs:label> <rdfs:label xml:lang="zh">组成数据项</rdfs:label>
        <skos:altLabel xml:lang="en">composition specification</skos:altLabel> <skos:altLabel xml:lang="zh">组成规范</skos:altLabel>
        <skos:definition xml:lang="en">Composition data item is an information content entity that is about composition of a material enity. It has members fraction value specifications which specifiy values of propotions of compounds, which are parts of the material enity.</skos:definition> <skos:definition xml:lang="zh">成分数据项是一个信息内容实体，涉及材料实体的成分。它包含分数值规范成员，这些规范指定作为材料实体部分的化合物的比例值。</skos:definition>
        <skos:example xml:lang="en">Nitric acid solution has quality  composition, and  the composition data item is about this composition.The composition data item has members fraction specifications of nitric acid, e.g., 4 vol.%, and distilled water. These fraction specifications specify value of pure substances of nitric acid and distilled water, respectively. Furthermore, these fraction specifications specify values of relational qualities (volume) proportion of nitric acid and (volume) proportion of distilled water.</skos:example> <skos:example xml:lang="zh">硝酸溶液具有质量成分，而成分数据项涉及该成分。成分数据项包含硝酸（例如4 vol.%）和蒸馏水的分数规范成员。这些分数规范分别指定硝酸和蒸馏水纯物质的值。此外，这些分数规范指定了硝酸和蒸馏水的（体积）比例关系质量的值。</skos:example>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020005 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020005">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020131"/>
        <rdfs:label xml:lang="en">porosity</rdfs:label> <rdfs:label xml:lang="zh">孔隙率</rdfs:label>
        <skos:definition xml:lang="en">itensive quality embodiying the fraction of the materials (enclosing) spatial region occupied by pores.</skos:definition> <skos:definition xml:lang="zh">体现材料（包围的）空间区域中被孔隙占据的分数的一种强度性质。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020022 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020022">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/pmd/co/PMD_0025013"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000551"/>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000080"/>
                                <owl:someValuesFrom>
                                    <owl:Class>
                                        <owl:intersectionOf rdf:parseType="Collection">
                                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000040"/>
                                            <owl:Restriction>
                                                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000091"/>
                                                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000016"/>
                                            </owl:Restriction>
                                        </owl:intersectionOf>
                                    </owl:Class>
                                </owl:someValuesFrom>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Corrosion is typically of interest when the change of the material affects the objects ability to fulfill its function.</rdfs:comment>
        <rdfs:label xml:lang="en">corrosion</rdfs:label> <rdfs:label xml:lang="zh">腐蚀</rdfs:label>
        <skos:definition xml:lang="en">corrosion is a slow chemical or electrochemical degradation process of a material entity due to its interaction with the surrounding environment.</skos:definition> <skos:definition xml:lang="zh">腐蚀是材料实体因其与周围环境的相互作用而发生的缓慢化学或电化学降解过程。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020023 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020023">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0020027"/>
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0020097"/>
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0020100"/>
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0020107"/>
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0020109"/>
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0020110"/>
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0020111"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBI_0001930"/>
        <rdfs:label xml:lang="en">metallic grain structures</rdfs:label> <rdfs:label xml:lang="zh">金属晶粒结构</rdfs:label>
        <skos:definition xml:lang="en">The metallic grain structures is a categorical value specification that specifies value of the  metallic grain structure quality. It describes the morphology of polycrystalline metallic materials. Polycrystalline metallic materials will typically form their grain structures as one of those categories or a transition or mixture state of those.</skos:definition> <skos:definition xml:lang="zh">金属晶粒结构是一种类别值规范，指定金属晶粒结构质量的值。它描述多晶金属材料的形态。多晶金属材料通常会形成这些类别之一或这些类别的过渡或混合状态的晶粒结构。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020024 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020024">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050000"/>
        <rdfs:label xml:lang="en">hydrogen bond</rdfs:label> <rdfs:label xml:lang="zh">氢键</rdfs:label>
        <skos:definition xml:lang="en">A hydrogen bond is a bond that binds one molecule’s hydrogen atom with the electronegative atoms of another molecule.</skos:definition> <skos:definition xml:lang="zh">氢键是一种将一个分子的氢原子与另一个分子的电负性原子结合的键。</skos:definition>
        <skos:example xml:lang="en">The bond that forms between liquid water molecules at one molecules hydrogen ends and the other molecules oxygen end.</skos:example> <skos:example xml:lang="zh">在液态水分子之间形成的键，位于一个分子的氢端和另一个分子的氧端。</skos:example>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020025 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020025">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000023"/>
        <rdfs:label xml:lang="en">obstacle role</rdfs:label> <rdfs:label xml:lang="zh">障碍角色</rdfs:label>
        <skos:definition xml:lang="en">An obstacle role is a role of an independent continuant C that is realized in a motion process and indictes that C hinders the motion of a participant in the process.</skos:definition> <skos:definition xml:lang="zh">障碍角色是一个独立持续体C的角色，在运动过程中实现，并表明C阻碍了过程中参与者的运动。</skos:definition>
        <skos:example xml:lang="en">A precipitate or grain boundary may hinder the motion of a dislocation.</skos:example> <skos:example xml:lang="zh">沉淀物或晶界可能阻碍位错的运动。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020026 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020026">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0020140"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                        <owl:allValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_18248"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020140"/>
        <rdfs:comment xml:lang="en">A Portion Of Matter that consists of only Iron atoms.</rdfs:comment>
        <rdfs:label xml:lang="en">portion of iron</rdfs:label> <rdfs:label xml:lang="zh">铁</rdfs:label>
        <skos:definition xml:lang="en">A 'portion of iron' is a 'Poriton Of Pure Substance' that 'consists of' only chebi:iron atom.</skos:definition> <skos:definition xml:lang="zh">'铁的部分'是'纯物质的部分'，仅由chebi:iron atom组成。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020028 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020028">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
