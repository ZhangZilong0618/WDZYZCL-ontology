    <!-- http://purl.obolibrary.org/obo/CHEBI_33394 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CHEBI_33394">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CHEBI_33521"/>
        <rdfs:label xml:lang="en">fermium</rdfs:label> <rdfs:label xml:lang="zh">镄</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/CHEBI_33395 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CHEBI_33395">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CHEBI_33521"/>
        <rdfs:label xml:lang="en">mendelevium atom</rdfs:label> <rdfs:label xml:lang="zh">钔原子</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/CHEBI_33396 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CHEBI_33396">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CHEBI_33521"/>
        <rdfs:label xml:lang="en">nobelium</rdfs:label> <rdfs:label xml:lang="zh">锘</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/CHEBI_33397 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CHEBI_33397">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CHEBI_33521"/>
        <rdfs:label xml:lang="en">lawrencium atom</rdfs:label> <rdfs:label xml:lang="zh">铹原子</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/CHEBI_33517 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CHEBI_33517">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CHEBI_33521"/>
        <obo:IAO_0000115 xml:lang="en">A zinc group element atom with a symbol Cn and atomic number 112. All its isotopes are intensely radioactive. Prior to its discovery, it had the placeholder name ununbium (in accordance with IUPAC recommendations). Following its discovery (in Darmstadt, 1996) and subsequent confirmation, the name copernicium was adopted in 2010.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">一种锌族元素原子，符号为Cn，原子序数为112。它的所有同位素都具有强放射性。在发现之前，它曾使用临时名称ununbium（根据IUPAC建议）。在1996年于Darmstadt发现并随后确认后，于2010年采用了名称鿔。</obo:IAO_0000115>
        <rdfs:label xml:lang="en">copernicium atom</rdfs:label> <rdfs:label xml:lang="zh">鿔原子</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/CHEBI_33521 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CHEBI_33521">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CHEBI_33250"/>
        <obo:IAO_0000115 xml:lang="en">An atom of an element that exhibits typical metallic properties, being typically shiny, with high electrical and thermal conductivity.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">一种元素原子，表现出典型的金属性质，通常有光泽，具有高电导率和热导率。</obo:IAO_0000115>
        <rdfs:label xml:lang="en">metal atom</rdfs:label> <rdfs:label xml:lang="zh">金属原子</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/CHEBI_33839 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CHEBI_33839">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CHEBI_23367"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000040"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115 xml:lang="en">A macromolecule is a molecule of high relative molecular mass, the structure of which essentially comprises the multiple repetition of units derived, actually or conceptually, from molecules of low relative molecular mass.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">大分子是相对分子质量高的分子，其结构基本上由实际上或概念上源自低相对分子质量分子的单元多次重复组成。</obo:IAO_0000115>
        <rdfs:label xml:lang="en">macromolecule</rdfs:label> <rdfs:label xml:lang="zh">大分子</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/CHEBI_37376 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CHEBI_37376">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CHEBI_23367"/>
        <rdfs:label xml:lang="en">tetraphosphorus decaoxide</rdfs:label> <rdfs:label xml:lang="zh">十氧化四磷</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/CHEBI_49475 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CHEBI_49475">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CHEBI_23367"/>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CHEBI_25585"/>
        <rdfs:label xml:lang="en">argon atom</rdfs:label> <rdfs:label xml:lang="zh">氩原子</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/CHEBI_49631 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CHEBI_49631">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CHEBI_33521"/>
        <obo:IAO_0000115 xml:lang="en">A metallic element predicted as eka-aluminium by Mendeleev in 1870 and discovered by Paul-Emile Lecoq de Boisbaudran in 1875. Named in honour of France (Latin &lt;em&gt;Gallia&lt;/em&gt;) and perhaps also from the Latin &lt;em&gt;gallus&lt;/em&gt; cock, a translation of Lecoq.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">一种金属元素，由门捷列夫于1870年预测为类铝，由保罗-埃米尔·勒科克·德布瓦博德兰于1875年发现。其名称是为了纪念法国（拉丁语&lt;em&gt;Gallia&lt;/em&gt;），也可能来自拉丁语&lt;em&gt;gallus&lt;/em&gt;公鸡，是Lecoq的翻译。</obo:IAO_0000115>
        <rdfs:label xml:lang="en">gallium atom</rdfs:label> <rdfs:label xml:lang="zh">镓原子</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/CHEBI_49637 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CHEBI_49637">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CHEBI_23367"/>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CHEBI_25585"/>
        <rdfs:label xml:lang="en">hydrogen atom</rdfs:label> <rdfs:label xml:lang="zh">氢原子</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/CHEBI_49648 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CHEBI_49648">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CHEBI_33319"/>
        <rdfs:label xml:lang="en">holmium atom</rdfs:label> <rdfs:label xml:lang="zh">钬原子</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/CHEBI_49666 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CHEBI_49666">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CHEBI_33521"/>
        <rdfs:label xml:lang="en">iridium atom</rdfs:label> <rdfs:label xml:lang="zh">铱原子</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/CHEBI_49696 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CHEBI_49696">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CHEBI_23367"/>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CHEBI_25585"/>
        <rdfs:label xml:lang="en">krypton atom</rdfs:label> <rdfs:label xml:lang="zh">氪原子</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/CHEBI_49828 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CHEBI_49828">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CHEBI_33319"/>
        <rdfs:label xml:lang="en">praseodymium atom</rdfs:label> <rdfs:label xml:lang="zh">镨原子</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/CHEBI_49882 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CHEBI_49882">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CHEBI_33521"/>
        <rdfs:label xml:lang="en">rhenium atom</rdfs:label> <rdfs:label xml:lang="zh">铼原子</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/CHEBI_49957 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CHEBI_49957">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CHEBI_23367"/>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CHEBI_25585"/>
        <rdfs:label xml:lang="en">xenon atom</rdfs:label> <rdfs:label xml:lang="zh">氙原子</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/CHEBI_53284 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CHEBI_53284">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CHEBI_33839"/>
        <obo:IAO_0000115 xml:lang="en">A homopolymer macromolecule composed of units connected by carbamate (-O-CO-NH-) linkages.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">由氨基甲酸酯（-O-CO-NH-）键连接单元组成的均聚大分子。</obo:IAO_0000115>
        <rdfs:label xml:lang="en">polyurethane macromolecule</rdfs:label> <rdfs:label xml:lang="zh">聚氨酯大分子</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/CHEBI_59999 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CHEBI_59999">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CHEBI_24431"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000001"/>
        <obo:IAO_0000115 xml:lang="en">A chemical substance is a portion of matter of constant composition, composed of molecular entities of the same type or of different types.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">化学物质是组成恒定的物质部分，由相同类型或不同类型的分子实体组成。</obo:IAO_0000115>
        <rdfs:comment xml:lang="en">Frequently used for fluidic portions of matter and/or in the context of chemical reactions. Boundary to material not always sharp.</rdfs:comment>
        <rdfs:label xml:lang="en">chemical substance</rdfs:label> <rdfs:label xml:lang="zh">化学物质</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/CHEBI_60003 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CHEBI_60003">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CHEBI_59999"/>
        <obo:IAO_0000115 xml:lang="en">A pure substance is a chemical substance composed of multiple molecules, which are all of the same kind.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">纯物质是由多种分子组成的化学物质，这些分子均为同一种类。</obo:IAO_0000115>
        <rdfs:label xml:lang="en">pure substance</rdfs:label> <rdfs:label xml:lang="zh">纯物质</rdfs:label>
        <rdfs:seeAlso rdf:resource="http://purl.obolibrary.org/obo/CHEBI_60003"/>
        <skos:example xml:lang="en">Pure water, a portion of iron atoms. In contrast, salt water 'has part' a portion of pure water and a portion of pure NaCl. Steel 'has part' a 'portion of pure iron', a 'portion of pure carbon' and possibly portions of other alloying- and impurity-elements.</skos:example> <skos:example xml:lang="zh">纯水，一份铁原子。相比之下，盐水“包含”一份纯水和一份纯NaCl。钢“包含”一份“纯铁”、一份“纯碳”，以及可能的其他合金元素和杂质元素。</skos:example>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/CHEBI_74236 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CHEBI_74236">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000023"/>
        <obo:IAO_0000115 xml:lang="en">Any compound used as a monomer for a polymerisation process. The term is generally used in relation to industrial polymerisation processes.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">任何用作聚合过程单体的化合物。该术语通常用于工业聚合过程。</obo:IAO_0000115>
        <rdfs:label xml:lang="en">polymerisation monomer</rdfs:label> <rdfs:label xml:lang="zh">聚合单体</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/CHEBI_81045 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CHEBI_81045">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CHEBI_23367"/>
        <obo:IAO_0000115 xml:lang="en">An inorganic lead salt composed from lead(2+) and oxide.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">由铅(2+)和氧化物组成的无机铅盐。</obo:IAO_0000115>
        <rdfs:label xml:lang="en">lead oxide</rdfs:label> <rdfs:label xml:lang="zh">氧化铅</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/COB_0000035 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/COB_0000035">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/COB_0000082"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000055"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OBI_0000260"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="http://purl.obolibrary.org/obo/COB_0000083"/>
        <owl:disjointWith rdf:resource="http://purl.obolibrary.org/obo/GO_0008150"/>
        <rdfs:label xml:lang="en">completely executed planned process</rdfs:label> <rdfs:label xml:lang="zh">完全执行的计划过程</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/COB_0000082 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/COB_0000082">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <owl:disjointWith rdf:resource="https://w3id.org/pmd/co/PMD_0025009"/>
        <obo:IAO_0000115 xml:lang="en">A process that is initiated by an agent who intends to carry out a plan to achieve an objective through one or more actions as described in a plan specification.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">由行为者发起的过程，该行为者意图执行计划，通过一个或多个如计划规范所述的行为来实现目标。</obo:IAO_0000115>
        <rdfs:label xml:lang="en">planned process</rdfs:label> <rdfs:label xml:lang="zh">计划过程</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/COB_0000083 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/COB_0000083">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/COB_0000082"/>
        <rdfs:label xml:lang="en">failed planned process</rdfs:label> <rdfs:label xml:lang="zh">失败的计划过程</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/GO_0008150 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/GO_0008150">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115 xml:lang="en">A biological process is the execution of a genetically-encoded biological module or program. It consists of all the steps required to achieve the specific biological objective of the module. A biological process is accomplished by a particular set of molecular functions carried out by specific gene products (or macromolecular complexes), often in a highly regulated manner and in a particular temporal sequence.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">生物过程是遗传编码的生物模块或程序的执行。它包含实现该模块特定生物目标所需的所有步骤。生物过程由特定基因产物（或大分子复合物）执行的一组特定分子功能完成，通常以高度调控的方式和特定的时间顺序进行。</obo:IAO_0000115>
        <rdfs:label xml:lang="en">biological process</rdfs:label> <rdfs:label xml:lang="zh">生物过程</rdfs:label>
        <rdfs:label xml:lang="en">biological_process</rdfs:label> <rdfs:label xml:lang="zh">生物过程</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/IAO_0000003 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/IAO_0000003">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000009"/>
        <obo:IAO_0000112 xml:lang="en">Examples of measurement unit labels are liters, inches, weight per volume.</obo:IAO_0000112> <obo:IAO_0000112 xml:lang="zh">测量单位标签的例子有升、英寸、重量每体积。</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">A measurement unit label is as a label that is part of a scalar measurement datum and denotes a unit of measure.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">测量单位标签是作为标量测量数据一部分的标签，表示测量单位。</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">2009-03-16: provenance: a term measurement unit was
proposed for OBI (OBI_0000176) , edited by Chris Stoeckert and
Cristian Cocos, and subsequently moved to IAO where the objective for
which the original term was defined was satisfied with the definition
of this, different, term.</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">2009-03-16：来源：术语"measurement unit"曾为OBI（OBI_0000176）提出，由Chris Stoeckert和Cristian Cocos编辑，随后移至IAO，原始术语定义的目标通过这个不同的术语定义得到满足。</obo:IAO_0000116>
        <obo:IAO_0000116 xml:lang="en">2009-03-16: review of this term done during during the OBI workshop winter 2009 and the current definition was considered acceptable for use in OBI. If there is a need to modify this definition please notify OBI.</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">2009-03-16：在2009年冬季OBI研讨会上对该术语进行了审查，当前定义被认为可用于OBI。如需修改此定义，请通知OBI。</obo:IAO_0000116>
        <rdfs:label xml:lang="en">measurement unit label</rdfs:label> <rdfs:label xml:lang="zh">测量单位标签</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/IAO_0000005 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/IAO_0000005">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000033"/>
        <obo:IAO_0000112 xml:lang="en">In the protocol of a ChIP assay the objective specification says to identify protein and DNA interaction.</obo:IAO_0000112> <obo:IAO_0000112 xml:lang="zh">在ChIP实验的方案中，目标说明是鉴定蛋白质和DNA的相互作用。</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">A directive information entity that describes an intended process endpoint. When part of a plan specification the concretization is realized in a planned process in which the bearer tries to effect the world so that the process endpoint is achieved.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">一种描述预期过程终点的指令信息实体。当作为计划规范的一部分时，其具体化在计划过程中实现，承载者试图影响世界以使过程终点得以达成。</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">2009-03-16: original definition when imported from OBI read: "objective is an non realizable information entity which can serve as that  proper part of a plan towards which the realization of the plan is directed."</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">2009-03-16：从OBI导入时的原始定义写道：“目标是一种不可实现的信息实体，可作为计划中实现计划所指向的适当部分。”</obo:IAO_0000116>
        <obo:IAO_0000116 xml:lang="en">2014-03-31: In the example of usage ("In the protocol of a ChIP assay the objective specification says to identify protein and DNA interaction") there is a protocol which is the ChIP assay protocol. In addition to being concretized on paper, the protocol can be concretized as a realizable entity, such as a plan that inheres in a person. The objective specification is the part that says that some protein and DNA interactions are identified. This is a specification of a process endpoint: the boundary in the process before which they are not identified and after which they are. During the realization of the plan, the goal is to get to the point of having the interactions, and participants in the realization of the plan try to do that.</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">2014-03-31：在使用示例中（“在ChIP实验方案中，目标规范说明要识别蛋白质与DNA的相互作用”）有一个方案，即ChIP实验方案。除了在纸上具体化外，方案还可以具体化为可实现实体，例如存在于人身上的计划。目标规范是说明某些蛋白质与DNA相互作用被识别的那部分。这是对过程终点的规范：过程中的边界，在该边界之前它们未被识别，之后被识别。在计划的实现过程中，目标是达到拥有相互作用的时间点，而计划实现的参与者试图做到这一点。</obo:IAO_0000116>
        <obo:IAO_0000116 xml:lang="en">Answers the question, why did you do this experiment?</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">回答这个问题：你为什么做这个实验？</obo:IAO_0000116>
        <obo:IAO_0000119 xml:lang="en">OBI Plan and Planned Process/Roles Branch</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">OBI 计划与计划过程/角色分支</obo:IAO_0000119>
        <obo:IAO_0000119 xml:lang="en">OBI_0000217</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">OBI_0000217</obo:IAO_0000119>
        <rdfs:label xml:lang="en">objective specification</rdfs:label> <rdfs:label xml:lang="zh">目标规范</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/IAO_0000007 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/IAO_0000007">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000033"/>
        <obo:IAO_0000112 xml:lang="en">Pour the contents of flask 1 into flask 2</obo:IAO_0000112> <obo:IAO_0000112 xml:lang="zh">将烧瓶1的内容物倒入烧瓶2</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">A directive information entity that describes an action the bearer will take.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">一种描述承载者将要采取行动的指令信息实体。</obo:IAO_0000115>
        <obo:IAO_0000119 xml:lang="en">OBI Plan and Planned Process branch</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">OBI 计划与计划过程分支</obo:IAO_0000119>
        <rdfs:label xml:lang="en">action specification</rdfs:label> <rdfs:label xml:lang="zh">行动规范</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/IAO_0000009 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/IAO_0000009">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000030"/>
        <obo:IAO_0000115 xml:lang="en">A label is a symbol that is part of some other datum and is used to either partially define  the denotation of that datum or to provide a means for identifying the datum as a member of the set of data with the same label</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">标签是一种符号，是某个其他数据的一部分，用于部分定义该数据的指称，或提供一种将该数据标识为具有相同标签的数据集成员的方法。</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">http://www.golovchenko.org/cgi-bin/wnsearch?q=label#4n</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">http://www.golovchenko.org/cgi-bin/wnsearch?q=标签#4n</obo:IAO_0000116>
        <obo:IAO_0000232>9/22/11 BP: changed the rdfs:label for this class from 'label' to 'datum label' to convey that this class is not intended to cover all kinds of labels (stickers, radiolabels, etc.), and not even all kind of textual labels, but rather the kind of labels occuring in a datum. 
</obo:IAO_0000232>
        <rdfs:label xml:lang="en">datum label</rdfs:label> <rdfs:label xml:lang="zh">数据标签</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/IAO_0000010 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/IAO_0000010">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000104"/>
        <obo:IAO_0000115 xml:lang="en">Software is a plan specification composed of a series of instructions that can be 
interpreted by or directly executed by a processing unit.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">软件是一种计划规范，由一系列可由处理单元解释或直接执行的指令组成。</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">see sourceforge tracker discussion at http://sourceforge.net/tracker/index.php?func=detail&amp;aid=1958818&amp;group_id=177891&amp;atid=886178</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">参见 sourceforge 跟踪器讨论，网址为 http://sourceforge.net/tracker/index.php?func=detail&amp;aid=1958818&amp;group_id=177891&amp;atid=886178</obo:IAO_0000116>
        <obo:IAO_0000119 xml:lang="en">GROUP: OBI</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">组：OBI</obo:IAO_0000119>
        <rdfs:label xml:lang="en">software</rdfs:label> <rdfs:label xml:lang="zh">软件</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/IAO_0000027 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/IAO_0000027">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000030"/>
        <obo:IAO_0000112 xml:lang="en">Data items include counts of things, analyte concentrations, and statistical summaries.</obo:IAO_0000112> <obo:IAO_0000112 xml:lang="zh">数据项包括事物计数、分析物浓度和统计摘要。</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">An information content entity that is intended to be a truthful statement about something (modulo, e.g., measurement precision or other systematic errors) and is constructed/acquired by a method which reliably tends to produce (approximately) truthful statements.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">一种信息内容实体，旨在成为关于某事物的真实陈述（考虑到例如测量精度或其他系统误差），并通过可靠地倾向于产生（近似）真实陈述的方法构建/获取。</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">2/2/2009 Alan and Bjoern discussing FACS run output data. This is a data item because it is about the cell population. Each element records an event and is typically further composed a set of measurment data items that record the fluorescent intensity stimulated by one of the lasers.</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">2009年2月2日 Alan 和 Bjoern 讨论 FACS 运行输出数据。这是一个数据项，因为它关于细胞群体。每个元素记录一个事件，通常进一步由一组测量数据项组成，这些数据项记录由其中一个激光器激发的荧光强度。</obo:IAO_0000116>
        <obo:IAO_0000116 xml:lang="en">2009-03-16: data item deliberatly ambiguous: we merged data set and datum to be one entity, not knowing how to define singular versus plural. So data item is more general than datum.</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">2009-03-16：数据项故意模棱两可：我们将数据集和数据合并为一个实体，不知道如何定义单数与复数。因此数据项比数据更一般。</obo:IAO_0000116>
        <obo:IAO_0000116 xml:lang="en">2009-03-16: removed datum as alternative term as datum specifically refers to singular form, and is thus not an exact synonym.</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">2009-03-16：移除了数据作为替代术语，因为数据特指单数形式，因此不是精确同义词。</obo:IAO_0000116>
        <obo:IAO_0000116 xml:lang="en">2014-03-31: See discussion at http://odontomachus.wordpress.com/2014/03/30/aboutness-objects-propositions/</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">2014-03-31：参见讨论，网址为 http://odontomachus.wordpress.com/2014/03/30/aboutness-objects-propositions/</obo:IAO_0000116>
        <obo:IAO_0000116 xml:lang="en">JAR: datum     -- well, this will be very tricky to define, but maybe some 
information-like stuff that might be put into a computer and that is 
meant, by someone, to denote and/or to be interpreted by some 
process... I would include lists, tables, sentences... I think I might 
defer to Barry, or to Brian Cantwell Smith

JAR: A data item is an approximately justified approximately true approximate belief</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">JAR：数据——好吧，这很难定义，但也许是一些可以放入计算机的类信息东西，由某人意图表示和/或被某个过程解释……我会包括列表、表格、句子……我想我可能会请教 Barry 或 Brian Cantwell Smith

JAR：数据项是一种近似合理、近似真实、近似的信念。</obo:IAO_0000116>
        <rdfs:label xml:lang="en">data item</rdfs:label> <rdfs:label xml:lang="zh">数据项</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/IAO_0000028 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/IAO_0000028">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000030"/>
        <obo:IAO_0000112 xml:lang="en">a serial number such as "12324X"</obo:IAO_0000112> <obo:IAO_0000112 xml:lang="zh">一串序列号例如"12324X"</obo:IAO_0000112>
        <obo:IAO_0000112 xml:lang="en">a stop sign</obo:IAO_0000112> <obo:IAO_0000112 xml:lang="zh">一个停止标志</obo:IAO_0000112>
        <obo:IAO_0000112 xml:lang="en">a written proper name such as "OBI"</obo:IAO_0000112> <obo:IAO_0000112 xml:lang="zh">一个书面专有名称例如"OBI"</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">An information content entity that is a mark(s) or character(s) used as a conventional representation of another entity.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">一个信息内容实体，是作为另一实体的常规表示的标记或字符。</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">20091104, MC: this needs work and will most probably change</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">20091104, MC: 这需要改进，很可能会改变</obo:IAO_0000116>
        <obo:IAO_0000116 xml:lang="en">2014-03-31: We would like to have a deeper analysis of 'mark' and 'sign' in the future (see https://github.com/information-artifact-ontology/IAO/issues/154).</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">2014-03-31: 我们希望将来对'mark'和'sign'进行更深入的分析（参见 https://github.com/information-artifact-ontology/IAO/issues/154）。</obo:IAO_0000116>
        <obo:IAO_0000119 xml:lang="en">based on Oxford English Dictionary</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">基于牛津英语词典</obo:IAO_0000119>
        <rdfs:label xml:lang="en">symbol</rdfs:label> <rdfs:label xml:lang="zh">符号</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/IAO_0000030 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/IAO_0000030">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000031"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000001"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000112 xml:lang="en">Examples of information content entites include journal articles, data, graphical layouts, and graphs.</obo:IAO_0000112> <obo:IAO_0000112 xml:lang="zh">信息内容实体的例子包括期刊文章、数据、图形布局和图表。</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">A generically dependent continuant that is about some thing.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">一个泛指依赖于某个事物的持续性实体。</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">2014-03-10: The use of "thing" is intended to be general enough to include universals and configurations (see https://groups.google.com/d/msg/information-ontology/GBxvYZCk1oc/-L6B5fSBBTQJ).</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">2014-03-10: 使用"thing"旨在足够通用以包括普遍性和配置（参见 https://groups.google.com/d/msg/information-ontology/GBxvYZCk1oc/-L6B5fSBBTQJ）。</obo:IAO_0000116>
        <obo:IAO_0000116 xml:lang="en">Pier: 'data, information or knowledge'. OR 'representation'</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">Pier: '数据、信息或知识'。或'表示'</obo:IAO_0000116>
        <obo:IAO_0000116 xml:lang="en">information_content_entity 'is_encoded_in' some digital_entity in obi before split (040907). information_content_entity 'is_encoded_in' some physical_document in obi before split (040907).

Previous. An information content entity is a non-realizable information entity that 'is encoded in' some digital or physical entity.</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">information_content_entity 'is_encoded_in' some digital_entity in obi before split (040907). information_content_entity 'is_encoded_in' some physical_document in obi before split (040907).

之前。信息内容实体是一个不可实现的信息实体，它'被编码在'某个数字或物理实体中。</obo:IAO_0000116>
        <obo:IAO_0000119 xml:lang="en">OBI_0000142</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">OBI_0000142</obo:IAO_0000119>
        <rdfs:label xml:lang="en">information content entity</rdfs:label> <rdfs:label xml:lang="zh">信息内容实体</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/IAO_0000033 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/IAO_0000033">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000030"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000017"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115 xml:lang="en">An information content entity whose concretizations indicate to their bearer how to realize them in a process.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">一个信息内容实体，其具体化向其承载者指示如何在过程中实现它们。</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">2009-03-16: provenance: a term realizable information entity was proposed for OBI (OBI_0000337) , edited by the PlanAndPlannedProcess branch. Original definition was  "is the specification of a process that can be concretized and realized by an actor" with alternative term  "instruction".It has been subsequently moved to IAO where the objective for which the original term was defined was satisfied with the definitionof this, different, term.</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">2009-03-16: 出处：为OBI提出了一个术语'可实现信息实体'（OBI_0000337），由PlanAndPlannedProcess分支编辑。原始定义是'是一个过程的规范，可以由行动者具体化和实现'，替代术语是'指令'。随后它被移到了IAO，其中原始术语定义的目标通过这个不同的术语的定义得到了满足。</obo:IAO_0000116>
        <obo:IAO_0000116 xml:lang="en">2013-05-30 Alan Ruttenberg: What differentiates a directive information entity from an information concretization is that it can have concretizations that are either qualities or realizable entities. The concretizations that are realizable entities are created when an individual chooses to take up the direction, i.e. has the intention to (try to) realize it.</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">2013-05-30 Alan Ruttenberg: 指令信息实体与信息具体化的区别在于它可以有要么是品质要么是可实现实体的具体化。那些是可实现实体的具体化是在个体选择接受指令时创建的，即有意向（尝试）实现它。</obo:IAO_0000116>
        <obo:IAO_0000116 xml:lang="en">8/6/2009 Alan Ruttenberg: Changed label from "information entity about a realizable" after discussions at ICBO</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">8/6/2009 Alan Ruttenberg: 在ICBO讨论后，将标签从'关于可实现的的信息实体'更改。</obo:IAO_0000116>
        <obo:IAO_0000116 xml:lang="en">Werner pushed back on calling it realizable information entity as it isn't realizable. However this name isn't right either. An example would be a recipe. The realizable entity would be a plan, but the information entity isn't about the plan, it, once concretized, *is* the plan. -Alan</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">Werner反对称其为可实现的的信息实体，因为它不可实现。然而这个名字也不正确。一个例子是食谱。可实现实体将是一个计划，但信息实体不是关于计划的，它一旦具体化，*就是*计划。-Alan</obo:IAO_0000116>
        <rdfs:label xml:lang="en">directive information entity</rdfs:label> <rdfs:label xml:lang="zh">指令信息实体</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/IAO_0000098 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/IAO_0000098">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000033"/>
        <obo:IAO_0000112 xml:lang="en">you might consinder EDAM formats as sublasses here http://edamontology.org/format_1915</obo:IAO_0000112> <obo:IAO_0000112 xml:lang="zh">你可能会考虑EDAM格式作为子类，参见 http://edamontology.org/format_1915</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">A data format specification is the information content borne by the document published defining the specification.
Example: The ISO document specifying what encompasses an XML document; The instructions in a XSD file</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">数据格式规范是由定义该规范的文件所承载的信息内容。
示例：规定XML文档应包含什么内容的ISO文档；XSD文件中的指令。</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">2009-03-16: provenance: term imported from OBI_0000187, which had original definition "A data format specification is a plan which organizes
information. Example: The ISO document specifying what encompasses an
XML document; The instructions in a XSD file"</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">2009-03-16: 出处：术语从OBI_0000187导入，其原始定义为'数据格式规范是一个组织信息的计划。
示例：规定XML文档应包含什么内容的ISO文档；XSD文件中的指令。'</obo:IAO_0000116>
        <obo:IAO_0000119 xml:lang="en">OBI branch derived</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">OBI分支派生</obo:IAO_0000119>
        <obo:IAO_0000119 xml:lang="en">OBI_0000187</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">OBI_0000187</obo:IAO_0000119>
        <rdfs:label xml:lang="en">data format specification</rdfs:label> <rdfs:label xml:lang="zh">数据格式规范</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/IAO_0000100 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/IAO_0000100">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000027"/>
        <obo:IAO_0000112 xml:lang="en">Intensity values in a CEL file or from multiple CEL files comprise a data set (as opposed to the CEL files themselves).</obo:IAO_0000112> <obo:IAO_0000112 xml:lang="zh">CEL文件中的强度值或来自多个CEL文件的强度值构成数据集（而不是CEL文件本身）。</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">A data item that is an aggregate of other data items of the same type that have something in common. Averages and distributions can be determined for data sets.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">一种数据项，它是其他同类数据项的聚合，这些数据项有共同点。可以对数据集确定平均值和分布。</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">2009/10/23 Alan Ruttenberg. The intention is that this term represent collections of like data. So this isn't for, e.g. the whole contents of a cel file, which includes parameters, metadata etc. This is more like java arrays of a certain rather specific type</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">2009/10/23 Alan Ruttenberg. 其意图是让该术语代表同类数据的集合。因此，这并不适用于例如cel文件的全部内容，其中包含参数、元数据等。这更像是某种相当特定类型的Java数组。</obo:IAO_0000116>
        <obo:IAO_0000116 xml:lang="en">2014-05-05: Data sets are aggregates and thus must include two or more data items. We have chosen not to add logical axioms to make this restriction.</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">2014-05-05: 数据集是聚合体，因此必须包含两个或更多数据项。我们选择不添加逻辑公理来施加这一限制。</obo:IAO_0000116>
        <obo:IAO_0000119 xml:lang="en">OBI_0000042</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">OBI_0000042</obo:IAO_0000119>
        <obo:IAO_0000119 xml:lang="en">group:OBI</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">组:OBI</obo:IAO_0000119>
        <rdfs:label xml:lang="en">data set</rdfs:label> <rdfs:label xml:lang="zh">数据集</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/IAO_0000104 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/IAO_0000104">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000033"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/IAO_0000005"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/IAO_0000007"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000112 xml:lang="en">PMID: 18323827.Nat Med. 2008 Mar;14(3):226.New plan proposed to help resolve conflicting medical advice.</obo:IAO_0000112> <obo:IAO_0000112 xml:lang="zh">PMID: 18323827.Nat Med. 2008 Mar;14(3):226.提出了帮助解决相互矛盾的医疗建议的新计划。</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">A directive information entity with action specifications and objective specifications as parts, and that may be concretized as a realizable entity that, if realized, is realized in a process in which the bearer tries to achieve the objectives by taking the actions specified.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">一种指导性信息实体，以行动规范和目标规范为组成部分，并且可以具体化为一个可实现实体，如果实现，则在过程中实现，其中承载者通过采取所指定的行动来努力实现目标。</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">2009-03-16: provenance: a term a plan was proposed for OBI (OBI_0000344) , edited by the PlanAndPlannedProcess branch. Original definition was " a plan is a specification of a process that is realized by an actor to achieve the objective specified as part of the plan". It has been subsequently moved to IAO where the objective for which the original term was defined was satisfied with the definitionof this, different, term.</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">2009-03-16: 来源：为OBI (OBI_0000344) 提出了术语'计划'，由PlanAndPlannedProcess分支编辑。原始定义是“计划是对过程的规范，由参与者实现以达到计划中指定的目标”。随后它被移至IAO，其中原始术语定义的目标通过这个不同的术语的定义得到了满足。</obo:IAO_0000116>
        <obo:IAO_0000116 xml:lang="en">2014-03-31: A plan specification can have other parts, such as conditional specifications.</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">2014-03-31: 计划规范可以有其他部分，例如条件规范。</obo:IAO_0000116>
        <obo:IAO_0000116 xml:lang="en">2022-01-16 Updated definition to that proposed by Clint Dowloand, IAO Issue 231.</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">2022-01-16 更新为Clint Dowloand在IAO Issue 231中提出的定义。</obo:IAO_0000116>
        <obo:IAO_0000116 xml:lang="en">Alternative previous definition: a plan is a set of instructions that specify how an objective should be achieved</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">替代的先前定义：计划是一组说明如何实现目标的指令</obo:IAO_0000116>
        <obo:IAO_0000119 xml:lang="en">OBI Plan and Planned Process branch</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">OBI 计划与计划过程分支</obo:IAO_0000119>
        <obo:IAO_0000119 xml:lang="en">OBI_0000344</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">OBI_0000344</obo:IAO_0000119>
        <rdfs:comment xml:lang="en">2/3/2009 Comment from OBI review.

Action specification not well enough specified.
Conditional specification not well enough specified.
Question whether all plan specifications have objective specifications.

Request that IAO either clarify these or change definitions not to use them</rdfs:comment>
        <rdfs:label xml:lang="en">plan specification</rdfs:label> <rdfs:label xml:lang="zh">计划规范</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/IAO_0000109 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/IAO_0000109">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000027"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0001938"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OBI_0001933"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000112 xml:lang="en">Examples of measurement data are the recoding of the weight of a mouse as {40,mass,"grams"}, the recording of an observation of the behavior of the mouse {,process,"agitated"}, the recording of the expression level of a gene as measured through the process of microarray experiment {3.4,luminosity,}.</obo:IAO_0000112> <obo:IAO_0000112 xml:lang="zh">测量数据的例子包括将小鼠体重记录为{40,mass,"grams"}，记录小鼠行为的观察结果{,process,"agitated"}，以及通过微阵列实验过程测量的基因表达水平记录{3.4,luminosity,}。</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">A measurement datum is an information content entity that is a recording of the output of a measurement such as produced by a device.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">测量数据是一种信息内容实体，是测量输出的记录，例如由设备产生。</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">2/2/2009 is_specified_output of some assay?</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">2/2/2009 是某个检测的指定输出？</obo:IAO_0000116>
        <obo:IAO_0000119 xml:lang="en">OBI_0000305</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">OBI_0000305</obo:IAO_0000119>
        <obo:IAO_0000119 xml:lang="en">group:OBI</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">组:OBI</obo:IAO_0000119>
        <rdfs:label xml:lang="en">measurement datum</rdfs:label> <rdfs:label xml:lang="zh">测量数据</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/IAO_0000129 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/IAO_0000129">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000028"/>
        <obo:IAO_0000115 xml:lang="en">A version number is an information content entity which is a sequence of characters borne by part of each of a class of manufactured products or its packaging and indicates its order within a set of other products having the same name.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">版本号是一种信息内容实体，它是由一类制造产品或其包装的某部分承载的字符序列，并指示其在具有相同名称的其他产品集合中的顺序。</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Note: we feel that at the moment we are happy with a general version number, and that we will subclass as needed in the future. For example, see 7. genome sequence version</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">注：我们认为目前通用的版本号已经足够，未来会根据需要进行子分类。例如，参见7. 基因组序列版本。</obo:IAO_0000116>
        <rdfs:label xml:lang="en">version number</rdfs:label> <rdfs:label xml:lang="zh">版本号</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/IAO_0000300 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/IAO_0000300">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000030"/>
        <obo:IAO_0000112 xml:lang="en">Words, sentences, paragraphs, and the written (non-figure) parts of publications are all textual entities</obo:IAO_0000112> <obo:IAO_0000112 xml:lang="zh">单词、句子、段落以及出版物中非图形的书面部分都是文本实体</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">A textual entity is a part of a manifestation (FRBR sense), a generically dependent continuant whose concretizations are patterns of glyphs intended to be interpreted as words, formulas, etc.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">文本实体是表现（FRBR意义上的）的一部分，是一种普遍依赖的持续存在物，其具体化是旨在被解释为单词、公式等的字形模式。</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">AR, (IAO call 2009-09-01): a document as a whole is not typically a textual entity, because it has pictures in it - rather there are parts of it that are textual entities. Examples: The title, paragraph 2 sentence 7, etc.</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">AR，（IAO通话2009-09-01）：一个文档整体上通常不是文本实体，因为它包含图片——而是它的一些部分构成文本实体。例如：标题、第2段第7句等。</obo:IAO_0000116>
        <obo:IAO_0000116 xml:lang="en">MC, 2009-09-14 (following IAO call 2009-09-01): textual entities live at the FRBR (http://en.wikipedia.org/wiki/Functional_Requirements_for_Bibliographic_Records) manifestation level. Everything is significant: line break, pdf and html versions of same document are different textual entities.</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">MC，2009-09-14（遵循IAO通话2009-09-01）：文本实体存在于FRBR（http://en.wikipedia.org/wiki/Functional_Requirements_for_Bibliographic_Records）表现层面。一切都有意义：同一文档的换行、PDF和HTML版本是不同的文本实体。</obo:IAO_0000116>
        <rdfs:label xml:lang="en">textual entity</rdfs:label> <rdfs:label xml:lang="zh">文本实体</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/IAO_0000310 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/IAO_0000310">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000030"/>
        <obo:IAO_0000112 xml:lang="en">A journal article, patent application, laboratory notebook, or a book</obo:IAO_0000112> <obo:IAO_0000112 xml:lang="zh">一篇期刊文章、专利申请、实验室笔记或一本书</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">A collection of information content entities intended to be understood together as a whole</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">一组信息内容实体的集合，旨在作为一个整体被理解</obo:IAO_0000115>
        <rdfs:label xml:lang="en">document</rdfs:label> <rdfs:label xml:lang="zh">文档</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/IAO_0000311 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/IAO_0000311">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/IAO_0000310"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000312"/>
                        <owl:allValuesFrom rdf:resource="http://purl.obolibrary.org/obo/IAO_0000444"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000310"/>
        <obo:IAO_0000112 xml:lang="en">journal article, newspaper story, book, etc.</obo:IAO_0000112> <obo:IAO_0000112 xml:lang="zh">期刊文章、新闻报道、书籍等</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">A document that is the output of a publishing process.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">作为出版过程输出的文档。</obo:IAO_0000115>
        <obo:IAO_0000233 rdf:resource="https://github.com/information-artifact-ontology/IAO/issues/232"/>
        <rdfs:comment xml:lang="en">Revisit the term in Octorber 2020. Improve the defintion.</rdfs:comment>
        <rdfs:label xml:lang="en">publication</rdfs:label> <rdfs:label xml:lang="zh">出版物</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/IAO_0000444 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/IAO_0000444">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/COB_0000035"/>
        <obo:IAO_0000115 xml:lang="en">A planned process of making information, such as literature, music, and software etc., available to the public for sale or for free.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">一个计划性的过程，使信息（如文学、音乐、软件等）向公众提供，供出售或免费使用。</obo:IAO_0000115>
        <obo:IAO_0000119>https://en.wikipedia.org/wiki/Publishing</obo:IAO_0000119>
        <obo:IAO_0000233 rdf:resource="https://github.com/information-artifact-ontology/IAO/issues/232"/>
        <rdfs:label xml:lang="en">publishing process</rdfs:label> <rdfs:label xml:lang="zh">出版过程</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/IAO_0000591 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/IAO_0000591">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000010"/>
        <obo:IAO_0000115 xml:lang="en">A software method (also called subroutine, subprogram, procedure, method, function, or routine) is software designed to execute a specific task.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">软件方法（也称为子程序、子过程、过程、方法、函数或例程）是旨在执行特定任务的软件。</obo:IAO_0000115>
        <obo:IAO_0000119 xml:lang="en">https://github.com/information-artifact-ontology/IAO/issues/80</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">https://github.com/information-artifact-ontology/IAO/issues/80</obo:IAO_0000119>
        <rdfs:label xml:lang="en">software method</rdfs:label> <rdfs:label xml:lang="zh">软件方法</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/IAO_0020000 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/IAO_0020000">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/IAO_0000030"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000219"/>
                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000001"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000312"/>
                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/IAO_0020010"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000030"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000219"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000001"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000312"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/IAO_0020010"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115 xml:lang="en">An information content entity that is the outcome of a dubbing process and is used to refer to one instance of entity shared by a group of people to refer to that individual entity.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">一种信息内容实体，是配音过程的结果，用于指代一组人共享的实体实例，以指代该个体实体。</obo:IAO_0000115>
        <obo:IAO_0000233 xml:lang="en">https://github.com/information-artifact-ontology/IAO/issues/237</obo:IAO_0000233> <obo:IAO_0000233 xml:lang="zh">https://github.com/information-artifact-ontology/IAO/issues/237</obo:IAO_0000233>
        <rdfs:comment xml:lang="en">Sep 29, 2016: The current definition has been amended from the previous version: "A proper name is an information content entity that is the outcome of a dubbing process and is used to refer to one instance of entity shared by a group of people to refer to that individual entity." to more accuratly reflect the necessary and sufficient condition on the class. (MB)</rdfs:comment>
        <rdfs:label xml:lang="en">identifier</rdfs:label> <rdfs:label xml:lang="zh">标识符</rdfs:label>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/IAO_0020010 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/IAO_0020010">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/COB_0000035"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000299"/>
                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/IAO_0020000"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/COB_0000035"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000299"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/IAO_0020000"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115 xml:lang="en">A planned process that provides a reference to an individual entity shared by a group of subscribers to refer to that individual entity.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">一个计划性的过程，提供对一组订阅者共享的个体实体的引用，以指代该个体实体。</obo:IAO_0000115>
        <obo:IAO_0000233 xml:lang="en">https://github.com/information-artifact-ontology/IAO/issues/237</obo:IAO_0000233> <obo:IAO_0000233 xml:lang="zh">https://github.com/information-artifact-ontology/IAO/issues/237</obo:IAO_0000233>
        <rdfs:label xml:lang="en">identifier creating process</rdfs:label> <rdfs:label xml:lang="zh">标识符创建过程</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/NCBITaxon_9606 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/NCBITaxon_9606">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000040"/>
        <rdfs:label>Homo sapiens</rdfs:label>
        <rdfs:label>homo sapiens</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBI_0000011 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBI_0000011">
        <obo:IAO_0000112 xml:lang="en">Injecting mice with a vaccine in order to test its efficacy</obo:IAO_0000112> <obo:IAO_0000112 xml:lang="zh">为了测试疫苗效力而给小鼠注射疫苗</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">A process that realizes a plan which is the concretization of a plan specification.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">实现一个计划的过程，该计划是计划规范的具体化。</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">'Plan' includes a future direction sense. That can be problematic if plans are changed during their execution. There are however implicit contingencies for protocols that an agent has in his mind that can be considered part of the plan, even if the agent didn't have them in mind before. Therefore, a planned process can diverge from what the agent would have said the plan was before executing it, by adjusting to problems encountered during execution (e.g. choosing another reagent with equivalent properties, if the originally planned one has run out.)</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">'计划'包含未来方向的意义。如果在执行过程中计划发生改变，这可能会带来问题。然而，对于代理心中已有的协议，存在隐含的应急措施，这些措施可以被视为计划的一部分，即使代理之前并未考虑到它们。因此，计划性过程可能会偏离代理在执行前所说的计划，通过调整以应对执行中遇到的问题（例如，如果原计划使用的试剂用完，则选择另一种具有等效性质的试剂。）</obo:IAO_0000116>
        <obo:IAO_0000116 xml:lang="en">PMDco : migration: https://github.com/materialdigital/core-ontology/issues/269</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">PMDco：迁移：https://github.com/materialdigital/core-ontology/issues/269</obo:IAO_0000116>
        <obo:IAO_0000116 xml:lang="en">We are only considering successfully completed planned processes. A plan may be modified, and details added during execution. For a given planned process, the associated realized plan specification is the one encompassing all changes made during execution. This means that all processes in which an agent acts towards achieving some objectives is a planned process.</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">我们只考虑成功完成的计划性过程。计划可以在执行过程中被修改并添加细节。对于给定的计划性过程，相关联的实现计划规范是包含执行过程中所有变更的那个。这意味着，所有代理为实现某些目标而采取行动的过程都是计划性过程。</obo:IAO_0000116>
        <obo:IAO_0000119 xml:lang="en">branch derived</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">分支派生</obo:IAO_0000119>
        <obo:IAO_0000232>6/11/9: Edited at workshop. Used to include: is initiated by an agent</obo:IAO_0000232>
        <obo:IAO_0000232>This class merges the previously separated objective driven process and planned process, as they the separation proved hard to maintain. (1/22/09, branch call)</obo:IAO_0000232>
        <obo:IAO_0100001 rdf:resource="http://purl.obolibrary.org/obo/COB_0000035"/>
        <rdfs:label xml:lang="en">obsolete planned process</rdfs:label> <rdfs:label xml:lang="zh">过时的计划性过程</rdfs:label>
        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBI_0000067 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBI_0000067">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000023"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000052"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000040"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OBI_0000070"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000112 xml:lang="en">When a specimen of blood is assayed for glucose concentration, the blood has the evaluant role. When measuring the mass of a mouse, the evaluant is the mouse. When measuring the time of DNA replication, the evaluant is the DNA. When measuring the intensity of light on a surface, the evaluant is the light source.</obo:IAO_0000112> <obo:IAO_0000112 xml:lang="zh">当检测血液样本中的葡萄糖浓度时，血液具有被评估者角色。当测量小鼠的质量时，被评估者是小鼠。当测量DNA复制的时间时，被评估者是DNA。当测量表面光照强度时，被评估者是光源。</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">a role that inheres in a material entity that is realized in an assay in which data is generated about the bearer of the evaluant role</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">一种内在于物质实体的角色，该角色在产生关于其承载者的数据的测定中被实现。</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Role call - 17nov-08: JF and MC think an evaluant role is always specified input of a process. Even in the case where we have an assay taking blood as evaluant and outputting blood, the blood is not the specified output at the end of the assay (the concentration of glucose in the blood is)</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">角色讨论 - 2008年11月17日：JF和MC认为被评估者角色始终是过程的指定输入。即使在我们有一个以血液为被评估者并输出血液的测定中，血液也不是测定结束时的指定输出（输出的是血液中的葡萄糖浓度）</obo:IAO_0000116>
        <obo:IAO_0000116 xml:lang="en">examples of features that could be described in an evaluant: quality.... e.g. "contains 10 pg/ml IL2", or "no glucose detected")</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">可描述被评估者特征的示例：质量……例如“含有10 pg/ml IL2”，或“未检测到葡萄糖”）</obo:IAO_0000116>
        <obo:IAO_0000119>OBI</obo:IAO_0000119>
        <obo:IAO_0000232>Feb 10, 2009.  changes after discussion at OBI Consortium Workshop Feb 2-6, 2009.  accepted as core term.</obo:IAO_0000232>
        <rdfs:label xml:lang="en">evaluant role</rdfs:label> <rdfs:label xml:lang="zh">被评估者角色</rdfs:label>
    </owl:Class>
    


