                                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020228"/>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">solution</rdfs:label> <rdfs:label xml:lang="zh">溶液</rdfs:label>
        <skos:definition xml:lang="en">A portion of matter that is homogeneous, made up of at least two entity types, one playing the role of sovlent and the others playing the role of solute</skos:definition> <skos:definition xml:lang="zh">一种均匀的物质部分，由至少两种实体类型组成，其中一种扮演溶剂角色，其他扮演溶质角色</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020230 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020230">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0020229"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000086"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:intersectionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000512"/>
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="https://w3id.org/pmd/co/PMD_0000077"/>
                                        <owl:hasValue rdf:resource="https://w3id.org/pmd/co/PMD_0020117"/>
