        <rdfs:label xml:lang="en">electroceramic</rdfs:label> <rdfs:label xml:lang="zh">电陶瓷</rdfs:label>
        <skos:definition xml:lang="en">ceramic that is specifically engineered for electrical, magnetic, or superconducting applications</skos:definition> <skos:definition xml:lang="zh">专门为电气、磁性或超导应用设计的陶瓷</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050082 -->

