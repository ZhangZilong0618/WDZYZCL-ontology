        <rdfs:label xml:lang="en">zirconium diboride ceramic</rdfs:label> <rdfs:label xml:lang="zh">二硼化锆陶瓷</rdfs:label>
        <skos:definition xml:lang="en">boride ceramic that is a non-oxide ceramic composed of zirconium and boron, known for its excellent thermal conductivity and stability</skos:definition> <skos:definition xml:lang="zh">由锆和硼组成的非氧化物陶瓷，以其优异的热导率和稳定性著称</skos:definition>
        <PMD_0050117>ZrB₂</PMD_0050117>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050074 -->

