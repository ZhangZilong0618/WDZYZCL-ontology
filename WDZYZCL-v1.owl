                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OBI_0000571"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115 xml:lang="en">A person or organization that has a manufacturer role.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">具有制造商角色的个人或组织。</obo:IAO_0000115>
        <rdfs:label xml:lang="en">manufacturer</rdfs:label> <rdfs:label xml:lang="zh">制造商</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBI_0001930 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBI_0001930">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBI_0001933"/>
        <obo:IAO_0000115 xml:lang="en">A value specification that is specifies one category out of a fixed number of nominal categories</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">指定固定数量的名义类别中的一个类别的值规范。</obo:IAO_0000115>
        <rdfs:label xml:lang="en">categorical value specification</rdfs:label> <rdfs:label xml:lang="zh">分类值规范</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBI_0001931 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBI_0001931">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBI_0001933"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0001937"/>
                <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115 xml:lang="en">A value specification that consists of two parts: a numeral and a unit label</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">由数字和单位标签两部分组成的值规范。</obo:IAO_0000115>
        <rdfs:label xml:lang="en">scalar value specification</rdfs:label> <rdfs:label xml:lang="zh">标量值规范</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBI_0001933 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBI_0001933">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000030"/>
        <obo:IAO_0000112 xml:lang="en">The value of 'positive' in a classification scheme of "positive or negative"; the value of '20g' on the quantitative scale of mass.</obo:IAO_0000112> <obo:IAO_0000112 xml:lang="zh">在'阳性或阴性'分类方案中'阳性'的值；在质量定量标度上'20g'的值。</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">An information content entity that specifies a value within a classification scheme or on a quantitative scale.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">在分类方案或定量标度上指定值的信息内容实体。</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">This term is currently a descendant of 'information content entity', which requires that it 'is about' something. A value specification of '20g' for a measurement data item of the mass of a particular mouse 'is about' the mass of that mouse. However there are cases where a value specification is not clearly about any particular. In the future we may change 'value specification' to remove the 'is about' requirement.</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">该术语当前是'信息内容实体'的子类，要求它'关于'某物。对于特定小鼠质量的测量数据项，'20g'的值规范'关于'该小鼠的质量。然而，有些情况下值规范并不明确关于任何特定事物。未来我们可能会更改'值规范'以移除'关于'的要求。</obo:IAO_0000116>
        <rdfs:label xml:lang="en">value specification</rdfs:label> <rdfs:label xml:lang="zh">值规范</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBI_0002201 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBI_0002201">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/COB_0000082"/>
        <obo:IAO_0000115 xml:lang="en">A planned process that is used to assess whether an assay will provide reliable results based on the conditions or qualities of the inputs, devices, and other participants of the assay.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">一种计划过程，用于根据测定输入、设备和其他参与者的条件或质量来评估测定是否将提供可靠结果。</obo:IAO_0000115>
        <obo:IAO_0000119>OBI</obo:IAO_0000119>
        <rdfs:label xml:lang="en">determination if assay will provide reliable results</rdfs:label> <rdfs:label xml:lang="zh">测定是否将提供可靠结果的确定</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBI_0302911 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBI_0302911">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/COB_0000035"/>
        <obo:IAO_0000112 xml:lang="en">PMID: 18557814 . Chemical and genetic validation of dihydrofolate reductase-thymidylate synthase as a drug target in African trypanosomes. Mol Microbiol. 2008 Jun 16.</obo:IAO_0000112> <obo:IAO_0000112 xml:lang="zh">PMID: 18557814 . 二氢叶酸还原酶-胸苷酸合成酶作为非洲锥虫药物靶点的化学和遗传验证。Mol Microbiol. 2008年6月16日。</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">a planned process with objective to check that the accuracy or the quality of a claim or prediction  satisfies some criteria and which is assessed by comparing with independent results</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">一种计划过程，其目标是检查声明或预测的准确性或质量是否满足某些标准，并通过与独立结果进行比较来评估。</obo:IAO_0000115>
        <obo:IAO_0000119 xml:lang="en">adapted from wordnet (wkipedia)</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">改编自WordNet（维基百科）</obo:IAO_0000119>
        <rdfs:label xml:lang="en">validation</rdfs:label> <rdfs:label xml:lang="zh">验证</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/UO_0000000 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UO_0000000">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000003"/>
        <obo:IAO_0000115 xml:lang="en">A unit of measurement is a standardized quantity of a physical quality.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">计量单位是物理量的标准化量度。</obo:IAO_0000115>
        <rdfs:label xml:lang="en">unit</rdfs:label> <rdfs:label xml:lang="zh">单位</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/UO_0000000"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>A unit of measurement is a standardized quantity of a physical quality.</owl:annotatedTarget>
        <oboInOwl:hasDbXref>Wikipedia:Wikipedia</oboInOwl:hasDbXref>
    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/UO_0000003 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UO_0000003">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UO_0000000"/>
        <obo:IAO_0000115 xml:lang="en">A unit which is a standard measure of the dimension in which events occur in sequence.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">时间单位是事件按顺序发生的维度的标准度量。</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>time derived unit</oboInOwl:hasExactSynonym>
        <rdfs:label xml:lang="en">time unit</rdfs:label> <rdfs:label xml:lang="zh">时间单位</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/UO_0000003"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>A unit which is a standard measure of the dimension in which events occur in sequence.</owl:annotatedTarget>
        <oboInOwl:hasDbXref>Wikipedia:Wikipedia</oboInOwl:hasDbXref>
    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/UO_0000076 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UO_0000076">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UO_1000076"/>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/UO_0000163 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UO_0000163">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UO_1000163"/>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/UO_0000164 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UO_0000164">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UO_1000164"/>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/UO_1000076 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UO_1000076">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UO_0000000"/>
        <rdfs:label xml:lang="en">mole fraction based unit</rdfs:label> <rdfs:label xml:lang="zh">基于摩尔分数的单位</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/UO_1000163 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UO_1000163">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UO_0000000"/>
        <rdfs:label xml:lang="en">mass percentage based unit</rdfs:label> <rdfs:label xml:lang="zh">基于质量百分比的单位</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/UO_1000164 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UO_1000164">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UO_0000000"/>
        <rdfs:label xml:lang="en">mass volume percentage based unit</rdfs:label> <rdfs:label xml:lang="zh">基于质量体积百分比的单位</rdfs:label>
    </owl:Class>
    


    <!-- https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000027 -->

    <owl:Class rdf:about="https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000027">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000027"/>
        <rdfs:comment xml:lang="en">A file data item is a data item that represents a file stored on a hard drive. It might also include essential attributes like its name, location, download URL, size, type, and timestamps for creation, modification, and access. It might also capture permissions and ownership details to control how the file can be accessed or modified.</rdfs:comment>
        <rdfs:label xml:lang="en">file data item</rdfs:label> <rdfs:label xml:lang="zh">文件数据项</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000000 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000000">
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000001"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000053"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000005"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000086"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020131"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002353"/>
                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Instances of Portions Of Matter whose shape is relevant for their dispostion to participate in a manufacturing process may be (subclasses of) objects that bear a 'blank role' in the context of the manufacturing process.</rdfs:comment>
        <rdfs:comment xml:lang="en">Material is defined in terms of the three main perspectives that material specifications rely on: the structure of the material ("intensive quality"), the performance of the material ("behavoiral material property") and the processing the material must have undergone ("output of some process").

When defining specific materials/material taxonomies, these three aspects shall be taken into account in the aristotelian ("per genus et differentiam") as differentiation.</rdfs:comment>
        <rdfs:comment xml:lang="en">The sum of portions of matter of the same type form a portion of matter of that type.</rdfs:comment>
        <rdfs:label xml:lang="de">Material</rdfs:label> <rdfs:label xml:lang="zh">材料</rdfs:label>
        <rdfs:label xml:lang="en">material</rdfs:label> <rdfs:label xml:lang="zh">材料</rdfs:label>
        <skos:altLabel xml:lang="en">Portion of Material</skos:altLabel> <skos:altLabel xml:lang="zh">材料部分</skos:altLabel>
        <skos:definition xml:lang="en">A material is a portion of matter that may participate in some manufacturing process and whose shape is not relevant for its participation in the manufacturing process.</skos:definition> <skos:definition xml:lang="zh">材料是可能参与某些制造过程的物质部分，其形状对于参与制造过程并不重要。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000001 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000001">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000040"/>
        <rdfs:comment xml:lang="en">It is also representing a distinct physical or conceptual part of a material or substance.

The open energy ontology OEO defines portion of matter as a subclass of object aggregate, which implies countability. Our portion is not (precisely) countable and thus bearer of intensive properties.</rdfs:comment>
        <rdfs:comment xml:lang="en">Lome explanation for portion of matter: "What is a molecule cluster at the cellular level? Contrary to the molecular level, at the cellular level of granularity the boundary of each molecule is outside of the level of granular focus. What forms a discontinuous cluster of countable individual molecules and thus bona fide objects at the molecular level, is a continuous and non-countable molecular substance at coarser levels of
granularity. At these coarser levels, the individual molecules cannot be differentiated and demarcated anymore and the cluster as a whole possesses only fiat inner boundaries."</rdfs:comment>
        <rdfs:label xml:lang="en">portion of matter</rdfs:label> <rdfs:label xml:lang="zh">物质部分</rdfs:label>
        <skos:definition xml:lang="en">A material entity that is not demarcated by any physical discontinuities. At some finer level of granularity it is an object aggregate, at some coarser level of granularity it is a fiat object part,but at this level of granularity it is neither.</skos:definition> <skos:definition xml:lang="zh">一种未被任何物理不连续性界定的材料实体。在更细的粒度层次上，它是一个对象聚合体；在更粗的粒度层次上，它是一个平直对象部分；但在该粒度层次上，两者都不是。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000002 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000002">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000000"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000312"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000833"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000000"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000312"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000833"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">We recognize that some of the materials in the subclasses also occur naturally. However, these are not within the scope of our consideration for technical use.</rdfs:comment>
        <rdfs:label xml:lang="en">engineered material</rdfs:label> <rdfs:label xml:lang="zh">工程材料</rdfs:label>
        <skos:definition xml:lang="en">An engineered material is a material that is output of a manufacturing process.</skos:definition> <skos:definition xml:lang="zh">工程材料是制造过程输出的材料。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000005 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000005">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000016"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000950"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf rdf:nodeID="genid177"/>
        <rdfs:comment xml:lang="en">A property is a material trait in terms of the kind and magnitude of response to a specific imposed stimulus. Generally, definitions of properties are made independent of material shape and size.
(Callister, W.D., Rethwisch, D.G., Materials Science and Engineering, Wiley, 2014)

Technical materials are complex aggregates. Many properties that are determined for those aggregates are intrinsically associated with the methodologies employed in the measurement process. This is in contrast to typical 'physical' properties, which like e.g. mass that can be determined to high accuracy independently of the measurement process. 
As a consequence, material properties in the ontology are differeciated according to their measurement method, e.g. Brinell hardness and Vickers hardness are different types of indentation hardness rather than different measures/quantification (GDC) of the materials property 'indentation hardness'.
 The 'unit idenifieres' of such properties (e.g. "HV1", "HV10", "HBW") are strictly speaking not units but rather references to the measurement methodology used to determine a numeric value that quantifies the property.

Extensive properties that depend on the object being tested rather than on the portion of matter are (extensive) object- or system-properties.</rdfs:comment>
        <rdfs:label xml:lang="en">material property</rdfs:label> <rdfs:label xml:lang="zh">材料属性</rdfs:label>
        <skos:definition xml:lang="en">a disposition of a portion of matter that is realized in a compatible process and whose realization is grounded in the portions intensive qualities</skos:definition> <skos:definition xml:lang="zh">物质部分的一种倾向，在兼容过程中得以实现，其实现基于该部分的密集性质。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    <owl:Restriction rdf:nodeID="genid177">
        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000052"/>
        <owl:someValuesFrom>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000001"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000056"/>
                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:someValuesFrom>
    </owl:Restriction>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://w3id.org/pmd/co/PMD_0000005"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:nodeID="genid177"/>
        <rdfs:comment xml:lang="en">Due to the duality of object and portion of matter this axiom can not be an equivalent class axiom.</rdfs:comment>
    </owl:Axiom>
    


    <!-- https://w3id.org/pmd/co/PMD_0000007 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000007">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBI_0001933"/>
        <obo:IAO_0000116 xml:lang="en">also see "The Ontology of Fields" - Report of a specialist meeting held under the auspices of the varenius project: Donna Peuquet, Barry Smith, and Berit Brogaard; Bar Harbor, Maine 1998</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">另见《场的本体论》——在Varenius项目支持下召开的专家会议报告：Donna Peuquet、Barry Smith和Berit Brogaard；缅因州巴尔港，1998年</obo:IAO_0000116>
        <rdfs:label xml:lang="en">vector field specification</rdfs:label> <rdfs:label xml:lang="zh">向量场规范</rdfs:label>
        <skos:definition xml:lang="en">Vector field specification is a value specification that represents an assignment of a vector to each point in a discretized spatial region.</skos:definition> <skos:definition xml:lang="zh">向量场规范是一种值规范，表示将向量分配给离散空间区域中的每个点。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000008 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000008">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000003"/>
        <obo:IAO_0000116 xml:lang="en">an attribute of a process</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">过程的属性</obo:IAO_0000116>
        <rdfs:comment xml:lang="en">Process attribute for a process has a similar application to specifically dependened continuant (SDC) for an independent continuant (IC). Furthermore, process attribute describes how SDCs of some participants, i.e., ICs, change in a process. 

Specific rates, e.g., tensile rate, cooling rate, etc. should be added as  subclasses of this class.</rdfs:comment>
        <rdfs:label xml:lang="en">process attribute</rdfs:label> <rdfs:label xml:lang="zh">过程属性</rdfs:label>
        <rdfs:seeAlso xml:lang="en">process attribute from OEO https://openenergyplatform.org/ontology/oeo/OEO_00030019</rdfs:seeAlso>
        <owl:versionInfo xml:lang="en">Renamed to avoid confusion with has characteristic object property</owl:versionInfo>
        <skos:altLabel xml:lang="en">process characteristic</skos:altLabel> <skos:altLabel xml:lang="zh">过程特征</skos:altLabel>
        <skos:definition xml:lang="en">a process attribute is a dependent occurrent that existentially depends on a process.</skos:definition> <skos:definition xml:lang="zh">过程属性是一种依赖的持续发生，它存在性地依赖于一个过程。</skos:definition>
        <skos:example xml:lang="en">Tensile rate in a tensile testing process. Cooling rate in a quenching process</skos:example> <skos:example xml:lang="zh">拉伸测试过程中的拉伸速率。淬火过程中的冷却速率</skos:example>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000010 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000010">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000591"/>
        <rdfs:label xml:lang="en">workflow function</rdfs:label> <rdfs:label xml:lang="zh">工作流函数</rdfs:label>
        <skos:definition xml:lang="en">A plan specification representing a callable software method that prescribes a specific computational action, including execution instructions and a defined set of input and output specifications.</skos:definition> <skos:definition xml:lang="zh">一种计划规范，表示可调用的软件方法，规定特定的计算动作，包括执行指令和一组定义的输入输出规范。</skos:definition>
        <PMD_0001032>https://github.com/materialdigital/core-ontology/issues/246</PMD_0001032>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000011 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000011">
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000583"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:unionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000066"/>
                                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000067"/>
                                </owl:unionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000059"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000010"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">workflow node</rdfs:label> <rdfs:label xml:lang="zh">工作流节点</rdfs:label>
        <skos:definition xml:lang="en">A computing process that executes a workflow function within a workflow run, consuming input data and producing output data according to the function’s specifications.</skos:definition> <skos:definition xml:lang="zh">一种计算过程，在工作流运行中执行工作流函数，根据函数规范消耗输入数据并产生输出数据。</skos:definition>
        <PMD_0001032>https://github.com/materialdigital/core-ontology/issues/246</PMD_0001032>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000012 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000012">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000104"/>
        <rdfs:label xml:lang="en">workflow definition</rdfs:label> <rdfs:label xml:lang="zh">工作流定义</rdfs:label>
        <skos:definition xml:lang="en">A plan specification that prescribes the ordered application of one or more workflow functions, including their interconnections via input and output specifications, in order to achieve a specified computational objective.</skos:definition> <skos:definition xml:lang="zh">一种计划规范，规定一个或多个工作流函数的有序应用，包括通过输入输出规范的相互连接，以实现指定的计算目标。</skos:definition>
        <PMD_0001032>https://github.com/materialdigital/core-ontology/issues/246</PMD_0001032>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000013 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000013">
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/IAO_0000033"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/IAO_0000027"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">parameter specification</rdfs:label> <rdfs:label xml:lang="zh">参数规范</rdfs:label>
        <skos:definition xml:lang="en">A directive information entity that specifies a parameter required or produced by a workflow function, including its intended role, position, and constraints.</skos:definition> <skos:definition xml:lang="zh">一种指令信息实体，指定工作流函数需要或产生的参数，包括其预期角色、位置和约束。</skos:definition>
        <PMD_0001032>https://github.com/materialdigital/core-ontology/issues/246</PMD_0001032>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000014 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000014">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000013"/>
        <rdfs:label xml:lang="en">input specification</rdfs:label> <rdfs:label xml:lang="zh">输入规范</rdfs:label>
        <skos:definition xml:lang="en">A parameter specification that prescribes a data item required as input for the execution of a workflow function.</skos:definition> <skos:definition xml:lang="zh">一种参数规范，规定工作流函数执行所需的输入数据项。</skos:definition>
        <PMD_0001032>https://github.com/materialdigital/core-ontology/issues/246</PMD_0001032>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000015 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000015">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000013"/>
        <rdfs:label xml:lang="en">output specification</rdfs:label> <rdfs:label xml:lang="zh">输出规范</rdfs:label>
        <skos:definition xml:lang="en">A parameter specification that prescribes a data item intended to be produced as output by the execution of a workflow function.</skos:definition> <skos:definition xml:lang="zh">一种参数规范，规定工作流函数执行应产生的输出数据项。</skos:definition>
        <PMD_0001032>https://github.com/materialdigital/core-ontology/issues/246</PMD_0001032>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000016 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000016">
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000583"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000059"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000012"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">workflow run</rdfs:label> <rdfs:label xml:lang="zh">工作流运行</rdfs:label>
        <skos:definition xml:lang="en">A computing process that realizes a workflow definition by executing its prescribed workflow nodes in a concrete temporal order, consuming and producing specific data items.</skos:definition> <skos:definition xml:lang="zh">一种计算过程，通过按照具体时间顺序执行规定的工作流节点来实现工作流定义，消耗和产生特定的数据项。</skos:definition>
        <PMD_0001032>https://github.com/materialdigital/core-ontology/issues/246</PMD_0001032>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000051 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000051">
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000023"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000933"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000081"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000004"/>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000056"/>
                                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000933"/>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">simulation entity role</rdfs:label> <rdfs:label xml:lang="zh">仿真实体角色</rdfs:label>
        <skos:definition xml:lang="en">Simulation entity role is a role that inheres in an independent continuant (IC) and is realized in a simulation process. This role enables the IC to participate in the simulation as a proxy, model, or representative of a real or hypothetical entity within the simulated context</skos:definition> <skos:definition xml:lang="zh">仿真实体角色是一种内在于独立持续体(IC)并在仿真过程中实现的角色。该角色使IC能够作为仿真情境中真实或假设实体的代理、模型或代表参与仿真。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000053 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000053">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/COB_0000035"/>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000547"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000293"/>
                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000040"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000299"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020139"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="de">Schmelzprozess</rdfs:label> <rdfs:label xml:lang="zh">熔炼过程</rdfs:label>
        <rdfs:label xml:lang="en">melting process</rdfs:label> <rdfs:label xml:lang="zh">熔化过程</rdfs:label>
        <skos:definition xml:lang="de">Ein Schmelzvorgang ist ein thermisch induzierter Prozess, bei dem ein festes Material einen Phasenübergang in einen flüssigen Zustand erfährt. Er beinhaltet die Absorption von Wärme und findet bei oder oberhalb des Schmelzpunkts des Materials statt.</skos:definition> <skos:definition xml:lang="zh">熔融过程是一种热诱导过程，其中固体材料经历相变为液态。它涉及热量的吸收，并在材料熔点或以上发生。</skos:definition>
        <skos:definition xml:lang="en">a thermally induced change of aggregate state during which a solid material undergoes a phase transition into a liquid state. It involves the absorption of heat and occurs at or above the material's melting point.</skos:definition> <skos:definition xml:lang="zh">一种热诱导的聚集状态变化，在此过程中固体材料相变为液态。它涉及热量的吸收，并在材料的熔点或以上发生。</skos:definition>
        <skos:example xml:lang="en">The process of melting aluminum ingots in preparation for extrusion.</skos:example> <skos:example xml:lang="zh">为准备挤压而熔化铝锭的过程。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000054 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000054">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000969"/>
        <rdfs:label xml:lang="de">Heizfunktion</rdfs:label> <rdfs:label xml:lang="zh">加热功能</rdfs:label>
        <rdfs:label xml:lang="en">heating function</rdfs:label> <rdfs:label xml:lang="zh">加热功能</rdfs:label>
        <skos:definition xml:lang="en">A temperature change function that, when realized, enables a system or device to increase the thermal energy of a material, typically to reach temperatures required for processing, transformation, or reaction.</skos:definition> <skos:definition xml:lang="zh">一种温度变化功能，当实现时，使系统或设备能够增加材料的热能，通常以达到加工、转化或反应所需的温度。</skos:definition>
        <skos:definition xml:lang="de">Eine Heizfunktion ist eine (realisierbare) Funktion, die ein System oder Gerät in die Lage versetzt, die Wärmeenergie eines Materials zu erhöhen, um die für die Verarbeitung, Umwandlung oder Reaktion erforderlichen Temperaturen zu erreichen.</skos:definition> <skos:definition xml:lang="zh">加热功能是一种（可实现的）功能，它使系统或设备能够增加材料的热能，以达到加工、转化或反应所需的温度。</skos:definition>
        <skos:example xml:lang="en">The function of a resistance heater in a vacuum furnace.</skos:example> <skos:example xml:lang="zh">真空炉中电阻加热器的功能。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000055 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000055">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000969"/>
        <rdfs:label xml:lang="de">Kühlfunktion</rdfs:label> <rdfs:label xml:lang="zh">冷却功能</rdfs:label>
        <rdfs:label xml:lang="en">cooling function</rdfs:label> <rdfs:label xml:lang="zh">冷却功能</rdfs:label>
        <skos:definition xml:lang="en">A temperature change function that enables a system or device to lower the temperature of a material, often to control solidification or maintain a stable state below a desired thermal threshold.</skos:definition> <skos:definition xml:lang="zh">一种温度变化功能，使系统或设备能够降低材料的温度，通常用于控制凝固或维持低于所需热阈值的稳定状态。</skos:definition>
        <skos:definition xml:lang="de">Eine Kühlfunktion ist eine (realisierbare) Funktion, die es einem System oder Gerät ermöglicht, die Temperatur eines Materials zu senken, häufig um die Erstarrung zu steuern oder einen stabilen Zustand unterhalb eines gewünschten thermischen Schwellenwerts aufrechtzuerhalten.</skos:definition>
        <skos:example xml:lang="en">The function of a water-cooled mold to solidify molten metal in casting.</skos:example> <skos:example xml:lang="zh">水冷模具在铸造中凝固熔融金属的功能。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000056 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000056">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000780"/>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000655"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000085"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000057"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">An electric arc furnace used in steelmaking.</rdfs:comment>
        <rdfs:label xml:lang="de">Schmelzofen</rdfs:label> <rdfs:label xml:lang="zh">熔炉</rdfs:label>
        <rdfs:label xml:lang="en">melting furnace</rdfs:label> <rdfs:label xml:lang="zh">熔炼炉</rdfs:label>
        <skos:definition xml:lang="en">A melting furnace is a device that bears a melting function, typically designed to raise the temperature of a solid material to initiate and sustain its transformation into a melt.</skos:definition> <skos:definition xml:lang="zh">熔炼炉是一种具有熔化功能的设备，通常设计用于提高固体材料的温度，以启动并维持其向熔体的转变。</skos:definition>
        <skos:definition xml:lang="de">Ein Schmelzofen ist ein Gerät, das eine Schmelzfunktion hat und in der Regel dazu dient, die Temperatur eines festen Materials zu erhöhen, um seine Umwandlung in eine Schmelze einzuleiten und aufrechtzuerhalten.</skos:definition> <skos:definition xml:lang="zh">熔炼炉是一种具有熔炼功能的设备，通常用于提高固体材料的温度，以引发并维持其向熔体的转变。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000057 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000057">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000054"/>
        <rdfs:label xml:lang="de">Schmelzfunktion</rdfs:label> <rdfs:label xml:lang="zh">熔炼功能</rdfs:label>
        <rdfs:label xml:lang="en">melting function</rdfs:label> <rdfs:label xml:lang="zh">熔化功能</rdfs:label>
        <skos:definition xml:lang="en">A heating function that, when realized, enables a device or system to initiate or sustain the phase transition of a solid material into a liquid by raising its temperature above the melting point.</skos:definition> <skos:definition xml:lang="zh">一种加热功能，当实现时，使设备或系统能够通过将固体材料的温度升高到熔点以上来启动或维持其相变成为液体。</skos:definition>
        <skos:definition xml:lang="de">Eine Schmelzfunktion ist eine Heizfunktion, die es einem Gerät oder System ermöglicht, den Phasenübergang eines festen Materials in eine Flüssigkeit einzuleiten oder aufrechtzuerhalten, indem seine Temperatur über den Schmelzpunkt angehoben wird.</skos:definition> <skos:definition xml:lang="zh">熔炼功能是一种加热功能，它使设备或系统能够通过将固体材料的温度升高到熔点以上，来引发或维持其向液体的相变。</skos:definition>
        <skos:example xml:lang="en">The function of an induction coil in a furnace to heat metal until it melts.</skos:example> <skos:example xml:lang="zh">感应线圈在炉中加热金属直至其熔化的功能。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000066 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000066">
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000035"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000583"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000057"/>
                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/IAO_0000030"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">input assignment</rdfs:label> <rdfs:label xml:lang="zh">输入分配</rdfs:label>
        <skos:definition xml:lang="en">Input assignment is a process boundary which is part of a computing process and which connects a material entity or i.c.e as input to the computing process</skos:definition> <skos:definition xml:lang="zh">输入分配是计算过程的一部分的过程边界，它将物质实体或i.c.e作为输入连接到计算过程。</skos:definition>
        <PMD_0001032>https://github.com/materialdigital/core-ontology/issues/184

https://github.com/pyiron/semantikon/pull/278</PMD_0001032>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000067 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000067">
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000035"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000583"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000057"/>
                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/IAO_0000030"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">output assignment</rdfs:label> <rdfs:label xml:lang="zh">输出分配</rdfs:label>
        <skos:definition xml:lang="en">Output assignment is a process boundary which is part of a computing process and which connects a material entity or i.c.e as output to the computing process</skos:definition> <skos:definition xml:lang="zh">输出分配是计算过程的一部分的过程边界，它将物质实体或i.c.e作为输出连接到计算过程。</skos:definition>
        <PMD_0001032>https://github.com/materialdigital/core-ontology/issues/184

https://github.com/pyiron/semantikon/pull/278</PMD_0001032>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000068 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000068">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000004"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000108"/>
                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000008"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/pmd/co/PMD_0000070"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:intersectionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000004"/>
                                    <owl:Class>
                                        <owl:complementOf rdf:resource="https://w3id.org/pmd/co/PMD_0000068"/>
                                    </owl:Class>
                                </owl:intersectionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000004"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000108"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000008"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/pmd/co/PMD_0000070"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000004"/>
                            <owl:Class>
                                <owl:complementOf rdf:resource="https://w3id.org/pmd/co/PMD_0000068"/>
                            </owl:Class>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000116 xml:lang="en">For any temporally qualified continuant x@t, there exists a continuant y such that x@t has_state y, meaning that y is the anchor continuant of which x@t is a temporal phase existing at temporal regions t. The relation has_state is functional and signifies that all such temporally qualified continuants are uniquely associated with their basic anchor continuant.</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">对于任何时间限定的连续体x@t，存在一个连续体y，使得x@t具有状态y，意味着y是锚定连续体，而x@t是在时间区域t存在的时间相位。关系has_state是函数性的，表示所有这类时间限定的连续体都唯一地与其基本锚定连续体相关联。</obo:IAO_0000116>
        <rdfs:label xml:lang="en">temporally qualified continuant</rdfs:label> <rdfs:label xml:lang="zh">时间限定的连续体</rdfs:label>
        <skos:definition xml:lang="en">A temporally qualified continuant is a continuant that, by reference to a determinate temporal region, is such as to possess its properties only for so long as that period obtains, being otherwise in its essentiality unchanged.</skos:definition> <skos:definition xml:lang="zh">时间限定的连续体是一种连续体，参照一个确定的时期，它只在那个时期持续期间拥有其属性，否则在其本质性上保持不变。</skos:definition>
        <PMD_0001032>https://github.com/materialdigital/core-ontology/issues/185</PMD_0001032>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000075 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000075">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000602"/>
        <rdfs:label xml:lang="en-us">mold</rdfs:label> <rdfs:label xml:lang="zh">模具</rdfs:label>
        <rdfs:label xml:lang="en">mould</rdfs:label> <rdfs:label xml:lang="zh">模具</rdfs:label>
        <skos:definition xml:lang="en">A device consisting of a hollowed-out cavity that shapes fluid or plastic material into a specific form through the process of solidification or cooling.</skos:definition> <skos:definition xml:lang="zh">一种由空腔构成的装置，通过凝固或冷却过程将流体或塑性材料塑造成特定形状。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000100 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000100">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000300"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000219"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000010"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/pmd/co/PMD_0000006"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">function name</rdfs:label> <rdfs:label xml:lang="zh">函数名称</rdfs:label>
        <skos:definition xml:lang="en">A textual entity that denotes a workflow function</skos:definition> <skos:definition xml:lang="zh">表示工作流函数的文本实体</skos:definition>
        <PMD_0001032 rdf:resource="https://github.com/materialdigital/core-ontology/issues/280"/>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000101 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000101">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000300"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000219"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000010"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/pmd/co/PMD_0000006"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">import path</rdfs:label> <rdfs:label xml:lang="zh">导入路径</rdfs:label>
        <skos:definition xml:lang="en">A textual entity that denotes a workflow function via import resolution rules</skos:definition> <skos:definition xml:lang="zh">通过导入解析规则表示工作流函数的文本实体</skos:definition>
        <PMD_0001032 rdf:resource="https://github.com/materialdigital/core-ontology/issues/280"/>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000103 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000103">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000833"/>
        <rdfs:label xml:lang="en">hardening</rdfs:label> <rdfs:label xml:lang="zh">硬化</rdfs:label>
        <skos:altLabel xml:lang="en">toughening</skos:altLabel> <skos:altLabel xml:lang="zh">增韧</skos:altLabel>
        <skos:definition xml:lang="en">A manufacturing process that increases the strength and hardness of a material.</skos:definition> <skos:definition xml:lang="zh">一种增加材料强度和硬度的制造工艺。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000104 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000104">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000103"/>
        <rdfs:label xml:lang="en">ion-exchange hardening</rdfs:label> <rdfs:label xml:lang="zh">离子交换硬化</rdfs:label>
        <skos:definition xml:lang="en">Hardening process used in glass manufacturing where ions in the glass are replaced by larger ions from a solution which create compressive stress and increased hardness.</skos:definition> <skos:definition xml:lang="zh">玻璃制造中使用的硬化工艺，其中玻璃中的离子被溶液中较大的离子替代，从而产生压应力并提高硬度。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000107 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000107">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000877"/>
        <rdfs:label xml:lang="en">nonlinear optical property</rdfs:label> <rdfs:label xml:lang="zh">非线性光学性质</rdfs:label>
        <rdfs:label xml:lang="en">optical non-linearity</rdfs:label> <rdfs:label xml:lang="zh">光学非线性</rdfs:label>
        <skos:definition xml:lang="en">Optical property that is dependent on the intensity of the input light.</skos:definition> <skos:definition xml:lang="zh">依赖于输入光强度的光学性质。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000110 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000110">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:label xml:lang="en">geological process</rdfs:label> <rdfs:label xml:lang="zh">地质过程</rdfs:label>
        <rdfs:seeAlso>https://terminology.tib.eu/ts/ontologies/gemet/terms?iri=http%3A%2F%2Fwww.eionet.europa.eu%2Fgemet%2Fconcept%2F3648&amp;obsoletes=false&amp;lang=en</rdfs:seeAlso>
        <skos:definition xml:lang="en">A natural process that operates within the Earth system to transform, transport, or deform Earth materials, thereby changing Earth structures and landforms</skos:definition> <skos:definition xml:lang="zh">在地球系统内运行的自然过程，用于转化、运输或变形地球物质，从而改变地球结构和地貌。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000111 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000111">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000016"/>
        <rdfs:label xml:lang="en">superconducting</rdfs:label> <rdfs:label xml:lang="zh">超导的</rdfs:label>
        <skos:definition xml:lang="en">The disposition of a material to conduct electricity without electrical resistance or infinite electrical conductance respectively.</skos:definition> <skos:definition xml:lang="zh">材料分别以无电阻或无限电导的方式导电的特性。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000112 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000112">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000016"/>
        <rdfs:label xml:lang="en">dielectric disposition</rdfs:label> <rdfs:label xml:lang="zh">介电性质</rdfs:label>
        <skos:definition xml:lang="en">The disposition of an electric insulator to be polarized when subjected to an electric field.</skos:definition> <skos:definition xml:lang="zh">电绝缘体在电场作用下被极化的特性。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000113 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000113">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/COB_0000035"/>
        <rdfs:label xml:lang="en">conventional ceramics manufacturing</rdfs:label> <rdfs:label xml:lang="zh">传统陶瓷制造</rdfs:label>
        <skos:definition xml:lang="en">A manufacturing process that relies on traditional and manual methods to produce ceramics.</skos:definition> <skos:definition xml:lang="zh">一种依赖传统和手工方法制造陶瓷的工艺。</skos:definition>
        <skos:example xml:lang="en">forming green bodies by hand
using a bonfire, pit or kiln for firing/sintering</skos:example> <skos:example xml:lang="zh">手工成型坯体
使用篝火、坑窑或窑炉进行烧制/烧结</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000114 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000114">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000000"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000546"/>
                            <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0020105"/>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000086"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0010027"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">clay</rdfs:label> <rdfs:label xml:lang="zh">黏土</rdfs:label>
        <skos:definition xml:lang="en">material that is naturally occurring, fine-grained earthy and composed primarily of hydrous aluminum silicates and other minerals, formed by the geological processes</skos:definition> <skos:definition xml:lang="zh">天然存在的、细粒土质材料，主要由含水铝硅酸盐及其他矿物经地质作用形成</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000117 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000117">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000577"/>
        <rdfs:label xml:lang="en">structural composite</rdfs:label> <rdfs:label xml:lang="zh">结构复合材料</rdfs:label>
        <skos:definition xml:lang="en">composite of material that is multi-layered and normally low-density, engineered for applications requiring structural integrity through high tensile, compressive, and torsional strengths and stiffnesses</skos:definition> <skos:definition xml:lang="zh">多层且通常低密度的材料复合材料，设计用于需要结构完整性的应用，通过高拉伸、压缩和扭转强度及刚度实现</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000118 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000118">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000117"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000000"/>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000087"/>
                                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000122"/>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">laminated composite</rdfs:label> <rdfs:label xml:lang="zh">层压复合材料</rdfs:label>
        <skos:definition xml:lang="en">A structural composite composed of two-dimensional sheets or panels (plies or laminae) bonded to one another, where each ply possesses a preferred high-strength direction</skos:definition> <skos:definition xml:lang="zh">由二维片材或面板（铺层或薄层）相互粘合而成的结构复合材料，其中每层具有优选的高强度方向</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000119 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000119">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000117"/>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:intersectionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000000"/>
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000087"/>
                                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000124"/>
                                    </owl:Restriction>
                                </owl:intersectionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:intersectionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000000"/>
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000087"/>
                                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000125"/>
                                    </owl:Restriction>
                                </owl:intersectionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">sandwich panel composite</rdfs:label> <rdfs:label xml:lang="zh">夹芯板复合材料</rdfs:label>
        <skos:definition xml:lang="en">A structural composite designed as a lightweight beam or panel consisting of two stiff and strong outer face sheets separated by a lightweight core layer with a low modulus of elasticity</skos:definition> <skos:definition xml:lang="zh">设计为轻质梁或板的结构复合材料，由两个刚硬的外层面板和一个低弹性模量的轻质芯层隔开</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000120 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000120">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000577"/>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:intersectionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000000"/>
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000087"/>
                                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020001"/>
                                    </owl:Restriction>
                                </owl:intersectionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:intersectionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000852"/>
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000087"/>
                                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000845"/>
                                    </owl:Restriction>
                                </owl:intersectionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">metal matrix composite</rdfs:label> <rdfs:label xml:lang="zh">金属基复合材料</rdfs:label>
        <skos:definition xml:lang="en">composite consisting of a metal or alloy matrix and one or more reinforcement materials</skos:definition> <skos:definition xml:lang="zh">由金属或合金基体与一种或多种增强材料组成的复合材料</skos:definition>
        <PMD_0050117>MMC</PMD_0050117>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000121 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000121">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000577"/>
