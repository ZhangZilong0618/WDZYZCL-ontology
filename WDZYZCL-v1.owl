        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">boron nitride ceramic</rdfs:label> <rdfs:label xml:lang="zh">氮化硼陶瓷</rdfs:label>
        <skos:definition xml:lang="en">nitride ceramic sonsisting of boron nitride</skos:definition> <skos:definition xml:lang="zh">由氮化硼组成的氮化物陶瓷</skos:definition>
    </owl:Class>
    


