    <!-- https://w3id.org/pmd/co/PMD_0020118 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/co/PMD_0020118">
        <rdfs:label xml:lang="en">aggregate state liquid</rdfs:label> <rdfs:label xml:lang="zh">液态</rdfs:label>
        <skos:definition xml:lang="en">A state where the bonds of the entities transmit no shear force.</skos:definition> <skos:definition xml:lang="zh">实体间的键不传递剪切力的状态。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/co/PMD_0020119 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/co/PMD_0020119">
        <rdfs:label xml:lang="en">aggregate state gaseous</rdfs:label> <rdfs:label xml:lang="zh">气态</rdfs:label>
        <skos:definition xml:lang="en">A state where the entities have no bonding.</skos:definition> <skos:definition xml:lang="zh">一种实体之间没有键合的状态。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/co/PMD_0020120 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/co/PMD_0020120">
        <rdfs:label xml:lang="en">aggregate state plasma</rdfs:label> <rdfs:label xml:lang="zh">聚集态等离子体</rdfs:label>
        <skos:definition xml:lang="en">An aggregate state where the entities are atom nuclei and have no bonds.</skos:definition> <skos:definition xml:lang="zh">一种实体为原子核且没有键合的聚集态。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/co/PMD_0020121 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/co/PMD_0020121">
        <rdfs:label xml:lang="en">aggregate state atom gas</rdfs:label> <rdfs:label xml:lang="zh">聚集态原子气体</rdfs:label>
        <skos:definition xml:lang="en">A gaseous state where the gas entities are atoms.</skos:definition> <skos:definition xml:lang="zh">一种气体实体为原子的气态。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/co/PMD_0020122 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/co/PMD_0020122">
        <rdfs:label xml:lang="en">aggregate state supercritical fluid</rdfs:label> <rdfs:label xml:lang="zh">聚集态超临界流体</rdfs:label>
        <skos:definition xml:lang="en">A state with strong bindings between entities that do not transmit shear force.</skos:definition> <skos:definition xml:lang="zh">一种实体间具有强结合但无法传递剪切力的状态。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/co/PMD_0020123 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/co/PMD_0020123">
        <rdfs:label xml:lang="en">aggregate state mesomorphic</rdfs:label> <rdfs:label xml:lang="zh">聚集态中介相</rdfs:label>
        <skos:definition xml:lang="en">A state where some bonds transmit shear stresses and some do not.</skos:definition> <skos:definition xml:lang="zh">一种部分键传递剪切应力而部分不传递的状态。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/co/PMD_0020124 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/co/PMD_0020124">
        <rdfs:label xml:lang="en">aggregate state suprafluid</rdfs:label> <rdfs:label xml:lang="zh">聚集态超流体</rdfs:label>
        <skos:definition xml:lang="en">A state with frictionless binding that transmits no shear force between entities.</skos:definition> <skos:definition xml:lang="zh">一种具有无摩擦结合且实体间不传递剪切力的状态。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/co/PMD_0020125 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/co/PMD_0020125">
        <rdfs:label xml:lang="en">aggregate state suprasolid</rdfs:label> <rdfs:label xml:lang="zh">聚集态超固体</rdfs:label>
        <skos:definition xml:lang="en">A state that exhibits suprafluid and solid properties.</skos:definition> <skos:definition xml:lang="zh">一种同时表现超流体和固体性质的状态。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/co/PMD_0020217 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/co/PMD_0020217">
        <rdfs:label xml:lang="en">short range order</rdfs:label> <rdfs:label xml:lang="zh">短程有序</rdfs:label>
        <skos:definition xml:lang="en">periodic arrangement of structural features up to a few entities</skos:definition> <skos:definition xml:lang="zh">结构特征在少数几个实体范围内的周期性排列。</skos:definition>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/co/PMD_0020218 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/co/PMD_0020218">
        <rdfs:label xml:lang="en">medium range order</rdfs:label> <rdfs:label xml:lang="zh">中程有序</rdfs:label>
        <skos:definition xml:lang="en">periodic arrangement of structural features of many entities</skos:definition> <skos:definition xml:lang="zh">结构特征在多个实体范围内的周期性排列。</skos:definition>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/co/PMD_0020219 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/co/PMD_0020219">
        <rdfs:label xml:lang="en">long range order</rdfs:label> <rdfs:label xml:lang="zh">长程有序</rdfs:label>
        <skos:definition xml:lang="en">periodic arrangement of structural features of virtually all entities</skos:definition> <skos:definition xml:lang="zh">结构特征在几乎所有实体范围内的周期性排列。</skos:definition>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/co/PMD_0020242 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/co/PMD_0020242">
        <rdfs:label xml:lang="en">no range order</rdfs:label> <rdfs:label xml:lang="zh">无程有序</rdfs:label>
        <skos:definition xml:lang="en">no periodic arrangement of structural features of entites</skos:definition> <skos:definition xml:lang="zh">实体结构特征无周期性排列。</skos:definition>
    </owl:NamedIndividual>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotations
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/IAO_0000002">
        <rdfs:label xml:lang="en">example to be eventually removed</rdfs:label> <rdfs:label xml:lang="zh">示例最终将被移除</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/IAO_0000103">
        <obo:IAO_0000115 xml:lang="en">The term was used in an attempt to structure part of the ontology but in retrospect failed to do a good job</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">该术语曾用于尝试构建本体的一部分，但事后看来未能起到良好作用。</obo:IAO_0000115>
        <rdfs:label xml:lang="en">failed exploratory term</rdfs:label> <rdfs:label xml:lang="zh">失败的探索性术语</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/IAO_0000120">
        <obo:IAO_0000115 xml:lang="en">Class has all its metadata, but is either not guaranteed to be in its final location in the asserted IS_A hierarchy or refers to another class that is not complete.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">类具有所有元数据，但无法保证其位于断言的IS_A层次结构中的最终位置，或者引用了另一个不完整的类。</obo:IAO_0000115>
        <rdfs:label xml:lang="en">metadata complete</rdfs:label> <rdfs:label xml:lang="zh">元数据完整</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/IAO_0000121">
        <obo:IAO_0000115 xml:lang="en">Term created to ease viewing/sort terms for development purpose, and will not be included in a release</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">为便于开发目的查看/排序术语而创建的术语，不会包含在发布版本中</obo:IAO_0000115>
        <rdfs:label xml:lang="en">organizational term</rdfs:label> <rdfs:label xml:lang="zh">组织术语</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/IAO_0000122">
        <obo:IAO_0000115 xml:lang="en">Class has undergone final review, is ready for use, and will be included in the next release. Any class lacking "ready_for_release" should be considered likely to change place in hierarchy, have its definition refined, or be obsoleted in the next release.  Those classes deemed "ready_for_release" will also derived from a chain of ancestor classes that are also "ready_for_release."</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">类已通过最终审查，可供使用，并将包含在下一个发布版本中。任何缺少"ready_for_release"的类应被视为可能在下一个版本中改变层级位置、精炼定义或被废弃。那些被认定为"ready_for_release"的类也将从一系列同样为"ready_for_release"的祖先类派生而来。</obo:IAO_0000115>
        <rdfs:label xml:lang="en">ready for release</rdfs:label> <rdfs:label xml:lang="zh">准备发布</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/IAO_0000123">
        <obo:IAO_0000115 xml:lang="en">Class is being worked on; however, the metadata (including definition) are not complete or sufficiently clear to the branch editors.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">类正在处理中；但元数据（包括定义）尚未完成或对分支编辑者不够清晰。</obo:IAO_0000115>
        <rdfs:label xml:lang="en">metadata incomplete</rdfs:label> <rdfs:label xml:lang="zh">元数据不完整</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/IAO_0000124">
        <obo:IAO_0000115 xml:lang="en">Nothing done yet beyond assigning a unique class ID and proposing a preferred term.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">除分配唯一类ID和提出首选术语外，尚未采取任何措施。</obo:IAO_0000115>
        <rdfs:label xml:lang="en">uncurated</rdfs:label> <rdfs:label xml:lang="zh">未整理</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/IAO_0000125">
        <obo:IAO_0000115 xml:lang="en">All definitions, placement in the asserted IS_A hierarchy and required minimal metadata are complete. The class is awaiting a final review by someone other than the term editor.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">所有定义、在断言IS_A层级中的位置以及所需的最小元数据均已完整。该类正在等待术语编辑者以外的某人进行最终审查。</obo:IAO_0000115>
        <rdfs:label xml:lang="en">pending final vetting</rdfs:label> <rdfs:label xml:lang="zh">待最终审核</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/IAO_0000226">
        <rdfs:label xml:lang="en">placeholder removed</rdfs:label> <rdfs:label xml:lang="zh">占位符已移除</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/IAO_0000227">
        <obo:IAO_0000116 xml:lang="en">An editor note should explain what were the merged terms and the reason for the merge.</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">编辑注释应说明合并了哪些术语以及合并的原因。</obo:IAO_0000116>
        <rdfs:label xml:lang="en">terms merged</rdfs:label> <rdfs:label xml:lang="zh">术语已合并</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/IAO_0000228">
        <obo:IAO_0000116 xml:lang="en">This is to be used when the original term has been replaced by a term imported from an other ontology. An editor note should indicate what is the URI of the new term to use.</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">当原始术语已被从其他本体导入的术语替换时使用。编辑注释应指明要使用的新术语的URI。</obo:IAO_0000116>
        <rdfs:label xml:lang="en">term imported</rdfs:label> <rdfs:label xml:lang="zh">术语已导入</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/IAO_0000229">
        <obo:IAO_0000116 xml:lang="en">This is to be used when a term has been split in two or more new terms. An editor note should indicate the reason for the split and indicate the URIs of the new terms created.</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">当一个术语被拆分为两个或多个新术语时使用。编辑注释应说明拆分的原因并指明所创建新术语的URI。</obo:IAO_0000116>
        <rdfs:label xml:lang="en">term split</rdfs:label> <rdfs:label xml:lang="zh">术语已拆分</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/IAO_0000410">
        <obo:IAO_0000116 xml:lang="en">Hard to give a definition for. Intuitively a "natural kind" rather than a collection of any old things, which a class is able to be, formally. At the meta level, universals are defined as positives, are disjoint with their siblings, have single asserted parents.</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">难以给出定义。直观上是一种"自然类"，而不是任何旧事物的集合（形式上一个类可以是任何事物的集合）。在元层面，共相被定义为正面的，与其兄弟不相交，具有单一断言父类。</obo:IAO_0000116>
        <obo:IAO_0000119 xml:lang="en">A Formal Theory of Substances, Qualities, and Universals, http://ontology.buffalo.edu/bfo/SQU.pdf</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">《物质、性质与共相的形式理论》，http://ontology.buffalo.edu/bfo/SQU.pdf</obo:IAO_0000119>
        <rdfs:label xml:lang="en">universal</rdfs:label> <rdfs:label xml:lang="zh">共相</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/IAO_0000420">
        <obo:IAO_0000115 xml:lang="en">A defined class is a class that is defined by a set of logically necessary and sufficient conditions but is not a universal</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">一个定义类是由一组逻辑上必要且充分的条件定义的类，但不是共相</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">"definitions", in some readings, always are given by necessary and sufficient conditions. So one must be careful (and this is difficult sometimes) to distinguish between defined classes and universal.</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">在某些解读中，"定义"总是由必要且充分条件给出的。因此必须小心（有时这很困难）区分定义类和共相。</obo:IAO_0000116>
        <rdfs:label xml:lang="en">defined class</rdfs:label> <rdfs:label xml:lang="zh">定义类</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/IAO_0000421">
        <obo:IAO_0000115 xml:lang="en">A named class expression is a logical expression that is given a name. The name can be used in place of the expression.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">命名类表达式是一个被赋予名称的逻辑表达式。该名称可以用来代替该表达式。</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">named class expressions are used in order to have more concise logical definition but their extensions may not be interesting classes on their own. In languages such as OWL, with no provisions for macros, these show up as actuall classes. Tools may with to not show them as such, and to replace uses of the macros with their expansions</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">命名类表达式用于实现更简洁的逻辑定义，但其扩展本身可能并非有趣的类。在诸如OWL等不支持宏的语言中，这些表达式会显示为实际类。工具可能希望不将其显示为类，而是用宏的扩展替换宏的使用</obo:IAO_0000116>
        <rdfs:label xml:lang="en">named class expression</rdfs:label> <rdfs:label xml:lang="zh">命名类表达式</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/IAO_0000423">
        <obo:IAO_0000115 xml:lang="en">Terms with this status should eventually replaced with a term from another ontology.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">具有此状态的术语应最终被另一个本体中的术语替换。</obo:IAO_0000115>
        <obo:IAO_0000119 xml:lang="en">group:OBI</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">组:OBI</obo:IAO_0000119>
        <rdfs:label xml:lang="en">to be replaced with external ontology term</rdfs:label> <rdfs:label xml:lang="zh">待替换为外部本体术语</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/IAO_0000428">
        <obo:IAO_0000115 xml:lang="en">A term that is metadata complete, has been reviewed, and problems have been identified that require discussion before release. Such a term requires editor note(s) to identify the outstanding issues.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">一个元数据完备、已审核且发现需要在发布前讨论的问题的术语。此类术语需要编辑器注释以识别悬而未决的问题。</obo:IAO_0000115>
        <obo:IAO_0000119 xml:lang="en">group:OBI</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">组:OBI</obo:IAO_0000119>
        <rdfs:label xml:lang="en">requires discussion</rdfs:label> <rdfs:label xml:lang="zh">需要讨论</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/OMO_0001000">
        <obo:IAO_0000115 xml:lang="en">The term was added to the ontology on the assumption it was in scope, but it turned out later that it was not.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">该术语最初基于其在本体范围内的假设被添加，但后来发现并非如此。</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">This obsolesence reason should be used conservatively. Typical valid examples are: un-necessary grouping classes in disease ontologies, a phenotype term added on the assumption it was a disease.</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">此废弃原因应保守使用。典型的有效示例有：疾病本体中不必要的分组类、假设为疾病而添加的表型术语。</obo:IAO_0000116>
        <obo:IAO_0000233>https://github.com/information-artifact-ontology/ontology-metadata/issues/77</obo:IAO_0000233>
        <rdfs:label xml:lang="en">out of scope</rdfs:label> <rdfs:label xml:lang="zh">超出范围</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/UO_0000076">
        <obo:IAO_0000115 xml:lang="en">A concentration unit which denotes the number of moles of solute as a proportion of the total number of moles in a solution.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">一种浓度单位，表示溶质的摩尔数与溶液中总摩尔数之比。</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>(x)</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>chi</oboInOwl:hasExactSynonym>
        <rdfs:label xml:lang="en">mole fraction</rdfs:label> <rdfs:label xml:lang="zh">摩尔分数</rdfs:label>
    </rdf:Description>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/UO_0000076"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>A concentration unit which denotes the number of moles of solute as a proportion of the total number of moles in a solution.</owl:annotatedTarget>
        <oboInOwl:hasDbXref>Wikipedia:Wikipedia</oboInOwl:hasDbXref>
    </owl:Axiom>
    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/UO_0000163">
        <obo:IAO_0000115 xml:lang="en">A dimensionless concentration unit which denotes the mass of a substance in a mixture as a percentage of the mass of the entire mixture.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">一种无量纲浓度单位，表示混合物中物质的质量占整个混合物质量的百分比。</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>w/w</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>weight-weight percentage</oboInOwl:hasExactSynonym>
        <rdfs:label xml:lang="en">mass percentage</rdfs:label> <rdfs:label xml:lang="zh">质量百分比</rdfs:label>
    </rdf:Description>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/UO_0000163"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>A dimensionless concentration unit which denotes the mass of a substance in a mixture as a percentage of the mass of the entire mixture.</owl:annotatedTarget>
        <oboInOwl:hasDbXref>Wikipedia:Wikipedia</oboInOwl:hasDbXref>
    </owl:Axiom>
    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/UO_0000164">
        <obo:IAO_0000115 xml:lang="en">A dimensionless concentration unit which denotes the mass of the substance in a mixture as a percentage of the volume of the entire mixture.</obo:IAO_0000115> <obo:IAO_0000115 xml:lang="zh">一种无量纲浓度单位，表示混合物中物质的质量占整个混合物体积的百分比。</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>(w/v)</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>weight-volume percentage</oboInOwl:hasExactSynonym>
        <rdfs:label xml:lang="en">mass volume percentage</rdfs:label> <rdfs:label xml:lang="zh">质量体积百分比</rdfs:label>
    </rdf:Description>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/UO_0000164"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>A dimensionless concentration unit which denotes the mass of the substance in a mixture as a percentage of the volume of the entire mixture.</owl:annotatedTarget>
        <oboInOwl:hasDbXref>UOC:GVG</oboInOwl:hasDbXref>
    </owl:Axiom>
