        <skos:definition xml:lang="en">composite consisting of a ceramic matrix and one or more reinforcement materials</skos:definition> <skos:definition xml:lang="zh">由陶瓷基体和一种或多种增强材料组成的复合材料</skos:definition>
        <PMD_0050117>CMC</PMD_0050117>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050075 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050075">
