        <rdfs:label xml:lang="en">substitutional solid solution</rdfs:label> <rdfs:label xml:lang="zh">置换固溶体</rdfs:label>
        <skos:definition xml:lang="en">a solid solution whose solute entities occupy lattice points</skos:definition> <skos:definition xml:lang="zh">溶质实体占据晶格点的固溶体</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020233 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020233">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000029"/>
        <rdfs:label xml:lang="en">dislocation</rdfs:label> <rdfs:label xml:lang="zh">位错</rdfs:label>
        <skos:definition xml:lang="en">a linear site in a cystal that interrupts the cystal ordering</skos:definition> <skos:definition xml:lang="zh">晶体中破坏晶体有序性的线性位点</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020234 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020234">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020233"/>
        <rdfs:label xml:lang="en">screw dislocation</rdfs:label> <rdfs:label xml:lang="zh">螺型位错</rdfs:label>
        <skos:definition xml:lang="en">a dislocation characterized by shearing the chrystal by one plane</skos:definition> <skos:definition xml:lang="zh">通过一个平面剪切晶体来表征的位错</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020235 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020235">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020233"/>
        <rdfs:label xml:lang="en">edge dislocation</rdfs:label> <rdfs:label xml:lang="zh">刃型位错</rdfs:label>
        <skos:definition xml:lang="en">a dislocation characterized by adding one extra half plane into the crystal lattice</skos:definition> <skos:definition xml:lang="zh">通过在晶格中添加一个额外的半平面来表征的位错</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020236 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020236">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0020234"/>
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0020235"/>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020234"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020235"/>
        <rdfs:label xml:lang="en">mixed dislocation</rdfs:label> <rdfs:label xml:lang="zh">混合位错</rdfs:label>
        <skos:definition xml:lang="en">a dislocation that spans edge dislocation as well as screw dislocation</skos:definition> <skos:definition xml:lang="zh">同时包含刃型位错和螺型位错的位错</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020237 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020237">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020148"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000080"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0020233"/>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0001025"/>
                                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020003"/>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">Burgers vector</rdfs:label> <rdfs:label xml:lang="zh">伯氏矢量</rdfs:label>
        <skos:definition xml:lang="en">quality of a dislocation in terms of amount and direction in a specific crystal type</skos:definition> <skos:definition xml:lang="zh">位错在特定晶体类型中的数量和方向特性</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020238 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020238">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020213"/>
        <rdfs:label xml:lang="en">high angle grain boundary</rdfs:label> <rdfs:label xml:lang="zh">大角度晶界</rdfs:label>
        <skos:definition xml:lang="en">a grain boundary whose adjacent crystalls have a high angle of misalignment</skos:definition> <skos:definition xml:lang="zh">相邻晶体具有高取向偏差角的晶界</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020239 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020239">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020213"/>
        <rdfs:label xml:lang="en">small angle grain boundary</rdfs:label> <rdfs:label xml:lang="zh">小角度晶界</rdfs:label>
        <skos:definition xml:lang="en">a grain boundary whose adjacent crystalls have a small angle of misalignment</skos:definition> <skos:definition xml:lang="zh">相邻晶体具有小取向偏差角的晶界</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020240 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020240">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020213"/>
        <rdfs:label xml:lang="en">twin boundary</rdfs:label> <rdfs:label xml:lang="zh">孪晶界</rdfs:label>
        <skos:definition xml:lang="en">grain boundary without distorted lattice</skos:definition> <skos:definition xml:lang="zh">无晶格畸变的晶界</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020241 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020241">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0001035"/>
        <rdfs:label xml:lang="en">angle of misalignment (crystallography)</rdfs:label> <rdfs:label xml:lang="zh">取向偏差角（晶体学）</rdfs:label>
        <skos:definition xml:lang="en">smallest rotation angle needed to rotate one crystal orientation to coincide with the neighboring orientation</skos:definition> <skos:definition xml:lang="zh">使一个晶体取向与相邻取向重合所需的最小旋转角</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020243 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020243">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020131"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000080"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020106"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000116 xml:lang="en">size values of indiviudal grains are properties of the respective objects</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">单个晶粒的尺寸值是各自对象的属性</obo:IAO_0000116>
        <rdfs:label xml:lang="en">grain size</rdfs:label> <rdfs:label xml:lang="zh">晶粒尺寸</rdfs:label>
        <skos:definition xml:lang="en">an intensive quality epitomizing the average size of the grains of a polycrystal</skos:definition> <skos:definition xml:lang="zh">概括多晶体晶粒平均尺寸的强度性质</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020244 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020244">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020226"/>
        <rdfs:label xml:lang="en">flux</rdfs:label> <rdfs:label xml:lang="zh">通量</rdfs:label>
        <skos:definition xml:lang="en">a flow of a unit-entity per unit time</skos:definition> <skos:definition xml:lang="zh">单位时间内单位实体的流动</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020245 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020245">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <obo:IAO_0000116 xml:lang="en">the moved entity is passive, locomotion would be the active counterpart</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">被移动实体是被动的，移动则是主动的对等</obo:IAO_0000116>
        <rdfs:label xml:lang="en">transport</rdfs:label> <rdfs:label xml:lang="zh">输运</rdfs:label>
        <skos:definition xml:lang="en">is a process in which an entity being moved within or accross another entity</skos:definition> <skos:definition xml:lang="zh">是一个实体在另一个实体内部或穿过另一个实体被移动的过程</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020246 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020246">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020245"/>
        <rdfs:label xml:lang="en">continous transport</rdfs:label> <rdfs:label xml:lang="zh">连续输运</rdfs:label>
        <skos:definition xml:lang="en">recurring transport of multiple entities, such that the transported entities are not being discretized anymore</skos:definition> <skos:definition xml:lang="zh">多个实体的重复输运，使得被输运的实体不再被离散化</skos:definition>
        <skos:example xml:lang="en">the flow of a liquid in a pipe, diffusion of a gas in different gas</skos:example> <skos:example xml:lang="zh">液体在管道中的流动，气体在另一种气体中的扩散</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020247 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020247">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000877"/>
        <rdfs:comment xml:lang="en">dispersion in optical glass is a refraction dependent on wavelength</rdfs:comment>
        <rdfs:label xml:lang="en">dispersion</rdfs:label> <rdfs:label xml:lang="zh">色散</rdfs:label>
        <skos:definition xml:lang="en">Optical property describing the wavelength dependent phase velocity.</skos:definition> <skos:definition xml:lang="zh">描述波长相关相速度的光学性质。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020248 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020248">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020244"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/pmd/co/PMD_0025006"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0020194"/>
                            <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0020246"/>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">diffusion flux</rdfs:label> <rdfs:label xml:lang="zh">扩散通量</rdfs:label>
        <skos:definition xml:lang="en">flux transported by diffusion</skos:definition> <skos:definition xml:lang="zh">通过扩散输运的通量</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020249 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020249">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020003"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/CHEBI_33250"/>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="https://w3id.org/pmd/co/PMD_0025998"/>
                                <owl:someValuesFrom>
                                    <owl:Class>
                                        <owl:unionOf rdf:parseType="Collection">
                                            <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0050001"/>
                                            <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0050003"/>
                                        </owl:unionOf>
                                    </owl:Class>
                                </owl:someValuesFrom>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">ceramic crystal</rdfs:label> <rdfs:label xml:lang="zh">陶瓷晶体</rdfs:label>
        <skos:definition xml:lang="en">a crystal whose atomic entities have a ionic or a covalent bond</skos:definition> <skos:definition xml:lang="zh">原子实体具有离子键或共价键的晶体</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020250 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020250">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020003"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/CHEBI_33250"/>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="https://w3id.org/pmd/co/PMD_0025998"/>
                                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0050002"/>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">alloy crystal</rdfs:label> <rdfs:label xml:lang="zh">合金晶体</rdfs:label>
        <skos:definition xml:lang="en">a crystal whose atomic entities have a metallic bond</skos:definition> <skos:definition xml:lang="zh">原子实体具有金属键的晶体</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020251 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020251">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0010023"/>
        <rdfs:label xml:lang="en">biocompatible</rdfs:label> <rdfs:label xml:lang="zh">生物相容的</rdfs:label>
        <skos:definition xml:lang="en">bioactive without causing harmful or unacceptable biological responses (toxicity, inflammation, immune reaction) and performce of its intended function or integration with the tissue.</skos:definition> <skos:definition xml:lang="zh">具有生物活性，不会引起有害或不可接受的生物学反应（毒性、炎症、免疫反应），并能执行其预期功能或与组织整合。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0025001 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0025001">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020131"/>
        <obo:IAO_0000116 xml:lang="en">There's a dfference between composition and chemical compositon for the following reason: chemical compositon is relevant when the mass/volume/mole proportions of chemical elements(!) are identified, whlist composition includes proportions of molecules, other pure chemical substances, or even proptions of objects (in an object aggregate).</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">成分与化学组成之间存在如下区别：化学组成涉及化学元素的质量/体积/摩尔比例，而成分包括分子、其他纯化学物质的比例，甚至包括物体（在物体聚集中）的比例。</obo:IAO_0000116>
        <rdfs:label xml:lang="en">composition</rdfs:label> <rdfs:label xml:lang="zh">成分</rdfs:label>
        <skos:definition xml:lang="en">Composition is an intensive quality which defines types and proportions of compounds present in a material entity and is subject of some composition data item.</skos:definition> <skos:definition xml:lang="zh">成分是一种内禀性质，定义了材料实体中存在的化合物的类型和比例，并且是某些成分数据项的主题。</skos:definition>
        <skos:example xml:lang="en">4 vol.% nitric acid solution, Styrene-Butadiene-Styrene (SBS) Block Copolymer with 50 vol.% of both styrene and butadiene</skos:example> <skos:example xml:lang="zh">4 vol.% 硝酸溶液，苯乙烯-丁二烯-苯乙烯（SBS）嵌段共聚物，其中苯乙烯和丁二烯各占 50 vol.%</skos:example>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
        <PMD_0000064 xml:lang="en">Composition is a collective property of a portion of matter, i.e., the triple portion of matter has quality composition holds. As "has quality" is an inverse  functional property, only one instance of portion of matter can have this specific composition. However, proportions describe the relation between the prortion of matter (the whole) and some compound (the part). Thus, the following triples hold: portion of matter has relational quality proportion; portion of matter has part some substance (or whatever is your part); substance has relational quality proportion. "Has relational quality" is not inverse functional, i.e., it can point to a single object from 2 distinct subjects.</PMD_0000064>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0025002 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0025002">
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0020004"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000551"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">chemical composition data item</rdfs:label> <rdfs:label xml:lang="zh">化学组成数据项</rdfs:label>
        <skos:altLabel xml:lang="en">chemical composition specification</skos:altLabel> <skos:altLabel xml:lang="zh">化学组成规范</skos:altLabel>
        <skos:definition xml:lang="en">Chemical composition data item is an information content entity that is about composition of a portion of matter. It has members fraction value specifications which specifiy values of propotions of portions of (pure) chemical elements, which are parts of the portion of matter.</skos:definition> <skos:definition xml:lang="zh">化学组成数据项是一种信息内容实体，涉及某部分物质的组成。它包含分数值规范成员，这些规范指定了作为该物质部分成分的（纯）化学元素的比例值。</skos:definition>
        <skos:example xml:lang="en">Steel has quality chemical composition , and the chemical composition data item is about the chemical composition .The chemical composition data item has members fraction specifications of iron and carbon. These fraction specifications specify value of portion of iron and portion of carbon respectively. Furthermore, these fraction specifications specify  values of relational qualities (mass) proportion of iron and (mass) proportion of carbon.</skos:example> <skos:example xml:lang="zh">钢具有化学组成性质，而化学组成数据项是关于该化学组成的。化学组成数据项包含铁和碳的分数规范成员。这些分数规范分别指定了铁和碳的比例值。此外，这些分数规范还指定了关系性质（质量）中铁的比例和碳的比例的值。</skos:example>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0025003 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0025003">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/pmd/co/PMD_0000077"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/pmd/co/PMD_0020023"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020131"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/pmd/co/PMD_0000077"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020023"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">ferrite, austenite, martensite, etc.</rdfs:comment>
        <rdfs:label xml:lang="en">metallic grain structure</rdfs:label> <rdfs:label xml:lang="zh">金属晶粒结构</rdfs:label>
        <skos:definition xml:lang="en">intensive quality epitomizing the distinct phases in the microscopic structure of a metallic material.</skos:definition> <skos:definition xml:lang="zh">概括金属材料微观结构中不同相的内禀性质。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0025004 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0025004">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000852"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020250"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000852"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020250"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">alloy</rdfs:label> <rdfs:label xml:lang="zh">合金</rdfs:label>
        <skos:definition xml:lang="en">metal that has part a mixture of chemical elements of which at least one is a metallic element</skos:definition> <skos:definition xml:lang="zh">包含化学元素混合物的金属，其中至少一种是金属元素</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0025005 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0025005">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000027"/>
        <rdfs:label xml:lang="en">3D</rdfs:label> <rdfs:label xml:lang="zh">三维</rdfs:label>
        <skos:definition xml:lang="en">A three-dimensional data item is a representation or analysis, commonly applied in studying material properties in its volume or describing a dependency of one variable on two other variables.</skos:definition> <skos:definition xml:lang="zh">三维数据项是一种表示或分析，通常用于研究材料在体积内的性质，或描述一个变量对另外两个变量的依赖性。</skos:definition>
        <skos:example xml:lang="en">Orientation distribution function (ODF), potential energy landscape</skos:example> <skos:example xml:lang="zh">取向分布函数（ODF），势能面</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0025007 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0025007">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000008"/>
        <rdfs:label xml:lang="en">frequency</rdfs:label> <rdfs:label xml:lang="zh">频率</rdfs:label>
        <skos:definition xml:lang="en">Frequency is a process attribute which characterizes the rate per second of oscillation or vibration.</skos:definition> <skos:definition xml:lang="zh">频率是一种过程属性，表征每秒振荡或振动的速率。</skos:definition>
        <skos:example xml:lang="en">Frequency of electromagnetic wave, Frequency of sound wave.</skos:example> <skos:example xml:lang="zh">电磁波频率，声波频率。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0025008 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0025008">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000624"/>
        <rdfs:label xml:lang="de">Transmissionselektronenmikroskop</rdfs:label> <rdfs:label xml:lang="zh">透射电子显微镜</rdfs:label>
        <rdfs:label xml:lang="en">transmission electron microscope</rdfs:label> <rdfs:label xml:lang="zh">透射电子显微镜</rdfs:label>
        <skos:definition xml:lang="en">An electron microscope that produces high-resolution images of a sample's internal structure by transmitting electrons through the sample.</skos:definition> <skos:definition xml:lang="zh">一种通过将电子透射过样品来产生样品内部结构高分辨率图像的电子显微镜。</skos:definition>
        <skos:definition xml:lang="de">Ein Elektronenmikroskop, das hochauflösende Bilder der inneren Struktur einer Probe erzeugt, indem es Elektronen durch die Probe strahlt.</skos:definition> <skos:definition xml:lang="zh">一种电子显微镜，通过将电子束穿过样品来生成样品内部结构的高分辨率图像。</skos:definition>
        <PMD_0050117>TEM</PMD_0050117>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0025009 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0025009">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000015"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000066"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000001"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/pmd/co/PMD_0001028"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:intersectionOf rdf:parseType="Collection">
                                    <owl:Class>
                                        <owl:unionOf rdf:parseType="Collection">
                                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000016"/>
                                            <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000005"/>
                                        </owl:unionOf>
                                    </owl:Class>
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000950"/>
                                    </owl:Restriction>
                                </owl:intersectionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000066"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000001"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/pmd/co/PMD_0001028"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <owl:Class>
                                <owl:unionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000016"/>
                                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000005"/>
                                </owl:unionOf>
                            </owl:Class>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000950"/>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">material reacting process has always energy minimization as a driving force.</rdfs:comment>
        <rdfs:label xml:lang="en">material reacting process</rdfs:label> <rdfs:label xml:lang="zh">材料反应过程</rdfs:label>
        <skos:definition xml:lang="en">Material reacting process is a process which occurs in a portion of matter due to some of its disposition or behavioral material property which has realization in some  stimulating process. Both the material reacting process and stimulating process must be occurent parts of a planned process, if the planned process takes place.</skos:definition> <skos:definition xml:lang="zh">材料反应过程是由于物质的某种倾向或行为材料属性而在物质的一部分中发生的过程，该属性在某种刺激过程中得以实现。如果计划过程发生，则材料反应过程和刺激过程都必须作为该计划过程的组成部分。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0025010 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0025010">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000549"/>
        <rdfs:label xml:lang="en">heating</rdfs:label> <rdfs:label xml:lang="zh">加热</rdfs:label>
        <skos:definition xml:lang="en">Heating is a change of temperature which corresponds to the increase of temperature in the system or object.</skos:definition> <skos:definition xml:lang="zh">加热是一种温度变化，对应于系统或物体中温度的升高。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0025011 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0025011">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000549"/>
        <rdfs:label xml:lang="en">cooling</rdfs:label> <rdfs:label xml:lang="zh">冷却</rdfs:label>
        <skos:definition xml:lang="en">Cooling is a change of temperature which corresponds to the decrease of temperature in the system or object.</skos:definition> <skos:definition xml:lang="zh">冷却是一种温度变化，对应于系统或物体中温度的降低。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0025012 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0025012">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000583"/>
        <rdfs:label xml:lang="en">analytical calculation</rdfs:label> <rdfs:label xml:lang="zh">解析计算</rdfs:label>
        <skos:definition xml:lang="en">Analytical calculation is a computing process which has value specification or measurement datum as a specified output. It applies a closed-form mathematical expression or formula to a set it specified inputs (value specifications) without requiring stochastic sampling, iterative numerical solving, or data-driven training.</skos:definition> <skos:definition xml:lang="zh">解析计算是一种计算过程，其指定输出为值规格或测量数据。它将封闭形式的数学表达式或公式应用于一组指定的输入（值规格），无需随机采样、迭代数值求解或数据驱动训练。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0025014 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0025014">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020003"/>
        <rdfs:label xml:lang="en">single crystal</rdfs:label> <rdfs:label xml:lang="zh">单晶</rdfs:label>
        <skos:definition xml:lang="en">Single crystal is a crystal which is not part of a polycrystal and its boundaries are its external surfaces.</skos:definition> <skos:definition xml:lang="zh">单晶是指不属于多晶的一部分且其边界为其外部表面的晶体。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0025015 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0025015">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0020140"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                        <owl:allValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_33336"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020140"/>
        <rdfs:comment xml:lang="en">'portion of pure chemical element' and 'has part' only CHEBI:33336</rdfs:comment>
        <rdfs:label xml:lang="en">portion of lanthanum</rdfs:label> <rdfs:label xml:lang="zh">镧</rdfs:label>
        <skos:definition xml:lang="en">A portion of lanthanum is a portion of pure substance that has parts only chebi:lanthanum atom.</skos:definition> <skos:definition xml:lang="zh">镧部分是指仅由chebi:lanthanum atom组成的纯物质部分。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0025016 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0025016">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050051"/>
        <rdfs:label xml:lang="de">Innendurchmesser</rdfs:label> <rdfs:label xml:lang="zh">内径</rdfs:label>
        <rdfs:label xml:lang="en">inner diameter</rdfs:label> <rdfs:label xml:lang="zh">内径</rdfs:label>
        <skos:definition xml:lang="de">Der Innendurchmesser ist die Länge einer geraden Linie von einer Innenfläche eines Objekts oder Raums zur anderen Seite seiner Innenfläche durch den Mittelpunkt eines Objekts oder Raums, wenn es eine Innen- und Außenfläche hat.</skos:definition> <skos:definition xml:lang="zh">内径是从物体或空间的一个内表面穿过其中心点到另一侧内表面的直线长度，前提是该物体或空间具有内表面和外表面。</skos:definition>
        <skos:definition xml:lang="en">Inner diameter is a length of a straight line from one inner surface of an object or space to the other side of its inner surface through the center of an object or space when it has the inside and outside surface.</skos:definition> <skos:definition xml:lang="zh">内径是指当物体或空间具有内表面和外表面时，从其一内表面穿过物体或空间中心到内表面另一侧的直线长度。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0025017 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0025017">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050051"/>
        <rdfs:label xml:lang="de">Außendurchmesser</rdfs:label> <rdfs:label xml:lang="zh">外径</rdfs:label>
        <rdfs:label xml:lang="en">outer diameter</rdfs:label> <rdfs:label xml:lang="zh">外径</rdfs:label>
        <skos:definition xml:lang="de">Der Außendurchmesser ist die Länge einer geraden Linie von einer Außenfläche eines Objekts oder Raums zur anderen Seite seiner Außenfläche durch den Mittelpunkt eines Objekts oder Raums, wenn es eine Innen- und Außenfläche hat.</skos:definition> <skos:definition xml:lang="zh">外径是从物体或空间的一个外表面穿过其中心到另一外表面的直线长度，前提是该物体或空间具有内外表面。</skos:definition>
        <skos:definition xml:lang="en">Outer diameter is a length of a straight line from one outer surface of an object or space to the other side of its outer surface through the center of an object or space when it has the inside and outside surface.</skos:definition> <skos:definition xml:lang="zh">外径是指当物体或空间具有内表面和外表面时，从其一外表面穿过物体或空间中心到外表面另一侧的直线长度。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0025018 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0025018">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000145"/>
        <rdfs:label xml:lang="en">geometric relational quality</rdfs:label> <rdfs:label xml:lang="zh">几何关系质量</rdfs:label>
        <skos:definition xml:lang="en">Geometric relational quality is a relational quality describing the geometric relation between two or more independent continuants.</skos:definition> <skos:definition xml:lang="zh">几何关系质量是描述两个或多个独立持续物之间几何关系的关系质量。</skos:definition>
        <skos:example xml:lang="en">Elongation of a specimen after a tensile step, i.e., the specimen before and after the test. Angle between a rolling direction of a rolled material and the longitudinal side of a specimen.</skos:example> <skos:example xml:lang="zh">拉伸步骤后试样的伸长率，即试验前后的试样。轧制材料的轧制方向与试样纵向侧面之间的角度。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0025020 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0025020">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000849"/>
        <rdfs:label xml:lang="en">single fatigue testing process</rdfs:label> <rdfs:label xml:lang="zh">单次疲劳测试过程</rdfs:label>
        <skos:definition xml:lang="en">Mechanical property analyzing process that is an occurent part of a fatigue testing process (S-N testing process). A single fatigue testing process assesses how many cycles a material can withstand under the given loading.</skos:definition> <skos:definition xml:lang="zh">机械性能分析过程，是疲劳测试过程（S-N测试过程）的一个发生部分。单次疲劳测试过程评估材料在给定载荷下能承受多少循环次数。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0025021 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0025021">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000602"/>
        <obo:IAO_0000119>https://en.wikipedia.org/wiki/Stamping_press</obo:IAO_0000119>
        <rdfs:label xml:lang="de">Stanzmachine</rdfs:label> <rdfs:label xml:lang="zh">冲压机</rdfs:label>
        <rdfs:label xml:lang="en">stamping press</rdfs:label> <rdfs:label xml:lang="zh">冲压机</rdfs:label>
        <skos:definition xml:lang="de">Eine Stanzmachine ist ein Werkzeug/Gerät zur Metallbearbeitung, das dazu dient, geschnittenes Metall durch Verformung mit einer Matrize zu formen.</skos:definition> <skos:definition xml:lang="zh">冲压机是一种用于金属加工的工具/设备，通过模具使切屑的金属变形来成型。</skos:definition>
        <skos:definition xml:lang="en">Stamping press is a metalworking device which is used to shape a cut metal by deforming it with a die.</skos:definition> <skos:definition xml:lang="zh">冲压机是一种金属加工设备，用于通过模具变形来成型切割金属。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0025997 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0025997">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBI_0001931"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0001927"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0020101"/>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="https://w3id.org/pmd/co/PMD_0025999"/>
                                <owl:someValuesFrom>
                                    <owl:Class>
                                        <owl:intersectionOf rdf:parseType="Collection">
                                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000040"/>
                                            <owl:Restriction>
                                                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                                                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000040"/>
                                            </owl:Restriction>
                                        </owl:intersectionOf>
                                    </owl:Class>
                                </owl:someValuesFrom>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002350"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020004"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">fraction value specification</rdfs:label> <rdfs:label xml:lang="zh">分数值规范</rdfs:label>
        <skos:definition xml:lang="en">Fraction value specification is a value specification that contains information about quantitative share of a part relative to a specified whole.</skos:definition> <skos:definition xml:lang="zh">分数值规范是包含关于部分相对于指定整体的定量份额信息的数值规范。</skos:definition>
        <skos:example xml:lang="en">2.05 wt.% of carbon in steel, 4 vol.% of nitric acid in a solution</skos:example> <skos:example xml:lang="zh">钢中2.05 wt.%的碳，溶液中4 vol.%的硝酸</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0040001 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0040001">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020132"/>
        <rdfs:comment xml:lang="en">Length is a size that describes the spatial extent of its bearer in one dimension.</rdfs:comment>
        <rdfs:label xml:lang="en">length</rdfs:label> <rdfs:label xml:lang="zh">长度</rdfs:label>
        <skos:altLabel xml:lang="en">dimension</skos:altLabel> <skos:altLabel xml:lang="zh">尺寸</skos:altLabel>
        <skos:definition xml:lang="en">Length is a one dimensional size.</skos:definition> <skos:definition xml:lang="zh">长度是一维尺寸。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050000 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050000">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000145"/>
        <rdfs:label xml:lang="en">bond</rdfs:label> <rdfs:label xml:lang="zh">键</rdfs:label>
        <skos:definition xml:lang="en">A bond is a relational quality describing the force interaction between atoms.</skos:definition> <skos:definition xml:lang="zh">键是描述原子间力相互作用的关联性质。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050001 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050001">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050000"/>
        <obo:IAO_0000119 rdf:resource="https://sciencenotes.org/types-of-chemical-bonds/"/>
        <rdfs:label xml:lang="en">covalent bond</rdfs:label> <rdfs:label xml:lang="zh">共价键</rdfs:label>
        <skos:definition xml:lang="en">A covalent bond is a bond that forms when nonmetal atoms share electrons to achieve a stable electron configuration.</skos:definition> <skos:definition xml:lang="zh">共价键是非金属原子共享电子以实现稳定电子构型时形成的键。</skos:definition>
        <skos:example xml:lang="en">In a water molecule (H₂O), the hydrogen and oxygen atoms share electrons.</skos:example> <skos:example xml:lang="zh">在水分子（H₂O）中，氢原子和氧原子共享电子。</skos:example>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050002 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050002">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050000"/>
        <obo:IAO_0000119 rdf:resource="https://www.thoughtco.com/metallic-bond-definition-properties-and-examples-4117948"/>
        <rdfs:label xml:lang="en">metallic bond</rdfs:label> <rdfs:label xml:lang="zh">金属键</rdfs:label>
        <skos:definition xml:lang="en">A metallic bond is a bond that forms between metal atoms, where electrons are shared in a "sea" of electrons that move freely around the metal ions. This type of bonding gives metals their characteristic properties such as conductivity and malleability.</skos:definition> <skos:definition xml:lang="zh">金属键是金属原子之间形成的键，其中电子在围绕金属离子自由运动的“电子海”中共享。这种键合赋予金属导电性和延展性等特性。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050003 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050003">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050000"/>
        <obo:IAO_0000119 rdf:resource="https://sciencenotes.org/types-of-chemical-bonds/"/>
        <rdfs:label xml:lang="en">ionic bond</rdfs:label> <rdfs:label xml:lang="zh">离子键</rdfs:label>
        <skos:definition xml:lang="en">An ionic bond is a bond that occurs when one atom donates an electron to another atom, resulting in oppositely charged ions that attract each other.</skos:definition> <skos:definition xml:lang="zh">离子键是一个原子向另一个原子捐赠电子时形成的键，产生带相反电荷的离子并相互吸引。</skos:definition>
        <skos:example xml:lang="en">An example is the interaction between the atoms of sodium chloride (NaCl), where the sodium atom donates an electron to a chlorine atom.</skos:example> <skos:example xml:lang="zh">一个例子是氯化钠（NaCl）原子之间的相互作用，其中钠原子向氯原子捐赠一个电子。</skos:example>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050004 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050004">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000888"/>
        <rdfs:label xml:lang="en">thermoplastic polymer</rdfs:label> <rdfs:label xml:lang="zh">热塑性聚合物</rdfs:label>
        <skos:definition xml:lang="en">polymer that becomes moldable when heated and solidifies upon cooling</skos:definition> <skos:definition xml:lang="zh">加热时可塑、冷却时固化的聚合物</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050005 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050005">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050004"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002353"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0010033"/>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002233"/>
                                <owl:someValuesFrom>
                                    <owl:Class>
                                        <owl:intersectionOf rdf:parseType="Collection">
                                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/CHEBI_29362"/>
                                            <owl:Restriction>
                                                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000087"/>
                                                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_74236"/>
                                            </owl:Restriction>
                                        </owl:intersectionOf>
                                    </owl:Class>
                                </owl:someValuesFrom>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">polyethylene</rdfs:label> <rdfs:label xml:lang="zh">聚乙烯</rdfs:label>
        <skos:definition xml:lang="en">poylethylen is a thermoplastic polymer produced by polymerization of the monomer ethylene including further crosslinking and modifications using other comonomers; it excludes ultra hight molecular polyethylen</skos:definition> <skos:definition xml:lang="zh">聚乙烯是一种通过乙烯单体聚合生产的热塑性聚合物，包括进一步交联和使用其他共聚单体进行改性；它不包括超高分子量聚乙烯</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050006 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050006">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050005"/>
        <rdfs:label xml:lang="en">low-density polyethylene</rdfs:label> <rdfs:label xml:lang="zh">低密度聚乙烯</rdfs:label>
        <skos:definition xml:lang="en">polyethylene that is characterized by a branched molecular structure and low density</skos:definition> <skos:definition xml:lang="zh">以支链分子结构和低密度为特征的聚乙烯</skos:definition>
        <PMD_0050117>PE-LD</PMD_0050117>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050007 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050007">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050005"/>
        <rdfs:label xml:lang="en">high-density polyethylene</rdfs:label> <rdfs:label xml:lang="zh">高密度聚乙烯</rdfs:label>
        <skos:definition xml:lang="en">polyethylene that is characterized by a linear molecular structure and high density</skos:definition> <skos:definition xml:lang="zh">以线性分子结构和高密度为特征的聚乙烯</skos:definition>
        <PMD_0050117>PE-HD</PMD_0050117>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050008 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050008">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050005"/>
        <rdfs:label xml:lang="en">linear low-density polyethylene</rdfs:label> <rdfs:label xml:lang="zh">线性低密度聚乙烯</rdfs:label>
        <skos:definition xml:lang="en">polyethylene that is distinguished by its linear backbone with short-chain branching</skos:definition> <skos:definition xml:lang="zh">以其线性主链和短链支化为特征的聚乙烯</skos:definition>
        <PMD_0050117>PE_LLD</PMD_0050117>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050009 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050009">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050004"/>
        <rdfs:label xml:lang="en">polypropylene</rdfs:label> <rdfs:label xml:lang="zh">聚丙烯</rdfs:label>
        <skos:altLabel xml:lang="en">polyethene</skos:altLabel> <skos:altLabel xml:lang="zh">聚乙烯</skos:altLabel>
        <skos:comment xml:lang="en">this excludes ultra hight molecular polyethylen because very high molecular weight polyethylene is not thermoplastic anymore</skos:comment> <skos:comment xml:lang="zh">这排除了超高分子量聚乙烯，因为极高分子量的聚乙烯不再具有热塑性</skos:comment>
        <skos:definition xml:lang="en">thermoplastic polymer produced by polymerization of the monomer propylene including further crosslinking and modifications using other comonomers</skos:definition> <skos:definition xml:lang="zh">通过丙烯单体聚合生产的热塑性聚合物，包括进一步交联和使用其他共聚单体进行改性</skos:definition>
        <PMD_0050117>PP</PMD_0050117>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050010 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050010">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050009"/>
        <rdfs:label xml:lang="en">isotactic polypropylene</rdfs:label> <rdfs:label xml:lang="zh">等规聚丙烯</rdfs:label>
        <skos:definition xml:lang="en">polypropylene in which all the methyl groups are aligned on the same side of the polymer chain</skos:definition> <skos:definition xml:lang="zh">所有甲基基团排列在聚合物链同一侧的聚丙烯</skos:definition>
        <PMD_0050117>iPP</PMD_0050117>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050011 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050011">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050009"/>
        <rdfs:label xml:lang="en">syndiotactic polypropylene</rdfs:label> <rdfs:label xml:lang="zh">间规聚丙烯</rdfs:label>
        <skos:definition xml:lang="en">polypropylene in which the methyl groups alternate regularly along the polymer chain</skos:definition> <skos:definition xml:lang="zh">甲基基团沿聚合物链规则交替的聚丙烯</skos:definition>
        <PMD_0050117>sPP</PMD_0050117>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050012 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050012">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050009"/>
        <rdfs:label xml:lang="en">atactic polypropylene</rdfs:label> <rdfs:label xml:lang="zh">无规聚丙烯</rdfs:label>
        <skos:definition xml:lang="en">polypropylene in which the methyl groups are randomly distributed along the polymer chain</skos:definition> <skos:definition xml:lang="zh">甲基基团随机分布在聚合物链上的聚丙烯</skos:definition>
        <PMD_0050117>aPP</PMD_0050117>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050013 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050013">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050004"/>
        <rdfs:label xml:lang="en">polyvinyl chloride</rdfs:label> <rdfs:label xml:lang="zh">聚氯乙烯</rdfs:label>
        <skos:altLabel xml:lang="en">vinyl or polyvinyl</skos:altLabel> <skos:altLabel xml:lang="zh">乙烯基或聚乙烯基</skos:altLabel>
        <skos:comment xml:lang="en">they are usualy hard or soft and flexible with incrased use of plasticisers.</skos:comment> <skos:comment xml:lang="zh">它们通常为硬质或软质且柔韧，随着增塑剂使用量的增加而变得柔软</skos:comment>
        <skos:definition xml:lang="en">thermoplastic polymer produced by polymerization of the monomer vinyl chloride</skos:definition> <skos:definition xml:lang="zh">通过氯乙烯单体聚合生产的热塑性聚合物</skos:definition>
        <PMD_0050117>PVC</PMD_0050117>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050014 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050014">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050013"/>
        <rdfs:label xml:lang="en">rigid polyvinyl chloride</rdfs:label> <rdfs:label xml:lang="zh">硬质聚氯乙烯</rdfs:label>
        <skos:definition xml:lang="en">polyvinyl chloride that is characterized by its stiffness and durability</skos:definition> <skos:definition xml:lang="zh">以其刚性和耐久性为特征的聚氯乙烯</skos:definition>
        <PMD_0050117>uPVC</PMD_0050117>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050015 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050015">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050013"/>
        <rdfs:label xml:lang="en">flexible polyvinyl chloride</rdfs:label> <rdfs:label xml:lang="zh">软质聚氯乙烯</rdfs:label>
        <skos:definition xml:lang="en">polyvinyl chloride that has been modified with plasticizers to impart flexibility</skos:definition> <skos:definition xml:lang="zh">经增塑剂改性赋予柔韧性的聚氯乙烯</skos:definition>
        <PMD_0050117>fPVC</PMD_0050117>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050016 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050016">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050004"/>
        <rdfs:label xml:lang="en">polystyrene</rdfs:label> <rdfs:label xml:lang="zh">聚苯乙烯</rdfs:label>
        <skos:definition xml:lang="en">thermoplastic polymer produced by polymerization of the aromatic hydrocarbon styrene</skos:definition> <skos:definition xml:lang="zh">由芳香烃苯乙烯聚合而成的热塑性聚合物</skos:definition>
        <PMD_0050117>PS</PMD_0050117>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050017 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050017">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050016"/>
        <rdfs:label xml:lang="en">general purpose polystyrene</rdfs:label> <rdfs:label xml:lang="zh">通用聚苯乙烯</rdfs:label>
        <skos:definition xml:lang="en">polystyrene that is valued for its clarity and ease of processing</skos:definition> <skos:definition xml:lang="zh">以透明性和易加工性为特点的聚苯乙烯</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050018 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050018">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050016"/>
        <rdfs:label xml:lang="en">high impact polystyrene</rdfs:label> <rdfs:label xml:lang="zh">高抗冲聚苯乙烯</rdfs:label>
        <skos:definition xml:lang="en">polystyrene that is modified with rubber to improve its impact resistance</skos:definition> <skos:definition xml:lang="zh">经橡胶改性以提高抗冲击性的聚苯乙烯</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050019 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050019">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050004"/>
        <rdfs:label xml:lang="en">polyethylene terephthalate</rdfs:label> <rdfs:label xml:lang="zh">聚对苯二甲酸乙二醇酯</rdfs:label>
        <skos:comment xml:lang="en">it is the dominant polyester utilized in global packaging and fiber applications</skos:comment> <skos:comment xml:lang="zh">它是全球包装和纤维应用中使用的主要聚酯</skos:comment>
        <skos:definition xml:lang="en">thermoplastic polymer produced by polycondensation of ethylene glycol and terephthalate precursors</skos:definition> <skos:definition xml:lang="zh">通过乙二醇和对苯二甲酸前体的缩聚反应生产的热塑性聚合物</skos:definition>
        <PMD_0050117>PET</PMD_0050117>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050020 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050020">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050019"/>
        <rdfs:label xml:lang="en">amorphous polyethylene terephthalate</rdfs:label> <rdfs:label xml:lang="zh">无定形聚对苯二甲酸乙二醇酯</rdfs:label>
        <skos:definition xml:lang="en">polyethylene terephthalate that is characterized by a non-crystalline structure</skos:definition> <skos:definition xml:lang="zh">以非晶态结构为特征的聚对苯二甲酸乙二醇酯</skos:definition>
        <PMD_0050117>APET</PMD_0050117>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050021 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050021">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050019"/>
        <rdfs:label xml:lang="en">crystalline polyethylene terephthalate</rdfs:label> <rdfs:label xml:lang="zh">结晶性聚对苯二甲酸乙二醇酯</rdfs:label>
        <skos:definition xml:lang="en">polyethylene terephthalate that is distinguished by its ordered, crystalline structure</skos:definition> <skos:definition xml:lang="zh">以其有序结晶结构为特征的聚对苯二甲酸乙二醇酯</skos:definition>
        <PMD_0050117>CPET</PMD_0050117>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050022 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050022">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000888"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002353"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0010034"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">thermosetting polymer</rdfs:label> <rdfs:label xml:lang="zh">热固性聚合物</rdfs:label>
        <skos:definition xml:lang="en">polymer that, once cured, irreversibly sets into a permanent shape</skos:definition> <skos:definition xml:lang="zh">一旦固化就不可逆地固定成永久形状的聚合物</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050023 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050023">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050022"/>
        <rdfs:label xml:lang="en">epoxy resin</rdfs:label> <rdfs:label xml:lang="zh">环氧树脂</rdfs:label>
        <skos:altLabel xml:lang="en">epoxy or polyepoxide</skos:altLabel> <skos:altLabel xml:lang="zh">环氧树脂或聚环氧化物</skos:altLabel>
        <skos:comment xml:lang="en">they are utilized for high-performance structural adhesives, composite matrices, and protective coatings.</skos:comment> <skos:comment xml:lang="zh">它们用于高性能结构粘合剂、复合材料基体和保护涂层。</skos:comment>
        <skos:definition xml:lang="en">thermosetting polymer that is a epoxide-functional oligomer curing via ring-opening into crosslinked networks used as precursors to thermosetting polymers</skos:definition> <skos:definition xml:lang="zh">一种具有环氧官能团的低聚物，通过开环固化形成交联网络，用作热固性聚合物的前体</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050024 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050024">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050023"/>
        <rdfs:label xml:lang="en">bisphenol a epoxy</rdfs:label> <rdfs:label xml:lang="zh">双酚A环氧树脂</rdfs:label>
        <skos:definition xml:lang="en">epoxy resin that is formulated using bisphenol a to enhance its mechanical properties</skos:definition> <skos:definition xml:lang="zh">使用双酚A配制以增强其机械性能的环氧树脂</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050025 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050025">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050023"/>
        <rdfs:label xml:lang="en">novolac epoxy</rdfs:label> <rdfs:label xml:lang="zh">酚醛环氧树脂</rdfs:label>
        <skos:definition xml:lang="en">epoxy resin that is based on novolac resins to provide improved thermal and chemical resistance</skos:definition> <skos:definition xml:lang="zh">基于酚醛树脂以提供改进的耐热性和耐化学性的环氧树脂</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050026 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050026">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050022"/>
        <rdfs:label xml:lang="en">phenolic resin</rdfs:label> <rdfs:label xml:lang="zh">酚醛树脂</rdfs:label>
        <skos:altLabel xml:lang="en">phenol-formaldehyde</skos:altLabel> <skos:altLabel xml:lang="zh">苯酚-甲醛</skos:altLabel>
        <skos:comment xml:lang="en">they are utilized for flame-resistant adhesives, friction materials, and molded components</skos:comment> <skos:comment xml:lang="zh">它们用于阻燃粘合剂、摩擦材料和模塑部件</skos:comment>
        <skos:comment xml:lang="en">they form rigid, char-forming crosslinked networks</skos:comment> <skos:comment xml:lang="zh">它们形成刚性、成炭的交联网络</skos:comment>
        <skos:definition xml:lang="en">thermosetting polymer synthesized via condensation of phenol and formaldehyde</skos:definition> <skos:definition xml:lang="zh">通过苯酚和甲醛缩合合成的热固性聚合物</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050027 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050027">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050026"/>
        <rdfs:label xml:lang="en">phenol-formaldehyde resin</rdfs:label> <rdfs:label xml:lang="zh">苯酚-甲醛树脂</rdfs:label>
        <skos:definition xml:lang="en">phenolic resin that is synthesized from phenol and formaldehyde</skos:definition> <skos:definition xml:lang="zh">由苯酚和甲醛合成的酚醛树脂</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050028 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050028">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050022"/>
        <rdfs:label xml:lang="en">melamine formaldehyde</rdfs:label> <rdfs:label xml:lang="zh">三聚氰胺甲醛</rdfs:label>
        <skos:altLabel xml:lang="en">melamine-formaldehyde</skos:altLabel> <skos:altLabel xml:lang="zh">三聚氰胺-甲醛</skos:altLabel>
        <skos:comment xml:lang="en">they are widely used in decorative laminates, kitchenware, and coating crosslinkers.</skos:comment> <skos:comment xml:lang="zh">它们广泛用于装饰层压板、厨具和涂料交联剂。</skos:comment>
        <skos:comment xml:lang="en">they form hard, durable crosslinked networks.</skos:comment> <skos:comment xml:lang="zh">它们形成坚硬、耐久的交联网络。</skos:comment>
        <skos:definition xml:lang="en">thermosetting aminoplast polymer synthesized via condensation</skos:definition> <skos:definition xml:lang="zh">通过缩合合成的热固性氨基塑料聚合物</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050029 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050029">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050022"/>
        <rdfs:label xml:lang="en">urea formaldehyde</rdfs:label> <rdfs:label xml:lang="zh">脲醛树脂</rdfs:label>
        <skos:definition xml:lang="en">thermosetting polymer formed from urea and formaldehyde, commonly used in adhesives and molding compounds.</skos:definition> <skos:definition xml:lang="zh">由尿素和甲醛形成的热固性聚合物，常用于粘合剂和模塑化合物。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050030 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050030">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000888"/>
        <rdfs:label xml:lang="en">elastomer</rdfs:label> <rdfs:label xml:lang="zh">弹性体</rdfs:label>
        <skos:definition xml:lang="en">polymer that exhibits elasticity by returning to its original shape after deformation</skos:definition> <skos:definition xml:lang="zh">变形后恢复原状从而表现出弹性的聚合物</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050031 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050031">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050030"/>
        <rdfs:label xml:lang="en">natural rubber</rdfs:label> <rdfs:label xml:lang="zh">天然橡胶</rdfs:label>
        <skos:comment xml:lang="en">they are predominantly cis-1,4-polyisoprene,</skos:comment> <skos:comment xml:lang="zh">它们主要是顺式-1,4-聚异戊二烯，</skos:comment>
        <skos:comment xml:lang="en">they are used widely in Heavy-duty truck tires</skos:comment> <skos:comment xml:lang="zh">它们广泛用于重型卡车轮胎</skos:comment>
        <skos:definition xml:lang="en">elastomer polymer, and a biopolymer harvested as plant latex; consisting of cis-1,4-polyisoprene chains; typically sulfur-vulcanized to create crosslinks between chains</skos:definition> <skos:definition xml:lang="zh">弹性体聚合物，作为植物乳胶收获的生物聚合物；由顺式-1,4-聚异戊二烯链组成；通常通过硫磺硫化在链间形成交联</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050032 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050032">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050030"/>
        <rdfs:label xml:lang="en">synthetic rubber</rdfs:label> <rdfs:label xml:lang="zh">合成橡胶</rdfs:label>
        <skos:definition xml:lang="en">elastomer that is produced through chemical synthesis to mimic natural rubber’s properties</skos:definition> <skos:definition xml:lang="zh">通过化学合成生产的、模拟天然橡胶性能的弹性体</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050033 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050033">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050032"/>
        <rdfs:label xml:lang="en">styrene-butadiene rubber</rdfs:label> <rdfs:label xml:lang="zh">丁苯橡胶</rdfs:label>
        <skos:comment xml:lang="en">used widely for its good abrasion resistance and tunable hardness, for instance in tire treads.</skos:comment> <skos:comment xml:lang="zh">因其良好的耐磨性和可调硬度而广泛使用，例如轮胎胎面。</skos:comment>
        <skos:definition xml:lang="en">synthetic rubber and belongs to a family of synthetic random copolymer elastomers of styrene and butadiene, made by emulsion or solution polymerization and typically vulcanized</skos:definition> <skos:definition xml:lang="zh">合成橡胶，属于苯乙烯和丁二烯的合成无规共聚弹性体家族，通过乳液或溶液聚合制成，通常进行硫化</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050034 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050034">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050032"/>
        <rdfs:label xml:lang="en">nitrile butadiene rubber</rdfs:label> <rdfs:label xml:lang="zh">丁腈橡胶</rdfs:label>
        <skos:altLabel xml:lang="en">Nitrile </skos:altLabel> <skos:altLabel xml:lang="zh">丁腈橡胶</skos:altLabel>
        <skos:comment xml:lang="en">Oil resistance, Fuel resistance</skos:comment> <skos:comment xml:lang="zh">耐油性，耐燃油性</skos:comment>
        <skos:comment xml:lang="en">it can have tunable polarity and oil/fuel resistance</skos:comment> <skos:comment xml:lang="zh">它具有可调的极性和耐油/耐燃油性</skos:comment>
        <skos:definition xml:lang="en">synthetic rubber that belongs to a family of synthetic acrylonitrile–butadiene copolymer elastomers</skos:definition> <skos:definition xml:lang="zh">属于合成丙烯腈-丁二烯共聚弹性体家族的一种合成橡胶</skos:definition>
        <skos:example xml:lang="en"> it is widely used in oil/fuel resistance applicaitons such as seals, fuel hoses, and protective gloves</skos:example> <skos:example xml:lang="zh">它广泛用于耐油/耐燃油的应用，如密封件、燃油软管和防护手套</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050035 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050035">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050032"/>
        <rdfs:label xml:lang="en">ethylene propylene diene monomer</rdfs:label> <rdfs:label xml:lang="zh">三元乙丙橡胶</rdfs:label>
        <skos:comment xml:lang="en">it offers excellent weather resistance</skos:comment> <skos:comment xml:lang="zh">它具有优异的耐候性</skos:comment>
        <skos:definition xml:lang="en">synthetic rubber produced from ethylene, propylene, and a diene monomer</skos:definition> <skos:definition xml:lang="zh">由乙烯、丙烯和二烯单体生产的合成橡胶</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050036 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050036">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000888"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000091"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0200001"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000888"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000091"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0200001"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">biodegradable polymers</rdfs:label> <rdfs:label xml:lang="zh">可生物降解聚合物</rdfs:label>
        <skos:definition xml:lang="en">polymeric material that possesses the disposition to undergo decomposition through the metabolic activity of biological organisms, resulting in conversion into environmentally benign substances—such as carbon dioxide, methane, mineral salts, and biomass—within a timescale that does not cause harmful accumulation in the environment</skos:definition> <skos:definition xml:lang="zh">具有通过生物有机体的代谢活动进行分解的倾向的聚合物材料，从而转化为环境友好物质——如二氧化碳、甲烷、矿物盐和生物质——在不会导致环境中有害积累的时间范围内</skos:definition>
        <PMD_0001032>https://github.com/materialdigital/core-ontology/issues/126</PMD_0001032>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050037 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050037">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050004"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050036"/>
        <rdfs:label xml:lang="en">polylactic acid</rdfs:label> <rdfs:label xml:lang="zh">聚乳酸</rdfs:label>
        <skos:definition xml:lang="en">biodegradable thermoplastic polymer produced from renewable resources such as corn starch</skos:definition> <skos:definition xml:lang="zh">由可再生资源（如玉米淀粉）生产的可生物降解热塑性聚合物</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050038 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050038">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000888"/>
        <rdfs:label xml:lang="en">polyhydroxyalkanoates</rdfs:label> <rdfs:label xml:lang="zh">聚羟基脂肪酸酯</rdfs:label>
        <skos:definition xml:lang="en">polyhydroxyalkanoates are biodegradable polymers that are biosynthesized by microorganisms from sugars or lipids</skos:definition> <skos:definition xml:lang="zh">聚羟基脂肪酸酯是由微生物从糖或脂质生物合成的可生物降解聚合物</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050039 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050039">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050004"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050036"/>
        <rdfs:label xml:lang="en">polybutylene succinate</rdfs:label> <rdfs:label xml:lang="zh">聚丁二酸丁二醇酯</rdfs:label>
        <skos:definition xml:lang="en">biodegradable thermoplastic polymer polyester that is synthesized via the polycondensation of succinic acid and 1,4-butanediol</skos:definition> <skos:definition xml:lang="zh">通过丁二酸和1,4-丁二醇缩聚合成的可生物降解热塑性聚酯聚合物</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050040 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050040">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000546"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000312"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000113"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000546"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000312"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000113"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">natural ceramic</rdfs:label> <rdfs:label xml:lang="zh">天然陶瓷</rdfs:label>
        <skos:definition xml:lang="en">ceramic that is produced using conventional methods with natural raw materials such as clay and silica</skos:definition> <skos:definition xml:lang="zh">使用常规方法以天然原料（如粘土和二氧化硅）生产的陶瓷</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050041 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050041">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050055"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020050"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">silicate ceramic</rdfs:label> <rdfs:label xml:lang="zh">硅酸盐陶瓷</rdfs:label>
        <skos:definition xml:lang="en">oxide ceramic consisting primarily of silicon oxide</skos:definition> <skos:definition xml:lang="zh">主要由氧化硅组成的氧化物陶瓷</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050042 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050042">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000002"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050041"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000312"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000833"/>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000293"/>
                                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000114"/>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://w3id.org/pmd/co/PMD_0050049"/>
        <rdfs:label xml:lang="en">clay-based ceramic</rdfs:label> <rdfs:label xml:lang="zh">粘土基陶瓷</rdfs:label>
        <skos:definition xml:lang="en">silicate ceramics that are formed from natural clays</skos:definition> <skos:definition xml:lang="zh">由天然粘土形成的硅酸盐陶瓷</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050043 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050043">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050040"/>
        <rdfs:label xml:lang="en">earthenware</rdfs:label> <rdfs:label xml:lang="zh">陶器</rdfs:label>
        <skos:definition xml:lang="en">natural ceramic that is clay-based, formed at relatively low temperatures, resulting in a porous, rustic material</skos:definition> <skos:definition xml:lang="zh">以粘土为基础的天然陶瓷，在较低温度下成型，产生多孔、质朴的材料</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050044 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050044">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050040"/>
        <rdfs:label xml:lang="en">stoneware</rdfs:label> <rdfs:label xml:lang="zh">炻器</rdfs:label>
        <skos:definition xml:lang="en">natural ceramic that is clay-based, fired at higher temperatures than earthenware to yield a denser, more durable material</skos:definition> <skos:definition xml:lang="zh">天然陶瓷，以粘土为基础，在比陶器更高的温度下烧制，得到更致密、更耐用的材料</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050045 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050045">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050040"/>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:intersectionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000546"/>
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000087"/>
                                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020001"/>
                                    </owl:Restriction>
                                </owl:intersectionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:intersectionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000661"/>
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000087"/>
                                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000845"/>
                                    </owl:Restriction>
                                </owl:intersectionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">porcelain</rdfs:label> <rdfs:label xml:lang="zh">瓷器</rdfs:label>
        <skos:comment xml:lang="en">a glass binder with ceramic filler produced from ceramics</skos:comment> <skos:comment xml:lang="zh">由陶瓷制成的含有陶瓷填料的玻璃粘合剂</skos:comment>
        <skos:definition xml:lang="en">natural ceramic that is clay-bsed, distinguished by its translucency, strength, and refined appearance</skos:definition> <skos:definition xml:lang="zh">天然陶瓷，以粘土为基础，以其半透明性、强度和精致外观而著称</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050046 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050046">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050041"/>
        <rdfs:label xml:lang="en">aluminosilicate ceramic</rdfs:label> <rdfs:label xml:lang="zh">铝硅酸盐陶瓷</rdfs:label>
        <skos:definition xml:lang="en">silicate ceramics that consist of aluminum and silicon oxides</skos:definition> <skos:definition xml:lang="zh">由铝和硅氧化物组成的硅酸盐陶瓷</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050047 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050047">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050046"/>
        <rdfs:label xml:lang="en">mullite ceramic</rdfs:label> <rdfs:label xml:lang="zh">莫来石陶瓷</rdfs:label>
        <skos:definition xml:lang="en">aluminosilicate ceramic known for its excellent high-temperature stability</skos:definition> <skos:definition xml:lang="zh">以其优异的高温稳定性而闻名的铝硅酸盐陶瓷</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050048 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050048">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050046"/>
        <rdfs:label xml:lang="en">kaolinite ceramic</rdfs:label> <rdfs:label xml:lang="zh">高岭石陶瓷</rdfs:label>
        <skos:definition xml:lang="en">aluminosilicate ceramic based on the mineral kaolinite, valued for its fine particle size and plasticity</skos:definition> <skos:definition xml:lang="zh">基于高岭石矿物的铝硅酸盐陶瓷，因其细小的颗粒尺寸和可塑性而受到重视</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050049 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050049">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050040"/>
        <rdfs:label xml:lang="en">non-clay ceramic</rdfs:label> <rdfs:label xml:lang="zh">非粘土陶瓷</rdfs:label>
        <skos:definition xml:lang="en">natural ceramic that is formed from raw materials other than clay</skos:definition> <skos:definition xml:lang="zh">由粘土以外的原材料形成的天然陶瓷</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050050 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050050">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000002"/>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                                <owl:someValuesFrom>
                                    <owl:Class>
                                        <owl:intersectionOf rdf:parseType="Collection">
                                            <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000546"/>
                                            <owl:Restriction>
                                                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000087"/>
                                                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020001"/>
                                            </owl:Restriction>
                                        </owl:intersectionOf>
                                    </owl:Class>
                                </owl:someValuesFrom>
                            </owl:Restriction>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                                <owl:someValuesFrom>
                                    <owl:Class>
                                        <owl:intersectionOf rdf:parseType="Collection">
                                            <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000661"/>
                                            <owl:Restriction>
                                                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000087"/>
                                                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000845"/>
                                            </owl:Restriction>
                                        </owl:intersectionOf>
                                    </owl:Class>
                                </owl:someValuesFrom>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000086"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000591"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">glass-ceramic</rdfs:label> <rdfs:label xml:lang="zh">玻璃陶瓷</rdfs:label>
        <skos:definition xml:lang="en">Glass‑ceramics are inorganic, non‑metallic materials prepared by controlled crystallization of glasses via different processing methods; they contain at least one type of functional crystalline phase and a residual glass, and the crystallized volume fraction may vary from ppm to almost 100%.</skos:definition> <skos:definition xml:lang="zh">玻璃陶瓷是无机非金属材料，通过不同的处理方法对玻璃进行受控结晶制备而成；它们含有至少一种功能性晶相和残留玻璃，结晶体积分数可能从百万分之一到接近100%不等。</skos:definition>
        <skos:definition xml:lang="en">engenieered material that is inorganic, non‑metallic and prepared by controlled crystallization of glasses via different processing methods; they contain at least one type of functional crystalline phase and a residual glass, and the crystallized volume fraction may vary from ppm to almost 100%</skos:definition> <skos:definition xml:lang="zh">工程材料，为无机非金属材料，通过不同的处理方法对玻璃进行受控结晶制备而成；它们含有至少一种功能性晶相和残留玻璃，结晶体积分数可能从百万分之一到接近100%不等。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050051 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050051">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0040001"/>
        <obo:IAO_0000119 xml:lang="en">“Diameter.” Merriam-Webster.com Dictionary, Merriam-Webster, https://www.merriam-webster.com/dictionary/diameter. Accessed 5 Dec. 2022.</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">“直径。”Merriam-Webster.com词典，Merriam-Webster，https://www.merriam-webster.com/dictionary/diameter。访问于2022年12月5日。</obo:IAO_0000119>
        <rdfs:label xml:lang="de">Durchmesser</rdfs:label> <rdfs:label xml:lang="zh">直径</rdfs:label>
        <rdfs:label xml:lang="en">diameter</rdfs:label> <rdfs:label xml:lang="zh">直径</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://w3id.org/pmd/co/2.0.8/Diameter"/>
        <skos:definition xml:lang="de">Die Länge einer geraden Linie durch den Mittelpunkt eines Objekts oder Raums.</skos:definition> <skos:definition xml:lang="zh">通过物体或空间中心的一条直线的长度。</skos:definition>
        <skos:definition xml:lang="en">The length of a straight line through the center of an object or space.</skos:definition> <skos:definition xml:lang="zh">通过物体或空间中心的一条直线的长度。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050052 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050052">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050050"/>
        <rdfs:label xml:lang="en">leucite-based glass-ceramic</rdfs:label> <rdfs:label xml:lang="zh">基于白榴石的玻璃陶瓷</rdfs:label>
        <skos:definition xml:lang="en">glass-ceramics that are non-clay ceramics containing leucite crystals to enhance thermal and mechanical properties</skos:definition> <skos:definition xml:lang="zh">含有白榴石晶体以增强热学和机械性能的非粘土陶瓷玻璃陶瓷</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050053 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050053">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050049"/>
        <rdfs:label xml:lang="en">fritted ceramic</rdfs:label> <rdfs:label xml:lang="zh">熔块陶瓷</rdfs:label>
        <skos:definition xml:lang="en">non-clay ceramic that is manufactured by fusing and subsequently grinding glass materials</skos:definition> <skos:definition xml:lang="zh">通过熔融然后研磨玻璃材料制造的非粘土陶瓷</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050054 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050054">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000546"/>
        <rdfs:label xml:lang="en">technical ceramic</rdfs:label> <rdfs:label xml:lang="zh">技术陶瓷</rdfs:label>
        <skos:definition xml:lang="en">ceramics that are engineered for high-performance applications</skos:definition> <skos:definition xml:lang="zh">工程化高性能陶瓷</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050055 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050055">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000546"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020091"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020249"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">oxide ceramic</rdfs:label> <rdfs:label xml:lang="zh">氧化物陶瓷</rdfs:label>
        <skos:definition xml:lang="en">ceramic consisting primarily of metal oxide</skos:definition> <skos:definition xml:lang="zh">主要由金属氧化物组成的陶瓷</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050056 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050056">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050055"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020071"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">alumina ceramic</rdfs:label> <rdfs:label xml:lang="zh">氧化铝陶瓷</rdfs:label>
        <skos:definition xml:lang="en">oxide ceramic consisting primarily of aluminium oxide</skos:definition> <skos:definition xml:lang="zh">主要由氧化铝组成的氧化物陶瓷</skos:definition>
        <PMD_0050117>Al₂O₃</PMD_0050117>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050057 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050057">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050055"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020053"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">zirconia ceramic</rdfs:label> <rdfs:label xml:lang="zh">氧化锆陶瓷</rdfs:label>
        <skos:definition xml:lang="en">oxide ceramic consisting primarily of zirconium oxide</skos:definition> <skos:definition xml:lang="zh">主要由氧化锆组成的氧化物陶瓷</skos:definition>
        <PMD_0050117>ZrO₂</PMD_0050117>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050058 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050058">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050057"/>
        <rdfs:label xml:lang="en">yttria-stabilized zirconia ceramic</rdfs:label> <rdfs:label xml:lang="zh">氧化钇稳定氧化锆陶瓷</rdfs:label>
        <skos:definition xml:lang="en">zirconia ceramic stabilized with yttria to enhance its thermal and mechanical performance</skos:definition> <skos:definition xml:lang="zh">通过氧化钇稳定以提高其热学和力学性能的氧化锆陶瓷</skos:definition>
        <PMD_0050117>YSZ</PMD_0050117>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050059 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050059">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050057"/>
        <rdfs:label xml:lang="en">magnesia-stabilized zirconia ceramic</rdfs:label> <rdfs:label xml:lang="zh">氧化镁稳定氧化锆陶瓷</rdfs:label>
        <skos:definition xml:lang="en">zirconia ceramic stabilized with magnesia to improve its thermal stability</skos:definition> <skos:definition xml:lang="zh">通过氧化镁稳定以提高其热稳定性的氧化锆陶瓷</skos:definition>
        <PMD_0050117>MSZ</PMD_0050117>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050060 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050060">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050055"/>
        <rdfs:label xml:lang="en">titania ceramic</rdfs:label> <rdfs:label xml:lang="zh">氧化钛陶瓷</rdfs:label>
        <skos:definition xml:lang="en">oxide ceramic composed of titanium dioxide, used for its photocatalytic and pigment properties</skos:definition> <skos:definition xml:lang="zh">由二氧化钛组成的氧化物陶瓷，因其光催化和颜料特性而使用</skos:definition>
        <PMD_0050117>TiO₂</PMD_0050117>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050061 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050061">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050055"/>
        <rdfs:label xml:lang="en">beryllia ceramic</rdfs:label> <rdfs:label xml:lang="zh">氧化铍陶瓷</rdfs:label>
        <skos:definition xml:lang="en">oxide ceramic that is an advanced ceramic composed of beryllium oxide, valued for its high thermal conductivity and electrical insulation</skos:definition> <skos:definition xml:lang="zh">由氧化铍组成的高级陶瓷，以其高热导率和电绝缘性而受重视</skos:definition>
        <PMD_0050117>BeO</PMD_0050117>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050062 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050062">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000546"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020249"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">non-oxide ceramic</rdfs:label> <rdfs:label xml:lang="zh">非氧化物陶瓷</rdfs:label>
        <skos:definition xml:lang="en">ceramic consisting primarily of non-oxide elements</skos:definition> <skos:definition xml:lang="zh">主要由非氧化物元素组成的陶瓷</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050063 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050063">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050062"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020030"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">carbide ceramic</rdfs:label> <rdfs:label xml:lang="zh">碳化物陶瓷</rdfs:label>
        <skos:definition xml:lang="en">non-oxide ceramic consisting of a metal and carbon</skos:definition> <skos:definition xml:lang="zh">由金属和碳组成的非氧化物陶瓷</skos:definition>
    </owl:Class>
    


