        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">oxide-oxide composite</rdfs:label> <rdfs:label xml:lang="zh">氧化物-氧化物复合材料</rdfs:label>
        <skos:definition xml:lang="en">ceramic matrix composite that consists entirely of oxide ceramic phases for both the matrix and reinforcement</skos:definition> <skos:definition xml:lang="zh">完全由氧化物陶瓷相组成的陶瓷基复合材料，基体和增强体均为氧化物</skos:definition>
        <skos:example xml:lang="en">aluminum oxide composites</skos:example> <skos:example xml:lang="zh">氧化铝复合材料</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050076 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050076">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050075"/>
        <rdfs:label xml:lang="en">alumina matrix composite</rdfs:label> <rdfs:label xml:lang="zh">氧化铝基复合材料</rdfs:label>
        <skos:definition xml:lang="en">oxide-oxide composite that uses alumina as the primary matrix reinforced by secondary oxide phases</skos:definition> <skos:definition xml:lang="zh">以氧化铝为主要基体，由二次氧化物相增强的氧化物-氧化物复合材料</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050077 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050077">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050075"/>
        <rdfs:label xml:lang="en">zirconia matrix composite</rdfs:label> <rdfs:label xml:lang="zh">氧化锆基复合材料</rdfs:label>
        <skos:definition xml:lang="en">oxide-oxide composite that uses zirconia as the primary matrix reinforced by additional oxide phases</skos:definition> <skos:definition xml:lang="zh">以氧化锆为主要基体，由其他氧化物相增强的氧化物-氧化物复合材料</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050078 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050078">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050074"/>
