                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0010023"/>
                            <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0010024"/>
                            <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0010025"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">bioceramic</rdfs:label> <rdfs:label xml:lang="zh">生物陶瓷</rdfs:label>
        <skos:definition xml:lang="en">ceramic that is engineered to be compatible with biological systems</skos:definition> <skos:definition xml:lang="zh">设计为与生物系统兼容的陶瓷</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050092 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050092">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000546"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000091"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0010024"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050091"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000091"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0010024"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">bioinert ceramic</rdfs:label> <rdfs:label xml:lang="zh">生物惰性陶瓷</rdfs:label>
        <skos:definition xml:lang="en">ceramic that is designed to remain inert in biological environments to minimize adverse reactions</skos:definition> <skos:definition xml:lang="zh">设计在生物环境中保持惰性以最小化不良反应的陶瓷</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050095 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050095">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000546"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000091"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0010023"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050091"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000091"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0010023"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">bioactive ceramic</rdfs:label> <rdfs:label xml:lang="zh">生物活性陶瓷</rdfs:label>
        <skos:definition xml:lang="en">ceramic that interacts with biological tissues to promote bonding or regeneration</skos:definition> <skos:definition xml:lang="zh">与生物组织相互作用以促进结合或再生的陶瓷</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050096 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050096">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050055"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050095"/>
        <rdfs:label xml:lang="en">hydroxyapatite ceramic</rdfs:label> <rdfs:label xml:lang="zh">羟基磷灰石陶瓷</rdfs:label>
        <skos:definition xml:lang="en">oxide ceramic that is bioactive and composed of calcium phosphate and closely resembles the mineral component of bone</skos:definition> <skos:definition xml:lang="zh">具有生物活性、由磷酸钙组成且与骨骼矿物成分极为相似的氧化物陶瓷</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050098 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050098">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000546"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000091"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0010025"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050095"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000091"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0010025"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">bioresorbable ceramic</rdfs:label> <rdfs:label xml:lang="zh">生物可吸收陶瓷</rdfs:label>
        <skos:definition xml:lang="en">ceramic that is designed to gradually be resorbed and replaced by natural tissue</skos:definition> <skos:definition xml:lang="zh">设计为逐渐被吸收并被天然组织替代的陶瓷</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050101 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050101">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000661"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_30563"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">silicate glass</rdfs:label> <rdfs:label xml:lang="zh">硅酸盐玻璃</rdfs:label>
        <skos:definition xml:lang="en">glass whose network is based primarily on silica (SiO₂)</skos:definition> <skos:definition xml:lang="zh">网络结构主要基于二氧化硅（SiO₂）的玻璃</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050102 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050102">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050101"/>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_31344"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_32145"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">soda-lime glass</rdfs:label> <rdfs:label xml:lang="zh">钠钙玻璃</rdfs:label>
        <skos:comment xml:lang="en">soda (Na₂O) acting as a flux and lime (CaO) acting as a stabilizer</skos:comment> <skos:comment xml:lang="zh">钠（Na₂O）作为助熔剂、石灰（CaO）作为稳定剂</skos:comment>
        <skos:definition xml:lang="en">silicate glass that is composed of about 70% silica (SiO₂) with soda (Na₂O) and lime (CaO)</skos:definition> <skos:definition xml:lang="zh">由约70%二氧化硅（SiO₂）以及钠（Na₂O）和石灰（CaO）组成的硅酸盐玻璃</skos:definition>
        <skos:example xml:lang="en">widely used as common window and container glass.</skos:example> <skos:example xml:lang="zh">广泛用于普通窗户和容器玻璃。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050106 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050106">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050101"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_30163"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">borosilicate glass</rdfs:label> <rdfs:label xml:lang="zh">硼硅酸盐玻璃</rdfs:label>
        <skos:comment xml:lang="en">characteristically low thermal expansion and high thermal/chemical resistance compared with soda‑lime glass.</skos:comment> <skos:comment xml:lang="zh">与钠钙玻璃相比，具有特征性的低热膨胀性和高耐热/耐化学性。</skos:comment>
        <skos:definition xml:lang="en">silicate glass that uses boron trioxide (B₂O₃) as a major additional glass‑forming constituent</skos:definition> <skos:definition xml:lang="zh">以三氧化二硼（B₂O₃）为主要附加玻璃形成组分的硅酸盐玻璃</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050107 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050107">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050106"/>
        <rdfs:label xml:lang="en">pyrex-type glass</rdfs:label> <rdfs:label xml:lang="zh">派热克斯型玻璃</rdfs:label>
        <skos:definition xml:lang="en">borosilicate glass that is renowned for its high resistance to thermal shock.</skos:definition> <skos:definition xml:lang="zh">以高抗热震性著称的硼硅酸盐玻璃。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050108 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050108">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050101"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_30187"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">aluminosilicate glass</rdfs:label> <rdfs:label xml:lang="zh">铝硅酸盐玻璃</rdfs:label>
        <skos:comment xml:lang="en">typically higher transformation/softening temperatures and improved mechanical/chemical performance compared with many common silicates</skos:comment> <skos:comment xml:lang="zh">与许多常见硅酸盐相比，通常具有更高的转变/软化温度和改善的机械/化学性能</skos:comment>
        <skos:definition xml:lang="en">silicate glass in which SiO₂ and Al₂O₃ are key structural units</skos:definition> <skos:definition xml:lang="zh">其中SiO₂和Al₂O₃是关键结构单元的硅酸盐玻璃</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050109 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050109">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050101"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_81045"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">lead glass</rdfs:label> <rdfs:label xml:lang="zh">铅玻璃</rdfs:label>
        <skos:comment xml:lang="en">increased refractive index and modified working properties relative to ordinary silicate glasses</skos:comment> <skos:comment xml:lang="zh">相对于普通硅酸盐玻璃，折射率提高且工作性能改变</skos:comment>
        <skos:definition xml:lang="en">silicate glass in which lead(II) oxide (PbO) is incorporated in significant amounts</skos:definition> <skos:definition xml:lang="zh">大量掺入氧化铅（PbO）的硅酸盐玻璃</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050110 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050110">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050109"/>
        <rdfs:label xml:lang="en">potash lead glass</rdfs:label> <rdfs:label xml:lang="zh">钾铅玻璃</rdfs:label>
        <skos:definition xml:lang="en">lead glass that utilizes potash as a flux in addition to lead oxide</skos:definition> <skos:definition xml:lang="zh">除了氧化铅之外，还使用钾碱作为助熔剂的铅玻璃</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050111 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050111">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050109"/>
        <rdfs:label xml:lang="en">barium glass</rdfs:label> <rdfs:label xml:lang="zh">钡玻璃</rdfs:label>
        <skos:definition xml:lang="en">Barium glass is a form of lead glass that is modified with barium oxide to alter its optical properties</skos:definition> <skos:definition xml:lang="zh">钡玻璃是一种用氧化钡改性以改变其光学特性的铅玻璃</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050112 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050112">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050108"/>
        <rdfs:label xml:lang="en">high-temperature resistant glass</rdfs:label> <rdfs:label xml:lang="zh">耐高温玻璃</rdfs:label>
        <skos:definition xml:lang="en">aluminosilicate glass that is engineered to maintain stability at elevated temperatures</skos:definition> <skos:definition xml:lang="zh">经设计可在高温下保持稳定性的铝硅酸盐玻璃</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050113 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050113">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000661"/>
        <rdfs:label xml:lang="en">non-silicate glass</rdfs:label> <rdfs:label xml:lang="zh">非硅酸盐玻璃</rdfs:label>
        <skos:comment xml:lang="en">Based on other glass formers or non‑oxide systems (e.g., phosphate (P₂O₅)-based, fluoride-based, or chalcogenide (S/Se/Te)-based compositions).</skos:comment> <skos:comment xml:lang="zh">基于其他玻璃形成体或非氧化物体系（例如，磷酸盐（P₂O₅）基、氟化物基或硫系（S/Se/Te）基成分）。</skos:comment>
        <skos:definition xml:lang="en">glass whose primary glass‑forming network is not based on SiO₂</skos:definition> <skos:definition xml:lang="zh">主要玻璃形成网络不基于SiO₂的玻璃</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050114 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050114">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050113"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_37376"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">phosphate glass</rdfs:label> <rdfs:label xml:lang="zh">磷酸盐玻璃</rdfs:label>
        <skos:comment xml:lang="en"> (P₂O₅) as the glass former (i.e., replacing SiO₂ as the network basis).</skos:comment> <skos:comment xml:lang="zh">以（P₂O₅）作为玻璃形成体（即取代SiO₂作为网络基础）。</skos:comment>
        <skos:definition xml:lang="en">non‑silicate glass based primarily on phosphorus pentoxide (P₂O₅)</skos:definition> <skos:definition xml:lang="zh">主要基于五氧化二磷（P₂O₅）的非硅酸盐玻璃</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050115 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050115">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050113"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_30163"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">borate glass</rdfs:label> <rdfs:label xml:lang="zh">硼酸盐玻璃</rdfs:label>
        <skos:comment xml:lang="en">It is distinct from borosilicate glass because B₂O₃ is the primary network former here rather than an added co‑former in a silica‑based network.</skos:comment> <skos:comment xml:lang="zh">它与硼硅酸盐玻璃不同，因为B₂O₃是主要的网络形成体，而不是硅基网络中添加的共形成体。</skos:comment>
        <skos:definition xml:lang="en">non‑silicate glass based primarily on boron oxide (B₂O₃) as the glass‑forming network</skos:definition> <skos:definition xml:lang="zh">主要基于氧化硼（B₂O₃）作为玻璃形成网络的非硅酸盐玻璃</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050116 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050116">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050113"/>
        <rdfs:label xml:lang="en">germanate glass</rdfs:label> <rdfs:label xml:lang="zh">锗酸盐玻璃</rdfs:label>
        <skos:definition xml:lang="en">non-silicate glass that is composed primarily of germanium oxide, noted for its infrared transmission</skos:definition> <skos:definition xml:lang="zh">主要由氧化锗组成的非硅酸盐玻璃，以其红外透射性能著称</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050118 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050118">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000661"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000053"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000877"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000661"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000053"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000790"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">optical glass</rdfs:label> <rdfs:label xml:lang="zh">光学玻璃</rdfs:label>
        <skos:comment xml:lang="en">composition and processing chosen to achieve specified optical/mechanical parameters such as refractive index and dispersion.</skos:comment> <skos:comment xml:lang="zh">选择和加工以实现指定的光学/机械参数，如折射率和色散。</skos:comment>
        <skos:definition xml:lang="en">glass manufactured for optical components</skos:definition> <skos:definition xml:lang="zh">为光学元件制造的玻璃</skos:definition>
        <skos:example xml:lang="en">e.g., lenses, prisms, mirrors</skos:example> <skos:example xml:lang="zh">例如，透镜、棱镜、反射镜</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050119 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050119">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050101"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050118"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000312"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0025011"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">fused silica glass</rdfs:label> <rdfs:label xml:lang="zh">熔融石英玻璃</rdfs:label>
        <skos:comment xml:lang="en">obtained by melting silica and cooling fast enough to avoid crystallization.</skos:comment> <skos:comment xml:lang="zh">通过熔化二氧化硅并快速冷却以避免结晶获得。</skos:comment>
        <skos:definition xml:lang="en">optical glass that is made from pure silica, prized for its high transparency and thermal stability.|Fused silica is a silicate glass that is essentially pure, amorphous SiO₂</skos:definition> <skos:definition xml:lang="zh">由纯二氧化硅制成的光学玻璃，以其高透明度和热稳定性而著称。|熔融石英是一种基本上为纯无定形SiO₂的硅酸盐玻璃。</skos:definition>
        <skos:definition xml:lang="en">silicate glass that is essentially pure, amorphous SiO₂</skos:definition> <skos:definition xml:lang="zh">基本上为纯无定形SiO₂的硅酸盐玻璃</skos:definition>
        <skos:example xml:lang="en">often called fused quartz or vitreous silica</skos:example> <skos:example xml:lang="zh">通常称为熔融石英或石英玻璃</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050120 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050120">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050118"/>
        <rdfs:label xml:lang="en">crown glass</rdfs:label> <rdfs:label xml:lang="zh">冠冕玻璃</rdfs:label>
        <skos:definition xml:lang="en">optical glass that is characterized by its low dispersion and high clarity</skos:definition> <skos:definition xml:lang="zh">一种光学玻璃，以低色散和高清晰度为特征</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050121 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050121">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050118"/>
        <rdfs:label xml:lang="en">flint glass</rdfs:label> <rdfs:label xml:lang="zh">燧石玻璃</rdfs:label>
        <skos:definition xml:lang="en">optical glass that is distinguished by its high refractive index and dispersion</skos:definition> <skos:definition xml:lang="zh">一种光学玻璃，以高折射率和高色散为特点</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050122 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050122">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000661"/>
        <rdfs:label xml:lang="en">specialty glass</rdfs:label> <rdfs:label xml:lang="zh">特种玻璃</rdfs:label>
        <skos:definition xml:lang="en">glass that is engineered primarily for a targeted functional performance profile</skos:definition> <skos:definition xml:lang="zh">主要为特定功能性能指标而设计的玻璃</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050123 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050123">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050126"/>
        <rdfs:label xml:lang="en">chemically strengthened glass</rdfs:label> <rdfs:label xml:lang="zh">化学强化玻璃</rdfs:label>
        <skos:definition xml:lang="en">glass that is treated via chemical processes to enhance its strength</skos:definition> <skos:definition xml:lang="zh">通过化学处理增强强度的玻璃</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050124 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050124">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000661"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000312"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000104"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050126"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000312"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000104"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">ion-exchanged glass</rdfs:label> <rdfs:label xml:lang="zh">离子交换玻璃</rdfs:label>
        <skos:definition xml:lang="en">glass that is chemically strengthened and produced by exchanging ions to improve durability</skos:definition> <skos:definition xml:lang="zh">通过离子交换进行化学强化以提高耐久性的玻璃</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050125 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050125">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050108"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050126"/>
        <rdfs:label xml:lang="en">aluminosilicate gorilla glass</rdfs:label> <rdfs:label xml:lang="zh">铝硅酸盐大猩猩玻璃</rdfs:label>
        <skos:definition xml:lang="en">glass that is chemically strengthened</skos:definition> <skos:definition xml:lang="zh">经过化学强化的玻璃</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050126 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050126">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000661"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000312"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000103"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000002"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000661"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000312"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000103"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">toughened (tempered) glass</rdfs:label> <rdfs:label xml:lang="zh">钢化玻璃</rdfs:label>
        <skos:definition xml:lang="en">glass that is mechanically treated to increase its strength and safety</skos:definition> <skos:definition xml:lang="zh">经过机械处理以提高强度和安全性</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050127 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050127">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000661"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000118"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">laminated glass</rdfs:label> <rdfs:label xml:lang="zh">夹层玻璃</rdfs:label>
        <skos:definition xml:lang="en">glass that is composed of multiple bonded layers to improve safety and acoustic performance</skos:definition> <skos:definition xml:lang="zh">由多层粘合层组成的玻璃，以提高安全性和隔音性能</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050128 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050128">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050133"/>
        <rdfs:label xml:lang="en">electrochromic glass</rdfs:label> <rdfs:label xml:lang="zh">电致变色玻璃</rdfs:label>
        <skos:definition xml:lang="en">functional glass that can reversibly change its light transmission properties when an electrical voltage is applied</skos:definition> <skos:definition xml:lang="zh">一种功能玻璃，在施加电压时可逆地改变其透光性能</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050129 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050129">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050133"/>
        <rdfs:label xml:lang="en">photochromic glass</rdfs:label> <rdfs:label xml:lang="zh">光致变色玻璃</rdfs:label>
        <skos:definition xml:lang="en">functional glass that alters its optical properties in response to exposure to light</skos:definition> <skos:definition xml:lang="zh">一种功能玻璃，其光学特性随光照而改变</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050130 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050130">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050133"/>
        <rdfs:label xml:lang="en">thermochromic glass</rdfs:label> <rdfs:label xml:lang="zh">热致变色玻璃</rdfs:label>
        <skos:definition xml:lang="en">functional glass that changes its optical properties as a function of temperature</skos:definition> <skos:definition xml:lang="zh">一种功能玻璃，其光学特性随温度变化</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050131 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050131">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050050"/>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020043"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020060"/>
                    </owl:Restriction>
                </owl:unionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">lithium disilicate glass-ceramic</rdfs:label> <rdfs:label xml:lang="zh">二硅酸锂玻璃陶瓷</rdfs:label>
        <skos:comment xml:lang="en">Provides transparent attenuation of X‑rays (and, depending on design, gamma radiation).</skos:comment> <skos:comment xml:lang="zh">提供对X‑rays（以及根据设计，对gamma radiation）的透明衰减。</skos:comment>
        <skos:definition xml:lang="en">glass-ceramics that contain lithium disilicate crystals to provide high strength and aesthetic appeal</skos:definition> <skos:definition xml:lang="zh">含有二硅酸锂晶体的玻璃陶瓷，具有高强度和高美观性</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050132 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050132">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050050"/>
        <rdfs:label xml:lang="en">transparent glass-ceramic</rdfs:label> <rdfs:label xml:lang="zh">透明玻璃陶瓷</rdfs:label>
        <skos:definition xml:lang="en">glass-ceramics that are engineered to maintain optical transparency despite partial crystallization</skos:definition> <skos:definition xml:lang="zh">经过工程设计以在部分结晶时仍保持光学透明性的玻璃陶瓷</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050133 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050133">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000661"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:intersectionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000030"/>
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000085"/>
                                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000034"/>
                                    </owl:Restriction>
                                </owl:intersectionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000654"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000661"/>
        <rdfs:label xml:lang="en">functional glass</rdfs:label> <rdfs:label xml:lang="zh">功能玻璃</rdfs:label>
        <skos:comment xml:lang="en">axiom is related to functional material</skos:comment> <skos:comment xml:lang="zh">公理与功能材料相关</skos:comment>
        <skos:definition xml:lang="en">glass that is designed to perform specific roles beyond conventional optical applications</skos:definition> <skos:definition xml:lang="zh">被设计用于执行超越传统光学应用特定功能的玻璃</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050134 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050134">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000661"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000091"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000620"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000661"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000091"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000620"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">conductive glass</rdfs:label> <rdfs:label xml:lang="zh">导电玻璃</rdfs:label>
        <skos:definition xml:lang="en">glass that has been modified to exhibit electrical conductivity</skos:definition> <skos:definition xml:lang="zh">经过改性以展现导电性的玻璃</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050137 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050137">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000661"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000053"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000825"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000661"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000053"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000825"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">magnetic glass</rdfs:label> <rdfs:label xml:lang="zh">磁性玻璃</rdfs:label>
        <skos:comment xml:lang="en">Its composition and/or microstructure contains a significant population of magnetic species - typically transition‑metal or rare‑earth ions and/or magnetic nanophases - so that magnetic susceptibility/permeability/magnetization is a designed functional property of the glass.</skos:comment> <skos:comment xml:lang="zh">其组成和/或微结构含有大量磁性物种——通常是过渡金属或稀土离子和/或磁性纳米相——使得磁化率/磁导率/磁化强度成为玻璃的设计功能性质。</skos:comment>
        <skos:definition xml:lang="en">glass that exhibits intrinsic bulk magnetic behavior|Magnetic glass is functional glass that is modified to exhibit magnetic properties</skos:definition> <skos:definition xml:lang="zh">展现固有体磁行为的玻璃|磁性玻璃是经过改性以展现磁性的功能玻璃</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050138 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050138">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050106"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050137"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000091"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000825"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">iron-borosilicate glass</rdfs:label> <rdfs:label xml:lang="zh">铁硼硅酸盐玻璃</rdfs:label>
        <skos:definition xml:lang="en">borosilicate glass that incorporates iron and borosilicate compounds to display magnetic behavior</skos:definition> <skos:definition xml:lang="zh">掺入铁和硼硅化合物以展现磁性的硼硅酸盐玻璃</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050139 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050139">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050106"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050137"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000091"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000825"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">cobalt-borosilicate glass</rdfs:label> <rdfs:label xml:lang="zh">钴硼硅酸盐玻璃</rdfs:label>
        <skos:definition xml:lang="en">borosilicate glass that is formulated with cobalt to enhance its magnetic properties</skos:definition> <skos:definition xml:lang="zh">用钴配制的以增强其磁性的硼硅酸盐玻璃</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050140 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050140">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0050118"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000053"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000107"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050118"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000053"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000107"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">nonlinear optical glass</rdfs:label> <rdfs:label xml:lang="zh">非线性光学玻璃</rdfs:label>
        <skos:definition xml:lang="en">optical glass that is engineered to display nonlinear optical responses under intense light</skos:definition> <skos:definition xml:lang="zh">经过工程设计以在强光下展现非线性光学响应的光学玻璃</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050141 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050141">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050113"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050118"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_33303"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000091"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000877"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">chalcogenide glass</rdfs:label> <rdfs:label xml:lang="zh">硫系玻璃</rdfs:label>
        <skos:comment xml:lang="en">Chalcogens such as sulfur, selenium, or tellurium as key constituents. Is valued particularly for infrared transparency.</skos:comment> <skos:comment xml:lang="zh">以硫、硒或碲等硫族元素为主要成分。因其红外透明性而受重视。</skos:comment>
        <skos:definition xml:lang="en">non‑silicate glass (generally non‑oxide) that contains one or more chalcogens</skos:definition> <skos:definition xml:lang="zh">含有一种或多种硫族元素的非硅酸盐玻璃（通常为非氧化物）</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050142 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050142">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050140"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000091"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000107"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">tellurite glass</rdfs:label> <rdfs:label xml:lang="zh">碲酸盐玻璃</rdfs:label>
        <skos:definition xml:lang="en">glass that is formulated with tellurium oxide to achieve a high refractive index and nonlinear properties</skos:definition> <skos:definition xml:lang="zh">用氧化碲配制的以实现高折射率和非线性性质的玻璃</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050143 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050143">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000661"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000091"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020251"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000661"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000091"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020251"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">bioactive glass</rdfs:label> <rdfs:label xml:lang="zh">生物活性玻璃</rdfs:label>
        <skos:comment xml:lang="en">enables bonding with bone tissue.</skos:comment> <skos:comment xml:lang="zh">能够与骨组织结合。</skos:comment>
        <skos:definition xml:lang="en">glass that forms a biologically compatible hydroxycarbonate apatite (HCA) layer on its surface in physiological conditions</skos:definition> <skos:definition xml:lang="zh">在生理条件下在其表面形成生物相容性羟基碳酸磷灰石（HCA）层的玻璃</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050144 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050144">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050101"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050143"/>
        <rdfs:label xml:lang="en">silicate-based bioactive glass</rdfs:label> <rdfs:label xml:lang="zh">硅酸盐基生物活性玻璃</rdfs:label>
        <skos:definition xml:lang="en">bioactive silicate glass that is composed primarily of silicate compounds to facilitate bonding with biological tissue</skos:definition> <skos:definition xml:lang="zh">主要由硅酸盐化合物组成的生物活性硅酸盐玻璃，以促进与生物组织的结合</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050145 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050145">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050144"/>
        <rdfs:label xml:lang="en">45S5 bioglass</rdfs:label> <rdfs:label xml:lang="zh">45S5生物玻璃</rdfs:label>
        <skos:definition xml:lang="en">silicate-based bioactive glass with a specific composition known for its ability to bond with bone</skos:definition> <skos:definition xml:lang="zh">具有特定成分的硅酸盐基生物活性玻璃，以其与骨骼结合的能力而闻名</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050146 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050146">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050144"/>
        <rdfs:label xml:lang="en">S53P4 bioglass</rdfs:label> <rdfs:label xml:lang="zh">S53P4生物玻璃</rdfs:label>
        <skos:definition xml:lang="en">silicate-based bioactive glass formulated with a distinct composition for enhanced bioactivity</skos:definition> <skos:definition xml:lang="zh">采用独特配方增强生物活性的硅酸盐基生物活性玻璃</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050147 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050147">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050114"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050143"/>
        <rdfs:label xml:lang="en">phosphate-based bioactive glass</rdfs:label> <rdfs:label xml:lang="zh">磷酸盐基生物活性玻璃</rdfs:label>
        <skos:definition xml:lang="en">phosphate glass that is bioactive and composed predominantly of phosphate compounds</skos:definition> <skos:definition xml:lang="zh">主要由磷酸盐化合物组成的生物活性磷酸盐玻璃</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050148 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050148">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050115"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050143"/>
        <rdfs:label xml:lang="en">borate-based bioactive glass</rdfs:label> <rdfs:label xml:lang="zh">硼酸盐基生物活性玻璃</rdfs:label>
        <skos:definition xml:lang="en">borate glass that is formulated with borate compounds to promote biological interaction</skos:definition> <skos:definition xml:lang="zh">采用硼酸盐化合物配方以促进生物相互作用的硼酸盐玻璃</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050149 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050149">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000661"/>
        <rdfs:label xml:lang="en">amorphous metal glass</rdfs:label> <rdfs:label xml:lang="zh">非晶金属玻璃</rdfs:label>
        <skos:definition xml:lang="en">glass that is characterized by a disordered, non-crystalline atomic structure, resembling a frozen liquid</skos:definition> <skos:definition xml:lang="zh">以无序、非晶态原子结构为特征的玻璃，类似于冻结的液体</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050150 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050150">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050149"/>
        <rdfs:label xml:lang="en">iron-based metallic glass</rdfs:label> <rdfs:label xml:lang="zh">铁基金属玻璃</rdfs:label>
        <skos:definition xml:lang="en">amorphous metal glass that is predominantly composed of iron</skos:definition> <skos:definition xml:lang="zh">主要由铁组成的非晶金属玻璃</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050151 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050151">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050149"/>
        <rdfs:label xml:lang="en">magnesium-based metallic glass</rdfs:label> <rdfs:label xml:lang="zh">镁基金属玻璃</rdfs:label>
        <skos:definition xml:lang="en">amorphous metal glass that is primarily composed of magnesium, noted for its low density</skos:definition> <skos:definition xml:lang="zh">主要由镁组成的非晶金属玻璃，以其低密度著称</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050152 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050152">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050149"/>
        <rdfs:label xml:lang="en">zirconium-based metallic glass</rdfs:label> <rdfs:label xml:lang="zh">锆基金属玻璃</rdfs:label>
        <skos:definition xml:lang="en">amorphous metal glass that is composed mainly of zirconium, valued for its corrosion resistance and strength</skos:definition> <skos:definition xml:lang="zh">主要由锆组成的非晶金属玻璃，以其耐腐蚀性和强度而备受重视</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050153 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050153">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0040001"/>
        <rdfs:label xml:lang="de">Dicke</rdfs:label> <rdfs:label xml:lang="zh">厚度</rdfs:label>
        <rdfs:label xml:lang="en">thickness</rdfs:label> <rdfs:label xml:lang="zh">厚度</rdfs:label>
        <skos:definition xml:lang="en">A length that describes the measured dimension in one direction of a test piece.</skos:definition> <skos:definition xml:lang="zh">描述试件在一个方向上测量尺寸的长度。</skos:definition>
        <skos:definition xml:lang="de">Diese Klasse beschreibt das gemessene Maß in einer Richtung eines Prüfkörpers.</skos:definition> <skos:definition xml:lang="zh">该类描述试件在一个方向上的测量尺寸。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050154 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050154">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0040001"/>
        <rdfs:label xml:lang="de">Breite</rdfs:label> <rdfs:label xml:lang="zh">宽度</rdfs:label>
        <rdfs:label xml:lang="en">width</rdfs:label> <rdfs:label xml:lang="zh">宽度</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://w3id.org/pmd/co/2.0.8/Width"/>
        <rdfs:seeAlso rdf:resource="https://www.merriam-webster.com/dictionary/width"/>
        <skos:definition xml:lang="de">Diese Klasse beschreibt eine horizontale Messung eines Objekts, die im rechten Winkel zur Länge des Objekts vorgenommen wird.</skos:definition> <skos:definition xml:lang="zh">该类描述对物体进行的水平测量，该测量与物体长度成直角。</skos:definition>
        <skos:definition xml:lang="en">This class describes a horizontal measurement of an object taken at right angles to the length of the object.</skos:definition> <skos:definition xml:lang="zh">该类描述对物体进行的水平测量，该测量与物体长度成直角。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050155 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050155">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020148"/>
        <obo:IAO_0000119 xml:lang="en">“Shape.” Merriam-Webster.com Dictionary, Merriam-Webster, https://www.merriam-webster.com/dictionary/shape. Accessed 13 Jan. 2023.</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">“形状”《Merriam-Webster.com词典》，Merriam-Webster出版社，https://www.merriam-webster.com/dictionary/shape。访问于2023年1月13日。</obo:IAO_0000119>
        <rdfs:label xml:lang="de">Form</rdfs:label> <rdfs:label xml:lang="zh">形态</rdfs:label>
        <rdfs:label xml:lang="en">shape</rdfs:label> <rdfs:label xml:lang="zh">形状</rdfs:label>
        <skos:definition xml:lang="de">Das sichtbare Ausstattungsmerkmal (räumliche Form oder Kontur) eines bestimmten Objektes oder einer Art von Objekt.</skos:definition> <skos:definition xml:lang="zh">特定对象或对象类型的可见外观特征（空间形状或轮廓）。</skos:definition>
        <skos:definition xml:lang="en">Extemsive quality, the visible makeup characteristic (spatial form or contour) of a particular item or kind of item.</skos:definition> <skos:definition xml:lang="zh">外延性质，特定物品或物品种类的可见构成特征（空间形状或轮廓）。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050156 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050156">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050155"/>
        <obo:IAO_0000119>DIN EN ISO 6892-1:2019</obo:IAO_0000119>
        <rdfs:label xml:lang="de">Geometrische Form</rdfs:label> <rdfs:label xml:lang="zh">几何形状</rdfs:label>
        <rdfs:label xml:lang="en">geometry shape</rdfs:label> <rdfs:label xml:lang="zh">几何形状</rdfs:label>
        <skos:definition xml:lang="de">Dieses Konzept beschreibt die geometrischen Abmessungen und das Erscheinungsbild (Form und Abmaße) einer Probe, eines Prüfkörpers oder eines Prüfstücks, wie sie üblicherweise durch eine entsprechende Norm definiert sind. Dementsprechend ist der angegebene Formwert in Übereinstimmung mit der definierenden Norm anzugeben, z. B. "Zugprüfstück Form 1 gemäß Anhang B der Zugversuchsnorm".</skos:definition> <skos:definition xml:lang="zh">此概念描述了试样、试件或测试件的几何尺寸和外观（形状和尺寸），这些通常由相应标准定义。因此，所提供的形状值应与定义的标准一致，例如“根据拉伸试验标准附录B的拉伸试样形状1”。</skos:definition>
        <skos:definition xml:lang="en">This concept describes the geometric dimensions and appearance (shape and dimensions) of a sample, specimen, or test piece as usually defined by a corresponding standard. Accordingly, the shape value given is in accordance with the defining standard, e.g., ‘tensile test piece shape 1 in accordance with annex B of the tensile test standard’.</skos:definition> <skos:definition xml:lang="zh">此概念描述了通常由相应标准定义的样品、试样或试件的几何尺寸和外观（形状和尺寸）。因此，给定的形状值应遵循定义标准，例如，‘根据拉伸试验标准附录B的拉伸试样形状1’。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050157 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050157">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050156"/>
        <rdfs:label xml:lang="de">3D Geometrie</rdfs:label> <rdfs:label xml:lang="zh">三维几何</rdfs:label>
        <rdfs:label xml:lang="en">shape 3d</rdfs:label> <rdfs:label xml:lang="zh">三维形状</rdfs:label>
        <skos:definition xml:lang="en">A shape 3D is a geometry shape that exists in three dimensions, having length, width, and height, and can be defined by its spatial properties such as volume and surface area.</skos:definition> <skos:definition xml:lang="zh">三维形状是一种存在于三个维度（长、宽、高）的几何形状，可通过其体积和表面积等空间属性来定义。</skos:definition>
        <skos:definition xml:lang="de">Eine 3D Geometrie ist eine geometrische Form, die in drei Dimensionen existiert, mit Länge, Breite und Höhe, und die durch ihre räumlichen Eigenschaften wie Volumen und Oberfläche definiert werden kann.</skos:definition> <skos:definition xml:lang="zh">三维几何是一种存在于三维空间中的几何形状，具有长度、宽度和高度，可以通过体积和表面等空间属性来定义。</skos:definition>
        <skos:example xml:lang="de">Beispiele sind Formen wie Würfel, Kugeln und Pyramiden.</skos:example> <skos:example xml:lang="zh">例如立方体、球体和棱锥等形状。</skos:example>
        <skos:example xml:lang="en">Examples include shapes like cubes, spheres, and pyramids.</skos:example> <skos:example xml:lang="zh">示例包括立方体、球体和棱锥等形状。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0060006 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0060006">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000033"/>
        <rdfs:label xml:lang="en">device specification</rdfs:label> <rdfs:label xml:lang="zh">设备规范</rdfs:label>
        <skos:definition xml:lang="en">A directive information entity that outlines the technical requirements, features, constraints, and performance criteria of a specific device, guiding its design, manufacturing, operation, or maintenance.</skos:definition> <skos:definition xml:lang="zh">一种指令性信息实体，概述特定设备的技术要求、特征、约束条件和性能标准，指导其设计、制造、操作或维护。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0060007 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0060007">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000033"/>
        <rdfs:label xml:lang="en">material specification</rdfs:label> <rdfs:label xml:lang="zh">材料规范</rdfs:label>
        <skos:definition xml:lang="en">A directive information entity that defines the composition, properties, performance criteria, and acceptable standards for a material, guiding its selection, processing, and application in a specific context.</skos:definition> <skos:definition xml:lang="zh">一种指令性信息实体，定义材料的成分、性能、性能标准和可接受标准，指导其在特定背景下的选择、加工和应用。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0060008 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0060008">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000104"/>
        <rdfs:label xml:lang="en">recipe</rdfs:label> <rdfs:label xml:lang="zh">配方</rdfs:label>
        <skos:definition xml:lang="en">A plan specification that outlines the ingredients, proportions, and procedural steps required to prepare a specific product, typically in cooking, manufacturing, or chemical processes.</skos:definition> <skos:definition xml:lang="zh">一种计划规范，概述制备特定产品所需的原料、比例和步骤，通常用于烹饪、制造或化学过程。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0060009 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0060009">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000033"/>
        <rdfs:comment xml:lang="en">The intent of the specification datum is to express the "Sollwert" of some qualitiy or behavioral material property. Then, the specification datum can be further specified by  some value specification.</rdfs:comment>
        <rdfs:label xml:lang="en">specification datum</rdfs:label> <rdfs:label xml:lang="zh">规范基准</rdfs:label>
        <skos:definition xml:lang="en">A directive information entity that provides information of a setpoint of some value, i.e., it is an intended value.</skos:definition> <skos:definition xml:lang="zh">一种指令性信息实体，提供某个值的设定点信息，即预期值。</skos:definition>
        <skos:example xml:lang="en">The setpoint value of a ultimate tensile strength of some steel material</skos:example> <skos:example xml:lang="zh">某种钢材的抗拉强度设定值。</skos:example>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0090000 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0090000">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000091"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0090001"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000000"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000086"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0090002"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000091"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0090001"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">semiconductor</rdfs:label> <rdfs:label xml:lang="zh">半导体</rdfs:label>
        <skos:definition xml:lang="en">A semiconductor is an engineered material representing a class of materials characterized by an electrical conductivity between that of a conductor and an insulator. This is a result of a range of inexistent energy states in ther electron configuration between the valence and conduction band (bandgap).</skos:definition> <skos:definition xml:lang="zh">半导体是一种工程材料，代表一类导电性介于导体和绝缘体之间的材料。这是由于电子构型中价带和导带之间（带隙）存在一系列不存在的能量态的结果。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0090001 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0090001">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000005"/>
        <rdfs:label xml:lang="en">semiconductivity</rdfs:label> <rdfs:label xml:lang="zh">半导电性</rdfs:label>
        <skos:definition xml:lang="en">Semiconductivity is the disposition of a material to conduct electricity only when a certain level of excitation (via temperature, impurities, photonic excitation, electric field) elevates electrons from the valence band into the conduction band.</skos:definition> <skos:definition xml:lang="zh">半导电性是材料仅在受到一定程度的激发（通过温度、杂质、光子激发、电场）将电子从价带提升到导带时才导电的特性。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0090002 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0090002">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020142"/>
        <rdfs:label xml:lang="en">band gap</rdfs:label> <rdfs:label xml:lang="zh">带隙</rdfs:label>
        <skos:altLabel xml:lang="en">bandgap</skos:altLabel> <skos:altLabel xml:lang="zh">带隙</skos:altLabel>
        <skos:altLabel xml:lang="en">energy gap</skos:altLabel> <skos:altLabel xml:lang="zh">能隙</skos:altLabel>
        <skos:definition xml:lang="en">A bandgap is an energy range between the valence band and the conduction band in a solid where no electronic states exist.</skos:definition> <skos:definition xml:lang="zh">带隙是固体中价带和导带之间不存在电子态的能量范围。</skos:definition>
        <skos:example xml:lang="en">Silicon has a band gap of 1.107 eV at room temperature.</skos:example> <skos:example xml:lang="zh">硅在室温下的带隙为1.107 eV。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0090004 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0090004">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000120"/>
        <rdfs:label xml:lang="en">aluminum matrix composite</rdfs:label> <rdfs:label xml:lang="zh">铝基复合材料</rdfs:label>
        <skos:comment xml:lang="en">often used to improve stiffness/wear at low weight,</skos:comment> <skos:comment xml:lang="zh">通常用于在低重量下提高刚度/耐磨性，</skos:comment>
        <skos:definition xml:lang="en">metal matrix composite, consisting of an aluminum or aluminum alloy matrix and one or more reinforcement materials</skos:definition> <skos:definition xml:lang="zh">金属基复合材料，由铝或铝合金基体与一种或多种增强材料组成</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0090005 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0090005">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000120"/>
        <rdfs:label xml:lang="en">titanium matrix composite</rdfs:label> <rdfs:label xml:lang="zh">钛基复合材料</rdfs:label>
        <skos:comment xml:lang="en">often chosen for elevated-temperature capability</skos:comment> <skos:comment xml:lang="zh">通常因其高温能力而被选用</skos:comment>
        <skos:definition xml:lang="en">metal matrix composite, consisting of a titanium or titanium alloy matrix and one or more reinforcement materials</skos:definition> <skos:definition xml:lang="zh">金属基复合材料，由钛或钛合金基体与一种或多种增强材料组成</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0090006 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0090006">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000120"/>
        <rdfs:label xml:lang="en">magnesium matrix composite</rdfs:label> <rdfs:label xml:lang="zh">镁基复合材料</rdfs:label>
        <skos:comment xml:lang="en">known for its ultra-low density and improved specific strength.</skos:comment> <skos:comment xml:lang="zh">以其超低密度和改善的比强度而闻名。</skos:comment>
        <skos:definition xml:lang="en">metal matrix composite, consisting of a magnesium or magnesium alloy matrix and one or more reinforcement materials</skos:definition> <skos:definition xml:lang="zh">金属基复合材料，由镁或镁合金基体与一种或多种增强材料组成</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0090007 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0090007">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000120"/>
        <rdfs:label xml:lang="en">copper matrix composite</rdfs:label> <rdfs:label xml:lang="zh">铜基复合材料</rdfs:label>
        <skos:comment xml:lang="en">often used for thermal management with high conductivity and tailored CTE (coefficient of thermal expansion)</skos:comment> <skos:comment xml:lang="zh">通常用于热管理，具有高导热性和可定制的CTE（热膨胀系数）</skos:comment>
        <skos:definition xml:lang="en">metal matrix composite, consisting of a copper or copper alloy matrix and one or more reinforcement materials</skos:definition> <skos:definition xml:lang="zh">金属基复合材料，由铜或铜合金基体与一种或多种增强材料组成</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0090008 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0090008">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000121"/>
        <rdfs:label xml:lang="en">glass fiber reinforced polymer</rdfs:label> <rdfs:label xml:lang="zh">玻璃纤维增强聚合物</rdfs:label>
        <skos:altLabel>GFRP/GRP</skos:altLabel>
        <skos:definition xml:lang="en">polymer matrix composite, consisting of a polymer matrix reinforced with glass fibers</skos:definition> <skos:definition xml:lang="zh">聚合物基复合材料，由玻璃纤维增强的聚合物基体组成</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0090009 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0090009">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000121"/>
        <rdfs:label xml:lang="en">carbon fiber reinforced polymer</rdfs:label> <rdfs:label xml:lang="zh">碳纤维增强聚合物</rdfs:label>
        <skos:definition xml:lang="en">polymer matrix composite, consisting of a polymer matrix reinforced with carbon fibers</skos:definition> <skos:definition xml:lang="zh">聚合物基复合材料，由碳纤维增强的聚合物基体组成</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0090010 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0090010">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000121"/>
        <rdfs:label xml:lang="en">aramid fiber composite</rdfs:label> <rdfs:label xml:lang="zh">芳纶纤维复合材料</rdfs:label>
        <skos:altLabel>Kevlar</skos:altLabel>
        <skos:definition xml:lang="en">polymer matrix composite, consisting of a polymer matrix reinforced with aramid (aromatic polyamide) fibers</skos:definition> <skos:definition xml:lang="zh">聚合物基复合材料，由芳纶（芳香族聚酰胺）纤维增强的聚合物基体组成</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0090011 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0090011">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000121"/>
        <rdfs:label xml:lang="en">natural fiber composite</rdfs:label> <rdfs:label xml:lang="zh">天然纤维复合材料</rdfs:label>
        <skos:definition xml:lang="en">polymer matrix composite, consisting of a polymer matrix reinforced with fibers derived from biological sources</skos:definition> <skos:definition xml:lang="zh">聚合物基复合材料，由生物来源纤维增强的聚合物基体组成</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0090012 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0090012">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000000"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002353"/>
                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/GO_0008150"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000000"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002353"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/GO_0008150"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">biological material</rdfs:label> <rdfs:label xml:lang="zh">生物材料</rdfs:label>
        <skos:altLabel xml:lang="en">biomaterial</skos:altLabel> <skos:altLabel xml:lang="zh">生物材料</skos:altLabel>
        <skos:comment xml:lang="en">produced through biological synthesis processes like Biological growth, morphogenesis, secretion etc.</skos:comment> <skos:comment xml:lang="zh">通过生物合成过程（如生物生长、形态发生、分泌等）产生</skos:comment>
        <skos:definition xml:lang="en">material produced by a living organism</skos:definition> <skos:definition xml:lang="zh">由生物体产生的材料</skos:definition>
        <skos:example xml:lang="en">Biological Comosite such as Wood, Bone, Silk, Wool;  Biopolymers such as cellulose, colagene;  Biogenic minerals such as hydroxyapatite</skos:example> <skos:example xml:lang="zh">生物复合材料如木材、骨骼、丝绸、羊毛；生物聚合物如纤维素、胶原蛋白；生物成因矿物如羟基磷灰石</skos:example>
        <PMD_0001032>https://github.com/materialdigital/core-ontology/issues/354</PMD_0001032>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0090013 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0090013">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000577"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002353"/>
                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/GO_0008150"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000577"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002353"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/GO_0008150"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">biological composite</rdfs:label> <rdfs:label xml:lang="zh">生物复合材料</rdfs:label>
        <skos:definition xml:lang="en">composite consisting of two or more distinct material phases organized in a multi-scale structure that act synergistically to fulfill specific properties or functions</skos:definition> <skos:definition xml:lang="zh">由两个或更多不同材料相组成的复合材料，这些相以多尺度结构组织，协同作用以实现特定的性能或功能</skos:definition>
        <skos:example xml:lang="en"> such as Wood, Bone, Silk, Wool;</skos:example> <skos:example xml:lang="zh">如木材、骨骼、丝绸、羊毛；</skos:example>
        <PMD_0001032>https://github.com/materialdigital/core-ontology/issues/354</PMD_0001032>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0090014 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0090014">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000888"/>
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0090012"/>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000888"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0090012"/>
        <rdfs:label xml:lang="en">biopolymer</rdfs:label> <rdfs:label xml:lang="zh">生物聚合物</rdfs:label>
        <skos:altLabel xml:lang="en">biomacromoleules</skos:altLabel> <skos:altLabel xml:lang="zh">生物大分子</skos:altLabel>
        <skos:definition xml:lang="en">polymer produced by the metabolic processes of a living organism</skos:definition> <skos:definition xml:lang="zh">由生物体的代谢过程产生的聚合物</skos:definition>
        <skos:example xml:lang="en">such as Polysaccharides like cellulose or Chitin; Proteins like colagene or Fibroin</skos:example> <skos:example xml:lang="zh">如多糖（纤维素或几丁质）；蛋白质（胶原蛋白或丝素蛋白）</skos:example>
        <PMD_0001032>https://github.com/materialdigital/core-ontology/issues/354</PMD_0001032>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0090015 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0090015">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000127"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002353"/>
                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/GO_0008150"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000127"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0090012"/>
        <rdfs:label xml:lang="en">biogenic mineral</rdfs:label> <rdfs:label xml:lang="zh">生物成因矿物</rdfs:label>
        <skos:definition xml:lang="en">mineral that is inorganic crystalline or amorphous solid synthesized by a living organism</skos:definition> <skos:definition xml:lang="zh">由生物体合成的无机晶体或非晶固体矿物</skos:definition>
        <skos:example xml:lang="en">such as Calcium Carbonates (in shells), Calcium Phosphates (Hydroxyapatite in bone/teeth), or Silica (in diatoms)</skos:example> <skos:example xml:lang="zh">如碳酸钙（贝壳中）、磷酸钙（骨骼/牙齿中的羟基磷灰石）或二氧化硅（硅藻中）</skos:example>
        <PMD_0001032>https://github.com/materialdigital/core-ontology/issues/354</PMD_0001032>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0090016 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0090016">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000000"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002353"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:intersectionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000833"/>
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000293"/>
                                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0090012"/>
                                    </owl:Restriction>
                                </owl:intersectionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000000"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002353"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000833"/>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000293"/>
                                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0090012"/>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">bio-based material</rdfs:label> <rdfs:label xml:lang="zh">生物基材料</rdfs:label>
        <skos:comment xml:lang="en">produced through industrial syntesis processes like Chemical extraction, fermentation, or polymerization</skos:comment> <skos:comment xml:lang="zh">通过工业合成过程（如化学提取、发酵或聚合）生产</skos:comment>
        <skos:definition xml:lang="en">material intentionally processed from materials derived from living (or once-living) organisms</skos:definition> <skos:definition xml:lang="zh">有意从来自活体（或曾经活着的）生物体的材料加工而成的材料</skos:definition>
        <skos:example xml:lang="en">Engineered Biopolymers such as Polylactic Acid (PLA);  Reconstituted Biopolymers such as Regenerated Cellulose (Rayon/Viscose); Biocomposites such as Wood-Plastic Composites (WPC);  Biochemicals (e.g. Bio-based Adhesives)</skos:example> <skos:example xml:lang="zh">工程生物聚合物如聚乳酸（PLA）；再生生物聚合物如再生纤维素（人造丝/粘胶）；生物复合材料如木塑复合材料（WPC）；生化制品（如生物基粘合剂）</skos:example>
        <PMD_0001032>https://github.com/materialdigital/core-ontology/issues/354</PMD_0001032>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0090017 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0090017">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0090016"/>
        <rdfs:label xml:lang="en">engineered biopolymer</rdfs:label> <rdfs:label xml:lang="zh">工程生物聚合物</rdfs:label>
        <skos:definition xml:lang="en">bio-based material and polymer synthesized through the intentional industrial transformation, synthesis, or reconstitution processes using materials derived from living (or once-living) organisms</skos:definition> <skos:definition xml:lang="zh">生物基材料和聚合物，通过有意的工业转化、合成或重构过程，使用源自活性（或曾经活性）生物体的材料制成</skos:definition>
        <skos:example xml:lang="en">synthetic Bio-polymer such as Polylactic Acid (PLA): or Regenrated Biopolymrs like Rayon / Viscose reconstituted from pulp cellulose; or microbial Biopolymers like Polyhydroxyalkanoates (PHA) synthesised by bacteria</skos:example> <skos:example xml:lang="zh">合成生物聚合物如聚乳酸（PLA）；或再生生物聚合物如从纸浆纤维素重构的人造丝/粘胶纤维；或微生物生物聚合物如细菌合成的聚羟基烷酸酯（PHA）</skos:example>
        <PMD_0001032>https://github.com/materialdigital/core-ontology/issues/354</PMD_0001032>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0090018 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0090018">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000577"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0090016"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000577"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0090016"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">bio-based composite</rdfs:label> <rdfs:label xml:lang="zh">生物基复合材料</rdfs:label>
        <skos:altLabel xml:lang="en">biocomposite; bio-composite</skos:altLabel> <skos:altLabel xml:lang="zh">生物复合材料；生物基复合材料</skos:altLabel>
        <skos:definition xml:lang="en">composite consisting of at least one constituent derived from biological or bio-based sources</skos:definition> <skos:definition xml:lang="zh">由至少一种源自生物或生物基来源的组分组成的复合材料</skos:definition>
        <skos:example xml:lang="en">such as Wood-Plastic Composite (WPC), Hemp-fiber reinforced Polypropylene</skos:example> <skos:example xml:lang="zh">如木塑复合材料（WPC）、麻纤维增强聚丙烯</skos:example>
        <PMD_0001032>https://github.com/materialdigital/core-ontology/issues/354</PMD_0001032>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0090019 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0090019">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0090016"/>
        <rdfs:label xml:lang="en">bio-based chemical</rdfs:label> <rdfs:label xml:lang="zh">生物基化学品</rdfs:label>
        <skos:altLabel xml:lang="en">biochemicals</skos:altLabel> <skos:altLabel xml:lang="zh">生物化学品</skos:altLabel>
        <skos:definition xml:lang="en">bio-based material used in chemical reactions as a reactant</skos:definition> <skos:definition xml:lang="zh">用作反应物的生物基材料</skos:definition>
        <skos:example xml:lang="en">such as bio-based adhesives (e.g. Lignin-based); Bio-epoxy resin.</skos:example> <skos:example xml:lang="zh">如生物基粘合剂（例如木质素基）；生物环氧树脂。</skos:example>
        <PMD_0001032>https://github.com/materialdigital/core-ontology/issues/354</PMD_0001032>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0090050 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0090050">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050022"/>
        <rdfs:label xml:lang="en">thermosetting polyurethane</rdfs:label> <rdfs:label xml:lang="zh">热固性聚氨酯</rdfs:label>
        <skos:comment xml:lang="en">offers high versatility in mechanical properties</skos:comment> <skos:comment xml:lang="zh">在机械性能方面提供高多功能性</skos:comment>
        <skos:definition xml:lang="en">thermosetting polymer with carbamate crosslinks</skos:definition> <skos:definition xml:lang="zh">具有氨基甲酸酯交联的热固性聚合物</skos:definition>
        <PMD_0050117>PUR</PMD_0050117>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0090051 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0090051">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050022"/>
        <rdfs:label xml:lang="en">unsaturated polyester resins</rdfs:label> <rdfs:label xml:lang="zh">不饱和聚酯树脂</rdfs:label>
        <skos:comment xml:lang="en">they are used for fiber-reinforced composites</skos:comment> <skos:comment xml:lang="zh">它们用于纤维增强复合材料</skos:comment>
        <skos:definition xml:lang="en">thermosetting polymer system of unsaturated polyester prepolymers in reactive vinyl monomers; it cures by radical crosslinking into rigid networks</skos:definition> <skos:definition xml:lang="zh">不饱和聚酯预聚物在反应性乙烯基单体中的热固性聚合物体系；通过自由基交联固化成刚性网络。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0090052 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0090052">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050032"/>
        <rdfs:label xml:lang="en">silicone rubber</rdfs:label> <rdfs:label xml:lang="zh">硅橡胶</rdfs:label>
        <skos:comment xml:lang="en">it is available in multiple formulations and often filled.</skos:comment> <skos:comment xml:lang="zh">它有多种配方且通常填充。</skos:comment>
        <skos:comment xml:lang="en">wide service temperature range</skos:comment> <skos:comment xml:lang="zh">宽使用温度范围</skos:comment>
        <skos:definition xml:lang="en">synthetic rubber that belongs to crosslinked polysiloxane elastomer family, with organic side groups</skos:definition> <skos:definition xml:lang="zh">属于交联聚硅氧烷弹性体家族的合成橡胶，带有有机侧基</skos:definition>
        <skos:example xml:lang="en">widely used for its broad service temperature range in medical devices, gaskets, and culinary tools</skos:example> <skos:example xml:lang="zh">因其宽使用温度范围而广泛应用于医疗器械、垫圈和烹饪工具</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0090053 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0090053">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050032"/>
        <rdfs:label xml:lang="en">polychloropren</rdfs:label> <rdfs:label xml:lang="zh">聚氯丁二烯</rdfs:label>
        <skos:altLabel> Neoprene</skos:altLabel>
        <skos:comment xml:lang="en">it offers good weathering and ozone resistance.</skos:comment> <skos:comment xml:lang="zh">它具有良好的耐候性和耐臭氧性。</skos:comment>
        <skos:comment xml:lang="en">weathering resistance; ozone resistance</skos:comment> <skos:comment xml:lang="zh">耐候性；耐臭氧性</skos:comment>
        <skos:definition xml:lang="en">synthetic rubber that belongs to the family of synthetic elastomeric rubbers; synthesised typically through emulsion polymerization of chloroprene</skos:definition> <skos:definition xml:lang="zh">属于合成弹性体橡胶家族的合成橡胶；通常通过氯丁二烯乳液聚合合成</skos:definition>
        <skos:example xml:lang="en"> it is widely used in gaskets and wetsuits. </skos:example> <skos:example xml:lang="zh">广泛用于垫片和潜水服。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0200000 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0200000">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000907"/>
        <dce:source xml:lang="de">Official definition can be found in: DIN 8580, group 1.2.1 “Pressformen”.</dce:source>
        <dce:source xml:lang="de">Offizielle Definition findet man in: DIN 8580, Gruppe 1.2.1 „Pressformen“.</dce:source>
        <rdfs:label xml:lang="de">Pressformen</rdfs:label> <rdfs:label xml:lang="zh">压制成型</rdfs:label>
        <rdfs:label xml:lang="en">compression molding</rdfs:label> <rdfs:label xml:lang="zh">压缩模塑</rdfs:label>
        <skos:altLabel xml:lang="en">compression moulding</skos:altLabel> <skos:altLabel xml:lang="zh">压缩模塑</skos:altLabel>
        <skos:definition xml:lang="en">A primary shaping from the plastic state process in which a pre-measured, usually preheated molding compound is placed in an open, heated mold cavity and shaped by closing the mold and applying pressure until the material cures or solidifies to the final part geometry.</skos:definition> <skos:definition xml:lang="zh">一种基于塑料态的一次成型工艺，将预定量（通常预热）的模塑料放入开放式加热模腔中，通过闭合模具并施加压力，使材料固化或凝固成最终零件几何形状。</skos:definition>
        <skos:definition xml:lang="de">Ein Urformverfahren, bei dem eine dosierte, meist vorgewärmte Formmasse in eine offene, beheizte Formkavität eingelegt und durch Schließen des Werkzeugs unter Druck zur endgültigen Bauteilgeometrie ausgehärtet bzw. erstarrt wird.</skos:definition> <skos:definition xml:lang="zh">一种一次成型工艺，将定量（通常预热）的模塑料放入开放式加热模腔中，通过闭合模具并施加压力，使其固化或凝固成最终零件几何形状。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0200001 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0200001">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000016"/>
        <obo:IAO_0000119 xml:lang="en">orginal: "[biodegradability] [...] is understood as the microbial conversion of all its organic constituents to carbon dioxide (or carbon dioxide and methane in conditions where oxygen is not present), new microbial biomass and mineral salts, within a timescale short enough not to lead to lasting harm or accumulation in the open environment."

European Commission: Directorate-General for Research and Innovation, Biodegradability of plastics in the open environment, Publications Office of the European Union, 2021, https://data.europa.eu/doi/10.2777/690248</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">原文：“[生物降解性] [...] 被理解为在足够短的时间内，将其所有有机成分微生物转化为二氧化碳（或在无氧条件下转化为二氧化碳和甲烷）、新的微生物生物量和矿物盐，而不会在开放环境中造成持久危害或积累。”

European Commission: Directorate-General for Research and Innovation, Biodegradability of plastics in the open environment, Publications Office of the European Union, 2021, https://data.europa.eu/doi/10.2777/690248</obo:IAO_0000119>
        <rdfs:label xml:lang="de">Biologische Abbaubarkeit</rdfs:label> <rdfs:label xml:lang="zh">生物降解性</rdfs:label>
        <rdfs:label xml:lang="en">biodegradability</rdfs:label> <rdfs:label xml:lang="zh">生物降解性</rdfs:label>
        <skos:definition xml:lang="de">"[Biologische Abbaubarkeit] [...] beschreibt die mikrobielle Umwandlung all seiner organischen Bestandteile in Kohlendioxid oder – unter sauerstofffreien Bedingungen – in Kohlendioxid und Methan, neue mikrobielle Biomasse und Mineralsalze verstanden, und zwar innerhalb eines Zeitraums, der so kurz ist, dass es nicht zu dauerhaften Schäden oder Anreicherungen in der offenen Umwelt kommt."</skos:definition> <skos:definition xml:lang="zh">“[生物降解性] [...] 被理解为将其所有有机成分微生物转化为二氧化碳（或在无氧条件下转化为二氧化碳和甲烷）、新的微生物生物量和矿物盐，并且在足够短的时间内不会在开放环境中造成持久损害或积累。”</skos:definition>
        <skos:definition xml:lang="en">biodegradability is a disposition of a material which specifies its capability to be fully microbially converted into inorganic end products (CO₂, CH₄, mineral salts, biomass) within an environmentally non-harmful timescale.</skos:definition> <skos:definition xml:lang="zh">生物降解性是材料的一种性质，指定其在环境无害的时间尺度内完全微生物转化为无机最终产物（CO₂、CH₄、矿物盐、生物质）的能力。</skos:definition>
        <PMD_0001032>https://github.com/materialdigital/core-ontology/issues/126</PMD_0001032>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0200002 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0200002">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000907"/>
        <dce:source xml:lang="en">Official definition can be found in: DIN 8580, group 1.2.2 “Spritzgießen”.</dce:source>
        <dce:source xml:lang="de">Offizielle Definition findet man in: DIN 8580, Gruppe 1.2.2 „Spritzgießen“.</dce:source>
        <rdfs:label xml:lang="de">Spritzgießen</rdfs:label> <rdfs:label xml:lang="zh">注塑成型</rdfs:label>
        <rdfs:label xml:lang="en">injection molding</rdfs:label> <rdfs:label xml:lang="zh">注塑成型</rdfs:label>
        <skos:altLabel xml:lang="en">injection moulding; plastic injection molding</skos:altLabel> <skos:altLabel xml:lang="zh">注塑成型；塑料注射成型</skos:altLabel>
        <skos:definition xml:lang="en">A primary shaping from the plastic state process in which plastic granules are plasticised in an injection unit and the melt is injected under high pressure into a closed mold cavity, where it cools and solidifies to the final part shape.</skos:definition> <skos:definition xml:lang="zh">一种基于塑料态的一次成型工艺，其中塑料颗粒在注射单元中塑化，熔体在高压下注入闭合模腔，冷却并凝固成最终零件形状。</skos:definition>
        <skos:definition xml:lang="de">Urformverfahren, bei dem Kunststoffgranulat in einem Plastifizieraggregat aufgeschmolzen und die Schmelze mit hohem Druck in einen geschlossenen Formhohlraum eingespritzt wird, wo sie verdichtet, abkühlt und zum Formteil erstarrt.</skos:definition> <skos:definition xml:lang="zh">一种一次成型工艺，其中塑料颗粒在塑化单元中熔化，熔体在高压下注入闭合模腔，在那里压实、冷却并凝固成成型件。</skos:definition>
        <skos:example xml:lang="en">Injection molding of polypropylene housings.</skos:example> <skos:example xml:lang="zh">聚丙烯外壳的注塑成型。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0200003 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0200003">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000907"/>
        <dce:source xml:lang="en">Official definition can be found in: DIN 8580, group 1.2.3 “Spritzpressen”.</dce:source>
        <dce:source xml:lang="de">Offizielle Definition findet man in: DIN 8580, Gruppe 1.2.3 „Spritzpressen“.</dce:source>
        <rdfs:label xml:lang="de">Spritzpressen</rdfs:label> <rdfs:label xml:lang="zh">注压成型</rdfs:label>
        <rdfs:label xml:lang="en">injection-compression molding</rdfs:label> <rdfs:label xml:lang="zh">注射压缩成型</rdfs:label>
        <skos:altLabel xml:lang="en">injection–compression moulding; transfer molding (Spritzpressen)</skos:altLabel> <skos:altLabel xml:lang="zh">注射压缩成型；传递模塑（注压成型）</skos:altLabel>
        <skos:definition xml:lang="en">A hybrid primary shaping from the plastic state process that combines injection and compression: a pre-plasticised charge or melt is injected into a closed or partially open mold and then compressed by further mold closure or a plunger so that the material completely fills the cavity and cures or solidifies under heat and pressure.</skos:definition> <skos:definition xml:lang="zh">一种结合注塑和压缩的混合型塑料态一次成型工艺：将预塑化的料坯或熔体注入闭合或部分打开的模具中，然后通过进一步闭合模具或柱塞压缩，使材料完全填充型腔，并在热和压力下固化或凝固。</skos:definition>
        <skos:definition xml:lang="de">Urformverfahren, bei dem eine vorplastifizierte Formmasse aus einer beheizten Vorkammer bzw. einem Plastifizieraggregat in ein (teil-)geschlossenes Werkzeug eingespritzt und anschließend durch Schließen des Werkzeugs bzw. Nachdrücken verpresst wird, bis der Werkstoff unter Wärme und Druck aushärtet.</skos:definition> <skos:definition xml:lang="zh">一种一次成型工艺，将预塑化的模塑料从加热的预腔或塑化单元注入（部分）闭合的模具中，然后通过闭合模具或保压压缩，直到材料在热和压力下固化。</skos:definition>
        <skos:example xml:lang="en">Injection-compression molding of epoxy-encapsulated electronic components.</skos:example> <skos:example xml:lang="zh">环氧树脂封装电子元件的注射压缩成型。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0200004 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0200004">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000907"/>
        <dce:source xml:lang="en">Official definition can be found in: DIN 8580, group 1.2.4 </dce:source>
        <dce:source xml:lang="de">Offizielle Definition findet man in: DIN 8580, Gruppe 1.2.4 </dce:source>
        <rdfs:label xml:lang="en">extrusion</rdfs:label> <rdfs:label xml:lang="zh">挤出成型</rdfs:label>
        <rdfs:label xml:lang="de">strangpressen (extrudieren)</rdfs:label> <rdfs:label xml:lang="zh">挤压成型（挤出）</rdfs:label>
        <skos:definition xml:lang="en">A primary shaping from the plastic state process in which a plastically deformable material, typically a polymer melt, is continuously forced by pressure through a shaping die to produce an endless strand with constant cross-section, which solidifies by cooling or curing.</skos:definition> <skos:definition xml:lang="zh">一种从塑性状态进行初次成型的工艺，其中可塑性变形材料（通常是聚合物熔体）在压力下连续通过成型模具，以生产具有恒定横截面的无限长条，通过冷却或固化而凝固。</skos:definition>
        <skos:definition xml:lang="de">Ein Urformverfahren, bei dem ein plastifizierter Werkstoff, meist eine Polymerschmelze, kontinuierlich unter Druck durch eine formgebende Düse gepresst wird und dabei einen Strang mit konstantem Querschnitt bildet, der durch Abkühlen oder Aushärten verfestigt wird.</skos:definition> <skos:definition xml:lang="zh">一种成型工艺，其中塑化材料（通常为聚合物熔体）在压力下连续通过成型模具挤出，形成具有恒定横截面的条状物，通过冷却或硬化使其固化。</skos:definition>
        <skos:example xml:lang="en">Extrusion of PVC window profiles; extrusion of plastic films or pipes from polyethylene melt.</skos:example> <skos:example xml:lang="zh">PVC窗框型材的挤出；从聚乙烯熔体挤出塑料薄膜或管道。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0200005 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0200005">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000907"/>
        <dce:source xml:lang="en">Official definition can be found in: DIN 8580, group 1.2.5 </dce:source>
        <dce:source xml:lang="de">Offizielle Definition findet man in: DIN 8580, Gruppe 1.2.5 </dce:source>
        <rdfs:label xml:lang="de">Ziehformen</rdfs:label> <rdfs:label xml:lang="zh">拉伸成型</rdfs:label>
        <rdfs:label xml:lang="en">drawing forming</rdfs:label> <rdfs:label xml:lang="zh">拉拔成型</rdfs:label>
        <skos:definition xml:lang="en">A primary shaping from the plastic state process in which a plastically deformable mass (for example fibre-reinforced resin or glass/plastic strands) is pulled through one or more shaping tools or dies so that the cross-section and surface are formed by tensile forces, while the material solidifies or cures to produce continuous profiles. It is conceptually related to pultrusion / profile drawing.</skos:definition> <skos:definition xml:lang="zh">一种从塑性状态进行初次成型的工艺，其中可塑性变形材料（例如纤维增强树脂或玻璃/塑料束）通过拉力被拉过一个或多个成型工具或模具，从而通过拉伸力形成横截面和表面，同时材料凝固或固化以生产连续型材。它在概念上与拉挤成型/型材拉拔相关。</skos:definition>
        <skos:definition xml:lang="de">Ein Urformverfahren, bei dem eine plastisch verformbare Masse (z. B. faserverstärkte Harzsysteme oder glasige/kunststoffhaltige Stränge) durch Zugkräfte durch formgebende Düsen oder Werkzeuge gezogen wird, sodass Querschnitt und Oberfläche ausgebildet und der Werkstoff dabei verfestigt bzw. ausgehärtet wird. Das Verfahren ist verwandt mit dem Strangzieh- bzw. Pultrusionsverfahren.</skos:definition> <skos:definition xml:lang="zh">一种原形制造工艺，其中可塑变形的物料（例如纤维增强树脂体系或玻璃/塑料条）通过拉力被拉过成型喷嘴或模具，从而形成截面和表面，同时材料固化或硬化。该工艺与拉挤成型工艺相关。</skos:definition>
        <skos:example xml:lang="en">Pultrusion of glass-fibre-reinforced polymer profiles; drawing of continuous fibre-reinforced rods through a heated die.</skos:example> <skos:example xml:lang="zh">玻璃纤维增强聚合物型材的拉挤成型；连续纤维增强棒材通过加热模具的拉拔。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0200006 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0200006">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000907"/>
        <dce:source xml:lang="en">Official definition can be found in: DIN 8580, group 1.2.6 </dce:source>
        <dce:source xml:lang="de">Offizielle Definition findet man in: DIN 8580, Gruppe 1.2.6 </dce:source>
        <rdfs:label xml:lang="de">Kalandrieren</rdfs:label> <rdfs:label xml:lang="zh">压延</rdfs:label>
        <rdfs:label xml:lang="en">calendering</rdfs:label> <rdfs:label xml:lang="zh">压延</rdfs:label>
        <skos:definition xml:lang="en">A primary shaping from the plastic state process in which a viscous polymer melt or plastic mass is passed through the narrow gaps between several counter-rotating, polished rolls so that it is compressed and rolled out into sheet or film of defined thickness and surface quality, then cooled to solidify.</skos:definition> <skos:definition xml:lang="zh">一种从塑性状态进行初次成型的工艺，其中粘稠的聚合物熔体或塑料物料通过多个反向旋转的抛光轧辊之间的狭窄间隙，从而被压缩并滚压成具有规定厚度和表面质量的片材或薄膜，然后冷却凝固。</skos:definition>
        <skos:definition xml:lang="de">Ein Urformverfahren, bei dem eine zähflüssige Polymerschmelze oder plastische Masse durch enge Spalte zwischen mehreren gegenläufig rotierenden, polierten Walzen geführt wird, wodurch sie verdichtet und zu Platten oder Folien definierter Dicke und Oberflächenqualität ausgewalzt und anschließend verfestigt wird.</skos:definition> <skos:definition xml:lang="zh">一种原形制造工艺，其中粘稠的聚合物熔体或塑性物料通过多个反向旋转的抛光辊之间的窄缝，被压实并滚压成具有规定厚度和表面质量的板材或薄膜，随后固化。</skos:definition>
        <skos:example xml:lang="en">Calendering of plasticised PVC into rigid or flexible sheets and films; calendering of ABS sheet for thermoforming.</skos:example> <skos:example xml:lang="zh">增塑PVC压延成硬质或软质片材和薄膜；ABS板材的压延用于热成型。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0200007 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0200007">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000907"/>
        <dce:source xml:lang="en">Official definition can be found in: DIN 8580, group 1.2.7 </dce:source>
        <dce:source xml:lang="de">Offizielle Definition findet man in: DIN 8580, Gruppe 1.2.7 </dce:source>
        <rdfs:label xml:lang="de">Blasformen</rdfs:label> <rdfs:label xml:lang="zh">吹塑</rdfs:label>
        <rdfs:label xml:lang="en">blow molding</rdfs:label> <rdfs:label xml:lang="zh">吹塑成型</rdfs:label>
        <skos:definition xml:lang="en">A primary shaping from the plastic state process in which a tube or preform of molten or plasticised material is enclosed in a mold and expanded by internal gas pressure so that it conforms to the mold cavity, producing hollow bodies which then solidify.</skos:definition> <skos:definition xml:lang="zh">一种从塑性状态进行初次成型的工艺，其中熔融或塑化材料的管材或预成型件被封闭在模具中，并通过内部气体压力膨胀，使其贴合模腔，产生空心体，随后凝固。</skos:definition>
        <skos:definition xml:lang="de">Ein Urformverfahren, bei dem ein Schlauch oder ein Vorformling aus geschmolzenem bzw. plastifizierten Werkstoff in ein Werkzeug eingelegt und durch inneren Gasdruck an die Formwand aufgeblasen wird, sodass ein Hohlkörper entsteht, der anschließend verfestigt wird.</skos:definition> <skos:definition xml:lang="zh">一种原形制造工艺，其中由熔融或塑化材料制成的管坯或预成型件被放入模具中，通过内部气体压力吹胀贴紧模壁，形成空心件，随后固化。</skos:definition>
        <skos:example xml:lang="en">Extrusion blow molding of HDPE bottles; stretch-blow molding of PET beverage containers; blow molding of fuel tanks for automotive applications.</skos:example> <skos:example xml:lang="zh">HDPE瓶的挤出吹塑成型；PET饮料容器的拉伸吹塑成型；汽车应用燃油箱的吹塑成型。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0200008 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0200008">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000907"/>
        <dce:source xml:lang="en">Official definition can be found in: DIN 8580, group 1.2.8 </dce:source>
        <dce:source xml:lang="de">Offizielle Definition findet man in: DIN 8580, Gruppe 1.2.8 </dce:source>
        <rdfs:label xml:lang="de">Modellieren</rdfs:label> <rdfs:label xml:lang="zh">造型</rdfs:label>
        <rdfs:label xml:lang="en">modelling</rdfs:label> <rdfs:label xml:lang="zh">塑形</rdfs:label>
        <skos:definition xml:lang="en">A primary shaping from the plastic state process in which a manually workable plastic mass (such as clay, wax, plastiline or gypsum paste) is shaped directly by hand and simple tools into a final or intermediate geometry and subsequently hardened, dried or fired to obtain a solid body.</skos:definition> <skos:definition xml:lang="zh">一种从塑性状态进行初次成型的工艺，其中可手工加工的塑性物料（例如粘土、蜡、塑性黏土或石膏浆）直接用手和简单工具塑形为最终或中间几何形状，随后硬化、干燥或烧制以获得固体。</skos:definition>
        <skos:definition xml:lang="de">Ein Urformverfahren, bei dem eine mit Hand und einfachen Werkzeugen formbare plastische Masse (z. B. Ton, Wachs, Plastilin oder Gipspaste) direkt zur gewünschten Geometrie modelliert und anschließend durch Trocknen, Brennen oder Aushärten zu einem festen Körper verfestigt wird.</skos:definition> <skos:definition xml:lang="zh">一种原形制造工艺，其中可用手和简单工具成型的可塑物料（如粘土、蜡、橡皮泥或石膏浆）直接塑造成所需几何形状，随后通过干燥、烧制或硬化固化成固体。</skos:definition>
        <skos:example xml:lang="en">Hand modelling of clay prior to firing (e.g. pottery, sculptures); modelling of wax or plasticine for casting patterns.</skos:example> <skos:example xml:lang="zh">烧制前粘土的手工塑形（例如陶器、雕塑）；用于铸造模型的蜡或橡皮泥塑形。</skos:example>
    </owl:Class>
    


