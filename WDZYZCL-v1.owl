                                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0010025"/>
                                </owl:unionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000546"/>
        <rdfs:subClassOf>
            <owl:Restriction>
