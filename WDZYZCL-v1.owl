        <rdfs:label xml:lang="en">nature constant</rdfs:label> <rdfs:label xml:lang="zh">自然常数</rdfs:label>
        <skos:definition xml:lang="en">A nature constant is a generically dependent continuant whose value, maginitude or configuration is determined by nature including physics and mathematics.</skos:definition> <skos:definition xml:lang="zh">自然常数是一种一般依赖的持续存在物，其值、大小或配置由自然（包括物理学和数学）决定。</skos:definition>
        <skos:example xml:lang="en">Examples of nature constants are the speed of light, pi, etc.</skos:example> <skos:example xml:lang="zh">自然常数的例子包括光速、pi等。</skos:example>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020099 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020099">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0020006"/>
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0020007"/>
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0020008"/>
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0020009"/>
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0020010"/>
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0020011"/>
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0020012"/>
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0020013"/>
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0020014"/>
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0020015"/>
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0020016"/>
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0020017"/>
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0020018"/>
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0020019"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBI_0001930"/>
        <rdfs:comment xml:lang="en">TODO: possibly extend for 2D (Graphene etc)

More elaborate crystal descriptions may be found in http://emmo.info/domain-crystallography/crystallography or https://purls.helmholtz-metadaten.de/disos/cso</rdfs:comment>
        <rdfs:label xml:lang="en">bravais lattice (3D)</rdfs:label> <rdfs:label xml:lang="zh">布拉维晶格（三维）</rdfs:label>
        <skos:definition xml:lang="en">The bravais lattice is a categorical value specification that specifies value of the crystal structure quality. It describes the possible geometric arrangement of lattice points in a crystal. The present descriptor is limited to the 14 possible three-dimensional arrangements.</skos:definition> <skos:definition xml:lang="zh">bravais lattice是一种分类值规范，指定晶体结构质量的值。它描述了晶体中晶格点的可能几何排列。本描述符限于14种可能的三维排列。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020101 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020101">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000145"/>
        <owl:disjointWith rdf:resource="https://w3id.org/pmd/co/PMD_0050000"/>
        <rdfs:label xml:lang="en">proportion</rdfs:label> <rdfs:label xml:lang="zh">比例</rdfs:label>
        <skos:altLabel xml:lang="en">concentration</skos:altLabel> <skos:altLabel xml:lang="zh">浓度</skos:altLabel>
        <skos:altLabel xml:lang="en">fraction</skos:altLabel> <skos:altLabel xml:lang="zh">分数</skos:altLabel>
        <skos:definition xml:lang="en">A proportion is a relational quality between two entities (the whole and the part) which quantifies the relation between the whole and its part.</skos:definition> <skos:definition xml:lang="zh">比例是两个实体（整体和部分）之间的关系质量，它量化了整体与其部分之间的关系。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020102 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020102">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020101"/>
        <rdfs:label xml:lang="en">mass proportion</rdfs:label> <rdfs:label xml:lang="zh">质量比例</rdfs:label>
        <skos:definition xml:lang="en">Mass proportion is a proportion which quantifies the mass of the part relative to the mass of the whole.</skos:definition> <skos:definition xml:lang="zh">质量比例是量化部分质量相对于整体质量的比例。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020103 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020103">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020101"/>
        <rdfs:label xml:lang="en">molar proportion</rdfs:label> <rdfs:label xml:lang="zh">摩尔比例</rdfs:label>
        <skos:altLabel xml:lang="en">Molar Ratio</skos:altLabel> <skos:altLabel xml:lang="zh">摩尔比</skos:altLabel>
        <skos:definition xml:lang="en">Molar proportion is the proportion which quantifies the entities count of the part in relation to the entities count of the whole.</skos:definition> <skos:definition xml:lang="zh">摩尔比例是量化部分实体数量相对于整体实体数量的比例。</skos:definition>
        <skos:example xml:lang="en">The molar ratio of hydrogen gas H2 molecules to water H2O molecules is 1/1 in the oxyhydrogen reaction. The molar ratio of oxygen molecules O2 to water molecules is 2/1.
The molar ratio of carbon dioxide to average atmosphere air is 420 ppm as of 2022 AD.</skos:example> <skos:example xml:lang="zh">在氢氧反应中，氢气H2分子与水H2O分子的摩尔比为1/1。氧气O2分子与水分子的摩尔比为2/1。截至公元2022年，二氧化碳与标准大气空气的摩尔比为420 ppm。</skos:example>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020104 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020104">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020101"/>
        <rdfs:label xml:lang="en">volume proportion</rdfs:label> <rdfs:label xml:lang="zh">体积比例</rdfs:label>
        <skos:definition xml:lang="en">Volume proportion is a proportion which quantifies the volume of the part relative to the volume of the whole.</skos:definition> <skos:definition xml:lang="zh">体积比例是量化部分体积相对于整体体积的比例。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020105 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020105">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000127"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002353"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000110"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000127"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002353"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000110"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">geogenic mineral</rdfs:label> <rdfs:label xml:lang="zh">地质成因矿物</rdfs:label>
        <skos:definition xml:lang="en">material that is formed through geological processes</skos:definition> <skos:definition xml:lang="zh">通过地质过程形成的材料</skos:definition>
        <skos:example xml:lang="en">such as Quartz (Silicates) or calcite (Carbonate) or Feldspar (Aluminosilicate)</skos:example> <skos:example xml:lang="zh">例如石英（硅酸盐）或方解石（碳酸盐）或长石（铝硅酸盐）</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020106 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020106">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000890"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000663"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">polycrystal</rdfs:label> <rdfs:label xml:lang="zh">多晶</rdfs:label>
        <skos:altLabel xml:lang="en">Polycrystalline structure</skos:altLabel> <skos:altLabel xml:lang="zh">多晶结构</skos:altLabel>
        <skos:definition xml:lang="en">A polycrystal is a connected material entity aggregate that consists of multiple crystal grains joined through crystallographic interfaces.</skos:definition> <skos:definition xml:lang="zh">多晶是一种连接的材料实体聚集体，由通过晶体学界面结合的多颗晶粒组成。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020112 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020112">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020131"/>
        <rdfs:label xml:lang="en">grain size distribution</rdfs:label> <rdfs:label xml:lang="zh">晶粒尺寸分布</rdfs:label>
        <skos:definition xml:lang="en">An intensive quality describing the lower length scale object aggregate (grains) that is part of the material.</skos:definition> <skos:definition xml:lang="zh">一种描述作为材料一部分的较低长度尺度对象聚集体（晶粒）的强度性质。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020113 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020113">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
        <rdfs:label xml:lang="en">fluid (object)</rdfs:label> <rdfs:label xml:lang="zh">流体（对象）</rdfs:label>
        <skos:definition xml:lang="en">Fluid (object) is an object that consists of some portion of matter which bears an aggregate state that concretizes a liquid or gaseous aggregate state.</skos:definition> <skos:definition xml:lang="zh">流体（对象）是一种由某部分物质组成的对象，该物质具有具体化为液态或气态聚集状态的聚集状态。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020114 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020114">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000023"/>
        <rdfs:label xml:lang="en">medium role</rdfs:label> <rdfs:label xml:lang="zh">介质角色</rdfs:label>
        <skos:definition xml:lang="en">Medium role is a role beared by an object which implies that the object serves as an intermediary for the transmission of something else, like energy, force, or information.</skos:definition> <skos:definition xml:lang="zh">介质角色是对象所承担的一种角色，表示该对象充当其他事物（如能量、力或信息）传输的中介。</skos:definition>
        <skos:example xml:lang="en">Air in the air cooling process, N2 atmosphere in a furnace cooling process, oil in a quenching process, crystal lattice in a solid state diffusion</skos:example> <skos:example xml:lang="zh">空气冷却过程中的空气、炉冷过程中的N2气氛、淬火过程中的油、固态扩散中的晶格</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020115 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020115">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000891"/>
        <rdfs:label xml:lang="en">aerosol</rdfs:label> <rdfs:label xml:lang="zh">气溶胶</rdfs:label>
        <skos:definition xml:lang="en">An aerosol is a disconnected material entity aggregate which:
1. consists of some portion of matter whose aggregate state quality concretizes gaseous and 
2. consists of some portion of matter whose aggregate state quality concretises solid or liquid (TODO: express that this portion is also a disconnected material entity aggregate)</skos:definition> <skos:definition xml:lang="zh">气溶胶是一种非连接的材料实体聚集体，其：
1. 由某部分物质组成，该物质的聚集状态性质具体化为气态；
2. 由某部分物质组成，该物质的聚集状态性质具体化为固态或液态（待办：说明该部分也是一种非连接的材料实体聚集体）。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020116 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020116">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0020117"/>
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0020118"/>
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0020119"/>
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0020120"/>
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0020121"/>
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0020122"/>
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0020123"/>
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0020124"/>
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0020125"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBI_0001930"/>
        <rdfs:label xml:lang="en">aggregate state value</rdfs:label> <rdfs:label xml:lang="zh">聚集状态值</rdfs:label>
        <skos:definition xml:lang="en">The aggregate state value is a categorical value specification that specifies value of the aggregate state quality.</skos:definition> <skos:definition xml:lang="zh">聚集状态值是一种分类值规范，用于指定聚集状态性质的值。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020126 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020126">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000890"/>
        <obo:IAO_0000119 xml:lang="en">old defintion: A foam is a material entity aggregate that is also a composite material c. 
The parts of c that have the filler role are vacuum-filled or gas filled pores. 
The parts of c that have the matrix role consist of a material that is bearer of solid or liquid aggregate state. 
One pore with its surrounding matrix is called 'cell'. 
Depending on the interconnectedness of the pores the foam is open- or closed-cell.</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">旧定义：泡沫是一种材料实体聚集体，也是一种复合材料c。
c中具有填充物角色的部分是真空填充或气体填充的孔隙。
c中具有基体角色的部分由承载固态或液态聚集状态的材料组成。
一个孔隙及其周围的基体称为‘胞’。
根据孔隙的连通性，泡沫分为开孔或闭孔。</obo:IAO_0000119>
        <rdfs:label xml:lang="en">foam</rdfs:label> <rdfs:label xml:lang="zh">泡沫</rdfs:label>
        <skos:definition xml:lang="en">A foam is a connected material entity aggregate that consists of a solid or liquid matrix containing gas-filled or vacuum-filled pores forming cellular structures.</skos:definition> <skos:definition xml:lang="zh">泡沫是一种连接的材料实体聚集体，由含有气体填充或真空填充孔隙的固态或液态基体组成，形成胞状结构。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020128 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020128">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000027"/>
        <rdfs:label xml:lang="en">thermodynamic system</rdfs:label> <rdfs:label xml:lang="zh">热力学系统</rdfs:label>
        <skos:definition xml:lang="en">A thermodynamic system is an object aggregate whose objects are bearer of  thermodynamic properties. A thermodynamic system environs a thermodynamic process by which the thermodynamic properties of the objects of the thermodynamic system change over time.</skos:definition> <skos:definition xml:lang="zh">热力学系统是一种对象聚集体，其对象承载热力学性质。热力学系统包围着一个热力学过程，通过该过程，热力学系统的对象的热力学性质随时间变化。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020129 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020129">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:label xml:lang="en">reversible process</rdfs:label> <rdfs:label xml:lang="zh">可逆过程</rdfs:label>
        <skos:definition xml:lang="en">A reversible process is a process whose participants form a thermodynamic system with an entropy S and S remains constant during the process.</skos:definition> <skos:definition xml:lang="zh">可逆过程是一种过程，其参与者形成一个熵为S的热力学系统，且S在该过程中保持不变。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020130 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020130">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000145"/>
        <rdfs:label xml:lang="en">driving force of phase in system</rdfs:label> <rdfs:label xml:lang="zh">系统中相驱动力</rdfs:label>
        <skos:definition xml:lang="en">Driving force of phase in a system is a relational quality that inheres between two material entities, the species and the material (system). The driving force is a factor that promotes a physical process or (eletro-)chemical reaction in a material (system) to occur and proceed towards completion. It can be quantified as the gradient of the activity of the participating species.</skos:definition> <skos:definition xml:lang="zh">系统中相驱动力是一种关系性质，存在于两个材料实体（物种和材料（系统））之间。驱动力是促进材料（系统）中物理过程或（电）化学反应发生并进行到底的因素。它可以量化为参与物种活度的梯度。</skos:definition>
        <skos:example xml:lang="en">For α → β: ΔG = G_β − G_α. If ΔG &lt; 0, the transformation is thermodynamically favorable; many report the driving force as F = −ΔG &gt; 0</skos:example> <skos:example xml:lang="zh">对于α→β：ΔG = G_β − G_α。如果ΔG &lt; 0，则转变在热力学上有利；许多人将驱动力报告为F = −ΔG &gt; 0</skos:example>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020131 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020131">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:subClassOf rdf:nodeID="genid919"/>
        <owl:disjointWith rdf:resource="https://w3id.org/pmd/co/PMD_0020148"/>
        <rdfs:label xml:lang="en">intensive quality</rdfs:label> <rdfs:label xml:lang="zh">强度性质</rdfs:label>
        <skos:altLabel xml:lang="en">Point property</skos:altLabel> <skos:altLabel xml:lang="zh">点性质</skos:altLabel>
        <skos:definition xml:lang="en">An intensive quality is a quality that inheres in only portion of matter and thus is independent of the bearers (system-) size.</skos:definition> <skos:definition xml:lang="zh">强度属性是一种只固着于部分物质的质量，因此独立于承载者（系统）的大小。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    <owl:Restriction rdf:nodeID="genid919">
        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000080"/>
        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000001"/>
    </owl:Restriction>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://w3id.org/pmd/co/PMD_0020131"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:nodeID="genid919"/>
        <rdfs:comment xml:lang="en">Due to the duality of object and portion of matter this axiom can not be an equivalent class axiom.</rdfs:comment>
    </owl:Axiom>
    


    <!-- https://w3id.org/pmd/co/PMD_0020132 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020132">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020148"/>
        <rdfs:label xml:lang="en">size</rdfs:label> <rdfs:label xml:lang="zh">大小</rdfs:label>
        <skos:definition xml:lang="en">an extensive quality of a material entity that describes its spatial extend.</skos:definition> <skos:definition xml:lang="zh">描述物质实体的空间延伸的广延属性。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020133 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020133">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020148"/>
        <rdfs:comment xml:lang="en">Mass is relevant in such processes as gravitation, acceleration, etc.</rdfs:comment>
        <rdfs:label xml:lang="en">mass</rdfs:label> <rdfs:label xml:lang="zh">质量</rdfs:label>
        <skos:definition xml:lang="en">Mass is fundamental extensive quality.</skos:definition> <skos:definition xml:lang="zh">质量是基本的广延属性。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020134 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020134">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000023"/>
        <rdfs:label xml:lang="en">stimulus role</rdfs:label> <rdfs:label xml:lang="zh">刺激角色</rdfs:label>
        <skos:definition xml:lang="en">The stimulus role is a role that an object bears in a process when causally influencing another object  that bears a stimulation target role in the same process. 'Role' implies here, that the 'bearing' assignment depends on the intent.</skos:definition> <skos:definition xml:lang="zh">刺激角色是一个对象在过程中因果影响另一个对象时所承担的角色，该另一个对象在同一过程中承担刺激目标角色。这里的'角色'意味着'承担'的分配取决于意图。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020135 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020135">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000975"/>
        <rdfs:label xml:lang="en">stimulation target role</rdfs:label> <rdfs:label xml:lang="zh">刺激目标角色</rdfs:label>
        <skos:definition xml:lang="en">See 'Stimulus role'</skos:definition> <skos:definition xml:lang="zh">参见'刺激角色'</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020136 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020136">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:comment xml:lang="en">The number of phases involved can vary as well as the mechanisms involved can be different.</rdfs:comment>
        <rdfs:label xml:lang="en">phase transformation</rdfs:label> <rdfs:label xml:lang="zh">相变</rdfs:label>
        <skos:definition xml:lang="en">A thermodynamic phase transformation is a process in/of a thermodynamic system, that involves the transformation of phases of the system to other phases.</skos:definition> <skos:definition xml:lang="zh">热力学相变是热力学系统内/的过程，涉及系统相态向其他相态的转变。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020137 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020137">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020000"/>
        <owl:disjointWith rdf:resource="https://w3id.org/pmd/co/PMD_0020149"/>
        <rdfs:comment xml:lang="en">See metastable phase</rdfs:comment>
        <rdfs:label xml:lang="en">stable phase</rdfs:label> <rdfs:label xml:lang="zh">稳定相</rdfs:label>
        <skos:definition xml:lang="en">A stable phase is a phase that does not have a "pmd:disposition of a phase to transform" in the "pmd:phase transformation" it participates.</skos:definition> <skos:definition xml:lang="zh">稳定相是不具有它所参与的"pmd:相变"中的"pmd:相变倾向"的相。</skos:definition>
        <skos:example xml:lang="en">A phase that participates in a phase transformation pt and pt that is not a metastable phase.</skos:example> <skos:example xml:lang="zh">参与相变pt且不是亚稳相的相。</skos:example>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020138 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020138">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000027"/>
        <rdfs:label xml:lang="en">lot</rdfs:label> <rdfs:label xml:lang="zh">批次</rdfs:label>
        <skos:definition xml:lang="en">A lot is an object aggregate whose parts are output of the same production process.</skos:definition> <skos:definition xml:lang="zh">批次是一个对象集合，其组成部分是同一生产过程的输出。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020139 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020139">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020113"/>
        <rdfs:label xml:lang="de">Schmelze</rdfs:label> <rdfs:label xml:lang="zh">熔体</rdfs:label>
        <rdfs:label xml:lang="en">melt</rdfs:label> <rdfs:label xml:lang="zh">熔体</rdfs:label>
        <skos:definition xml:lang="en">is a fluid (object) with a disposition to realize a blank role in a manufacturing process</skos:definition> <skos:definition xml:lang="zh">是一种流体（对象），具有在制造过程中实现空白角色的倾向。</skos:definition>
        <skos:example xml:lang="en">molten PLA in a 3D printing process</skos:example> <skos:example xml:lang="zh">3D打印过程中的熔融PLA</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020140 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020140">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CHEBI_60003"/>
        <rdfs:label xml:lang="en">portion of pure chemical element</rdfs:label> <rdfs:label xml:lang="zh">纯化学元素部分</rdfs:label>
        <skos:definition xml:lang="en">A portion of pure chemical element is a pure substance composed of multiple atoms, which are all of the same kind.</skos:definition> <skos:definition xml:lang="zh">纯化学元素部分是由多个原子组成的纯物质，这些原子都是同一种类的。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020141 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020141">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:comment xml:lang="en">Fatigue is typically of interest when the change of the material affects the objects ability to fulfill its function.</rdfs:comment>
        <rdfs:label xml:lang="en">fatigue (reaction to repetitive loading)</rdfs:label> <rdfs:label xml:lang="zh">疲劳（对重复加载的反应）</rdfs:label>
        <skos:definition xml:lang="en">fatigue is a process that affects an material entities integrity by nucleation and growing cracks.</skos:definition> <skos:definition xml:lang="zh">疲劳是一种通过形核和裂纹扩展影响材料实体完整性的过程。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020142 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020142">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020148"/>
        <obo:IAO_0000119 rdf:resource="http://openenergy-platform.org/ontology/oeo/OEO_00000150"/>
        <rdfs:label xml:lang="en">energy</rdfs:label> <rdfs:label xml:lang="zh">能量</rdfs:label>
        <skos:definition xml:lang="en">an extensive quality of material entities which manifests as a capacity to perform work (such as causing motion or the interaction of molecules)</skos:definition> <skos:definition xml:lang="zh">物质实体的一种广延性质，表现为做功的能力（例如引起运动或分子相互作用）</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020143 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020143">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:label xml:lang="en">process chain</rdfs:label> <rdfs:label xml:lang="zh">过程链</rdfs:label>
        <skos:definition xml:lang="en">A process chain is a process that 'has continuant part' subprocesses S1...Sn where S1...Sn precede each other and where some object or object aggregate that are output of Sn are then input to Sn+1.</skos:definition> <skos:definition xml:lang="zh">过程链是一个过程，它具有连续部分子过程S1...Sn，其中S1...Sn彼此先后发生，并且某些作为Sn输出的对象或对象聚合体随后作为Sn+1的输入。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020144 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020144">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000023"/>
        <rdfs:label xml:lang="en">product (chemical reaction)</rdfs:label> <rdfs:label xml:lang="zh">产物（化学反应）</rdfs:label>
        <skos:definition xml:lang="en">Product is the role of a material entity that is output of a chemical reaction and is created or transformed during the reaction.</skos:definition> <skos:definition xml:lang="zh">产物是物质实体的角色，该物质实体是化学反应的输出，并在反应过程中被创造或转化。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020145 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020145">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000023"/>
        <rdfs:label xml:lang="en">educt</rdfs:label> <rdfs:label xml:lang="zh">反应物</rdfs:label>
        <skos:definition xml:lang="en">Educt is the role of a material entity that is input of a chemical reaction and is consumed or transformed during the reaction</skos:definition> <skos:definition xml:lang="zh">反应物是物质实体的角色，该物质实体是化学反应的输入，并在反应过程中被消耗或转化。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020146 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020146">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000023"/>
        <rdfs:label xml:lang="en">catalyst</rdfs:label> <rdfs:label xml:lang="zh">催化剂</rdfs:label>
        <skos:definition xml:lang="en">Catalyst is the role of a participant in a chemical reaction that does not alter its qualities/realizable entities  after the chemical reaction.</skos:definition> <skos:definition xml:lang="zh">催化剂是化学反应中参与者的角色，该参与者在化学反应后不改变其性质/可实现实体。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020147 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020147">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020136"/>
        <rdfs:comment xml:lang="en">It is defined on the phase diagram at fixed composition and typically proceeds by diffusion‑controlled nucleation and growth (e.g., γ → α + Fe3C producing pearlite in steels).</rdfs:comment>
        <rdfs:label xml:lang="en">eutectoid phase transformation</rdfs:label> <rdfs:label xml:lang="zh">共析相变</rdfs:label>
        <skos:definition xml:lang="en">A eutectoid phase transformation is a phase transformation in which a solid parent phase of eutectoid composition decomposes into two distinct solid daughter phases at constant temperature and pressure.</skos:definition> <skos:definition xml:lang="zh">共析相变是一种相变，其中具有共析成分的固体母相在恒温恒压下分解为两种不同的固体子相。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020148 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020148">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:label xml:lang="en">extensive quality</rdfs:label> <rdfs:label xml:lang="zh">广延性质</rdfs:label>
        <skos:definition xml:lang="en">An extensive quality is a quality that inheres in only object or object aggregate or fiat object part or chemical entity and is dependent on the bearers (system-) size.</skos:definition> <skos:definition xml:lang="zh">广延性质是一种性质，它仅存在于对象或对象聚合体或平直对象部分或化学实体中，并且依赖于载体（系统）的大小。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020149 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020149">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020000"/>
        <rdfs:comment xml:lang="en">The stability of a phase can only be evaluated in the context of a (possibly unknown) phase transformation process.</rdfs:comment>
        <rdfs:label xml:lang="en">metastable phase</rdfs:label> <rdfs:label xml:lang="zh">亚稳相</rdfs:label>
        <skos:definition xml:lang="en">A metastable phase phase_trans is a phase that has a "pmd:disposition of a phase to transform" disp_trans and disp_trans is realized in a "pmd:phase transformation" proc_trans and proc_trans has participant sys_trans and sys_trans has part phase_trans.</skos:definition> <skos:definition xml:lang="zh">亚稳相phase_trans是一个相，它具有“pmd:相转变倾向”的倾向性disp_trans，并且disp_trans在“pmd:相变”过程proc_trans中实现，proc_trans具有参与者sys_trans，并且sys_trans具有部分phase_trans。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020150 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020150">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020132"/>
        <rdfs:label xml:lang="en">volume</rdfs:label> <rdfs:label xml:lang="zh">体积</rdfs:label>
        <skos:definition xml:lang="en">Volume is a three dimensional size.</skos:definition> <skos:definition xml:lang="zh">体积是一个三维大小。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020151 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020151">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020142"/>
        <owl:disjointWith rdf:resource="https://w3id.org/pmd/co/PMD_0020155"/>
        <rdfs:label xml:lang="en">internal energy</rdfs:label> <rdfs:label xml:lang="zh">内能</rdfs:label>
        <skos:definition xml:lang="en">Internal energy is a universal extensive quality that specifies the bearers potential to do work.</skos:definition> <skos:definition xml:lang="zh">内能是一种普遍性的广延性质，它规定了载体做功的潜力。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020152 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020152">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000027"/>
        <rdfs:label xml:lang="en">component</rdfs:label> <rdfs:label xml:lang="zh">组件</rdfs:label>
        <skos:definition xml:lang="en">A component is an object aggregate that bears a function in a technical system.</skos:definition> <skos:definition xml:lang="zh">组件是在技术系统中承担功能的对象聚合体。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020153 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020153">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000027"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000312"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000833"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000085"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000034"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">technical system</rdfs:label> <rdfs:label xml:lang="zh">技术系统</rdfs:label>
        <skos:definition xml:lang="en">A technical system is an object aggregate: 
1. that is output of a manufacturing process, 
2. that has some function 
3. whose continuant parts are some components.</skos:definition> <skos:definition xml:lang="zh">技术系统是一个对象聚合体：
1. 它是制造过程的输出，
2. 它具有某种功能，
3. 其连续部分是一些组件。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020154 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020154">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020136"/>
        <rdfs:comment xml:lang="en">It proceeds by nucleation and growth.</rdfs:comment>
        <rdfs:label xml:lang="en">precipitation (phase)</rdfs:label> <rdfs:label xml:lang="zh">沉淀（相）</rdfs:label>
        <skos:definition xml:lang="en">Precipitation from a supersaturated solid solution is a phase transformation process in which a single supersaturated parent phase decomposes into a solute‑depleted matrix and dispersed, compositionally distinct precipitate phases.</skos:definition> <skos:definition xml:lang="zh">从过饱和固溶体中析出是一种相变过程，其中单个过饱和母相分解为溶质贫化的基体和分散的、成分不同的析出相。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020155 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020155">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020142"/>
        <rdfs:label xml:lang="en">interatomic interaction energy</rdfs:label> <rdfs:label xml:lang="zh">原子间相互作用能</rdfs:label>
        <skos:definition xml:lang="en">Interatomic interaction energy is added/removed from the atom aggregate if one atom is moved infinitely away from the rest of the aggregate.</skos:definition> <skos:definition xml:lang="zh">如果将一个原子无限远离其余原子，则原子间相互作用能从原子聚集体中添加/移除。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020156 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020156">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020136"/>
        <rdfs:comment xml:lang="en">It is marked on phase diagrams by a peritectic point and proceeds by an interfacial, diffusion‑controlled reaction that is often kinetically sluggish, leading to incomplete transformation or complex microstructures during solidification.</rdfs:comment>
        <rdfs:label xml:lang="en">peritectic phase transformation</rdfs:label> <rdfs:label xml:lang="zh">包晶相变</rdfs:label>
        <skos:definition xml:lang="en">A peritectic phase transformation is a phase transformation in which a liquid parent phase and an existing solid phase react on cooling to form a different solid phase (L + α → β).</skos:definition> <skos:definition xml:lang="zh">包晶相变是一种相变，其中液态母相和已有的固相在冷却时反应形成不同的固相（L + α → β）。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020157 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020157">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020136"/>
        <rdfs:comment xml:lang="en">Unlike nucleation and growth transformations, it has no nucleation barrier and proceeds by uphill diffusion and wavelength‑selective amplification of composition modulations, producing an interconnected, compositionally modulated microstructure that coarsens over time.</rdfs:comment>
        <rdfs:label xml:lang="en">spinodal decomposition</rdfs:label> <rdfs:label xml:lang="zh">旋节分解</rdfs:label>
        <skos:definition xml:lang="en">Spinodal decomposition is a diffusion‑controlled  continuous phase transformation in which a single homogeneous solution spontaneously separates into two compositionally distinct phases by amplification of infinitesimal concentration fluctuations.</skos:definition> <skos:definition xml:lang="zh">旋节分解是一种扩散控制的连续相变，其中单一均匀溶液通过放大微小的浓度波动自发分离成两个成分不同的相。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020158 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020158">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000023"/>
        <owl:disjointWith rdf:resource="https://w3id.org/pmd/co/PMD_0020159"/>
        <rdfs:label xml:lang="en">parent phase role</rdfs:label> <rdfs:label xml:lang="zh">母相角色</rdfs:label>
        <skos:definition xml:lang="en">The parent phase role is the role of a phase that dissolves during the phase transformation process. As such, the bearer is a metastable phase.</skos:definition> <skos:definition xml:lang="zh">母相角色是在相变过程中溶解的相的角色。因此，承载者是亚稳相。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020159 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020159">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000023"/>
        <rdfs:label xml:lang="en">daughter phase role</rdfs:label> <rdfs:label xml:lang="zh">子相角色</rdfs:label>
        <skos:definition xml:lang="en">The daughter phase role is the role of a phase that forms during the phase transformation process.</skos:definition> <skos:definition xml:lang="zh">子相角色是在相变过程中形成的相的角色。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020160 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020160">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000001"/>
        <rdfs:comment xml:lang="en">In metallography the term phase is sometimes used to denote microconstituents. To avoid confusion, the term phase should only be used for thermodynamic phases.</rdfs:comment>
        <rdfs:label xml:lang="en">microconstituent (phase mixture)</rdfs:label> <rdfs:label xml:lang="zh">显微组织（相混合物）</rdfs:label>
        <skos:definition xml:lang="en">A portion of matter that has one or more thermodynamic phases arranged in a characteristic spatial configuration (morphology) as parts.</skos:definition> <skos:definition xml:lang="zh">具有一个或多个热力学相以特征空间构型（形貌）作为部分排列的物质部分。</skos:definition>
        <skos:example xml:lang="en">Pearlite is a microconstituent that has as parts the thermodynamic phases ferrite (α-Fe) and cementite (Fe3C) as parts. The characteristic spatial arrangement is in that case the lamellar orientation of the phases.

Martensite is a microconstituent that has as part the thermodynamic ferrite phase with characteristic morphologies and chemistry. Its presence and amount is governed by the processing path and kinetics.</skos:example> <skos:example xml:lang="zh">珠光体是一种显微组织，其组成部分包括热力学相铁素体（α-Fe）和渗碳体（Fe3C）。其特征空间排列是相的层状取向。

马氏体是一种显微组织，其组成部分是具有特征形貌和化学成分的热力学铁素体相。其存在和数量由加工路径和动力学决定。</skos:example>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020161 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020161">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000145"/>
        <obo:IAO_0000119 xml:lang="en">old defintion: 
Activity (a_X) is a relational property between a chemical species X and a non-ideal solution. a_X is a measure of the effective concentration of a chemical species X in the non-ideal solution, accounting for interactions between particles. It is defined as the product of the concentration and an activity coefficient, where the activity coefficient corrects for non-ideal behavior.</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">旧定义：
活度（a_X）是化学物种X与非理想溶液之间的关系属性。a_X是化学物种X在非理想溶液中有效浓度的度量，考虑了粒子间的相互作用。它定义为浓度与活度系数的乘积，其中活度系数校正非理想行为。</obo:IAO_0000119>
        <rdfs:label xml:lang="en">activity (thermodynamic)</rdfs:label> <rdfs:label xml:lang="zh">活度（热力学）</rdfs:label>
        <skos:definition xml:lang="en">Thermodynamic activity is a relational quality that inheres between a chemical species and a non-ideal solution and represents the effective concentration of the species accounting for particle interactions.</skos:definition> <skos:definition xml:lang="zh">热力学活度是一种关系性质，存在于化学物种与非理想溶液之间，表示考虑粒子相互作用的物种有效浓度。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020162 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020162">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000008"/>
        <rdfs:label xml:lang="en">activation energy</rdfs:label> <rdfs:label xml:lang="zh">活化能</rdfs:label>
        <skos:definition xml:lang="en">Activation energy (E_a) a process attribute characterizing the minimum amount of energy required to initiate a reaction, allowing educts to overcome an energy barrier to transform into products.</skos:definition> <skos:definition xml:lang="zh">活化能（E_a）是一种过程属性，表征引发反应所需的最小能量，使反应物克服能垒转化为产物。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020163 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020163">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020136"/>
        <rdfs:label xml:lang="en">eutectic phase transformation</rdfs:label> <rdfs:label xml:lang="zh">共晶相变</rdfs:label>
        <skos:definition xml:lang="en">A eutectic phase transformation is a phase transformation in which a liquid parent phase decomposes into two distinct solid daughter phases at constant temperature and pressure.</skos:definition> <skos:definition xml:lang="zh">共晶相变是一种相变，其中液态母相在恒温恒压下分解为两种不同的固态子相。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020164 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020164">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000882"/>
        <rdfs:label xml:lang="en">state of matter boundary</rdfs:label> <rdfs:label xml:lang="zh">物态边界</rdfs:label>
        <skos:definition xml:lang="en">A state of matter boundary is a phase boundary that is realized by the transition from one aggregate state to another aggregate state.</skos:definition> <skos:definition xml:lang="zh">物态边界是一种相边界，通过从一种聚集状态转变为另一种聚集状态来实现。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020165 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020165">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000016"/>
        <rdfs:comment xml:lang="en">The disposition is grounded in the phases activity in the thermodynamic system in question.</rdfs:comment>
        <rdfs:label xml:lang="en">disposition of a phase to transform</rdfs:label> <rdfs:label xml:lang="zh">相变倾向</rdfs:label>
        <skos:definition xml:lang="en">The disposition of a phase to transform into another phase in a phase transformation process.</skos:definition> <skos:definition xml:lang="zh">在相变过程中，相转变为另一相的倾向。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020166 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020166">
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0020139"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000087"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000534"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">heat (metallurgy)</rdfs:label> <rdfs:label xml:lang="zh">热（冶金）</rdfs:label>
        <skos:definition xml:lang="en">A heat is a fixed amount of metallic alloy that may be input to some manufacturing process.</skos:definition> <skos:definition xml:lang="zh">热处理是一定量金属合金，可作为某些制造过程的输入。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020167 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020167">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000882"/>
        <rdfs:label xml:lang="en">structural boundary</rdfs:label> <rdfs:label xml:lang="zh">结构边界</rdfs:label>
        <skos:definition xml:lang="en">Structural phase boundary is a phase boundary that is realized in the transition from one structure to another structure.</skos:definition> <skos:definition xml:lang="zh">结构相边界是一种相边界，在从一种结构到另一种结构的转变中实现。</skos:definition>
        <skos:example xml:lang="en">ɑ-Ɣ transformation in iron at 910 °C</skos:example> <skos:example xml:lang="zh">铁在910 °C时的ɑ-Ɣ转变</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020168 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020168">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000882"/>
        <rdfs:label xml:lang="en">magnetic boundary</rdfs:label> <rdfs:label xml:lang="zh">磁性边界</rdfs:label>
        <skos:definition xml:lang="en">A magnetic boundary is a phase boundary that is realized by the transition from one magnetic ordering to another magnetic ordering.</skos:definition> <skos:definition xml:lang="zh">磁性边界是一种相边界，通过从一种磁有序到另一种磁有序的转变实现。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020169 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020169">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000882"/>
        <rdfs:label xml:lang="en">mixture boundary</rdfs:label> <rdfs:label xml:lang="zh">混合物边界</rdfs:label>
        <skos:definition xml:lang="en">A mixture boundary is a phase boundary that is realized by the transition from one phase to another phase in a system involving also chemical variations.</skos:definition> <skos:definition xml:lang="zh">混合物边界是一种相边界，在涉及化学变化的系统中，通过从一个相到另一个相的转变实现。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020170 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020170">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
        <rdfs:comment xml:lang="en">The ingot may be hot rolled after casting...</rdfs:comment>
        <rdfs:label xml:lang="de">Bramme</rdfs:label> <rdfs:label xml:lang="zh">板坯</rdfs:label>
        <rdfs:label xml:lang="en">ingot</rdfs:label> <rdfs:label xml:lang="zh">铸锭</rdfs:label>
        <skos:definition xml:lang="en">An ingot is an object that has a thick section and may bear a semi finished product role and that is the specified output of a casting process. At the same time it is a material.</skos:definition> <skos:definition xml:lang="zh">铸锭是一种具有厚截面的物体，可能承担半成品角色，并且是铸造过程的指定输出。同时，它是一种材料。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020171 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020171">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000146"/>
        <obo:IAO_0000116 xml:lang="en">Should it have exactly two phases as member parts?</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">它是否应该恰好有两个相作为组成部分？</obo:IAO_0000116>
        <rdfs:label xml:lang="en">phase boundary (spatial)</rdfs:label> <rdfs:label xml:lang="zh">相边界（空间）</rdfs:label>
        <skos:definition xml:lang="en">A fiat surface separating one phase from another phase.</skos:definition> <skos:definition xml:lang="zh">一个平坦的表面，将一个相与另一个相分隔开。</skos:definition>
        <skos:example xml:lang="en">The phase boundary between liquid and the gaseous phase in a tank. 
The phase boundary between Fe3C and Fe of a pearlite lamellae.</skos:example> <skos:example xml:lang="zh">储罐中液相与气相之间的相边界。
珠光体片层中Fe3C与Fe之间的相边界。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020172 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020172">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
        <rdfs:label xml:lang="en">sheet</rdfs:label> <rdfs:label xml:lang="zh">薄板</rdfs:label>
        <skos:definition xml:lang="en">A plate is a thin rectangular object that may bear a semi finished product role. At the same time it is a material.</skos:definition> <skos:definition xml:lang="zh">板是一种薄的矩形物体，可能承担半成品角色。同时，它是一种材料。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020173 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020173">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
        <rdfs:label xml:lang="en">billet</rdfs:label> <rdfs:label xml:lang="zh">方坯</rdfs:label>
        <skos:definition xml:lang="en">A billet is a relatively compact object that may bear a semi finished product role. At the same time it is a material.</skos:definition> <skos:definition xml:lang="zh">方坯是一种相对紧凑的物体，可能承担半成品角色。同时，它是一种材料。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020174 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020174">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
        <rdfs:label xml:lang="en">foil</rdfs:label> <rdfs:label xml:lang="zh">箔</rdfs:label>
        <skos:definition xml:lang="en">A plate is a very thin rectangular object that may bear a semi finished product role. At the same time it may be a material.</skos:definition> <skos:definition xml:lang="zh">板是一种非常薄的矩形物体，可能承担半成品角色。同时，它可能是一种材料。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020175 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020175">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
        <rdfs:comment xml:lang="en">Coils may have several sheets that are joined together.</rdfs:comment>
        <rdfs:label xml:lang="en">coil (coiled sheet)</rdfs:label> <rdfs:label xml:lang="zh">卷材（卷状薄板）</rdfs:label>
        <skos:definition xml:lang="en">A coil is an object that has part some sheets or foils. At the same time it may be a material.</skos:definition> <skos:definition xml:lang="zh">卷材是一种物体，其部分由一些薄板或箔组成。同时，它可能是一种材料。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020176 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020176">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
        <rdfs:label xml:lang="en">plate</rdfs:label> <rdfs:label xml:lang="zh">厚板</rdfs:label>
        <skos:definition xml:lang="en">A plate is a thick rectangular object that may bear a semi finished product role. At the same time it may be a material.</skos:definition> <skos:definition xml:lang="zh">厚板是一种厚的矩形物体，可能承担半成品角色。同时，它可能是一种材料。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020177 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020177">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
        <rdfs:label xml:lang="en">bar</rdfs:label> <rdfs:label xml:lang="zh">棒材</rdfs:label>
        <skos:definition xml:lang="en">A bar is a long object with rectangular section that may bear a semi finished product role. At the same time it may be a material.</skos:definition> <skos:definition xml:lang="zh">棒材是一种具有矩形截面的长物体，可充当半成品角色，同时也可能是一种材料。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020178 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020178">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
        <rdfs:label xml:lang="en">rod</rdfs:label> <rdfs:label xml:lang="zh">棒材（圆形或椭圆形）</rdfs:label>
        <skos:definition xml:lang="en">A rod is a long object with oval or round section that may bear a semi finished product role. At the same time it may be a material.</skos:definition> <skos:definition xml:lang="zh">棒材是一种具有椭圆形或圆形截面的长物体，可充当半成品角色，同时也可能是一种材料。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020179 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020179">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
        <rdfs:comment xml:lang="en">This class does not include cables or other compound structures.</rdfs:comment>
        <rdfs:label xml:lang="en">wire (semi finished product)</rdfs:label> <rdfs:label xml:lang="zh">线材（半成品）</rdfs:label>
        <skos:definition xml:lang="en">A wire is a long and somewhat flexible object that may bear a semi finished product role. At the same time it is a material.</skos:definition> <skos:definition xml:lang="zh">线材是一种较长且具有一定柔韧性的物体，可充当半成品角色，同时是一种材料。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020180 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020180">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
        <rdfs:label xml:lang="en">tube</rdfs:label> <rdfs:label xml:lang="zh">管材（薄壁）</rdfs:label>
        <skos:definition xml:lang="en">A tube is a long object with a hollow section and moderate wall thickness that may bear a semi finished product role. At the same time it may be a material.</skos:definition> <skos:definition xml:lang="zh">管材是一种具有空心截面且壁厚适中的长物体，可充当半成品角色，同时也可能是一种材料。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020181 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020181">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
        <rdfs:label xml:lang="en">pipe</rdfs:label> <rdfs:label xml:lang="zh">管道（厚壁）</rdfs:label>
        <skos:definition xml:lang="en">A tube is a long object with a hollow section and pronounced wall thickness that may bear a semi finished product role. At the same time it may be a material.</skos:definition> <skos:definition xml:lang="zh">管道是一种具有空心截面且壁厚显著的长物体，可充当半成品角色，同时也可能是一种材料。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020182 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020182">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
        <rdfs:label xml:lang="en">profile (semi finished product)</rdfs:label> <rdfs:label xml:lang="zh">型材（半成品）</rdfs:label>
        <skos:definition xml:lang="en">A profile is a long object with determined section shape that may bear a semi finished product role. At the same time it may be a material.</skos:definition> <skos:definition xml:lang="zh">型材是一种具有确定截面形状的长物体，可充当半成品角色，同时也可能是一种材料。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020183 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020183">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000648"/>
        <rdfs:label xml:lang="de">Recker</rdfs:label>
        <rdfs:label xml:lang="en">stretch straightener machine</rdfs:label> <rdfs:label xml:lang="zh">拉伸矫直机</rdfs:label>
        <skos:definition xml:lang="en">A strech straightener machine is a forming machine that is used in a "forming under tensile conditions" process.</skos:definition> <skos:definition xml:lang="zh">拉伸矫直机是一种成型机器，用于“拉伸条件下的成型”工艺。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020184 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020184">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000602"/>
        <rdfs:label xml:lang="de">Walzwerk</rdfs:label> <rdfs:label xml:lang="zh">轧机</rdfs:label>
        <rdfs:label xml:lang="en">rolling mill</rdfs:label> <rdfs:label xml:lang="zh">轧机</rdfs:label>
        <skos:definition xml:lang="en">A rolling mill is a device that has part some rolling stand and whose specified input participates in some forming process.</skos:definition> <skos:definition xml:lang="zh">轧机是一种设备，其部件包含某些轧机机架，且其特定输入参与某些成型工艺。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020185 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020185">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000602"/>
        <rdfs:label xml:lang="en">rolling stand</rdfs:label> <rdfs:label xml:lang="zh">轧机机架</rdfs:label>
        <skos:definition xml:lang="en">A rolling stand is a device that is part of a rolling mill, has some work rolls and participates in a rolling pass.</skos:definition> <skos:definition xml:lang="zh">轧机机架是一种设备，它是轧机的一部分，拥有工作辊，并参与轧制道次。</skos:definition>
        <skos:definition xml:lang="de">Ein Walzstock ist ein Teil eines Walzwerks, hat als Teil Arbeitswalzen und nimmt Teil an einen Walzstich.</skos:definition> <skos:definition xml:lang="zh">轧辊机架是轧机的一部分，作为组成部分拥有工作辊，并参与轧制道次。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020186 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020186">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0010007"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0025004"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020071"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">aluminium alloy</rdfs:label> <rdfs:label xml:lang="zh">铝合金</rdfs:label>
        <skos:definition xml:lang="en">non-ferrous metal consisting primarily of aluminium mixed with other elements</skos:definition> <skos:definition xml:lang="zh">主要由铝与其他元素混合而成的有色金属</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020187 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020187">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0010007"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0025004"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020054"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">copper alloy</rdfs:label> <rdfs:label xml:lang="zh">铜合金</rdfs:label>
        <skos:definition xml:lang="en">non-ferrous metal consisting primarily of copper combined with other elements</skos:definition> <skos:definition xml:lang="zh">主要由铜与其他元素结合而成的有色金属</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020188 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020188">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0010007"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0025004"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020051"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">nickel alloy</rdfs:label> <rdfs:label xml:lang="zh">镍合金</rdfs:label>
        <skos:definition xml:lang="en">non-ferrous metal consisting primarily of nickel combined with other elements</skos:definition> <skos:definition xml:lang="zh">主要由镍与其他元素组合而成的有色金属</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020189 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020189">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0010007"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0025004"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020095"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">titanium alloy</rdfs:label> <rdfs:label xml:lang="zh">钛合金</rdfs:label>
        <skos:definition xml:lang="en">non-ferrous metal consisting primarily of titanium combined with other elements</skos:definition> <skos:definition xml:lang="zh">主要由钛与其他元素组合而成的有色金属</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020190 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020190">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000965"/>
        <rdfs:label xml:lang="en">metallographic section (surface)</rdfs:label> <rdfs:label xml:lang="zh">金相截面（表面）</rdfs:label>
        <skos:definition xml:lang="en">A surface layer (fiat object part) of an object which at the same time is a metal and the object is specified output of a planned process which describes the preparation of the surface.</skos:definition> <skos:definition xml:lang="zh">物体的表面层（扁平物体部分），该物体同时为金属，且是描述表面制备的有计划过程的指定输出。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020191 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020191">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
        <rdfs:comment xml:lang="en">Typical dimensions of the round mountings are a diameter of 20-50 mm and a thickness of 10-20 mm.</rdfs:comment>
        <rdfs:label xml:lang="en">metallographic section (embedded sample)</rdfs:label> <rdfs:label xml:lang="zh">金相截面（镶嵌试样）</rdfs:label>
        <skos:definition xml:lang="en">A metallographic section (embedded sample) is an object that has two parts: a metallic object that has a metallographic section (surface) as part and the mounting which is produced during a hot embedding or cold embedding process.</skos:definition> <skos:definition xml:lang="zh">金相截面（镶嵌试样）是一个物体，包含两部分：一个具有金相截面（表面）作为其部分的金属物体，以及在热镶嵌或冷镶嵌过程中产生的镶嵌料。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020192 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020192">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020190"/>
        <rdfs:label xml:lang="en">macrosection (metallography)</rdfs:label> <rdfs:label xml:lang="zh">宏观截面（金相学）</rdfs:label>
        <skos:definition xml:lang="en">A macrosection (metallography) is a metallographic section (surface) that is produced directly on an object. The object may be cut in order to make accessible a section (fiat surface) of interest.</skos:definition> <skos:definition xml:lang="zh">宏观截面（金相学）是直接在物体上制备的金相截面（表面）。可对物体进行切割以获取感兴趣的截面（扁平表面）。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020193 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020193">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
        <rdfs:label xml:lang="en">tensile testpiece</rdfs:label> <rdfs:label xml:lang="zh">拉伸试样</rdfs:label>
        <skos:definition xml:lang="en">A tensile testpiece is a longitudinal object that has two parts which were designed for gripping (gripping section) at its ends and a part between the gripping sections that has been designed to observe the materials or the objects reaction to tensile loading.</skos:definition> <skos:definition xml:lang="zh">拉伸试样是一种纵向物体，其两端设计有用于夹持的部分（夹持段），夹持段之间的部分设计用于观察材料或物体对拉伸载荷的反应。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020194 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020194">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:comment xml:lang="en">often used to describe mass transport from regions of high concentration to regions of low concentration</rdfs:comment>
        <rdfs:label xml:lang="en">diffusion</rdfs:label> <rdfs:label xml:lang="zh">扩散</rdfs:label>
        <skos:definition xml:lang="en">process by which material entities spread or move due to random thermal motion</skos:definition> <skos:definition xml:lang="zh">材料实体因随机热运动而扩散或移动的过程</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020195 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020195">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:label xml:lang="en">crystallization</rdfs:label> <rdfs:label xml:lang="zh">结晶</rdfs:label>
        <skos:definition xml:lang="en">process by which a solid with long-range order forms</skos:definition> <skos:definition xml:lang="zh">形成具有长程有序的固体的过程</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020196 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020196">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:label xml:lang="en">recrystallization</rdfs:label> <rdfs:label xml:lang="zh">再结晶</rdfs:label>
        <skos:definition xml:lang="en">process in which a new, defect-free grain structure forms in a material from an existing deformed grain structure.</skos:definition> <skos:definition xml:lang="zh">在材料中从现有变形晶粒结构形成新的无缺陷晶粒结构的过程。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020197 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020197">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000147"/>
        <rdfs:label xml:lang="en">lattice point</rdfs:label> <rdfs:label xml:lang="zh">晶格点</rdfs:label>
        <skos:definition xml:lang="en">A lattice point is a fiat point that represents a position in a crystal lattice at which structural entities are regularly arranged.</skos:definition> <skos:definition xml:lang="zh">晶格点是一个扁平的点，表示晶体结构中结构实体规则排列的位置。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020198 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020198">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000029"/>
        <rdfs:label xml:lang="en">interstitial site</rdfs:label> <rdfs:label xml:lang="zh">间隙位置</rdfs:label>
        <skos:definition xml:lang="en">An interstitial site is a site that is located between regular lattice points in a crystal structure.</skos:definition> <skos:definition xml:lang="zh">间隙位置是位于晶体结构中规则晶格点之间的位置。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020199 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020199">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000146"/>
        <rdfs:label xml:lang="en">slip plane</rdfs:label> <rdfs:label xml:lang="zh">滑移面</rdfs:label>
        <skos:definition xml:lang="en">A slip plane is a fiat surface that corresponds to a crystallographic plane of a 3D crystal along which dislocations can glide</skos:definition> <skos:definition xml:lang="zh">滑移面是一个扁平表面，对应于三维晶体的一个晶面，位错可沿其滑移</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020200 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020200">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000017"/>
        <obo:IAO_0000119 xml:lang="en">Old definition: Force is a reciprocal relation realized between two objects where the other object exerts the same force with opposite sign onto the first. Force may be responsible for changes in velocity and/or deformation of objects.</obo:IAO_0000119> <obo:IAO_0000119 xml:lang="zh">旧定义：力是两个物体之间实现的相互作用关系，其中另一个物体对第一个物体施加大小相同、符号相反的力。力可导致物体速度变化和/或变形。</obo:IAO_0000119>
        <rdfs:label xml:lang="en">force</rdfs:label> <rdfs:label xml:lang="zh">力是一种可实现的实体，由两个物体之间的相互作用构成，并表现为能够改变运动或引起变形的相等且相反的影响。</rdfs:label>
        <skos:definition xml:lang="en">A force is a realizable entity that consists of a reciprocal interaction between two objects and is realized as equal and opposite influences capable of changing motion or causing deformation.</skos:definition> <skos:definition xml:lang="zh">力是一种可实现的实体，由两个物体之间的相互作用构成，并表现为能够改变运动或引起变形的相等且相反的影响。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020201 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020201">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000146"/>
        <rdfs:label xml:lang="en">section</rdfs:label> <rdfs:label xml:lang="zh">截面是横切物体的平面平直表面。</rdfs:label>
        <skos:definition xml:lang="en">Section is a planar fiat surface cutting across the object</skos:definition> <skos:definition xml:lang="zh">截面是横切物体的平面平直表面。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020202 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020202">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000029"/>
        <rdfs:label xml:lang="en">crack</rdfs:label> <rdfs:label xml:lang="zh">裂纹是由材料实体内部原子键层次的物理分离构成的位置。</rdfs:label>
        <skos:definition xml:lang="en">A crack is a site that consists of a physical separation within a material entity occurring at the level of atomic bonds.</skos:definition> <skos:definition xml:lang="zh">裂纹是由材料实体内部原子键层次的物理分离构成的位置。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020203 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020203">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000029"/>
        <rdfs:label xml:lang="en">notch</rdfs:label> <rdfs:label xml:lang="zh">缺口是由物体几何表面特征构成的位置，其特征在于形状或横截面的强烈局部变化。</rdfs:label>
        <skos:definition xml:lang="en">A notch is a site that consists of a geometric surface feature of an object characterized by a strong local change in shape or cross-section.</skos:definition> <skos:definition xml:lang="zh">缺口是由物体几何表面特征构成的位置，其特征在于形状或横截面的强烈局部变化。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020204 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020204">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000029"/>
        <rdfs:label xml:lang="en">pore</rdfs:label> <rdfs:label xml:lang="zh">孔隙是由位于材料实体内部的空腔构成的位置。</rdfs:label>
        <skos:definition xml:lang="en">A pore is a site that consists of a cavity located within the bulk of a material entity.</skos:definition> <skos:definition xml:lang="zh">孔隙是由位于材料实体内部的空腔构成的位置。</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020205 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020205">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000023"/>
        <rdfs:label xml:lang="en">defect role</rdfs:label> <rdfs:label xml:lang="zh">缺陷角色是独立连续体C的角色，表示C可能影响材料实体E实现功能的能力。C是E的连续体部分。</rdfs:label>
        <skos:definition xml:lang="en">A defect role is a role of an independent continuant C indicating that C may affect a material entity E's ability to realize a function. C is continuant part of E.</skos:definition> <skos:definition xml:lang="zh">缺陷角色是独立连续体C的角色，表示C可能影响材料实体E实现功能的能力。C是E的连续体部分。</skos:definition>
        <skos:example xml:lang="en">A crack in an structural member may affect its ability to carry a load.</skos:example> <skos:example xml:lang="zh">结构构件中的裂纹可能影响其承载能力。</skos:example>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020206 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020206">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000028"/>
        <rdfs:label xml:lang="en">unit cell (3D crystal)</rdfs:label> <rdfs:label xml:lang="zh">晶胞（三维晶体）是三维空间区域，代表空间平移复现晶格的最小重复区域。</rdfs:label>
        <skos:definition xml:lang="en">A unit cell (3D crystal) is a three-dimensional spatial region that represents the smallest repeating region whose spatial translation reproduces a crystal lattice.</skos:definition> <skos:definition xml:lang="zh">晶胞（三维晶体）是三维空间区域，代表空间平移复现晶格的最小重复区域。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020207 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020207">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020103"/>
        <rdfs:label xml:lang="en">amount of substance</rdfs:label> <rdfs:label xml:lang="zh">物质的量n是摩尔比例，其中整体为物体集合N，N包含阿伏伽德罗常数个（同类型）物体作为部分（n = N/N_A）。</rdfs:label>
        <skos:definition xml:lang="en">Amount of substance n is a molar proportion when the whole is an object aggregate N, which has avogadro number objects (of same type) as parts (n = N/N_A).</skos:definition> <skos:definition xml:lang="zh">物质的量n是摩尔比例，其中整体为物体集合N，N包含阿伏伽德罗常数个（同类型）物体作为部分（n = N/N_A）。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020208 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020208">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000142"/>
        <rdfs:label xml:lang="en">slip direction</rdfs:label> <rdfs:label xml:lang="zh">滑移方向是与滑移面上位错滑移的晶体学方向对应的平直线。</rdfs:label>
        <skos:definition xml:lang="en">A slip direction is a fiat line that corresponds to the crystallographic direction along which dislocations glide os a slip plane.</skos:definition> <skos:definition xml:lang="zh">滑移方向是与滑移面上位错滑移的晶体学方向对应的平直线。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020209 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020209">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBI_0001930"/>
        <obo:IAO_0000116 xml:lang="en">TODO: Indiviuals for the possible values need to be created, similar to the values of the Bravais lattice value individuals.</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">TODO: 需要为可能值创建个体，类似于布拉维晶格值个体的值。</obo:IAO_0000116>
        <rdfs:comment xml:lang="en">Is determined by the Bravais lattice.</rdfs:comment>
        <rdfs:label xml:lang="en">slip system (3D)</rdfs:label> <rdfs:label xml:lang="zh">滑移系（三维）指定晶体滑移面与滑移方向的值。</rdfs:label>
        <skos:definition xml:lang="en">specifies the value of the crystal slip plane together with the slip direction.</skos:definition> <skos:definition xml:lang="zh">指定晶体滑移面与滑移方向的值。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020210 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020210">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002351"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/pmd/co/PMD_0020140"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020003"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002351"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020140"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">elemental crystal</rdfs:label> <rdfs:label xml:lang="zh">元素晶体是由单一原子种类组成的晶体。</rdfs:label>
        <skos:definition xml:lang="en">a crystal that consists of exactly one atomic species</skos:definition> <skos:definition xml:lang="zh">由单一原子种类组成的晶体。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020211 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020211">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020212"/>
        <obo:IAO_0000116 xml:lang="en">different structures of a crystal could be linked by a relational property 'allotrope of'</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">晶体的不同结构可通过关系属性“allotrope of”关联。</obo:IAO_0000116>
        <rdfs:label xml:lang="en">allotropy of an elemental crystal</rdfs:label> <rdfs:label xml:lang="zh">元素晶体的同素异形性</rdfs:label>
        <skos:definition xml:lang="en">a disposition of an elemental crystal to change its crystal structure</skos:definition> <skos:definition xml:lang="zh">元素晶体改变其晶体结构的倾向</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020212 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020212">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000016"/>
        <rdfs:comment xml:lang="en">stable structure depends on pressure and temperature</rdfs:comment>
        <rdfs:label xml:lang="en">polymorphism of crystal</rdfs:label> <rdfs:label xml:lang="zh">晶体的多晶型性</rdfs:label>
        <skos:definition xml:lang="en">disposition of a crystal to change its crystal structure</skos:definition> <skos:definition xml:lang="zh">晶体改变其晶体结构的倾向</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020213 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020213">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000146"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002350"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0020003"/>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="https://w3id.org/pmd/co/PMD_0025998"/>
                                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020241"/>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002350"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">2</owl:qualifiedCardinality>
                <owl:onClass>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0020003"/>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="https://w3id.org/pmd/co/PMD_0025998"/>
                                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020241"/>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:onClass>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">grain boundary</rdfs:label> <rdfs:label xml:lang="zh">晶界</rdfs:label>
        <skos:definition xml:lang="en">A grain boundary is a fiat surface that separates adjacent grains in a polycrystalline material and is characterized by structural discontinuity.</skos:definition> <skos:definition xml:lang="zh">晶界是分隔多晶材料中相邻晶粒的平坦表面，其特征在于结构不连续性。</skos:definition>
        <skos:definition xml:lang="en">the part of a grain that is close to the grain boundary and possibly characterized by disorder is a fiat object part (grain surface layer)</skos:definition> <skos:definition xml:lang="zh">晶粒中靠近晶界且可能具有无序特征的部分是一个平坦的对象部分（晶粒表层）</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020214 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020214">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:label xml:lang="en">diffraction</rdfs:label> <rdfs:label xml:lang="zh">衍射</rdfs:label>
        <skos:definition xml:lang="en">is a process of interference of waves which, scattered by a material’s periodic features, produce characteristic patterns</skos:definition> <skos:definition xml:lang="zh">是波干涉的过程，波被材料的周期性特征散射，产生特征花样。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020215 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020215">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:comment xml:lang="en">may propagate through a medium or vacuum
characterized by frequency, wavelength, and speed</rdfs:comment>
        <rdfs:label xml:lang="en">wave</rdfs:label> <rdfs:label xml:lang="zh">波</rdfs:label>
        <skos:definition xml:lang="en">is a process of a propagating of disturbance that transports energy and momentum</skos:definition> <skos:definition xml:lang="zh">是一种扰动传播的过程，传递能量和动量。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020216 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020216">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0020217"/>
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0020218"/>
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0020219"/>
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0020242"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBI_0001930"/>
        <rdfs:label xml:lang="en">order scale value</rdfs:label> <rdfs:label xml:lang="zh">有序尺度值</rdfs:label>
        <skos:definition xml:lang="en">possible values of characteristic length over which structural correlations persist in a material</skos:definition> <skos:definition xml:lang="zh">材料中结构相关性持续存在的特征长度的可能值</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020220 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020220">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/pmd/co/PMD_0000077"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/pmd/co/PMD_0020216"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020131"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/pmd/co/PMD_0000077"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020216"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">order scale</rdfs:label> <rdfs:label xml:lang="zh">有序尺度</rdfs:label>
        <skos:definition xml:lang="en">characteristic length over which structural correlations persist in a material</skos:definition> <skos:definition xml:lang="zh">材料中结构相关性持续存在的特征长度</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020221 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020221">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020194"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000057"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/CHEBI_60003"/>
                            <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0020003"/>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">self-diffusion in crystaline solid</rdfs:label> <rdfs:label xml:lang="zh">晶体固体中的自扩散</rdfs:label>
        <skos:definition xml:lang="en">diffusion of entites of a single type in a crystal that consists of entites of this same type</skos:definition> <skos:definition xml:lang="zh">单一类型实体在由同种实体组成的晶体中的扩散</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020222 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020222">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020194"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000057"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/CHEBI_60003"/>
                            <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0020003"/>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">inter-diffusion in crystalline solid</rdfs:label> <rdfs:label xml:lang="zh">晶体固体中的相互扩散</rdfs:label>
        <skos:definition xml:lang="en">diffusion of entites of some type in a crystal that consists mostly of entites of a different type</skos:definition> <skos:definition xml:lang="zh">在主要由不同类型实体组成的晶体中，某种类型实体的扩散</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020223 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020223">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020194"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000057"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020224"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">vacancy diffusion</rdfs:label> <rdfs:label xml:lang="zh">空位扩散</rdfs:label>
        <skos:definition xml:lang="en">diffusion process in which crystal forming entities move from lattice points to vacant adjacent lattice points</skos:definition> <skos:definition xml:lang="zh">扩散过程，其中晶体形成实体从晶格点移动到相邻的空晶格点</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020224 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020224">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000029"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020197"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000116 xml:lang="en">TODO: replace topObjectProperty with occupies spatial region</obo:IAO_0000116> <obo:IAO_0000116 xml:lang="zh">TODO: 将 topObjectProperty 替换为 occupies spatial region</obo:IAO_0000116>
        <rdfs:label xml:lang="en">vacancy (crystal)</rdfs:label> <rdfs:label xml:lang="zh">空位（晶体）</rdfs:label>
        <skos:definition xml:lang="en">site at lattice point at which the crystal forming entity is missing</skos:definition> <skos:definition xml:lang="zh">晶格点上晶体形成实体缺失的位置</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020225 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020225">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020194"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000057"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000040"/>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0001025"/>
                                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020198"/>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">interstitial diffusion</rdfs:label> <rdfs:label xml:lang="zh">间隙扩散</rdfs:label>
        <skos:definition xml:lang="en">diffusion process in which material entities move from interstitial sites to adjacent interstitial sites</skos:definition> <skos:definition xml:lang="zh">物质实体从间隙位置移动到相邻间隙位置的扩散过程</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020226 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020226">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000008"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/pmd/co/PMD_0025006"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020246"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">flow</rdfs:label> <rdfs:label xml:lang="zh">流动</rdfs:label>
        <skos:definition xml:lang="en">amount of transported entites per time</skos:definition> <skos:definition xml:lang="zh">单位时间传输的实体数量</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020227 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020227">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000023"/>
        <owl:disjointWith rdf:resource="https://w3id.org/pmd/co/PMD_0020228"/>
        <rdfs:label xml:lang="en">solute role</rdfs:label> <rdfs:label xml:lang="zh">溶质角色</rdfs:label>
        <skos:definition xml:lang="en">role of an entity that is present in minor concentration in a solution</skos:definition> <skos:definition xml:lang="zh">溶液中以低浓度存在的实体的角色</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020228 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020228">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000023"/>
        <rdfs:label xml:lang="en">solvent role</rdfs:label> <rdfs:label xml:lang="zh">溶剂角色</rdfs:label>
        <skos:definition xml:lang="en">role of an entity that is present in major concentration in a solution</skos:definition> <skos:definition xml:lang="zh">溶液中以高浓度存在的实体的角色</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020229 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020229">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
