        <rdfs:label xml:lang="en">aggregate state solid</rdfs:label> <rdfs:label xml:lang="zh">固态</rdfs:label>
        <skos:definition xml:lang="en">A state where the bonds between entities transmit shear forces.</skos:definition> <skos:definition xml:lang="zh">实体间的键传递剪切力的状态。</skos:definition>
