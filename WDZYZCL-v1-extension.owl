<?xml version="1.0"?>
<rdf:RDF xmlns="https://w3id.org/wdzyzcl/co/"
     xml:base="https://w3id.org/wdzyzcl/co/"
     xmlns:co="https://w3id.org/pmd/co/"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:obo="http://purl.obolibrary.org/obo/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:doap="http://usefulinc.com/ns/doap#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:dcterms="http://purl.org/dc/terms/"
     xmlns:oboInOwl="http://www.geneontology.org/formats/oboInOwl#">
    <owl:Ontology rdf:about="https://w3id.org/wdzyzcl/co/">
        <owl:versionIRI rdf:resource="https://w3id.org/wdzyzcl/co/1.0.0"/>
        <owl:imports rdf:resource="https://w3id.org/pmd/co/3.0.0"/>
        <dcterms:created>2026-05-14</dcterms:created>
        <dcterms:creator>Zhang Zilong</dcterms:creator>
        <dcterms:description xml:lang="en">Domain extension of PMDco for microelectronics heterogeneous materials, covering wide bandgap semiconductors, oxide semiconductors, thin-film materials, heterostructures, microelectronics processes, and semiconductor devices.</dcterms:description>
        <dcterms:description xml:lang="zh">基于PMDco的微电子异质材料领域扩展本体，覆盖宽禁带半导体、氧化物半导体、薄膜材料、异质结构、微电子工艺和半导体器件。</dcterms:description>
        <dcterms:title xml:lang="en">WDZYZCL Microelectronics Heterogeneous Materials Ontology</dcterms:title>
        <dcterms:title xml:lang="zh">微电子异质材料本体</dcterms:title>
        <owl:versionInfo>1.0.0</owl:versionInfo>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://w3id.org/wdzyzcl/co/WDZ_0100100 -->

    <owl:Class rdf:about="https://w3id.org/wdzyzcl/co/WDZ_0100100">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0010101"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000086"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/wdzyzcl/co/WDZ_0200000"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000086"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/wdzyzcl/co/WDZ_0210000"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000091"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000978"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000091"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/wdzyzcl/co/WDZ_0220000"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002353"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/wdzyzcl/co/WDZ_0300001"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">gallium nitride</rdfs:label>
        <rdfs:label xml:lang="zh">氮化镓</rdfs:label>
        <skos:altLabel xml:lang="en">GaN</skos:altLabel>
        <skos:definition xml:lang="en">Gallium nitride (GaN) is a III-V wide bandgap compound semiconductor with wurtzite crystal structure. It exhibits high electron mobility, high breakdown voltage, and is commonly used in high-power, high-frequency electronic devices and blue/UV light-emitting diodes.</skos:definition>
        <skos:definition xml:lang="zh">氮化镓（GaN）是一种III-V族宽禁带化合物半导体，具有纤锌矿晶体结构。它具有高电子迁移率、高击穿电压，广泛用于高功率、高频电子器件和蓝光/紫外发光二极管。</skos:definition>
        <skos:example xml:lang="en">GaN high electron mobility transistors (HEMTs) for 5G base station power amplifiers.</skos:example>
        <skos:example xml:lang="zh">用于5G基站功率放大器的GaN高电子迁移率晶体管（HEMT）。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/wdzyzcl/co/WDZ_0100101 -->

    <owl:Class rdf:about="https://w3id.org/wdzyzcl/co/WDZ_0100101">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0010101"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000086"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/wdzyzcl/co/WDZ_0200000"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000086"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/wdzyzcl/co/WDZ_0210000"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000091"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000978"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002353"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/wdzyzcl/co/WDZ_0300001"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">aluminium nitride</rdfs:label>
        <rdfs:label xml:lang="zh">氮化铝</rdfs:label>
        <skos:altLabel xml:lang="en">AlN</skos:altLabel>
        <skos:definition xml:lang="en">Aluminium nitride (AlN) is a III-V wide bandgap compound semiconductor with wurtzite crystal structure. It is characterised by high thermal conductivity, high electrical resistivity, and excellent piezoelectric properties, making it suitable for thermal management substrates, surface acoustic wave (SAW) devices, and deep-ultraviolet optoelectronics.</skos:definition>
        <skos:definition xml:lang="zh">氮化铝（AlN）是一种III-V族宽禁带化合物半导体，具有纤锌矿晶体结构。它具有高热导率、高电阻率和优异的压电特性，适用于热管理衬底、声表面波（SAW）器件和深紫外光电子器件。</skos:definition>
        <skos:example xml:lang="en">AlN thin films as buffer layers for GaN-based HEMTs on silicon substrates.</skos:example>
        <skos:example xml:lang="zh">AlN薄膜作为硅衬底上GaN基HEMT的缓冲层。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/wdzyzcl/co/WDZ_0100102 -->

    <owl:Class rdf:about="https://w3id.org/wdzyzcl/co/WDZ_0100102">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0010101"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000086"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/wdzyzcl/co/WDZ_0200001"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000091"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/wdzyzcl/co/WDZ_0230000"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000091"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/wdzyzcl/co/WDZ_0220001"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002353"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/wdzyzcl/co/WDZ_0300002"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">indium gallium zinc oxide</rdfs:label>
        <rdfs:label xml:lang="zh">铟镓锌氧化物</rdfs:label>
        <skos:altLabel xml:lang="en">IGZO</skos:altLabel>
        <skos:definition xml:lang="en">Indium gallium zinc oxide (IGZO) is a quaternary amorphous oxide semiconductor composed of indium, gallium, zinc, and oxygen. It exhibits high field-effect mobility, low off-state current, and optical transparency in the visible range, making it the dominant channel material in high-resolution thin-film transistor (TFT) backplanes for OLED and LCD displays.</skos:definition>
        <skos:definition xml:lang="zh">铟镓锌氧化物（IGZO）是一种由铟、镓、锌、氧组成的四元非晶氧化物半导体。它具有高场效应迁移率、低关态电流和可见光透过性，是高分辨率OLED和LCD显示器薄膜晶体管（TFT）背板的主流沟道材料。</skos:definition>
        <skos:example xml:lang="en">IGZO TFT backplanes in high-resolution OLED displays for smartphones and tablets.</skos:example>
        <skos:example xml:lang="zh">智能手机和平板电脑高分辨率OLED显示屏中的IGZO TFT背板。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/wdzyzcl/co/WDZ_0100103 -->

    <owl:Class rdf:about="https://w3id.org/wdzyzcl/co/WDZ_0100103">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0010100"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000086"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/wdzyzcl/co/WDZ_0200002"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000091"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/wdzyzcl/co/WDZ_0220000"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">silicon</rdfs:label>
        <rdfs:label xml:lang="zh">硅</rdfs:label>
        <skos:altLabel xml:lang="en">Si</skos:altLabel>
        <skos:definition xml:lang="en">Silicon (Si) is the most widely used elemental semiconductor, possessing a diamond cubic crystal structure and an indirect band gap of 1.12 eV. It forms the foundation of the modern integrated circuit industry and is the dominant substrate material for microelectronics manufacturing.</skos:definition>
        <skos:definition xml:lang="zh">硅（Si）是应用最广泛的元素半导体，具有金刚石立方晶体结构和1.12 eV的间接带隙。它是现代集成电路产业的基础，也是微电子制造的主导衬底材料。</skos:definition>
        <skos:example xml:lang="en">Silicon wafers as substrates for CMOS integrated circuit fabrication.</skos:example>
        <skos:example xml:lang="zh">硅晶圆作为CMOS集成电路制造的衬底。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/wdzyzcl/co/WDZ_0100104 -->

    <owl:Class rdf:about="https://w3id.org/wdzyzcl/co/WDZ_0100104">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0010101"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000086"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/wdzyzcl/co/WDZ_0210000"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">silicon carbide</rdfs:label>
        <rdfs:label xml:lang="zh">碳化硅</rdfs:label>
        <skos:altLabel xml:lang="en">SiC</skos:altLabel>
        <skos:altLabel xml:lang="zh">SiC</skos:altLabel>
        <skos:definition xml:lang="en">Silicon carbide (SiC) is a IV-IV wide bandgap compound semiconductor with outstanding thermal conductivity, high breakdown electric field, and excellent chemical stability. SiC power devices are widely used in electric vehicle traction inverters, industrial motor drives, and high-voltage power grids.</skos:definition>
        <skos:definition xml:lang="zh">碳化硅（SiC）是一种IV-IV族宽禁带化合物半导体，具有出色的热导率、高击穿电场和优异的化学稳定性。SiC功率器件广泛用于电动汽车牵引逆变器、工业电机驱动和高压电网。</skos:definition>
        <skos:example xml:lang="en">SiC MOSFETs in electric vehicle traction inverters for improved efficiency and range.</skos:example>
        <skos:example xml:lang="zh">电动汽车牵引逆变器中的SiC MOSFET，用于提升效率和续航。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/wdzyzcl/co/WDZ_0100105 -->

    <owl:Class rdf:about="https://w3id.org/wdzyzcl/co/WDZ_0100105">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0010101"/>
        <rdfs:label xml:lang="en">gallium arsenide</rdfs:label>
        <rdfs:label xml:lang="zh">砷化镓</rdfs:label>
        <skos:altLabel xml:lang="en">GaAs</skos:altLabel>
        <skos:altLabel xml:lang="zh">GaAs</skos:altLabel>
        <skos:definition xml:lang="en">Gallium arsenide (GaAs) is a III-V compound semiconductor with a direct band gap of 1.43 eV and high electron mobility, widely used in high-frequency microwave and millimetre-wave integrated circuits, laser diodes, and infrared LEDs.</skos:definition>
        <skos:definition xml:lang="zh">砷化镓（GaAs）是一种III-V族化合物半导体，具有1.43 eV的直接带隙和高电子迁移率，广泛用于高频微波和毫米波集成电路、激光二极管和红外LED。</skos:definition>
        <skos:example xml:lang="en">GaAs monolithic microwave integrated circuits (MMICs) in mobile phone front-end modules.</skos:example>
        <skos:example xml:lang="zh">手机前端模块中的GaAs单片微波集成电路（MMIC）。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/wdzyzcl/co/WDZ_0100106 -->

    <owl:Class rdf:about="https://w3id.org/wdzyzcl/co/WDZ_0100106">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0010101"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000086"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/wdzyzcl/co/WDZ_0210000"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">gallium oxide</rdfs:label>
        <rdfs:label xml:lang="zh">氧化镓</rdfs:label>
        <skos:altLabel xml:lang="en">Ga2O3</skos:altLabel>
        <skos:altLabel xml:lang="zh">Ga₂O₃</skos:altLabel>
        <skos:definition xml:lang="en">Gallium oxide (Ga₂O₃) is an emerging ultrawide bandgap semiconductor with a band gap of approximately 4.8 eV and an exceptionally high breakdown electric field. It is a promising material for next-generation high-voltage power devices and deep-ultraviolet photodetectors.</skos:definition>
        <skos:definition xml:lang="zh">氧化镓（Ga₂O₃）是一种新兴的超宽禁带半导体，带隙约4.8 eV，具有极高的击穿电场。它是下一代高压功率器件和深紫外光电探测器的有前景材料。</skos:definition>
        <skos:example xml:lang="en">Ga₂O₃ Schottky barrier diodes for high-voltage power rectification.</skos:example>
        <skos:example xml:lang="zh">用于高压功率整流的Ga₂O₃肖特基势垒二极管。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/wdzyzcl/co/WDZ_0100107 -->

    <owl:Class rdf:about="https://w3id.org/wdzyzcl/co/WDZ_0100107">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0010101"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000086"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/wdzyzcl/co/WDZ_0210000"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">zinc oxide</rdfs:label>
        <rdfs:label xml:lang="zh">氧化锌</rdfs:label>
        <skos:altLabel xml:lang="en">ZnO</skos:altLabel>
        <skos:altLabel xml:lang="zh">ZnO</skos:altLabel>
        <skos:definition xml:lang="en">Zinc oxide (ZnO) is a II-VI wide bandgap semiconductor with a direct band gap of 3.37 eV and a high exciton binding energy, featuring piezoelectric, pyroelectric, and transparent conductive properties, used in ultraviolet light emitters, transparent electrodes, and gas sensors.</skos:definition>
        <skos:definition xml:lang="zh">氧化锌（ZnO）是一种II-VI族宽禁带半导体，具有3.37 eV的直接带隙和高激子结合能，具备压电、热释电和透明导电特性，用于紫外光发射器、透明电极和气体传感器。</skos:definition>
        <skos:example xml:lang="en">ZnO nanowire-based UV photodetectors and piezoelectric nanogenerators.</skos:example>
        <skos:example xml:lang="zh">基于ZnO纳米线的紫外光电探测器和压电纳米发电机。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/wdzyzcl/co/WDZ_0100108 -->

    <owl:Class rdf:about="https://w3id.org/wdzyzcl/co/WDZ_0100108">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0010100"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000086"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/wdzyzcl/co/WDZ_0210000"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">diamond</rdfs:label>
        <rdfs:label xml:lang="zh">金刚石</rdfs:label>
        <skos:altLabel xml:lang="en">diamond semiconductor</skos:altLabel>
        <skos:altLabel xml:lang="zh">金刚石半导体</skos:altLabel>
        <skos:definition xml:lang="en">Diamond is an ultrawide bandgap elemental semiconductor with a band gap of 5.5 eV, the highest thermal conductivity of any material, and superior carrier mobility. Diamond-based devices target extreme-environment electronics, high-power high-frequency applications, and quantum sensing.</skos:definition>
        <skos:definition xml:lang="zh">金刚石是一种超宽禁带元素半导体，具有5.5 eV的带隙、所有材料中最高的热导率以及优异的载流子迁移率。金刚石基器件面向极端环境电子学、高功率高频应用和量子传感。</skos:definition>
        <skos:example xml:lang="en">Diamond Schottky diodes for high-temperature power electronics.</skos:example>
        <skos:example xml:lang="zh">用于高温功率电子学的金刚石肖特基二极管。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/wdzyzcl/co/WDZ_0100109 -->

    <owl:Class rdf:about="https://w3id.org/wdzyzcl/co/WDZ_0100109">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0010101"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000086"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/wdzyzcl/co/WDZ_0210000"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">aluminium gallium nitride</rdfs:label>
        <rdfs:label xml:lang="zh">铝镓氮</rdfs:label>
        <skos:altLabel xml:lang="en">AlGaN</skos:altLabel>
        <skos:altLabel xml:lang="zh">AlGaN</skos:altLabel>
        <skos:definition xml:lang="en">Aluminium gallium nitride (AlGaN) is a ternary III-V compound semiconductor alloy of AlN and GaN with a tuneable direct band gap between 3.4 eV (GaN) and 6.2 eV (AlN). AlGaN is the barrier layer material in AlGaN/GaN HEMTs and the active region material for deep-ultraviolet LEDs.</skos:definition>
        <skos:definition xml:lang="zh">铝镓氮（AlGaN）是AlN和GaN的三元III-V族化合物半导体合金，具有可在3.4 eV（GaN）至6.2 eV（AlN）之间调控的直接带隙。AlGaN是AlGaN/GaN HEMT中的势垒层材料和深紫外LED的有源区材料。</skos:definition>
        <skos:example xml:lang="zh">5G射频功率放大器中AlGaN/GaN HEMT的AlGaN势垒层。</skos:example>
        <skos:example xml:lang="en">AlGaN barrier layers in AlGaN/GaN HEMTs for 5G RF power amplifiers.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/wdzyzcl/co/WDZ_0100110 -->

    <owl:Class rdf:about="https://w3id.org/wdzyzcl/co/WDZ_0100110">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0010101"/>
        <rdfs:label xml:lang="en">indium gallium nitride</rdfs:label>
        <rdfs:label xml:lang="zh">铟镓氮</rdfs:label>
        <skos:altLabel xml:lang="en">InGaN</skos:altLabel>
        <skos:altLabel xml:lang="zh">InGaN</skos:altLabel>
        <skos:definition xml:lang="en">Indium gallium nitride (InGaN) is a ternary III-V compound semiconductor alloy of InN and GaN with a tuneable direct band gap spanning the entire visible spectrum. InGaN is the active quantum well material in blue and green LEDs, enabling high-efficiency solid-state white lighting.</skos:definition>
        <skos:definition xml:lang="zh">铟镓氮（InGaN）是InN和GaN的三元III-V族化合物半导体合金，具有覆盖整个可见光谱的可调直接带隙。InGaN是蓝光和绿光LED中的有源量子阱材料，实现高效固态白光照明。</skos:definition>
        <skos:example xml:lang="en">InGaN/GaN multiple quantum wells as the active region in blue LEDs for white lighting.</skos:example>
        <skos:example xml:lang="zh">InGaN/GaN多量子阱作为白光照明用蓝光LED的有源区。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/wdzyzcl/co/WDZ_0100200 -->

    <owl:Class rdf:about="https://w3id.org/wdzyzcl/co/WDZ_0100200">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000002"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000086"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000604"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000086"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/wdzyzcl/co/WDZ_0200001"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002353"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/wdzyzcl/co/WDZ_0300003"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">silicon dioxide</rdfs:label>
        <rdfs:label xml:lang="zh">二氧化硅</rdfs:label>
        <skos:altLabel xml:lang="en">SiO2</skos:altLabel>
        <skos:altLabel xml:lang="en">silica</skos:altLabel>
        <skos:definition xml:lang="en">Silicon dioxide (SiO2) is an amorphous dielectric material formed by thermal oxidation of silicon. It serves as the gate dielectric in MOSFET devices, an isolation layer between interconnects, and a passivation layer protecting the underlying semiconductor from environmental contamination.</skos:definition>
        <skos:definition xml:lang="zh">二氧化硅（SiO2）是一种通过硅的热氧化形成的非晶介电材料。它用作MOSFET器件中的栅介质、互连线之间的隔离层，以及保护下层半导体免受环境污染的钝化层。</skos:definition>
        <skos:example xml:lang="en">SiO2 gate dielectric thermally grown on a silicon channel in a MOSFET transistor.</skos:example>
        <skos:example xml:lang="zh">在MOSFET晶体管中通过热氧化在硅沟道上生长的SiO2栅介质。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/wdzyzcl/co/WDZ_0200000 -->

    <owl:Class rdf:about="https://w3id.org/wdzyzcl/co/WDZ_0200000">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000591"/>
        <rdfs:label xml:lang="en">wurtzite crystal structure</rdfs:label>
        <rdfs:label xml:lang="zh">纤锌矿晶体结构</rdfs:label>
        <skos:definition xml:lang="en">A hexagonal crystal structure commonly found in III-V wide bandgap semiconductors such as GaN and AlN, characterised by tetrahedrally coordinated atoms arranged in alternating hexagonal close-packed layers.</skos:definition>
        <skos:definition xml:lang="zh">六方晶体结构，常见于GaN、AlN等III-V族宽禁带半导体，由四面体配位的原子交替排列成六方密堆积层。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/wdzyzcl/co/WDZ_0200001 -->

    <owl:Class rdf:about="https://w3id.org/wdzyzcl/co/WDZ_0200001">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000591"/>
        <rdfs:label xml:lang="en">amorphous structure</rdfs:label>
        <rdfs:label xml:lang="zh">非晶结构</rdfs:label>
        <skos:definition xml:lang="en">A solid-state structure lacking long-range atomic periodicity, characteristic of oxide semiconductor thin films such as IGZO deposited at low temperatures.</skos:definition>
        <skos:definition xml:lang="zh">缺少长程原子周期性的固态结构，是低温沉积的IGZO等氧化物半导体薄膜的典型特征。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/wdzyzcl/co/WDZ_0200002 -->

    <owl:Class rdf:about="https://w3id.org/wdzyzcl/co/WDZ_0200002">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000591"/>
        <rdfs:label xml:lang="en">diamond cubic crystal structure</rdfs:label>
        <rdfs:label xml:lang="zh">金刚石立方晶体结构</rdfs:label>
        <skos:definition xml:lang="en">A cubic crystal structure consisting of two interpenetrating face-centred cubic lattices, characteristic of silicon and germanium, in which each atom is tetrahedrally coordinated with four nearest neighbours.</skos:definition>
        <skos:definition xml:lang="zh">由两个相互穿插的面心立方晶格组成的立方晶体结构，是硅和锗的典型结构，每个原子与四个最近邻原子形成四面体配位。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/wdzyzcl/co/WDZ_0200003 -->

    <owl:Class rdf:about="https://w3id.org/wdzyzcl/co/WDZ_0200003">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000591"/>
        <rdfs:label xml:lang="en">zinc blende crystal structure</rdfs:label>
        <rdfs:label xml:lang="zh">闪锌矿晶体结构</rdfs:label>
        <skos:altLabel xml:lang="en">sphalerite structure</skos:altLabel>
        <skos:altLabel xml:lang="zh">闪锌矿结构</skos:altLabel>
        <skos:definition xml:lang="en">A cubic crystal structure analogous to diamond cubic but with two different atom types occupying the two interpenetrating face-centred cubic sublattices, characteristic of III-V semiconductors such as GaAs, InP, and cubic GaN.</skos:definition>
        <skos:definition xml:lang="zh">一种立方晶体结构，类似于金刚石立方但由两种不同原子占据两个相互穿插的面心立方亚晶格，是GaAs、InP、立方GaN等III-V族半导体的典型结构。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/wdzyzcl/co/WDZ_0200004 -->

    <owl:Class rdf:about="https://w3id.org/wdzyzcl/co/WDZ_0200004">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000591"/>
        <rdfs:label xml:lang="en">rocksalt crystal structure</rdfs:label>
        <rdfs:label xml:lang="zh">岩盐晶体结构</rdfs:label>
        <skos:definition xml:lang="en">A cubic crystal structure in which each ion is octahedrally coordinated by six counter-ions, characteristic of certain oxide semiconductors and wide bandgap materials.</skos:definition>
        <skos:definition xml:lang="zh">一种立方晶体结构，每个离子由六个反离子八面体配位，是某些氧化物半导体和宽禁带材料的典型结构。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/wdzyzcl/co/WDZ_0210000 -->

    <owl:Class rdf:about="https://w3id.org/wdzyzcl/co/WDZ_0210000">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0090002"/>
        <rdfs:label xml:lang="en">wide band gap</rdfs:label>
        <rdfs:label xml:lang="zh">宽禁带</rdfs:label>
        <skos:definition xml:lang="en">A band gap exceeding approximately 3.0 eV, characteristic of semiconductors such as GaN (3.4 eV) and AlN (6.2 eV), enabling high breakdown voltage and high-temperature operation.</skos:definition>
        <skos:definition xml:lang="zh">超过约3.0 eV的带隙，是GaN（3.4 eV）和AlN（6.2 eV）等半导体的特征，使其具备高击穿电压和高温工作能力。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/wdzyzcl/co/WDZ_0210001 -->

    <owl:Class rdf:about="https://w3id.org/wdzyzcl/co/WDZ_0210001">
        <rdfs:subClassOf rdf:resource="https://w3id.org/wdzyzcl/co/WDZ_0210000"/>
        <rdfs:label xml:lang="en">ultra-wide band gap</rdfs:label>
        <rdfs:label xml:lang="zh">超宽禁带</rdfs:label>
        <skos:altLabel xml:lang="en">UWBG</skos:altLabel>
        <skos:altLabel xml:lang="zh">UWBG</skos:altLabel>
        <skos:definition xml:lang="en">An ultra-wide band gap exceeds approximately 4.0 eV, characteristic of emerging semiconductors such as Ga₂O₃ (4.8 eV) and diamond (5.5 eV), enabling extreme breakdown voltage and deep-ultraviolet optoelectronic applications.</skos:definition>
        <skos:definition xml:lang="zh">超宽禁带超过约4.0 eV，是Ga₂O₃（4.8 eV）和金刚石（5.5 eV）等新兴半导体的特征，可实现极高击穿电压和深紫外光电子应用。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/wdzyzcl/co/WDZ_0210002 -->

    <owl:Class rdf:about="https://w3id.org/wdzyzcl/co/WDZ_0210002">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0090002"/>
        <rdfs:label xml:lang="en">direct band gap</rdfs:label>
        <rdfs:label xml:lang="zh">直接带隙</rdfs:label>
        <skos:definition xml:lang="en">A direct band gap is a band gap in which the maximum of the valence band and the minimum of the conduction band occur at the same crystal momentum, enabling efficient photon absorption and emission without phonon participation. Direct band gap semiconductors such as GaN, GaAs, and InGaN are essential for light-emitting devices.</skos:definition>
        <skos:definition xml:lang="zh">直接带隙是指价带最大值和导带最小值发生在相同晶体动量处的带隙，能够在不参与声子的情况下实现高效的光子吸收和发射。GaN、GaAs和InGaN等直接带隙半导体对发光器件至关重要。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/wdzyzcl/co/WDZ_0210003 -->

    <owl:Class rdf:about="https://w3id.org/wdzyzcl/co/WDZ_0210003">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0090002"/>
        <rdfs:label xml:lang="en">indirect band gap</rdfs:label>
        <rdfs:label xml:lang="zh">间接带隙</rdfs:label>
        <skos:definition xml:lang="en">An indirect band gap is a band gap in which the maximum of the valence band and the minimum of the conduction band occur at different crystal momenta, requiring phonon participation for electronic transitions. Silicon, with its indirect band gap of 1.12 eV, is the dominant material for logic and power electronics but is inefficient as a light emitter.</skos:definition>
        <skos:definition xml:lang="zh">间接带隙是指价带最大值和导带最小值发生在不同晶体动量处的带隙，电子跃迁需要声子参与。硅具有1.12 eV的间接带隙，是逻辑和功率电子学的主导材料，但作为光发射器效率较低。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/wdzyzcl/co/WDZ_0220000 -->

    <owl:Class rdf:about="https://w3id.org/wdzyzcl/co/WDZ_0220000">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000621"/>
        <rdfs:label xml:lang="en">carrier mobility</rdfs:label>
        <rdfs:label xml:lang="zh">载流子迁移率</rdfs:label>
        <skos:definition xml:lang="en">Carrier mobility is the disposition of a semiconductor to allow charge carriers (electrons or holes) to move through its lattice under an applied electric field, expressed as drift velocity per unit electric field.</skos:definition>
        <skos:definition xml:lang="zh">载流子迁移率是半导体在外加电场下允许载流子（电子或空穴）在晶格中移动的特性，表示为每单位电场的漂移速度。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/wdzyzcl/co/WDZ_0220001 -->

    <owl:Class rdf:about="https://w3id.org/wdzyzcl/co/WDZ_0220001">
        <rdfs:subClassOf rdf:resource="https://w3id.org/wdzyzcl/co/WDZ_0220000"/>
        <rdfs:label xml:lang="en">field-effect mobility</rdfs:label>
        <rdfs:label xml:lang="zh">场效应迁移率</rdfs:label>
        <skos:definition xml:lang="en">Field-effect mobility is the carrier mobility extracted from the transfer characteristics of a field-effect transistor, characterising the effective carrier transport in the channel region under gate bias.</skos:definition>
        <skos:definition xml:lang="zh">场效应迁移率是从场效应晶体管转移特性中提取的载流子迁移率，表征栅偏压下沟道区域中有效载流子输运。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/wdzyzcl/co/WDZ_0220002 -->

    <owl:Class rdf:about="https://w3id.org/wdzyzcl/co/WDZ_0220002">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000621"/>
        <rdfs:label xml:lang="en">breakdown voltage</rdfs:label>
        <rdfs:label xml:lang="zh">击穿电压</rdfs:label>
        <skos:altLabel xml:lang="en">breakdown electric field</skos:altLabel>
        <skos:altLabel xml:lang="zh">击穿电场</skos:altLabel>
        <skos:definition xml:lang="en">Breakdown voltage is the electrical property of a semiconductor material or device representing the critical voltage at which avalanche or Zener breakdown occurs, resulting in a rapid increase in current. Wide bandgap semiconductors exhibit inherently higher breakdown voltages, making them superior for high-voltage power devices.</skos:definition>
        <skos:definition xml:lang="zh">击穿电压是半导体材料或器件的电学性质，表示发生雪崩击穿或齐纳击穿导致电流急剧增加时的临界电压。宽禁带半导体固有地表现出更高的击穿电压，使其在高压功率器件中具有优势。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/wdzyzcl/co/WDZ_0220003 -->

    <owl:Class rdf:about="https://w3id.org/wdzyzcl/co/WDZ_0220003">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000621"/>
        <rdfs:label xml:lang="en">saturation electron velocity</rdfs:label>
        <rdfs:label xml:lang="zh">饱和电子速度</rdfs:label>
        <skos:definition xml:lang="en">Saturation electron velocity is the electrical property of a semiconductor representing the maximum drift velocity electrons can attain under a high electric field before velocity saturation occurs due to increased optical phonon scattering. High saturation velocity is critical for high-frequency device performance.</skos:definition>
        <skos:definition xml:lang="zh">饱和电子速度是半导体的电学性质，表示在高电场下电子在速度饱和发生（由于光学声子散射增加）之前能达到的最大漂移速度。高饱和电子速度对高频器件性能至关重要。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/wdzyzcl/co/WDZ_0230000 -->

    <owl:Class rdf:about="https://w3id.org/wdzyzcl/co/WDZ_0230000">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000877"/>
        <rdfs:label xml:lang="en">optical transparency</rdfs:label>
        <rdfs:label xml:lang="zh">光学透明度</rdfs:label>
        <skos:definition xml:lang="en">Optical transparency is the property of a material to transmit visible light without significant absorption or scattering, characteristic of wide bandgap oxide semiconductors such as IGZO.</skos:definition>
        <skos:definition xml:lang="zh">光学透明度是材料在可见光范围内无明显吸收或散射而透光的特性，是IGZO等宽禁带氧化物半导体的典型特征。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/wdzyzcl/co/WDZ_0240000 -->

    <owl:Class rdf:about="https://w3id.org/wdzyzcl/co/WDZ_0240000">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000005"/>
        <rdfs:label xml:lang="en">piezoelectric property</rdfs:label>
        <rdfs:label xml:lang="zh">压电特性</rdfs:label>
        <skos:altLabel xml:lang="en">piezoelectricity</skos:altLabel>
        <skos:altLabel xml:lang="zh">压电性</skos:altLabel>
        <skos:definition xml:lang="en">Piezoelectric property is the disposition of a material to generate an electric charge in response to applied mechanical stress (direct piezoelectric effect) and conversely to deform under an applied electric field (converse piezoelectric effect). In AlGaN/GaN heterostructures, piezoelectric polarisation at the heterointerface contributes to 2DEG formation.</skos:definition>
        <skos:definition xml:lang="zh">压电特性是材料在施加机械应力时产生电荷（正压电效应）以及在施加电场时发生形变（逆压电效应）的性质。在AlGaN/GaN异质结构中，异质界面处的压电极化贡献了2DEG的形成。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/wdzyzcl/co/WDZ_0300000 -->

    <owl:Class rdf:about="https://w3id.org/wdzyzcl/co/WDZ_0300000">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000569"/>
        <rdfs:label xml:lang="en">epitaxial growth process</rdfs:label>
        <rdfs:label xml:lang="zh">外延生长工艺</rdfs:label>
        <skos:definition xml:lang="en">Epitaxial growth is a coating process from the gaseous or vapour state in which a crystalline film is deposited on a crystalline substrate with a defined crystallographic orientation relationship between the film and the substrate.</skos:definition>
        <skos:definition xml:lang="zh">外延生长是一种从气态或蒸气状态进行的涂覆工艺，在晶体衬底上沉积晶体薄膜，薄膜与衬底之间具有确定的晶体学取向关系。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/wdzyzcl/co/WDZ_0300001 -->

    <owl:Class rdf:about="https://w3id.org/wdzyzcl/co/WDZ_0300001">
        <rdfs:subClassOf rdf:resource="https://w3id.org/wdzyzcl/co/WDZ_0300000"/>
        <rdfs:label xml:lang="en">metal-organic chemical vapour deposition</rdfs:label>
        <rdfs:label xml:lang="zh">金属有机化学气相沉积</rdfs:label>
        <skos:altLabel xml:lang="en">MOCVD</skos:altLabel>
        <skos:altLabel xml:lang="zh">MOCVD</skos:altLabel>
        <skos:definition xml:lang="en">MOCVD is an epitaxial growth process using metal-organic precursors and hydride gases to deposit compound semiconductor thin films, widely used for GaN, AlN, and other III-V semiconductor layers.</skos:definition>
        <skos:definition xml:lang="zh">MOCVD是一种使用金属有机前驱体和氢化物气体沉积化合物半导体薄膜的外延生长工艺，广泛用于GaN、AlN和其他III-V族半导体层。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/wdzyzcl/co/WDZ_0300002 -->

    <owl:Class rdf:about="https://w3id.org/wdzyzcl/co/WDZ_0300002">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000571"/>
        <rdfs:label xml:lang="en">sputter deposition process</rdfs:label>
        <rdfs:label xml:lang="zh">溅射沉积工艺</rdfs:label>
        <skos:definition xml:lang="en">Sputter deposition is a coating process from the ionized state in which target material is ejected by ion bombardment and deposited onto a substrate, commonly used for oxide semiconductor thin films such as IGZO.</skos:definition>
        <skos:definition xml:lang="zh">溅射沉积是一种从离子态进行的涂覆工艺，靶材通过离子轰击溅射出原子并沉积到衬底上，常用于IGZO等氧化物半导体薄膜。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/wdzyzcl/co/WDZ_0300003 -->

    <owl:Class rdf:about="https://w3id.org/wdzyzcl/co/WDZ_0300003">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000833"/>
        <rdfs:label xml:lang="en">thermal oxidation process</rdfs:label>
        <rdfs:label xml:lang="zh">热氧化工艺</rdfs:label>
        <skos:definition xml:lang="en">Thermal oxidation is a manufacturing process in which a silicon wafer is exposed to an oxidizing atmosphere at elevated temperature to grow a thin, high-quality silicon dioxide layer on its surface, used as a gate dielectric or passivation layer in semiconductor devices.</skos:definition>
        <skos:definition xml:lang="zh">热氧化是一种制造工艺，将硅晶圆在高温下暴露于氧化气氛中，在其表面生长一层高质量二氧化硅薄膜，用作半导体器件中的栅介质或钝化层。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/wdzyzcl/co/WDZ_0300004 -->

    <owl:Class rdf:about="https://w3id.org/wdzyzcl/co/WDZ_0300004">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000569"/>
        <rdfs:label xml:lang="en">atomic layer deposition</rdfs:label>
        <rdfs:label xml:lang="zh">原子层沉积</rdfs:label>
        <skos:altLabel xml:lang="en">ALD</skos:altLabel>
        <skos:altLabel xml:lang="zh">ALD</skos:altLabel>
        <skos:definition xml:lang="en">Atomic layer deposition (ALD) is a coating process from the gaseous state in which alternating pulses of precursor gases react with a substrate surface in a self-limiting manner, enabling the growth of ultra-thin films with sub-nanometre thickness control and exceptional conformality. ALD is critical for high-k gate dielectrics in advanced CMOS nodes.</skos:definition>
        <skos:definition xml:lang="zh">原子层沉积（ALD）是一种从气态进行的涂覆工艺，交替脉冲的前驱体气体以自限制方式与衬底表面反应，能够以亚纳米厚度精度和出色的保形性生长超薄膜。ALD对先进CMOS节点中的高k栅介质至关重要。</skos:definition>
        <skos:example xml:lang="en">ALD HfO₂ as a high-k gate dielectric in advanced CMOS transistors.</skos:example>
        <skos:example xml:lang="zh">ALD HfO₂作为先进CMOS晶体管中的高k栅介质。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/wdzyzcl/co/WDZ_0300005 -->

    <owl:Class rdf:about="https://w3id.org/wdzyzcl/co/WDZ_0300005">
        <rdfs:subClassOf rdf:resource="https://w3id.org/wdzyzcl/co/WDZ_0300000"/>
        <rdfs:label xml:lang="en">molecular beam epitaxy</rdfs:label>
        <rdfs:label xml:lang="zh">分子束外延</rdfs:label>
        <skos:altLabel xml:lang="en">MBE</skos:altLabel>
        <skos:altLabel xml:lang="zh">MBE</skos:altLabel>
        <skos:definition xml:lang="en">Molecular beam epitaxy (MBE) is an epitaxial growth process in which thermal beams of atoms or molecules react with a heated single-crystal substrate under ultra-high vacuum, enabling atomically precise growth of semiconductor heterostructures with abrupt interfaces.</skos:definition>
        <skos:definition xml:lang="zh">分子束外延（MBE）是一种外延生长工艺，原子或分子的热束在超高真空下与加热的单晶衬底反应，能够以原子级精度生长具有突变界面的半导体异质结构。</skos:definition>
        <skos:example xml:lang="en">MBE growth of AlGaN/GaN heterostructures for HEMT devices.</skos:example>
        <skos:example xml:lang="zh">MBE生长AlGaN/GaN异质结构用于HEMT器件。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/wdzyzcl/co/WDZ_0300006 -->

    <owl:Class rdf:about="https://w3id.org/wdzyzcl/co/WDZ_0300006">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000833"/>
        <rdfs:label xml:lang="en">dry etching process</rdfs:label>
        <rdfs:label xml:lang="zh">干法刻蚀工艺</rdfs:label>
        <skos:altLabel xml:lang="en">RIE</skos:altLabel>
        <skos:altLabel xml:lang="zh">RIE</skos:altLabel>
        <skos:altLabel xml:lang="en">reactive ion etching</skos:altLabel>
        <skos:altLabel xml:lang="zh">反应离子刻蚀</skos:altLabel>
        <skos:definition xml:lang="en">Dry etching is a manufacturing process that removes material from a substrate using reactive plasma species, enabling anisotropic etching with high aspect ratios essential for semiconductor device patterning. Reactive ion etching (RIE) is the most common dry etching technique in microelectronics fabrication.</skos:definition>
        <skos:definition xml:lang="zh">干法刻蚀是一种使用反应等离子体物质从衬底去除材料的制造工艺，能够实现各向异性刻蚀和高深宽比，对半导体器件图形化至关重要。反应离子刻蚀（RIE）是微电子制造中最常见的干法刻蚀技术。</skos:definition>
        <skos:example xml:lang="en">RIE etching of GaN to define the mesa isolation in HEMT fabrication.</skos:example>
        <skos:example xml:lang="zh">RIE刻蚀GaN以定义HEMT制造中的台面隔离。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/wdzyzcl/co/WDZ_0300007 -->

    <owl:Class rdf:about="https://w3id.org/wdzyzcl/co/WDZ_0300007">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000833"/>
        <rdfs:label xml:lang="en">rapid thermal annealing</rdfs:label>
        <rdfs:label xml:lang="zh">快速热退火</rdfs:label>
        <skos:altLabel xml:lang="en">RTA</skos:altLabel>
        <skos:altLabel xml:lang="zh">RTA</skos:altLabel>
        <skos:definition xml:lang="en">Rapid thermal annealing (RTA) is a manufacturing process that heats a semiconductor wafer to high temperature for a short duration to activate dopants, repair crystal damage, or form ohmic contacts, while minimising thermal budget and dopant diffusion.</skos:definition>
        <skos:definition xml:lang="zh">快速热退火（RTA）是一种将半导体晶圆在短时间内加热到高温的制造工艺，用于激活掺杂剂、修复晶体损伤或形成欧姆接触，同时最小化热预算和掺杂剂扩散。</skos:definition>
        <skos:example xml:lang="en">RTA activation of Si-implanted dopants in GaN for source/drain contact formation.</skos:example>
        <skos:example xml:lang="zh">RTA激活GaN中硅离子注入掺杂剂以形成源漏接触。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/wdzyzcl/co/WDZ_0300008 -->

    <owl:Class rdf:about="https://w3id.org/wdzyzcl/co/WDZ_0300008">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000833"/>
        <rdfs:label xml:lang="en">ion implantation</rdfs:label>
        <rdfs:label xml:lang="zh">离子注入</rdfs:label>
        <skos:definition xml:lang="en">Ion implantation is a manufacturing process in which dopant ions are accelerated and embedded into a semiconductor substrate to precisely control its electrical properties, enabling selective area doping for transistor source/drain and channel engineering.</skos:definition>
        <skos:definition xml:lang="zh">离子注入是一种将掺杂剂离子加速并嵌入半导体衬底中以精确控制其电学性质的制造工艺，实现晶体管源漏和沟道工程的选区掺杂。</skos:definition>
        <skos:example xml:lang="en">Silicon ion implantation into GaN for n-type doping in HEMT ohmic contact regions.</skos:example>
        <skos:example xml:lang="zh">硅离子注入GaN以实现HEMT欧姆接触区域的n型掺杂。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/wdzyzcl/co/WDZ_0300009 -->

    <owl:Class rdf:about="https://w3id.org/wdzyzcl/co/WDZ_0300009">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000833"/>
        <rdfs:label xml:lang="en">photolithography</rdfs:label>
        <rdfs:label xml:lang="zh">光刻</rdfs:label>
        <skos:definition xml:lang="en">Photolithography is a manufacturing process that transfers a geometric pattern from a photomask to a photosensitive resist layer on a semiconductor wafer, defining the lateral dimensions of device features. It is the enabling patterning technology for integrated circuit fabrication.</skos:definition>
        <skos:definition xml:lang="zh">光刻是一种将几何图案从光掩模转移到半导体晶圆上光敏抗蚀剂层的制造工艺，定义器件特征的横向尺寸。它是集成电路制造的关键图形化技术。</skos:definition>
        <skos:example xml:lang="en">UV photolithography defining TFT channel dimensions in IGZO display backplane fabrication.</skos:example>
        <skos:example xml:lang="zh">紫外光刻在IGZO显示屏背板制造中定义TFT沟道尺寸。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/wdzyzcl/co/WDZ_0400000 -->

    <owl:Class rdf:about="https://w3id.org/wdzyzcl/co/WDZ_0400000">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
        <rdfs:label xml:lang="en">semiconductor device</rdfs:label>
        <rdfs:label xml:lang="zh">半导体器件</rdfs:label>
        <skos:definition xml:lang="en">A semiconductor device is an object that performs electronic functions based on the controlled electrical conduction through a semiconductor material, including transistors, diodes, light emitters, and sensors. Semiconductor devices are the fundamental building blocks of modern electronics.</skos:definition>
        <skos:definition xml:lang="zh">半导体器件是一种基于半导体材料中受控导电来实现电子功能的对象，包括晶体管、二极管、光发射器和传感器。半导体器件是现代电子产品的基本构建单元。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/wdzyzcl/co/WDZ_0400001 -->

    <owl:Class rdf:about="https://w3id.org/wdzyzcl/co/WDZ_0400001">
        <rdfs:subClassOf rdf:resource="https://w3id.org/wdzyzcl/co/WDZ_0400000"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/wdzyzcl/co/WDZ_0100102"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000086"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/wdzyzcl/co/WDZ_0220001"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002353"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/wdzyzcl/co/WDZ_0300002"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">thin-film transistor</rdfs:label>
        <rdfs:label xml:lang="zh">薄膜晶体管</rdfs:label>
        <skos:altLabel xml:lang="en">TFT</skos:altLabel>
        <skos:altLabel xml:lang="zh">TFT</skos:altLabel>
        <skos:definition xml:lang="en">A thin-film transistor (TFT) is a field-effect transistor fabricated by depositing thin films of a semiconductor active layer, dielectric layer, and metallic contacts onto a supporting substrate. IGZO-based TFTs are the dominant backplane technology for high-resolution OLED and LCD flat-panel displays.</skos:definition>
        <skos:definition xml:lang="zh">薄膜晶体管（TFT）是一种通过将半导体有源层、介电层和金属接触薄膜沉积到支撑衬底上制成的场效应晶体管。IGZO基TFT是高分辨率OLED和LCD平板显示器的主流背板技术。</skos:definition>
        <skos:example xml:lang="en">IGZO TFT backplanes in high-resolution OLED smartphone displays.</skos:example>
        <skos:example xml:lang="zh">高分辨率OLED智能手机显示屏中的IGZO TFT背板。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/wdzyzcl/co/WDZ_0400002 -->

    <owl:Class rdf:about="https://w3id.org/wdzyzcl/co/WDZ_0400002">
        <rdfs:subClassOf rdf:resource="https://w3id.org/wdzyzcl/co/WDZ_0400000"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/wdzyzcl/co/WDZ_0100100"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">light-emitting diode</rdfs:label>
        <rdfs:label xml:lang="zh">发光二极管</rdfs:label>
        <skos:altLabel xml:lang="en">LED</skos:altLabel>
        <skos:altLabel xml:lang="zh">LED</skos:altLabel>
        <skos:definition xml:lang="en">A light-emitting diode (LED) is a semiconductor device that emits light when an electric current passes through it, based on electroluminescence in a direct band gap semiconductor. GaN-based LEDs are the foundation of solid-state lighting and blue/UV optoelectronics.</skos:definition>
        <skos:definition xml:lang="zh">发光二极管（LED）是一种半导体器件，基于直接带隙半导体中的电致发光效应，在电流通过时发出光。GaN基LED是固态照明和蓝光/紫外光电子器件的基础。</skos:definition>
        <skos:example xml:lang="en">GaN blue LEDs used in white solid-state lighting.</skos:example>
        <skos:example xml:lang="zh">用于白色固态照明的GaN蓝光LED。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/wdzyzcl/co/WDZ_0400003 -->

    <owl:Class rdf:about="https://w3id.org/wdzyzcl/co/WDZ_0400003">
        <rdfs:subClassOf rdf:resource="https://w3id.org/wdzyzcl/co/WDZ_0400000"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/wdzyzcl/co/WDZ_0100103"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000086"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000604"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002353"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/wdzyzcl/co/WDZ_0300003"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">metal-oxide-semiconductor field-effect transistor</rdfs:label>
        <rdfs:label xml:lang="zh">金属氧化物半导体场效应晶体管</rdfs:label>
        <skos:altLabel xml:lang="en">MOSFET</skos:altLabel>
        <skos:altLabel xml:lang="zh">MOSFET</skos:altLabel>
        <skos:definition xml:lang="en">A metal-oxide-semiconductor field-effect transistor (MOSFET) is a field-effect transistor in which a silicon channel is separated from a gate electrode by a thermally grown silicon dioxide dielectric layer. MOSFETs are the fundamental building blocks of modern CMOS integrated circuits.</skos:definition>
        <skos:definition xml:lang="zh">金属氧化物半导体场效应晶体管（MOSFET）是一种场效应晶体管，硅沟道通过热生长的二氧化硅介电层与栅电极隔离。MOSFET是现代CMOS集成电路的基本构建单元。</skos:definition>
        <skos:example xml:lang="en">Silicon MOSFETs as the basic switching element in CMOS logic gates.</skos:example>
        <skos:example xml:lang="zh">硅MOSFET作为CMOS逻辑门中的基本开关元件。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/wdzyzcl/co/WDZ_0400004 -->

    <owl:Class rdf:about="https://w3id.org/wdzyzcl/co/WDZ_0400004">
        <rdfs:subClassOf rdf:resource="https://w3id.org/wdzyzcl/co/WDZ_0400000"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000086"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/wdzyzcl/co/WDZ_0210000"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">power semiconductor device</rdfs:label>
        <rdfs:label xml:lang="zh">功率半导体器件</rdfs:label>
        <skos:definition xml:lang="en">A power semiconductor device is a semiconductor device designed to handle high voltages and currents in power conversion and management applications. Wide bandgap materials such as GaN and SiC enable power devices with higher breakdown voltage, higher switching frequency, and higher operating temperature compared to silicon-based devices.</skos:definition>
        <skos:definition xml:lang="zh">功率半导体器件是一种设计用于处理高电压和大电流的半导体器件，应用于功率转换和管理。GaN和SiC等宽禁带材料使功率器件具有比硅基器件更高的击穿电压、更高的开关频率和更高的工作温度。</skos:definition>
        <skos:example xml:lang="en">GaN power HEMTs for electric vehicle on-board chargers.</skos:example>
        <skos:example xml:lang="zh">用于电动汽车车载充电器的GaN功率HEMT。</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/wdzyzcl/co/WDZ_0400005 -->
    <!-- https://w3id.org/wdzyzcl/co/WDZ_0400008 -->

    <owl:Class rdf:about="https://w3id.org/wdzyzcl/co/WDZ_0400008">
        <rdfs:subClassOf rdf:resource="https://w3id.org/wdzyzcl/co/WDZ_0400000"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/wdzyzcl/co/WDZ_0100100"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000086"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/wdzyzcl/co/WDZ_0220000"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000091"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000978"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">high electron mobility transistor</rdfs:label>
        <rdfs:label xml:lang="zh">高电子迁移率晶体管</rdfs:label>
        <skos:altLabel xml:lang="en">HEMT</skos:altLabel>
        <skos:altLabel xml:lang="zh">HEMT</skos:altLabel>
        <skos:definition xml:lang="en">A high electron mobility transistor (HEMT) is a field-effect transistor that incorporates a heterojunction between two materials with different band gaps as the channel, enabling very high electron mobility and fast switching speeds. GaN-based HEMTs are widely used in high-frequency power amplifiers for 5G base stations and radar systems.</skos:definition>
        <skos:definition xml:lang="zh">高电子迁移率晶体管（HEMT）是一种场效应晶体管，利用两种不同带隙材料之间的异质结作为沟道，实现极高的电子迁移率和快速开关速度。GaN基HEMT广泛用于5G基站和雷达系统的高频功率放大器。</skos:definition>
        <skos:example xml:lang="en">GaN HEMT power amplifiers for 5G base stations.</skos:example>
        <skos:example xml:lang="zh">用于5G基站的GaN HEMT功率放大器。</skos:example>
    </owl:Class>



    <!-- https://w3id.org/wdzyzcl/co/WDZ_0400005 -->

    <owl:Class rdf:about="https://w3id.org/wdzyzcl/co/WDZ_0400005">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000002"/>
        <rdfs:label xml:lang="en">heterostructure</rdfs:label>
        <rdfs:label xml:lang="zh">异质结构</rdfs:label>
        <skos:definition xml:lang="en">A heterostructure is an engineered material composed of two or more dissimilar semiconductors with different band gaps, forming an interface that enables unique electronic and optical properties not achievable in homogeneous materials. Heterostructures are the foundation of modern compound semiconductor devices including HEMTs, LEDs, and laser diodes.</skos:definition>
        <skos:definition xml:lang="zh">异质结构是一种工程材料，由两种或多种具有不同带隙的异质半导体组成，形成界面，实现均质材料无法达到的独特电子和光学特性。异质结构是现代化合物半导体器件（包括HEMT、LED和激光二极管）的基础。</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/wdzyzcl/co/WDZ_0400006 -->

    <owl:Class rdf:about="https://w3id.org/wdzyzcl/co/WDZ_0400006">
        <rdfs:subClassOf rdf:resource="https://w3id.org/wdzyzcl/co/WDZ_0400005"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000086"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/wdzyzcl/co/WDZ_0210000"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">aluminium gallium nitride/gallium nitride heterostructure</rdfs:label>
        <rdfs:label xml:lang="zh">铝镓氮/氮化镓异质结构</rdfs:label>
        <skos:altLabel xml:lang="en">AlGaN/GaN heterostructure</skos:altLabel>
        <skos:altLabel xml:lang="zh">AlGaN/GaN异质结构</skos:altLabel>
        <skos:definition xml:lang="zh">AlGaN/GaN异质结构是由外延铝镓氮层沉积在氮化镓层上组成的异质结构。界面处的自发极化和压电极化在不进行故意掺杂的情况下诱导高密度二维电子气（2DEG），使GaN HEMT具有极高的电子迁移率和面载流子密度。</skos:definition>
        <skos:definition xml:lang="en">An AlGaN/GaN heterostructure is a heterostructure consisting of an epitaxial aluminium gallium nitride layer on a gallium nitride layer. Spontaneous and piezoelectric polarisation at the interface induces a high-density two-dimensional electron gas (2DEG) without intentional doping, enabling GaN HEMTs with exceptionally high electron mobility and sheet carrier density.</skos:definition>
        <skos:example xml:lang="en">AlGaN/GaN heterostructure as the active channel in a GaN HEMT for RF power amplification.</skos:example>
        <skos:example xml:lang="zh">AlGaN/GaN异质结构作为GaN HEMT中有源沟道用于射频功率放大。</skos:example>
    </owl:Class>


    <!-- ============================================================ -->
    <!-- Additional Semiconductor Materials (no restrictions)           -->
    <!-- ============================================================ -->

    <!-- WDZ_0100111: indium phosphide -->

    <owl:Class rdf:about="https://w3id.org/wdzyzcl/co/WDZ_0100111">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0010101"/>
        <rdfs:label xml:lang="en">indium phosphide</rdfs:label>
        <rdfs:label xml:lang="zh">磷化铟</rdfs:label>
        <skos:altLabel xml:lang="en">InP</skos:altLabel>
        <skos:altLabel xml:lang="zh">InP</skos:altLabel>
        <skos:definition xml:lang="en">Indium phosphide (InP) is a III-V compound semiconductor with a direct band gap of 1.34 eV and high electron mobility, serving as the substrate and active material for optoelectronic devices such as laser diodes, photodetectors, and high-frequency heterojunction bipolar transistors (HBTs).</skos:definition>
        <skos:definition xml:lang="zh">磷化铟（InP）是一种III-V族化合物半导体，具有1.34 eV的直接带隙和高电子迁移率，用作激光二极管、光电探测器以及高频异质结双极晶体管（HBT）等光电器件中的衬底和有源材料。</skos:definition>
        <skos:example xml:lang="en">InP laser diodes as the light source in fibre-optic telecommunications.</skos:example>
        <skos:example xml:lang="zh">光纤通信中用作光源的InP激光二极管。</skos:example>
    </owl:Class>


    <!-- WDZ_0100112: indium tin oxide -->

    <owl:Class rdf:about="https://w3id.org/wdzyzcl/co/WDZ_0100112">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0010101"/>
        <rdfs:label xml:lang="en">indium tin oxide</rdfs:label>
        <rdfs:label xml:lang="zh">氧化铟锡</rdfs:label>
        <skos:altLabel xml:lang="en">ITO</skos:altLabel>
        <skos:altLabel xml:lang="zh">ITO</skos:altLabel>
        <skos:definition xml:lang="en">Indium tin oxide (ITO) is a transparent conducting oxide, typically composed of In₂O₃ doped with SnO₂. It combines high electrical conductivity with optical transparency in the visible range, making it the standard transparent electrode material for flat-panel displays, touchscreens, OLEDs, and solar cells.</skos:definition>
        <skos:definition xml:lang="zh">氧化铟锡（ITO）是一种透明导电氧化物，通常由SnO₂掺杂的In₂O₃组成。它兼具高电导率和可见光透明度，是平板显示器、触摸屏、OLED和太阳能电池的标准透明电极材料。</skos:definition>
        <skos:example xml:lang="en">ITO thin films as the transparent pixel electrode in OLED displays.</skos:example>
        <skos:example xml:lang="zh">ITO薄膜用作OLED显示屏中的透明像素电极。</skos:example>
    </owl:Class>


    <!-- WDZ_0100113: silicon germanium -->

    <owl:Class rdf:about="https://w3id.org/wdzyzcl/co/WDZ_0100113">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0010101"/>
        <rdfs:label xml:lang="en">silicon germanium</rdfs:label>
        <rdfs:label xml:lang="zh">硅锗</rdfs:label>
        <skos:altLabel xml:lang="en">SiGe</skos:altLabel>
        <skos:altLabel xml:lang="zh">SiGe</skos:altLabel>
        <skos:definition xml:lang="en">Silicon germanium (SiGe) is a group-IV compound semiconductor alloy that is fully compatible with standard silicon CMOS processing. Its tuneable band gap and higher carrier mobility than Si enable heterojunction bipolar transistors (HBTs) for RF and millimetre-wave circuits, as well as strained-Si channels for enhanced MOSFET performance.</skos:definition>
        <skos:definition xml:lang="zh">硅锗（SiGe）是一种IV族化合物半导体合金，完全兼容标准硅CMOS工艺。它的可调带隙和高于硅的载流子迁移率使其能够制造射频和毫米波电路的异质结双极晶体管（HBT），以及用于增强MOSFET性能的应变硅沟道。</skos:definition>
        <skos:example xml:lang="en">SiGe HBTs in 5G millimetre-wave transceiver front-ends.</skos:example>
        <skos:example xml:lang="zh">5G毫米波收发前端中的SiGe HBT。</skos:example>
    </owl:Class>


    <!-- WDZ_0100114: aluminium oxide -->

    <owl:Class rdf:about="https://w3id.org/wdzyzcl/co/WDZ_0100114">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0010101"/>
        <rdfs:label xml:lang="en">aluminium oxide</rdfs:label>
        <rdfs:label xml:lang="zh">氧化铝</rdfs:label>
        <skos:altLabel xml:lang="en">Al₂O₃</skos:altLabel>
        <skos:altLabel xml:lang="zh">Al₂O₃</skos:altLabel>
        <skos:altLabel xml:lang="en">sapphire</skos:altLabel>
        <skos:altLabel xml:lang="zh">蓝宝石</skos:altLabel>
        <skos:definition xml:lang="en">Aluminium oxide (Al₂O₃) is a wide bandgap dielectric material that in its single-crystal form (sapphire) serves as a common substrate for GaN epitaxial growth. It is also widely used as a high-k gate dielectric deposited by ALD and as an insulating or passivation layer in microelectronics.</skos:definition>
        <skos:definition xml:lang="zh">氧化铝（Al₂O₃）是一种宽禁带介电材料，其单晶形式（蓝宝石）是GaN外延生长的常用衬底。它也被广泛用作ALD沉积的高k栅介质以及微电子中的绝缘或钝化层。</skos:definition>
        <skos:example xml:lang="en">Sapphire substrates for GaN blue LED epitaxial growth.</skos:example>
        <skos:example xml:lang="zh">蓝宝石衬底用于GaN蓝光LED外延生长。</skos:example>
    </owl:Class>


    <!-- WDZ_0100115: hafnium oxide -->

    <owl:Class rdf:about="https://w3id.org/wdzyzcl/co/WDZ_0100115">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0010101"/>
        <rdfs:label xml:lang="en">hafnium oxide</rdfs:label>
        <rdfs:label xml:lang="zh">氧化铪</rdfs:label>
        <skos:altLabel xml:lang="en">HfO₂</skos:altLabel>
        <skos:altLabel xml:lang="zh">HfO₂</skos:altLabel>
        <skos:definition xml:lang="en">Hafnium oxide (HfO₂) is a high-k dielectric material widely adopted as the gate dielectric in advanced CMOS technology nodes, replacing SiO₂ to reduce gate leakage while maintaining equivalent oxide thickness. It is typically deposited by ALD and is also used in ferroelectric HfO₂-based memories.</skos:definition>
        <skos:definition xml:lang="zh">氧化铪（HfO₂）是一种高k介电材料，广泛用作先进CMOS工艺节点中的栅介质，取代SiO₂以减少栅极漏电流同时保持等效氧化层厚度。它通常通过ALD沉积，也用于铁电HfO₂存储器。</skos:definition>
        <skos:example xml:lang="en">ALD-deposited HfO₂ gate dielectric in 7 nm CMOS FinFETs.</skos:example>
        <skos:example xml:lang="zh">7nm CMOS FinFET中ALD沉积的HfO₂栅介质。</skos:example>
    </owl:Class>


    <!-- WDZ_0100116: silicon nitride -->

    <owl:Class rdf:about="https://w3id.org/wdzyzcl/co/WDZ_0100116">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0010101"/>
        <rdfs:label xml:lang="en">silicon nitride</rdfs:label>
        <rdfs:label xml:lang="zh">氮化硅</rdfs:label>
        <skos:altLabel xml:lang="en">Si₃N₄</skos:altLabel>
        <skos:altLabel xml:lang="zh">Si₃N₄</skos:altLabel>
        <skos:definition xml:lang="en">Silicon nitride (Si₃N₄) is an insulating dielectric material with high mechanical strength and chemical stability, widely used in microelectronics as a passivation layer, etch stop, diffusion barrier, and the dielectric film in MIS (metal-insulator-semiconductor) structures and MEMS devices.</skos:definition>
        <skos:definition xml:lang="zh">氮化硅（Si₃N₄）是一种具有高机械强度和化学稳定性的绝缘介电材料，在微电子中广泛用作钝化层、刻蚀停止层、扩散阻挡层以及MIS（金属-绝缘体-半导体）结构和MEMS器件中的介电薄膜。</skos:definition>
        <skos:example xml:lang="en">Si₃N₄ passivation layers protecting integrated circuits from moisture and ionic contamination.</skos:example>
        <skos:example xml:lang="zh">Si₃N₄钝化层保护集成电路免受湿气和离子污染。</skos:example>
    </owl:Class>


    <!-- WDZ_0100117: molybdenum disulfide -->

    <owl:Class rdf:about="https://w3id.org/wdzyzcl/co/WDZ_0100117">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0010101"/>
        <rdfs:label xml:lang="en">molybdenum disulfide</rdfs:label>
        <rdfs:label xml:lang="zh">二硫化钼</rdfs:label>
        <skos:altLabel xml:lang="en">MoS₂</skos:altLabel>
        <skos:altLabel xml:lang="zh">MoS₂</skos:altLabel>
        <skos:definition xml:lang="en">Molybdenum disulfide (MoS₂) is a layered two-dimensional semiconducting material belonging to the transition metal dichalcogenide (TMD) family. In its monolayer form it exhibits a direct band gap of approximately 1.8 eV, making it a promising channel material for ultra-thin, flexible transistors and optoelectronic devices.</skos:definition>
        <skos:definition xml:lang="zh">二硫化钼（MoS₂）是一种层状二维半导体材料，属于过渡金属二硫族化物（TMD）家族。其单层形式具有约1.8 eV的直接带隙，使其成为超薄柔性晶体管和光电器件中有前景的沟道材料。</skos:definition>
        <skos:example xml:lang="en">MoS₂ monolayer transistors on flexible substrates for wearable electronics.</skos:example>
        <skos:example xml:lang="zh">柔性衬底上的MoS₂单层晶体管用于可穿戴电子器件。</skos:example>
    </owl:Class>


    <!-- WDZ_0100118: graphene -->

    <owl:Class rdf:about="https://w3id.org/wdzyzcl/co/WDZ_0100118">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0010101"/>
        <rdfs:label xml:lang="en">graphene</rdfs:label>
        <rdfs:label xml:lang="zh">石墨烯</rdfs:label>
        <skos:altLabel xml:lang="en">graphene film</skos:altLabel>
        <skos:altLabel xml:lang="zh">石墨烯薄膜</skos:altLabel>
        <skos:definition xml:lang="en">Graphene is a two-dimensional allotrope of carbon arranged in a hexagonal honeycomb lattice, exhibiting extremely high electron mobility, mechanical strength, and thermal conductivity. While gapless graphene is not a conventional semiconductor, it is used as a transparent electrode, high-frequency transistor channel, and physical sensor material.</skos:definition>
        <skos:definition xml:lang="zh">石墨烯是碳的二维同素异形体，呈六方蜂窝状晶格排列，具有极高的电子迁移率、机械强度和热导率。无带隙的石墨烯不是传统半导体，但被用作透明电极、高频晶体管沟道和物理传感器材料。</skos:definition>
        <skos:example xml:lang="en">Graphene transparent electrodes in touchscreens and flexible displays.</skos:example>
        <skos:example xml:lang="zh">触摸屏和柔性显示屏中的石墨烯透明电极。</skos:example>
    </owl:Class>


    <!-- WDZ_0100119: germanium -->

    <owl:Class rdf:about="https://w3id.org/wdzyzcl/co/WDZ_0100119">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0010100"/>
        <rdfs:label xml:lang="en">germanium</rdfs:label>
        <rdfs:label xml:lang="zh">锗</rdfs:label>
        <skos:altLabel xml:lang="en">Ge</skos:altLabel>
        <skos:altLabel xml:lang="zh">Ge</skos:altLabel>
        <skos:definition xml:lang="en">Germanium (Ge) is a group-IV elemental semiconductor with a small indirect band gap of 0.67 eV and exceptionally high electron and hole mobility. It is used in high-speed heterojunction bipolar transistors (HBTs), infrared photodetectors, and as a key component in SiGe alloys for RF and millimetre-wave circuits.</skos:definition>
        <skos:definition xml:lang="zh">锗（Ge）是一种IV族元素半导体，具有0.67 eV的小间接带隙和极高的电子与空穴迁移率。它用于高速异质结双极晶体管（HBT）、红外光电探测器，并作为SiGe合金的关键组分用于射频和毫米波电路。</skos:definition>
        <skos:example xml:lang="en">Germanium photodetectors integrated on silicon photonic platforms.</skos:example>
        <skos:example xml:lang="zh">集成在硅光子平台上的锗光电探测器。</skos:example>
    </owl:Class>

</rdf:RDF>



